# Copy this to .env and fill in real values
# The app reads these env vars first, falling back to config.ini

OXYPC_DATABASE_URL=postgresql+asyncpg://oxypc:yourpassword@localhost:5432/oxypc_db
OXYPC_SECRET_KEY=generate-with: python -c "import secrets; print(secrets.token_hex(32))"
OXYPC_API_KEY=your-oxyqc-api-key
OXYPC_TOKEN_EXPIRE_MINUTES=60
OXYPC_REFRESH_DAYS=7
OXYPC_PORT=8000
OXYPC_HOST=0.0.0.0
