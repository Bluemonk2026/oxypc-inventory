# OxyPC Inventory — production environment file
# Copy to /opt/oxypc/.env on the server and fill REAL values. NEVER commit the real .env.

# --- Database (PostgreSQL on the same VPS) ---
OXYPC_DATABASE_URL=postgresql+asyncpg://oxypc_user:CHANGE_ME_STRONG_DB_PASSWORD@localhost:5432/oxypc_db

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
OXYPC_SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_HEX
OXYPC_TOKEN_EXPIRE_MINUTES=480
OXYPC_REFRESH_DAYS=7

# --- App ---
OXYPC_HOST=127.0.0.1
OXYPC_PORT=8000

# --- OxyQC standalone API key (rotate from the default!) ---
OXYPC_API_KEY=CHANGE_ME_OXYQC_KEY

# --- Cookies: set to 1 in production so auth cookies are HTTPS-only ---
OXYPC_COOKIE_SECURE=1

# --- CORS for ecosystem API (only if other apps call /api/v1/*) ---
OXYPC_ALLOWED_ORIGINS=https://erp.oxypc.in
