			Add_data_to_Product_Maste as "Add data to Product Master Inventory"
			{
				type =  form
				form = IQC_Format_for_Desktop
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											master_recs = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(input.Tag_No)];
										info "master_recs_search " + master_recs;
										if(master_recs.count() == 0)
										{
											info "entered loop";
											mapp = Map();
											mapp.put("Product_Sub_Category",input.Sub_Category.Sub_Category);
											mapp.put("Serial_No",input.Serial_No);
											mapp.put("LOT_No",input.LOT_No1.LOT_No);
											mapp.put("Grade",input.Grade);
											mapp.put("Tag_No2",input.Tag_No);
											// 	mapp.put("Desktop",input.ID);
											mapp.put("Make",input.Make.Make);
											mapp.put("Model",input.Model.Model);
											mapp.put("CPU",input.Processors);
											mapp.put("Generation",input.Generation);
											mapp.put("Product_Category2","Desktop");
											mapp.put("Quantity",1);
											mapp.put("Used_or_not","In-Zoho");
											mapp.put("Product_Stages","Ready for Engineer Assignment");
											mapp.put("Product_Category","IQC Completed");
											if(input.Location == "BMH")
											{
												mapp.put("Warehouse","TRC 2ND Floor");
											}
											else
											{
												mapp.put("Warehouse","Manesar");
											}
											empty_mapp = Map();
											create_rec = zoho.creator.createRecord("protaiga","oxypc-1","Product_Master_Inventory1",mapp,empty_mapp,"creator");
											sendmail
											[
												from :zoho.loginuserid
												to :"shubham.oxypc@gmail.com"
												subject :"Create record in Product Master Inventory map plus response"
												message :"Create record in Inventory after Desktop" + create_rec + "Mapp " + mapp
											]
											info "Inventory_records" + create_rec;
										}
										else
										{
											master_recs.Used_or_not="In-Zoho";
											mapp = Map();
											mapp.put("Product_Sub_Category",input.Sub_Category.Sub_Category);
											mapp.put("Serial_No",input.Serial_No);
											mapp.put("LOT_No",input.LOT_No1.LOT_No);
											mapp.put("Grade",input.Grade);
											// 	mapp.put("Tag_No2",input.Tag_No);
											// 	mapp.put("Desktop",input.ID);
											mapp.put("Make",input.Make.Make);
											mapp.put("Model",input.Model.Model);
											mapp.put("CPU",input.Processors);
											mapp.put("Generation",input.Generation);
											mapp.put("Product_Category2","Desktop");
											mapp.put("Quantity",1);
											mapp.put("Used_or_not","In-Zoho");
											mapp.put("Product_Stages","Ready for Engineer Assignment");
											mapp.put("Product_Category","IQC Completed");
											if(input.Location == "BMH")
											{
												mapp.put("Warehouse","TRC 2ND Floor");
											}
											else
											{
												mapp.put("Warehouse","Manesar");
											}
											empty_mapp = Map();
											updt_rec = zoho.creator.updateRecord("protaiga","oxypc-1","All_Product_Master_Inventories1",master_recs.ID,mapp,empty_mapp,"creator");
										}
						)
					}
				}

			}
