			Create_Purchase_Recieve_i as "Create Purchase Recieve in Zoho books"
			{
				type =  form
				form = GRN
				record event = on add or edit
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											mapp = Map();
										line_items_lst = list();
										for each  i in Item
										{
											line_items = Map();
											line_items.put("line_item_id",i.Line_Item_Id);
											line_items.put("item_id",i.Books_Item_ID);
											line_items.put("name",i.Item_Name1);
											line_items.put("description",i.Item_Description);
											line_items.put("quantity",i.Quantity.toLong());
											line_items.put("unit","qty");
											line_items.put("track_serial_number",true);
											line_items.put("warehouse_id",1243157000002593007);
											newline = hextotext("0A");
											serial_num_lst = List();
											if(i.Tag_Numbers != null)
											{
												for each  j in i.Tag_Numbers.toList(newline)
												{
													serial_num_lst.add(j);
												}
												line_items.put("serial_numbers",serial_num_lst);
											}
											line_items_lst.add(line_items);
										}
										mapp.put("line_items",line_items_lst);
										mapp.put("date",input.Added_Time.toString("yyyy-MM-dd"));
										// mapp.put("Invoice Number",input.Invoice_Number);
										customfieldmap1 = Map();
										customfieldmap2 = Map();
										customfieldmap3 = Map();
										//#########--- Invoice_Number ---#############
										customfieldmap1.put("custom_field_id",1243157000000346001);
										customfieldmap1.put("field_id",1243157000000346001);
										customfieldmap1.put("value",input.Invoice_Number);
										//#########--- Vehicle Number ---#############
										customfieldmap2.put("custom_field_id",1243157000000346023);
										customfieldmap2.put("field_id",1243157000000346023);
										customfieldmap2.put("value",input.Vehicle_Number);
										//#########--- Invoice_Value ---#############
										customfieldmap3.put("custom_field_id",1243157000000346029);
										customfieldmap3.put("field_id",1243157000000346029);
										customfieldmap3.put("value",input.Invoice_Value);
										customfieldlist = List();
										customfieldlist.add(customfieldmap1);
										customfieldlist.add(customfieldmap2);
										customfieldlist.add(customfieldmap3);
										mapp.put("custom_fields",customfieldlist);
										line_items_lst = List();
										create_pr = invokeurl
										[
											url :"https://www.zohoapis.in/inventory/v1/purchasereceives?organization_id=60020430422&purchaseorder_id=" + input.PO_Number.Books_PO
											type :POST
											parameters:mapp.toString()
											connection:"zoho_books"
										];
										info create_pr;
										//#########################----- Transfer Order for transferring From Oxy to TRC 2nd Floor ------######################
										for each  i in Item
										{
											mapp = Map();
											mapp.put("date",zoho.currentdate.toString("yyyy-MM-dd"));
											mapp.put("from_warehouse_id",1243157000000163010);
											mapp.put("to_warehouse_id",1243157000002593007);
											line_items_lst = List();
											line_item = Map();
											line_item.put("item_id",i.Books_Item_ID);
											line_item.put("name",i.Item_Name1);
											line_item.put("description",i.Item_Description);
											line_item.put("quantity_transfer",i.Quantity.toLong());
											if(i.Tag_Numbers != null)
											{
												newline = hextotext("0A");
												serial_num_lst = List();
												for each  j in i.Tag_Numbers.toList(newline)
												{
													serial_num_lst.add(j);
												}
												line_item.put("serial_numbers",serial_num_lst);
											}
											line_item.put("unit","qty");
											line_items_lst.add(line_item);
											mapp.put("line_items",line_items_lst);
											transfer_order = invokeurl
											[
												url :"https://www.zohoapis.in/inventory/v1/transferorders?organization_id=60020430422"
												type :POST
												parameters:mapp.toString()
												connection:"zoho_books"
											];
											info transfer_order;
										}
										// po_sbfrm = input.Purchase_Order.PO_Item_Details;
										// for each i in po_sbfrm
										// {
										// 	line_item_mp = map();
										// 	line_item_mp.put("item_id", )
										// }
						)
					}
				}

			}
			Create_Customer_in_Books as "Create Customer in Books"
			{
				type =  form
				form = Customer_Database
				record event = on add or edit
					status = inactive

				on success
