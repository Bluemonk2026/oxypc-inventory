		form Screen_QC
		{
			displayname = "Final QC Form"
			success message = "Data Added Successfully!"
			field alignment = left
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have unique Serial_Number
			(
    			type = text
				displayname = "Serial Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Tag_No
			(
    			type = text
				displayname = "Tag No"
				qrcode = true
				barcode = true
				camera = primary
				switch camera = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			Lot_Number
			(
    			type = text
				displayname = "Lot Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Screen_Type
			(
				type = picklist
				displayname = "Screen Type"
				maxchar = 100
				values = {"LCD","LED","PAPER","IPS"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Screen_Pin
			(
				type = picklist
				displayname = "Screen Pin"
				maxchar = 100
