			Add_to_Product_Master_Inv7 as "Add to Product Master Inventory"
			{
				type =  form
				form = Tablet_IQC_Part
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											// #######################-------------New Code(IQC AT MANESAR)--------------#################################
										master_inv = Product_Master_Inventory1[Tag_No2 == input.Tag_Number];
										info master_inv.count();
										if(master_inv.count() == 0)
										{
											mapp = Map();
											mapp.put("LOT_No",input.LOT_Number);
											mapp.put("Tag_No2",input.Tag_Number);
											mapp.put("Make",input.Make.Make);
											mapp.put("Model",input.Model.Model);
											mapp.put("RAM",input.RAM);
											mapp.put("HDD",input.HDD);
											// 	mapp.put("Model",input.Model1.Model);
											// 	mapp.put("Grade",input.Grade);
											if(input.IMEI_ITEM_SERIAL_NO1 == null || input.IMEI_ITEM_SERIAL_NO1 == "")
											{
												mapp.put("Serial_No",input.IMEI_ITEM_SERIAL_NO2);
											}
											else
											{
												mapp.put("Serial_No",input.IMEI_ITEM_SERIAL_NO1);
											}
											// 	mapp.put("IQC_Faults_Subform",input.Faulty_Spare_Parts);
											empty_mapp = Map();
											create_rec_inv = zoho.creator.createRecord("protaiga","oxypc-1","Product_Master_Inventory1",mapp,empty_mapp,"creator");
											info create_rec_inv;
											sendmail
											[
												from :zoho.loginuserid
												to :"shubham.namdev@crm-masters.com"
												subject :"Create laptop iqc record in inventory"
												message :"create_rec_inv" + create_rec_inv
											]
										}
										else
										{
											rec = Product_Master_Inventory1[Tag_No2 == input.Tag_Number];
											if(rec.count() != 0)
											{
												rec.LOT_No=input.LOT_Number;
												rec.Tag_No2=input.Tag_Number;
												rec.Product_Category2="Tablet";
												rec.Make=input.Make.Make;
												rec.RAM=input.RAM;
												rec.HDD=input.HDD;
												rec.Model=input.Model.Model;
												if(input.IMEI_ITEM_SERIAL_NO1 == null || input.IMEI_ITEM_SERIAL_NO1 == "")
												{
													rec.Serial_No=input.IMEI_ITEM_SERIAL_NO2;
												}
												else
												{
													rec.Serial_No=input.IMEI_ITEM_SERIAL_NO1;
												}
												rec.Product_Type="Tablet";
												// 		rec.Product_Stages="";
											}
										}
						)
					}
				}

			}
			Get_Make_model_and_other_ as "Get Make, model and other details"
			{
				type =  form
				form = Stock_audit
				record event = on add

				on success
				{
					actions  (Tag_No is not null)
					{
						custom deluge script
						(
											// ############### - Laptop - ##########################
										master_rec = Product_Master_Inventory1[Tag_No2 == input.Tag_No];
										final_qc_rec = Final_QC1[Tag_Number == input.Tag_No];
										iqc_rec = IQC_Format_for_Laptop[TAG_NO == input.Tag_No];
										if(master_rec.count() == 0)
										{
											if(final_qc_rec.count() == 0)
											{
												if(iqc_rec.count() > 0)
												{
													input.Make = iqc_rec.Make.Make;
													input.Model = iqc_rec.Model1.Model;
													input.CPU = iqc_rec.CPU;
													input.Generation = iqc_rec.Generation;
													input.RAM = iqc_rec.Capacity;
													if(iqc_rec.HDD_Capacity == "" || iqc_rec.HDD_Capacity1 == null)
													{
														input.HDD = iqc_rec.HDD_Capacity1;
													}
													else
													{
														input.HDD = iqc_rec.HDD_Capacity;
													}
													input.Category = "Laptop";
												}
											}
											else
											{
												if(final_qc_rec.Updated_Make == null)
												{
													input.Make = final_qc_rec.Make;
												}
												else
												{
													input.Make = final_qc_rec.Updated_Make;
												}
												if(final_qc_rec.Updated_Model == null)
												{
													input.Model = final_qc_rec.Model;
												}
												else
												{
													input.Model = final_qc_rec.Updated_Model;
												}
												if(final_qc_rec.Update_CPU1 == "" || final_qc_rec.Update_CPU1 == null)
												{
													input.CPU = final_qc_rec.CPU;
												}
												else
												{
													input.CPU = final_qc_rec.Update_CPU1;
												}
												if(final_qc_rec.Updated_Generation == "" || final_qc_rec.Updated_Generation == null)
												{
													input.Generation = final_qc_rec.Generation;
												}
												else
												{
													input.Generation = final_qc_rec.Updated_Generation;
												}
												if(final_qc_rec.Updated_RAM == "" || final_qc_rec.Updated_RAM == null)
												{
													input.RAM = final_qc_rec.RAM;
												}
												else
												{
													input.RAM = final_qc_rec.Updated_RAM;
												}
												if(final_qc_rec.Updated_HDD == "" || final_qc_rec.Updated_HDD == null)
												{
													input.HDD = final_qc_rec.HDD;
												}
												else
												{
													input.HDD = final_qc_rec.Updated_HDD;
												}
											}
											input.Category = final_qc_rec.Category;
										}
										else
										{
											input.Make = master_rec.Make;
											input.Model = master_rec.Model;
											input.CPU = master_rec.CPU;
											input.Generation = master_rec.Generation;
											input.RAM = master_rec.RAM;
											input.HDD = master_rec.HDD;
											input.Category = master_rec.Product_Category2;
											input.Inventory_Location = master_rec.Product_Stages;
										}
										// ############### - Desktop - ##########################
										master_rec = Product_Master_Inventory1[Tag_No2 == input.Tag_No];
										final_qc_rec = Final_QC1[Tag_Number == input.Tag_No];
										iqc_rec_desk = IQC_Format_for_Desktop[Tag_No == input.Tag_No];
										if(master_rec.count() == 0)
										{
											if(final_qc_rec.count() == 0)
											{
												if(iqc_rec_desk.count() > 0)
												{
													input.Make = iqc_rec_desk.Make.Make;
													input.Model = iqc_rec_desk.Model.Model;
													input.CPU = iqc_rec_desk.CPU;
													input.Generation = iqc_rec_desk.Generation;
													input.RAM = iqc_rec_desk.Capacity;
													input.Category = "Desktop";
												}
											}
											else
											{
												if(final_qc_rec.Updated_Make == null)
												{
													input.Make = final_qc_rec.Make;
												}
												else
												{
													input.Make = final_qc_rec.Updated_Make;
												}
												if(final_qc_rec.Updated_Model == null)
												{
													input.Model = final_qc_rec.Model;
												}
												else
												{
													input.Model = final_qc_rec.Updated_Model;
												}
												if(final_qc_rec.Update_CPU1 == "" || final_qc_rec.Update_CPU1 == null)
												{
													input.CPU = final_qc_rec.CPU;
												}
												else
												{
													input.CPU = final_qc_rec.Update_CPU1;
												}
												if(final_qc_rec.Updated_Generation == "" || final_qc_rec.Updated_Generation == null)
												{
													input.Generation = final_qc_rec.Generation;
												}
												else
												{
													input.Generation = final_qc_rec.Updated_Generation;
												}
												if(final_qc_rec.Updated_RAM == "" || final_qc_rec.Updated_RAM == null)
												{
													input.RAM = final_qc_rec.RAM;
												}
												else
												{
													input.RAM = final_qc_rec.Updated_RAM;
												}
												if(final_qc_rec.Updated_HDD == "" || final_qc_rec.Updated_HDD == null)
												{
													input.HDD = final_qc_rec.HDD;
												}
												else
												{
													input.HDD = final_qc_rec.Updated_HDD;
												}
											}
											input.Category = final_qc_rec.Category;
										}
										else
										{
											input.Make = master_rec.Make;
											input.Model = master_rec.Model;
											input.CPU = master_rec.CPU;
											input.Generation = master_rec.Generation;
											input.RAM = master_rec.RAM;
											input.HDD = master_rec.HDD;
											input.Category = master_rec.Product_Category2;
											input.Inventory_Location = master_rec.Product_Stages;
										}
										// ############### - TFT - ##########################
										master_rec = Product_Master_Inventory1[Tag_No2 == input.Tag_No];
										final_qc_rec = Final_QC1[Tag_Number == input.Tag_No];
										iqc_rec_tft = IQC_Format_for_TFT[TAG == input.Tag_No];
										if(master_rec.count() == 0)
										{
											if(final_qc_rec.count() == 0)
											{
												if(iqc_rec_tft.count() > 0)
												{
													input.Make = iqc_rec_tft.Make;
													input.Category = "TFT";
												}
											}
											else
											{
												if(final_qc_rec.Updated_Make == null)
												{
													input.Make = final_qc_rec.Make;
												}
												else
												{
													input.Make = final_qc_rec.Updated_Make;
												}
												if(final_qc_rec.Updated_Model == null)
												{
													input.Model = final_qc_rec.Model;
												}
												else
												{
													input.Model = final_qc_rec.Updated_Model;
												}
												if(final_qc_rec.Update_CPU1 == "" || final_qc_rec.Update_CPU1 == null)
												{
													input.CPU = final_qc_rec.CPU;
												}
												else
												{
													input.CPU = final_qc_rec.Update_CPU1;
												}
												if(final_qc_rec.Updated_Generation == "" || final_qc_rec.Updated_Generation == null)
												{
													input.Generation = final_qc_rec.Generation;
												}
												else
												{
													input.Generation = final_qc_rec.Updated_Generation;
												}
												if(final_qc_rec.Updated_RAM == "" || final_qc_rec.Updated_RAM == null)
												{
													input.RAM = final_qc_rec.RAM;
												}
												else
												{
													input.RAM = final_qc_rec.Updated_RAM;
												}
												if(final_qc_rec.Updated_HDD == "" || final_qc_rec.Updated_HDD == null)
												{
													input.HDD = final_qc_rec.HDD;
												}
												else
												{
													input.HDD = final_qc_rec.Updated_HDD;
												}
												input.Category = "TFT";
											}
										}
										else
										{
											input.Make = master_rec.Make;
											input.Model = master_rec.Model;
											input.CPU = master_rec.CPU;
											input.Generation = master_rec.Generation;
											input.RAM = master_rec.RAM;
											input.HDD = master_rec.HDD;
											input.Category = master_rec.Product_Category2;
											input.Inventory_Location = master_rec.Product_Stages;
										}
						)
					}
				}

			}
			Show_hide_fields as "Show/hide fields"
			{
				type =  form
				form = Stock_audit
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											hide Location;
										hide Generation;
										hide RAM;
										hide CPU;
										hide Make;
										hide Model;
										hide HDD;
										hide Tag_No;
										hide Category;
						)
					}
				}

			}
			Show_Field_Option_accordi as "Show Field Option according to floor"
			{
				type =  form
				form = Stock_audit
				record event = on add

				on user input of Floor
				{
					actions  (Floor is not null)
					{
						custom deluge script
						(
											stock_audit = Stock_audit[ID != 0 && Added_User == zoho.loginuser] sort by Added_Time desc;
										if(input.Floor == "Showroom/शोरूम" || input.Floor == "2nd Floor/द्वितीय मंज़िल")
										{
											show Location;
											if(input.Floor == "Showroom/शोरूम")
											{
												input.Location:ui.add("Showroom");
												input.Location:ui.add("QC Area Showroom");
											}
											else
											{
												input.Location:ui.add("Incoming Area");
												input.Location:ui.add("TRC");
												input.Location:ui.add("L1 Line");
												input.Location:ui.add("Cleaning");
												input.Location:ui.add("L4 Support");
												input.Location:ui.add("L4");
												input.Location:ui.add("Paint");
												input.Location:ui.add("Final QC");
												input.Location:ui.add("QC Area 2nd Floor");
											}
											show Tag_No;
										}
										else
										{
											hide Location;
											hide Tag_No;
										}
										input.Location = stock_audit.Location;
						)
					}
				}

			}
