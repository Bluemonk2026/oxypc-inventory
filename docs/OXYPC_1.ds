			Fetch_Details1 as "Fetch Details"
			{
				type =  form
				form = Screen_QC
				record event = on add or edit

				on user input of Tag_No
				{
					actions  (Tag_No is not null)
					{
						custom deluge script
						(
											if(input.Tag_No != "" || input.Tag_No != null)
										{
											info "entered 1st";
											repair_rec = Screen[Serial_Number1.equalsIgnoreCase(input.Serial_Number)];
											info "Repair record" + repair_rec;
											if(repair_rec.count() > 0)
											{
												if(repair_rec.Status != "Scrap")
												{
													iqc_rec = IQC_format_for_Screen[Serial_Number.equalsIgnoreCase(input.Serial_Number)];
													if(iqc_rec.count() > 0)
													{
														if(iqc_rec.Status != "Scrap")
														{
															info "entered 2nd";
															input.Lot_Number = iqc_rec.Lot_Number;
															input.Part_No = iqc_rec.Part_No;
															input.Tag_No = iqc_rec.Tag_No;
															input.Screen_Size = iqc_rec.Screen_Size;
															input.Screen_Pin = iqc_rec.Screen_Pin;
															input.Screen_Type = iqc_rec.Screen_Type;
															Serial_Number1 = iqc_rec.Serial_Number;
														}
														else
														{
															alert "This Screen is Scrap";
															input.Serial_Number = "";
														}
													}
												}
												else
												{
													alert "This Screen is Scrap";
													input.Serial_Number = "";
												}
											}
											else
											{
												iqc_rec = IQC_format_for_Screen[Serial_Number.equalsIgnoreCase(input.Serial_Number)];
												if(iqc_rec.count() > 0 && iqc_rec.Status == "OK")
												{
													if(iqc_rec.Status != "Scrap")
													{
														info "entered 2nd";
														input.Lot_Number = iqc_rec.Lot_Number;
														input.Part_No = iqc_rec.Part_No;
														input.Screen_Size = iqc_rec.Screen_Size;
														input.Tag_No = iqc_rec.Tag_No;
														input.Screen_Pin = iqc_rec.Screen_Pin;
														input.Screen_Type = iqc_rec.Screen_Type;
													}
												}
											}
										}
						)
					}
				}

			}
