	section L3_L4_Production_Dashboard
	{
		displayname= "L3/L4 Production Dashboard"
		icon = "design-mobile-design"
		form L3_L4_Engineer_Screen
		{
			displayname = "L3/L4 Engineer Screen"
			success message = "L3/l4 Engineer Screen Added Successfully"
			field alignment = left
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Barcode
			(
    			type = text
				displayname = "Tag No."
				qrcode = true
				barcode = true
				camera = primary
				show gallery = true
				switch camera = true
    			description
    			[
    				type = tooltip
    			 	message = "Scan the Barcode"
    			]
	 			row = 1
	 			column = 1   
				width = medium
			)
			Time
			(
    			type = time
				initial value = "${zoho.currenttime}"	
				timedisplayoptions = "hh:mm:ss" 
				private = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			Category
			(
				type = picklist
				maxchar = 100
				values = {"Laptop","Desktop","TFT"}
				private = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			Model
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			Generation
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			Problem_Reported
			(
				type = picklist
				displayname = "Problem Reported"
				maxchar = 100
				values = {"Not ON","On/Off","Hanging","KBD Not Working","Usb Not Working","VGA Port Not Working","HDMI Port Notworking","ON /OFF Switch Issue","KBD Some Key Not Working","Blue Dum Error","Wifi Not Working","Date Time issue","Audio Jack Not Working","Battery Not Charing","Battery Not detect","HDD Not detect","BIOS Password","LAN Port Not Working","T.pad Not Working","Sound issue","Auto Restart/Shut Down","OS Not Installed","C Type Connector Not Working","T.Pad Click Not working","Camera Not working","Microphone Not Working","Ram Slot Not Working","Power Button LED Issue","CPU Fan Error","Other Problem","CPU Pin Damage","No Display","No Power","USB","VGA","DP","HDMI","Menu Button","DIM Display","Others"}
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Date_field
			(
    			type = date
				displayname = "Date"
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
				private = true
	 			row = 1
	 			column = 2   
				width = medium
			)
			LOT_No
			(
    			type = text
				displayname = "LOT No."
	 			row = 1
	 			column = 2   
				width = medium
			)
			Make
			(
    			type = text
	 			row = 1
	 			column = 2   
				width = medium
			)
			CPU
			(
    			type = text
	 			row = 1
	 			column = 2   
				width = medium
			)
			Received_From
			(
				type = picklist
				displayname = "Received From"
				maxchar = 100
				values = {"L4 Support","L1/L2 Engineer"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Received_from_Engineer
			(
    			type = picklist
				displayname = "Received from Engineer"
				module = users
				displayformat = [username]
	 			row = 1
	 			column = 2   
				width = medium
				personal data = true
			)
			Section2
			(
				type = section
				displayname = ""
				visibility = true
	 			row = 2
	 			column = 0   
				width = medium
			)
			must have Problem_Observed
			(
				type = picklist
				displayname = "Problem Observed"
				maxchar = 100
				values = {"Not ON","On/Off","Hanging","KBD Not Working","Remote Management Error","Usb Not Working","VGA Port Not Working","HDMI Port Notworking","ON /OFF Switch Issue","KBD Some Key Not Working","Blue Dum Error","Wifi Not Working","Date Time issue","Audio Jack Not Working","Battery Not Charing","Battery Not detect","HDD Not detect","BIOS Password","LAN Port Not Working","T.pad Not Working","Sound issue","Auto Restart/Shut Down","OS Not Installed","C Type Connector Not Working","T.Pad Click Not working","Camera Not working","Microphone Not Working","Ram Slot Not Working","Power Button LED Issue","CPU Fan Error","Other Problem","Menu Button","DIM Display","No Display","No Power","USB","VGA","DP","HDMI","CPU Pin Damage","Others"}
	 			row = 2
	 			column = 1   
				width = medium
			)
			must have Final_Status
			(
				type = picklist
				displayname = "Final Status"
				maxchar = 100
				values = {"Ok","Scrap"}
	 			row = 2
	 			column = 1   
				width = medium
			)
			Scrap_Reason
			(
				type = picklist
				displayname = "Scrap Reason"
				maxchar = 100
				values = {"PCB Burn","Component Burn","CPU Sorting","PCB Damage","Component Damage","Component Missing"}
				others option = true
	 			row = 2
	 			column = 1   
				width = medium
			)
			must have Action_Taken
			(
				type = picklist
				displayname = "Action Taken"
				maxchar = 100
				values = {"Shorting removed","Resoldering","BIOS Programming","CPU Socket PIN alignment","Remote Management Error removed","CMOS change","Part replaced","Track Repair","Reflow","Re-soldering","Others"}
	 			row = 2
	 			column = 2   
				width = medium
			)
			Enter_Action_Taken
			(
    			type = text
				displayname = "Enter Action Taken"
	 			row = 2
	 			column = 2   
				width = medium
			)
			Customer_Internal
			(
				type = picklist
				displayname = "Customer/Internal"
				maxchar = 100
				values = {"Customer Service","Internal"}
	 			row = 2
	 			column = 2   
				width = medium
			)
	
			customize
			(
				icon = "tech-tablet-button"
			)
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
