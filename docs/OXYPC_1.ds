			Update_Product_Descriptio as "Update Product Description"
			{
				type =  form
				form = Spare_Part_Cost_LOT_Wise
				record event = on edit
					status = inactive

				on update of Sales_Price
				{
					actions 
					{
						custom deluge script
						(
											descrip = input.Product_Description1;
										price = Sales_Price_Laptop[Product_Description == descrip];
										input.Sales_Price = price.Sales_Price;
						)
					}
				}

			}
			CreateRecordInCRM as "CreateRecordInCRM"
			{
				type =  form
				form = IQC_Format_for_Laptop
				record event = on add
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											// fet = GRN[ID == input.Lot_No];
										// lot = fet.Lot_No;
										fetch = Make[ID == input.Make];
										make = fetch.Make;
										model_laptop = Model[ID == input.Model1];
										model = model_laptop.Model;
										cpu_laptop = CPU_Master[ID == input.CPU1];
										cpu = cpu_laptop.CPU;
										gen_laptop = Classifications_of_Make_and_Model[ID == input.Generation1];
										gen = gen_laptop.Generation;
										mainform = IQC_Format_for_Laptop[ID == input.ID];
										serialNO = mainform.Serial_No;
										mp = Map();
										mp.put("Name",input.LOT_Number);
										mp.put("LOT_No",input.LOT_Number);
										mp.put("Serial_Number",serialNO);
										mp.put("Make",make);
										mp.put("Model",model);
										mp.put("CPU",cpu);
										mp.put("Generation",gen);
										mp.put("Please_Specify",input.Please_Specify2);
										mp.put("Model_Description",input.Model_Description);
										mp.put("RAM",input.RAM_1);
										mp.put("RAM_replace",input.RAM_replace);
										mp.put("RAM_Rate",input.RAM_Rate);
										mp.put("Capacity",input.Capacity);
										mp.put("Please_Specify1",input.Please_Specify);
										mp.put("RAM_Status",input.RAM_Status);
										mp.put("HDD",input.HDD);
										mp.put("HDD_replace",input.HDD_replace);
										mp.put("HDD_Rate",input.HDD_Rate);
										mp.put("HDD_Category",input.Category);
										// mp.put("Provide_Description",input.Provide_Description1);
										mp.put("HDD_Capacity",input.HDD_Capacity);
										// mp.put("Provide_Description1",input.Provide_Description2);
										mp.put("Health_HDD",input.Health);
										mp.put("Microphone",input.Microphone);
										mp.put("Web_Cam",input.Web_Cam);
										mp.put("ALL_OK",input.ALL_OK);
										mp.put("Does_the_Laptop_Switch_on",input.Does);
										mp.put("BIOS_Password",input.BIOS_Password);
										mp.put("Microphone_replace",input.Microphone_replace);
										mp.put("Microphone_Rate",input.Microphone_Rate);
										mp.put("Front_Panel",input.Front_Panel);
										mp.put("Front_panel_replace",input.Front_panel_replace);
										mp.put("Front_Panel_Rate",input.Front_Panel_Rate);
										mp.put("Panel",input.Panel);
										mp.put("Panel_replace",input.Panel_replace);
										mp.put("Panel_Rate",input.Panel_Rate);
										mp.put("Screen_Size",input.Screen_Size);
										mp.put("Provide_Description2",input.Provide_Description5);
										mp.put("Screen",input.Screen);
										mp.put("Screen_replace",input.Screen_replace);
										mp.put("Screen_Rate",input.Screen_Rate);
										mp.put("Hinch",input.Hinch);
										mp.put("Hinch_replace",input.Hinch_replace);
										mp.put("Hinch_Rate",input.Hinch_Rate);
										mp.put("Hinch_Cover",input.Hinch_Cover);
										mp.put("Hinch_Cover_replace",input.Hinch_Cover_replace);
										mp.put("Hinch_Cover_Rate",input.Hinch_Cover_Rate);
										mp.put("Power_Panel",input.Power_Panel);
										mp.put("Power_Panel_replace",input.Power_Panel_replace);
										mp.put("Power_Panel_Rate",input.Power_Panel_Rate);
										mp.put("Touch_Pad",input.Touch_Pad);
										mp.put("Touch_Pad_replace",input.Touch_Pad_replace);
										mp.put("Touch_Pad_Rate",input.Touch_Pad_Rate);
										mp.put("Base",input.Base);
										mp.put("Base_replace",input.Base_replace);
										mp.put("Base_Rate",input.Base_Rate);
										mp.put("Keyboard",input.Keyboard);
										mp.put("Keyboard_replace",input.Keyboard_replace);
										mp.put("Keyboard_Rate",input.Keyboard_Rate);
										mp.put("Logic_Card",input.Logic_Card);
										mp.put("Logic_Card_replace",input.Logic_Card_replace);
										mp.put("Logic_Card_Rate",input.Logic_Card_Rate);
										mp.put("USB",input.USB);
										mp.put("USB_replace",input.USB_replace);
										mp.put("USB_Rate",input.USB_Rate);
										mp.put("HDD_Connector",input.HDD_Connector);
										mp.put("HDD_Connector_replace",input.HDD_Connector_replace);
										mp.put("HDD_Connector_Rate",input.HDD_Connector_Rate);
										mp.put("Sound",input.Sound);
										mp.put("Sound_replace",input.Sound_replace);
										mp.put("Sound_Rate",input.Sound_Rate);
										mp.put("HDD_Casing",input.HDD_Casing);
										mp.put("HDD_Casing_replace",input.HDD_Casing_replace);
										mp.put("HDD_Casing_Rate",input.HDD_Casing_Rate);
										mp.put("Web_Cam_replace",input.Web_Cam_replace);
										mp.put("Web_Cam_Rate",input.Web_Cam_Rate);
