			Inserting_Lot_Number as "Inserting Lot Number"
			{
				type =  form
				form = IQC_Format_for_Desktop
				record event = on add or edit

				on user input of Tag_No
				{
					actions 
					{
						custom deluge script
						(
											if(input.Tag_No != "" || input.Tag_No != null)
										{
											if(input.Tag_No.startswith("SN") || Tag_No.startswith("sn"))
											{
												// 		
											}
											else
											{
												lot_num = input.Tag_No.subString(0,4);
												info lot_num;
												lot_no_rec = LOT_No_s_GRN[LOT_No == lot_num];
												info lot_no_rec;
												if(lot_no_rec.count() == 0)
												{
													info "Lot number recs";
													mapp = Map();
													mapp.put("LOT_No",lot_num);
													info mapp;
													mapp1 = Map();
													record_create = zoho.creator.createRecord("protaiga","oxypc-1","LOT_No_s_GRN",mapp,mapp1,"creator");
													info record_create;
													if(record_create.get("code") == "3000")
													{
														info record_create.get("data").get("ID");
														input.LOT_No1 = record_create.get("data").get("ID").toLong();
													}
												}
												else
												{
													input.LOT_No1 = lot_no_rec.ID;
												}
											}
										}
						)
					}
				}

			}
			Check_if_GRN_completed_or as "Check if GRN completed or not"
