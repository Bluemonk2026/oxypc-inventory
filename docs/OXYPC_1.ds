			Calculate_Amount as "Calculate Amount"
			{
				type =  form
				form = Sales_Orders
				record event = on add or edit

				on user input of Item_Table.Quantity
				{
					actions 
					{
						custom deluge script
						(
											if(row.Quantity != null && row.Rate != null)
										{
											row.Amount=row.Quantity * row.Rate;
										}
										total_amt = 0;
										for each  i in Item_Table
										{
											if(i.Amount != null)
											{
												total_amt = total_amt + i.Amount;
											}
										}
										input.Basic_Value = total_amt;
										// --------------------Total Quantity Calculation----------------------//
										total_qty = 0;
										for each  i in Item_Table
										{
											if(i.Quantity != null)
											{
												total_qty = total_qty + i.Quantity;
											}
										}
										input.Total_Quantity = total_qty;
										// --------------------------Tax Value Calculation--------------------------------//
										tax_val = input.Basic_Value * 18 / 100;
										input.Tax_Value = tax_val;
										input.Basic_Value = input.Basic_Value - tax_val;
										input.Grand_Total = input.Tax_Value + input.Basic_Value;
										// --------------------------Product Wise Quantity in Sales order---------------------//
										// ########--Laptop--########
										laptop_quan = 0;
										for each  i in Item_Table
										{
											if(i.Quantity != null && i.Category == "Laptop")
											{
												laptop_quan = laptop_quan + i.Quantity;
												show Laptop_Quantity;
											}
										}
										input.Laptop_Quantity = laptop_quan;
										// ########--Desktop--########
										desktop_quan = 0;
										for each  i in Item_Table
										{
											if(i.Quantity != null && i.Category == "Desktop")
											{
												desktop_quan = desktop_quan + i.Quantity;
												show Desktop_Quantity;
											}
										}
										input.Desktop_Quantity = desktop_quan;
										// ########--TFT--########
										tft_quan = 0;
										for each  i in Item_Table
										{
											if(i.Quantity != null && i.Category == "TFT")
											{
												tft_quan = tft_quan + i.Quantity;
												show TFT_Quantity;
											}
										}
										input.TFT_Quantity = tft_quan;
						)
					}
				}

			}
