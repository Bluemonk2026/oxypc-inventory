			Add_to_Product_Master_Inv1 as "Add to Product Master Inventory"
			{
				type =  form
				form = GRN
				record event = on add
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											for each  i in Item
										{
											quantity = i.Quantity.toLong() - 1;
											genratedlst = leftpad(" ",quantity).replaceAll(" ",",");
											lst = genratedlst.toList();
											for each  j in lst
											{
												mapp = Map();
												mapp.put("LOT_No",i.Lot_No);
												vendor_rec = Vendors_Database[Vendor_Name == input.Vendor_Name];
												mapp.put("Vendor_Name",vendor_rec.ID);
												mapp.put("Customer_Name",i.Customer_Name);
												// 	mapp.put("Product_Type",i.Item_Value);
												// 	rec = Product_Master [ID == i.Item_Name];
												mapp.put("Product_Category2",i.Category);
												mapp.put("Product_Sub_Category",i.Sub_Category1);
												mapp.put("Product_Stages","Inspection In Progress");
												mapp.put("Product_Category","Inspection");
												mapp.put("Warehouse",i.Location);
												mapp.put("Purchase_Price",i.Price);
												mapp.put("Quantity",1);
												mapp1 = Map();
												info zoho.creator.createRecord("protaiga","oxypc-1","Product_Master_Inventory1",mapp,mapp1,"creator");
											}
										}
						)
					}
				}

			}
			update_production_tracker1 as "update_production_tracker"
			{
				type =  form
				form = L1_L2_Engineer_Screen
				record event = on add
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											fgh = L1_L2_Engineer_Screen[ID == input.ID];
										User = fgh.Added_User;
										info User;
										Today_Production_Tracker = Production_Tracker[Engineer_Name == User.toString() && Date_field == zoho.currentdate];
										Tracker_Size = Today_Production_Tracker.count();
										info Tracker_Size;
										if(Tracker_Size == 0)
										{
											Create_map = Map();
											Create_map.put("IQC_Completed",0);
											Create_map.put("Date_field",zoho.currentdate.toString("dd-MMM-yyyy"));
											Create_map.put("L1_L2",1);
											Create_map.put("L3_L4",0);
											Create_map.put("L4_Support",0);
											Create_map.put("Final_QC",0);
											Create_map.put("Cleaning",0);
											Create_map.put("Painting",0);
											Create_map.put("Engineer_Name",User);
											empty_map = Map();
											Create_record = zoho.creator.createRecord("protaiga","oxypc-1","Production_Tracker",Create_map,empty_map,"creator");
											info Create_record;
										}
										else
										{
											Today_Production_Tracker = zoho.creator.getRecords("protaiga","oxypc-1","All_Production_Trackers","Date_field == \"" + zoho.currentdate + "\" && Engineer_Name== \"" + User + "\"",1,200,"creator");
											info Today_Production_Tracker;
											L1_L2_Count = Today_Production_Tracker.get("data").get("0").get("L1_L2");
											update_map = Map();
											update_map.put("L1_L2",L1_L2_Count.toNumber() + 1);
											emptymap = Map();
											update_map1 = zoho.creator.updateRecord("protaiga","oxypc-1","All_Production_Trackers",Today_Production_Tracker.get("data").get("0").get("ID").toLong(),update_map,emptymap,"creator");
										}
						)
					}
				}

			}
			Production_Tracker_update as "Production_Tracker_update_laptop_iqc"
			{
				type =  form
				form = IQC_Format_for_Laptop
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											fgh = IQC_Format_for_Laptop[ID == input.ID];
										User = fgh.Added_User;
										info User;
										Today_Production_Tracker = Production_Tracker[Engineer_Name == User.toString() && Date_field == zoho.currentdate];
										Tracker_Size = Today_Production_Tracker.count();
										info Tracker_Size;
										if(Tracker_Size == 0)
										{
											Create_map = Map();
											Create_map.put("IQC_Completed",1);
											Create_map.put("Date_field",zoho.currentdate.toString("dd-MMM-yyyy"));
											Create_map.put("L1_L2",0);
											Create_map.put("L3_L4",0);
											Create_map.put("L4_Support",0);
											Create_map.put("Final_QC",0);
											Create_map.put("Cleaning",0);
											Create_map.put("Painting",0);
											Create_map.put("Engineer_Name",User);
											Create_map.put("Assigned_to_L1_L2",0);
											Create_map.put("Assigned_to_L4_Support",0);
											empty_map = Map();
											Create_record = zoho.creator.createRecord("protaiga","oxypc-1","Production_Tracker",Create_map,empty_map,"creator");
											info Create_record;
										}
										else
										{
											Today_Production_Tracker = zoho.creator.getRecords("protaiga","oxypc-1","All_Production_Trackers","Date_field == \"" + zoho.currentdate + "\" && Engineer_Name== \"" + User + "\"",1,200,"creator");
											info Today_Production_Tracker;
											IQC_Completed_Count = Today_Production_Tracker.get("data").get("0").get("IQC_Completed");
											update_map = Map();
											update_map.put("IQC_Completed",IQC_Completed_Count.toNumber() + 1);
											emptymap = Map();
