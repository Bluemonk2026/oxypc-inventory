												customfieldmap1.put("field_id",1243157000000823315);
												customfieldmap1.put("value",make1);
												customfieldmap2.put("custom_field_id",1243157000000823321);
												customfieldmap2.put("field_id",1243157000000823321);
												customfieldmap2.put("value",model1);
												customfieldlist = List();
												customfieldlist.add(customfieldmap1);
												customfieldlist.add(customfieldmap2);
												create_product_map.put("custom_fields",customfieldlist);
												info create_product_map;
												create_record_books = zoho.books.createRecord("items","60020430422",create_product_map,"zoho_books");
