			(
				Tag_No as "Tag No."
				Final_Status as "Final Status"
				Faults
				Make
				Model
				CPU
				Generation
				HDD
				RAM
				Date_field as "Date"
				Time
				Added_User as "Added User"
				Engineer as "Received From"
				Remarks
				Category
				Serial_Number as "Serial Number"
				L1_L2_Completion_Date as "L1/L2 Completion Date"
				QC_Completion_Date as "QC Pass Date"
				QC_Completed_By as "QC Passed By"
				LOT_Number as "LOT Number"
				Added_Time as "Submission Time"
			)
			options
			(
				icon = "users-2-a-time"
	 		)
			conditional formatting
			(
				"Pass"
				{
				condition = (Final_Status == "Pass")
				fields = [Final_Status]
				format = "color:#ffffff;background-color:#5dc35a;"
				}
				"Fail"
				{
				condition = (Final_Status == "Fail")
				fields = [Final_Status]
				format = "color:#ffffff;background-color:#ef1616;"
				}
			)
			quickview
			(
				layout
				(
		 			type = -1
					datablock1
					(
						layout type = -1
						fields
						(
							Added_User as "Added User"
							Date_field as "Date"
							Time
							Added_Time as "Submission Time"
							Tag_No as "Tag No."
							LOT_Number as "LOT Number"
							Serial_Number as "Serial Number"
							Make
							Model
							CPU
							Generation
							RAM
