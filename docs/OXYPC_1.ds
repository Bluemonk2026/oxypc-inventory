			Add_to_Inventory5 as "Add to Inventory"
			{
				type =  form
				form = Screen_Lamination
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											spare_part_Rec = Spare_Parts[Tag_Number.equalsIgnoreCase(input.Tag_Number)];
										if(spare_part_Rec.count() > 0)
										{
											data_mapp = Map();
											// 	data_mapp.put("Tag_Number",input.Tag_Number);
											// 	data_mapp.put("Screen_Type",input.Screen_Type);
											// 	data_mapp.put("Screen_Pin",input.scree;
