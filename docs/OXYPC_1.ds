			Total_Quantity_and_Varian as "Total Quantity and Variance"
			{
				type =  form
				form = Consumables
				record event = on add or edit

				on user input of Item.Physical_Quantity
				{
					actions 
					{
						custom deluge script
						(
											total_quan = 0;
										inv_total = 0;
										// total_quan = total_quan + row.Physical_Quantity;
										for each  i in input.Item
										{
											if(i.Physical_Quantity != null)
											{
												total_quan = total_quan + i.Physical_Quantity;
											}
											if(i.Quantity_in_Invoice != null)
											{
												inv_total = inv_total.toLong() + i.Quantity_in_Invoice.toLong();
											}
										}
										input.Total_Physical_Quantity = total_quan;
										input.Variance = inv_total - total_quan;
						)
					}
				}

			}
