			Fill_details_of_the_produ1 as "Fill details of the product"
			{
				type =  form
				form = Dry_Sanding
				record event = on add or edit

				on user input of Tag_No
				{
					actions 
					{
						custom deluge script
						(
											if(input.Tag_No != "")
										{
											cleaning_recs = Cleaning[Tag_No.equalsIgnoreCase(input.Tag_No)] sort by Modified_Time desc;
											qc_rec = Final_QC_for_Engineer[Tag_No.equalsIgnoreCase(input.Tag_No)] sort by Modified_Time desc;
											if(cleaning_recs.count() == 0)
											{
												alert "Cleaning Not Done for this Laptop";
												input.Tag_No = "";
											}
											else
											{
												input.Make = cleaning_recs.Make;
												input.Model = cleaning_recs.Model;
												input.CPU = cleaning_recs.CPU;
												input.Generation = cleaning_recs.Generation;
												input.RAM = cleaning_recs.RAM;
												input.HDD = cleaning_recs.HDD;
												input.QC_Completion_Date = cleaning_recs.Cleaning_Date;
												input.Engineer_Name = cleaning_recs.Added_User;
												input.Serial_Number = qc_rec.Serial_Number;
												input.LOT_Number = cleaning_recs.LOT_Number;
											}
										}
						)
					}
				}

			}
			Alert_if_Qc_not_done1 as "Alert if Qc not done"
			{
				type =  form
				form = Dry_Sanding
				record event = on add or edit
					status = inactive

				on user input of Tag_No
				{
					actions 
					{
						custom deluge script
						(
											if(input.Tag_No != "")
										{
											qc_rec = Final_QC_for_Engineer[Tag_No.equalsIgnoreCase(input.Tag_No)];
											if(qc_rec.count() == 0)
											{
												newLine = hexToText("0A");
												alert "Warning: QC not done for this Laptop" + newLine + "चेतावनी: इस लैपटॉप के लिए QC नहीं किया गया है";
												input.Tag_No = "";
												// 	alert "Warning: QC not done for this Laptop";
											}
										}
						)
					}
				}

			}
