				maxchar = 100
				values = {"1GB","2GB","4GB","6GB","8GB","12GB","16GB","32GB","64GB","Others","128 MB","256 MB","512 MB","1 GB","2 GB","4 GB","8 GB","16 GB","32 GB","64 GB","128 GB","256 GB"}
				layout = 3
	 			row = 1
	 			column = 2   
