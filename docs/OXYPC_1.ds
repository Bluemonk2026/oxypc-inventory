		default list Sales_Orders_Report
		{
			displayName = "Sales Orders Report"
			template = Saleordertemplate
			show all rows from Sales_Orders    
			(
				Sales_Order_Number11 as "Sales Order Number"
				Sales_Order_Date as "Sales Order Date"
				Expected_Shipment_Date as "Expected Shipment Date"
				Payment_Terms as "Payment Terms"
				custom action "Push to Books"
				(
	  			workflow = Push_to_Books
				show action in edit record menu = true
				column header = "Push to Books"
				)
				SO_Books_ID as "SO Books ID"
				Invoice_Created as "Invoice Created"
				Customer_Name as "Customer Name"
				Salesperson
				Tag_Number as "Tag Number"
				All_Products_Ready as "All Products Ready"
				CaAmount as "Cash Amount"
				Payment_Mode1 as "Payment Mode"
				Cheque_Amount as "Cheque Amount"
				UPI_Amount as "UPI Amount"
				Card_Swipe_Amount as "Card Swipe Amount"
				Bank_Transfer_Amount as "Bank Transfer Amount"
				Basic_Value as "Basic Value"
				Tax_Percent as "Tax Percent"
				Tax_Value as "Tax Value"
				Total_Quantity as "Total Quantity"
				Grand_Total as "Grand Total"
				Customer_Location as "Customer Location"
				GSTIN_UIN as "GSTIN/UIN"
				Total_Amount as "Total Amount"
				Customer_State as "Customer State"
				Branch
				Warehouse
				Laptop_Quantity as "Laptop Quantity"
				Desktop_Quantity as "Desktop Quantity"
				TFT_Quantity as "TFT Quantity"
				Sales_Order_File as "Sales Order File"
				Item_Table as "Item Table"
				(
					view = Sales_Order_Items_Report
					field = Item_Table.Product_Name + " " + Item_Table.Quantity + " " + Item_Table.Rate + " " + Item_Table.Amount
				)
			)
			options
			(
				icon = "shopping-list"
	 		)
			quickview
			(
				layout
				(
		 			type = -1
					datablock1
					(
						layout type = -1
						fields
						(
							Sales_Order_Number11 as "Sales Order Number"
							Sales_Order_Date as "Sales Order Date"
							Customer_Name as "Customer Name"
							Customer_State as "Customer State"
							Expected_Shipment_Date as "Expected Shipment Date"
							Payment_Terms as "Payment Terms"
							Sales_Order_File as "Sales Order File"
							Item_Table.Product_Name as "Item Table"
						)
					)
				)
				menu
    			(
    	 			header
    	 			(
    		 			Edit 
    		 			Duplicate 
    		 			Delete 
    	 			)
					record
					(
						Edit   	   
						Duplicate   	   
						Delete   	   
    				)
    			)
    			action
    			(
					on click
					(
						View Record   	   
    				)
					on right click
					(
						Edit   	   
						Delete   	   
						Duplicate   	   
						View Record   	   
    				)
     			)
			)
			detailview
			(
				layout
				(
		 			type = 1
					datablock1
					(
						layout type = -2
						fields
						(
							Sales_Order_Number11 as "Sales Order Number"
							Sales_Order_Date as "Sales Order Date"
							Expected_Shipment_Date as "Expected Shipment Date"
							Payment_Terms as "Payment Terms"
							SO_Books_ID as "SO Books ID"
							Invoice_Created as "Invoice Created"
							Customer_Name as "Customer Name"
							Salesperson
							Tag_Number as "Tag Number"
							All_Products_Ready as "All Products Ready"
							CaAmount as "Cash Amount"
							Payment_Mode1 as "Payment Mode"
							Cheque_Amount as "Cheque Amount"
							UPI_Amount as "UPI Amount"
							Card_Swipe_Amount as "Card Swipe Amount"
							Bank_Transfer_Amount as "Bank Transfer Amount"
							Basic_Value as "Basic Value"
							Tax_Percent as "Tax Percent"
							Tax_Value as "Tax Value"
							Total_Quantity as "Total Quantity"
							Grand_Total as "Grand Total"
							Customer_Location as "Customer Location"
							GSTIN_UIN as "GSTIN/UIN"
							Total_Amount as "Total Amount"
							Customer_State as "Customer State"
							Branch
							Warehouse
							Laptop_Quantity as "Laptop Quantity"
							Desktop_Quantity as "Desktop Quantity"
							TFT_Quantity as "TFT Quantity"
							Sales_Order_File as "Sales Order File"
						)
					)
				)
				menu
    			(
    	 			header
    	 			(
    		 			Edit 
    		 			Duplicate 
    		 			Delete 
    	 			)
    			)
			)
		}
	}
	section Sales_Order_Items
	{
		displayname= "Sales Order Items"
		icon = "shopping-tag-sale"
		form Sales_Order_Items
		{
			displayname = "Sales Order Items"
			success message = "Data Added Successfully!"
			field alignment = left
			feature property = 320
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			unique Tag_Number
			(
    			type = text
				displayname = "Tag Number"
				barcode = true
				show onload = true
				camera = primary
				preview duration = 20
				switch camera = true
	 			row = 1
	 			column = 1   
				width = 200px
			)
			SO_ID_Creator
			(
    			type = text
				displayname = "SO ID Creator"
	 			row = 1
	 			column = 1   
				width = 200px
			)
			Category
			(
				type = picklist
				maxchar = 100
				values = {"Laptop","Desktop","TFT"}
	 			row = 1
	 			column = 1   
				width = 120px
			)
			must have Product_Name1
			(
				type = picklist	
				displayname = "Product Name"
				values  = Stock_tranfer_TRC_to_Showroom[Make is not null].ID
    			displayformat = [Product_Description]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = 320px
			)
			Product_Name
			(
				type = picklist	
				displayname = "Product Name Old"
				values  = Final_QC1.ID
    			displayformat = [Product_Description]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = 320px
			)
			must have Quantity
			(
				type = number
	 			row = 1
	 			column = 1   
				width = 100px
			)
			Warehouse
			(
				type = picklist
				maxchar = 100
				values = {"Nehru Place(Delhi)","TRC 2ND Floor","Bluemonk House Showroom","Bluemonk House Basement","Manesar","Nehru Place (Delhi)","Mumbai"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Quantity_Available
			(
				type = number
				displayname = "Quantity Available"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Rate
			(
				type = INR
				format = commadotindian
	 			row = 1
	 			column = 1   
				width = 100px
			)
			Amount
			(
				type = INR
				format = commadotindian
	 			row = 1
	 			column = 1   
				width = 150px
			)
			must have RAM_Modification_Required
			(
				type = picklist
				displayname = "RAM Modification Required"
				maxchar = 100
				values = {"Yes","No"}
	 			row = 1
	 			column = 1   
				width = 100px
			)
			Required_RAM_Capacity
			(
				type = picklist
				displayname = "Required RAM Capacity"
				maxchar = 100
				values = {"4 GB","8 GB","16 GB","32 GB","64 GB"}
	 			row = 1
	 			column = 1   
				width = 100px
			)
			must have HDD_Modification_Required
			(
				type = picklist
				displayname = "HDD Modification Required"
				maxchar = 100
				values = {"Yes","No"}
	 			row = 1
	 			column = 1   
				width = 100px
			)
			Required_HDD_Capacity
			(
				type = picklist
				displayname = "Required HDD Capacity"
				maxchar = 100
				values = {"120 GB","180 GB","240 GB","250 GB","256 GB","500 GB","512 GB","1 TB","2 TB"}
	 			row = 1
	 			column = 1   
				width = 100px
			)
			Status
			(
				type = picklist
				maxchar = 100
				values = {"Ready","Not Ready"}
	 			row = 1
	 			column = 1   
				width = 100px
			)
			Serial_Number
			(
    			type = text
				displayname = "Serial Number"
	 			row = 1
	 			column = 1   
				width = 200px
			)
			Product_Books_ID
			(
    			type = text
				displayname = "Product Books ID"
	 			row = 1
	 			column = 1   
				width = 300px
			)
			Quantity_Ready_Products
			(
				type = number
				displayname = "Quantity(Ready Products)"
	 			row = 1
	 			column = 1   
				width = 300px
			)
			SO_No
			(
    			type = text
				displayname = "SO No."
	 			row = 1
	 			column = 1   
				width = 300px
			)
			Product_ready
			(
				type = radiobuttons
				displayname = "Product ready"
				maxchar = 100
				values = {"Yes","No"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Tag_Numbers
			(
    			type = textarea
				displayname = "Tag Numbers"
				height = 100px
	 			row = 1
	 			column = 1   
				width = 200px
			)
			Serial_Numbers
			(
    			type = textarea
				displayname = "Serial Numbers"
				height = 100px
	 			row = 1
	 			column = 1   
				width = 200px
			)
			Remarks
			(
    			type = textarea
				height = 100px
	 			row = 1
	 			column = 1   
				width = 200px
			)
	
			customize
			(
				icon = "shopping-tag-sale"
			)
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
