			Get_Details_from_PO as "Get Details from PO"
			{
				type =  form
				form = Consumables
				record event = on add or edit

				on user input of PO_Number
				{
					actions 
					{
						custom deluge script
						(
											if(input.PO_Number != null)
										{
											po_rec = Purchase_Order[ID == input.PO_Number];
											input.Item.clear();
											input.Vendor_Name = po_rec.Vendor_Name.Vendor_Name;
											input.Invoice_Value = po_rec.Total_PO_Amount.toLong();
											input.SGST = po_rec.SGST;
											input.CGST = po_rec.CGST;
											input.IGST = po_rec.IGST;
											create_coll = Collection();
											for each  i in po_rec.PO_Item_Details
											{
												sbfrm = Consumables.Item();
												sbfrm.Category_new=i.Category;
												sbfrm.Sub_Category_new=i.Sub_Category;
												sbfrm.Tax_Percentage=i.Tax_Percentage;
												sbfrm.Item_Name=i.Item_Name;
												sbfrm.Product_Description=i.Product_Description;
												sbfrm.Quantity=i.Quantity_Ordered.toString();
												sbfrm.Price=i.Rate;
												create_coll.insert(sbfrm);
											}
											input.Item.insert(create_coll);
										}
						)
					}
				}

			}
			Get_Purchase_order_detail as "Get Purchase order details filled"
			{
				type =  form
				form = Spare_Part_GRN
				record event = on add or edit

				on user input of PO_Number
				{
					actions 
					{
						custom deluge script
						(
											if(input.PO_Number != null)
										{
											po_rec = Purchase_Order[ID == input.PO_Number];
											input.Invoice_Value = po_rec.Total_PO_Amount.toLong();
											input.Vendor_Name = po_rec.Vendor_Name.ID;
											input.CGST = po_rec.CGST;
											input.SGST = po_rec.SGST;
											input.IGST = po_rec.IGST;
											//Invoice Tax
											// 	input.SGST_Invoice = po_rec.SGST;
											// 	input.CGST_Invoice = po_rec.CGST;
											// 	input.IGST_Invoice = po_rec.IGST;
											input.PO_Date = po_rec.PO_date;
											input.Total_Purchase_Value_Without_Tax = po_rec.Sub_Total;
											input.Tax_Amount = po_rec.Total_Tax_Amount;
											input.Taxable_Amount = po_rec.Sub_Total;
											coll = Collection();
											total_quan = 0;
											for each  i in po_rec.PO_Item_Details
											{
												sbfrm = Spare_Part_GRN.Items();
												sbfrm.Category=i.Category;
												sbfrm.Main_Category=i.Main_Category;
												sbfrm.Sub_Category=i.Sub_Category;
												sbfrm.Price=i.Rate;
												sbfrm.Make=i.Make;
												make_val = Make_for_GRN[ID == i.Make].Make;
												make_spare_part = Make_Spare_Part[Make == make_val];
												sbfrm.Make1=make_spare_part.ID;
												sbfrm.Item_Name=i.Item_Name;
												sbfrm.Product_Description=i.Product_Description;
												sbfrm.PO_Quantity=i.Quantity_Ordered;
												total_quan = total_quan + i.Quantity_Ordered;
												sbfrm.PO_Number=input.PO_Number.PO_Number;
												sbfrm.Tax_Percentage=i.Tax_Percentage;
												coll.insert(sbfrm);
											}
											input.Items.insert(coll);
										}
										input.Total_PO_Quantity = total_quan;
										// if(input.Purchase_Order != null)
										// {
										// 	po_rec = Purchase_Order[ID == input.Purchase_Order];
										// 	input.Item.clear();
										// 	input.Vendor_Name = po_rec.Vendor_Name.Vendor_Name;
										// 	input.Invoice_Value = po_rec.Total_PO_Amount.toLong();
										// 	create_coll = Collection();
										// 	for each  i in po_rec.PO_Item_Details
										// 	{
										// 		sbfrm = Consumables.Item();
										// 		sbfrm.Category_new=i.Category;
										// 		sbfrm.Sub_Category_new=i.Sub_Category;
										// 		sbfrm.Item_Name=i.Item_Name;
										// 		sbfrm.Product_Description=i.Product_Description;
										// 		sbfrm.Quantity=i.Quantity_Ordered.toString();
										// 		sbfrm.Price=i.Rate;
										// 		create_coll.insert(sbfrm);
										// 	}
										// 	input.Item.insert(create_coll);
										// }
						)
					}
				}

			}
			Update_Production_Tracker3 as "Update Production Tracker"
			{
				type =  form
				form = Dry_Sanding
				record event = on add
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											fgh = Cleaning[ID == input.ID];
										User = fgh.Added_User;
										info User;
										Today_Production_Tracker = Production_Tracker[Engineer_Name == User.toString() && Date_field == zoho.currentdate];
										Tracker_Size = Today_Production_Tracker.count();
										info Tracker_Size;
										if(Tracker_Size == 0)
										{
											Create_map = Map();
											Create_map.put("IQC_Completed",0);
											Create_map.put("Date_field",zoho.currentdate.toString("dd-MMM-yyyy"));
											Create_map.put("L1_L2",0);
											Create_map.put("L3_L4",0);
											Create_map.put("L4_Support",0);
											Create_map.put("Final_QC",0);
											Create_map.put("Cleaning",1);
											Create_map.put("Painting",0);
											Create_map.put("Engineer_Name",User);
											empty_map = Map();
											Create_record = zoho.creator.createRecord("protaiga","oxypc-1","Production_Tracker",Create_map,empty_map,"creator");
											info Create_record;
											info "testing";
										}
										else
										{
											Today_Production_Count = Production_Tracker[Engineer_Name == User.toString() && Date_field == zoho.currentdate];
											Cleaning_count = Today_Production_Count.Cleaning;
											Today_Production_Count.Cleaning=Cleaning_count.toNumber() + 1;
											info "testing2";
										}
						)
					}
				}

			}
			Update_Stage_in_product_m2 as "Update Stage in product master Inventory"
			{
				type =  form
				form = Dry_Sanding
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											rec = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(input.Tag_No)];
										rec.Product_Stages="Assigned for Masking";
										rec.Product_Category="Masking";
										rec.Warehouse="TRC 2ND Floor";
						)
					}
					actions 
					{
						custom deluge script
						(
											//-----Amazon Inventory---//
										//Search record in Amazon inventory 
										Tag_number_result = invokeurl
										[
											url :"https://creator.zoho.in/api/v2.1/protaiga/amazon-inventory/report/All_Amazon_Assets?Tag_Number=" + input.Tag_No
											type :GET
											connection:"creator"
										];
										info "Amazon Inventory Record" + Tag_number_result;
										//Data mapping 
										Data_map = Map();
										optional_map = Map();
										Data_map.put("Status","Masking");
										Data_map.put("Stage","Assigned for Masking");
										// update Record if already present in Amazon inventory
										Tag_code = Tag_number_result.getJSON("code");
										Tag_msg = Tag_number_result.getJSON("message");
										if(Tag_code == 3000)
										{
											// info "update Record";
											Tag_data = Tag_number_result.getJSON("data");
											record_ID = Tag_data.getJSON("ID");
											update_rec = zoho.creator.updateRecord("protaiga","amazon-inventory","All_Amazon_Assets",record_ID,Data_map,optional_map,"creator");
											info update_rec;
										}
										else
										{
											info "record not present";
										}
						)
					}
				}

			}
