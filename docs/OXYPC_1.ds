			Updating_the_Product_Mast as "Updating the Product Master Inventory"
			{
				type =  form
				form = Final_QC_for_Engineer
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											rec = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(input.Tag_No)];
										if(rec.count(Make) != 0)
										{
											// 	rec.Make=input.Make;
											// 	rec.Model_QC=input.Model;
											// 	rec.CPU_QC=input.CPU;
											// 	rec.Generation_QC=input.Generation;
											// 	rec.HDD_QC=input.HDD;
											// 	rec.RAM_QC=input.RAM;
											// 	rec.Faults=input.Faults;
											// 	rec.QC_Submission="Submitted";
											// 	rec.Final_Status_QC=input.Final_Status;
											if(input.Final_Status == "Fail")
											{
												rec.Product_Stages="Assigned to L1/L2 Engineer";
												rec.Product_Category="Repair";
											}
											else if(input.Final_Status == "Pass")
											{
												rec.Product_Stages="Ready for Cleaning Assignment";
												rec.Product_Category="QC Completed";
											}
										}
						)
					}
					actions 
					{
						custom deluge script
						(
											//-----Amazon Inventory---//
										//Search record in Amazon inventory 
										Tag_number_result = invokeurl
										[
											url :"https://creator.zoho.in/api/v2.1/protaiga/amazon-inventory/report/All_Amazon_Assets?Tag_Number=" + input.Tag_No
											type :GET
											connection:"creator"
										];
										info "Amazon Inventory Record" + Tag_number_result;
										//Data mapping 
										Data_map = Map();
										optional_map = Map();
										Data_map.put("Status","Cleaning");
										Data_map.put("Stage","Assigned for Cleaning");
										// update Record if already present in Amazon inventory
										Tag_code = Tag_number_result.getJSON("code");
										Tag_msg = Tag_number_result.getJSON("message");
										if(Tag_code == 3000)
										{
											// info "update Record";
											Tag_data = Tag_number_result.getJSON("data");
											record_ID = Tag_data.getJSON("ID");
											update_rec = zoho.creator.updateRecord("protaiga","amazon-inventory","All_Amazon_Assets",record_ID,Data_map,optional_map,"creator");
											info update_rec;
										}
										else
										{
											info "record not present";
										}
						)
					}
				}

			}
