			Open_Out_form_on_replace_2 as "Open Out form on replace status"
			{
				type =  form
				form = Desktop_L1_L2_Engineer_Screen1
				record event = on add or edit

				on user input of faults.Status
				{
					actions 
					{
						custom deluge script
						(
											// if(faults.Status == "Replaced"){
										// 	openUrl("#Form:Spare_Part_Consumption?Make=" + input.Make + "&Model=" + input.Model + "&Spare_Part_Name=" + "Test" + "&Out_Quantity=" + faults.Quantity,"popup window","height=500,width=500");
										// }
										for each  i in input.faults
										{
											spare_part_rec = Spare_Parts2[ID == i.Spare_Part1];
											spare_part_name = spare_part_rec.Spare_Part_Name;
											if(i.Status == "Replaced" && i.Replaced_Part_Updated != "Done")
											{
												openUrl("#Form:Spare_Part_Consumption?Make=" + input.Make + "&Model=" + input.Model + "&Spare_Part_Name=" + spare_part_name + "&Out_Quantity=" + i.Quantity,"popup window","height=500,width=500");
												i.Replaced_Part_Updated="Done";
											}
										}
						)
					}
				}

			}
			Add_harvest_part_to_inven2 as "Add harvest part to inventory"
			{
				type =  form
				form = Desktop_L1_L2_Engineer_Screen1
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											for each  i in input.faults
										{
											if(i.Status == "Replaced")
											{
												mapp = Map();
												mapp.put("In_Out","INWARD");
												mapp.put("Spare_Part_Type","Harvest");
												mapp.put("Make",input.Make);
												mapp.put("Model",input.Model);
												mapp.put("Spare_Part_Name1",i.Spare_Part1.Spare_Part_Name);
												mapp.put("In_Quantity",i.Quantity);
												mapp.put("Spare_Category","Laptop");
												mapp1 = Map();
												zoho.creator.createRecord("protaiga","oxypc-1","Spare_Part_Inventory",mapp,mapp1,"creator");
											}
										}
						)
					}
				}

			}
			Add_to_Product_Master_Inv5 as "Add to Product Master Inventory"
			{
				type =  form
				form = Desktop_L1_L2_Engineer_Screen1
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											product_master = Product_Master_Inventory1[Tag_No2 == input.Barcode];
										sendmail
										[
											from :zoho.loginuserid
											to :"shubham.namdev@crm-masters.com"
											subject :"Testing Add to product master inventory - Desktop"
											message :"Product record" + product_master
										]
										NewMake = input.New_Make.toList("");
										if(NewMake.size() == 0)
										{
											product_master.Make=input.New_Make;
											info "===============----------" + product_master.Make;
										}
										else
										{
											product_master.Make=input.Make;
											info input.Make;
										}
										NewModel = input.New_Model_Value.toList("");
										if(NewModel.size() == 0)
										{
											product_master.Model=input.New_Model_Value;
										}
										else
										{
											product_master.Model=input.Model;
										}
										NewGeneration = input.New_Generation_Value.toList("");
										if(NewGeneration.size() == 0)
										{
											product_master.Generation=input.New_Generation_Value;
										}
										else
										{
											product_master.Generation=input.Generation;
										}
										NewCPU = input.New_CPU_Value.toList("");
										if(NewCPU.size() == 0)
										{
											product_master.CPU=input.New_CPU_Value;
										}
										else
										{
											product_master.CPU=input.CPU;
										}
										product_master.RAM=input.RAM;
										product_master.HDD=input.HDD;
										// product_master.Dust_Cleaning=input.Dust_Cleaning;
										// product_master.C_MOS_Battery_Change=input.C_MOS_Battery_Change;
										// product_master.CPU_Thermal_Paste=input.CPU_Thermal_Paste1;
										// product_master.Final_Status=input.Final_Status;
										// product_master.L1_L2_Engineer="Submitted";
										// product_master.Action_Taken_RAM=input.Action_Taken_RAM;
										// product_master.Added_Capacity=input.Added_Capacity;
										product_master.L1_L2_Date=zoho.currentdate.toString("dd-MMM-yyyy");
										// product_master.Time_L3_L4_Engineer=zoho.currenttime;
										if(input.Final_Status == "Completed")
										{
											product_master.Product_Stages="Assigned to Final QC";
											product_master.Product_Category="Final QC";
										}
										else if(input.Final_Status == "Escalate to L4")
										{
											product_master.Product_Stages="Assigned to L3/L4";
											product_master.Product_Category="L4 Repair";
										}
										else if(input.Final_Status == "PNA")
										{
											product_master.Product_Stages="PNA(Part not available)";
											product_master.Product_Category="PNA";
										}
										else if(input.Final_Status == "Scrap")
										{
											product_master.Product_Stages="Scrap";
											product_master.Product_Category="Scrap";
										}
										info "testing done ";
						)
					}
				}

			}
