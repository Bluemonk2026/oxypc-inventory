			Sales_order_Auto_Count as "Sales order Auto Count"
			{
				type =  form
				form = Sales_Orders
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											result = Oxy_Pc_Count[ID != null];
										if(result.Sale_Order_Count >= 1 && result.Sale_Order_Count <= 9)
										{
											input.Sales_Order_Number11 = "SO-0000" + result.Sale_Order_Count;
										}
										else if(result.Sale_Order_Count >= 10 && result.Sale_Order_Count <= 99)
										{
											input.Sales_Order_Number11 = "SO-000" + result.Sale_Order_Count;
										}
										else if(result.Sale_Order_Count >= 100 && result.Sale_Order_Count <= 999)
										{
											input.Sales_Order_Number11 = "SO-00" + result.Sale_Order_Count;
										}
										else if(result.Sale_Order_Count >= 1000 && result.Sale_Order_Count <= 9999)
										{
											input.Sales_Order_Number11 = "SO-0" + result.Sale_Order_Count;
										}
						)
					}
				}

			}
