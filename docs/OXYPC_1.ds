																parameters:data_map.toString()
																connection:"creator"
															];
															quantity = quantity - 200;
															sendmail
															[
																from :zoho.loginuserid
																to :{"shivam.kountey@bluemonk.in","shubham.namdev@crm-masters.com"}
																subject :"1st loop Record creation response"
																message :"Record creation response= " + create_records_inmaster
															]
														}
													}
												}
												else if(master_inventory_rec.count() < i.Quantity.tolong())
												{
													quantity = i.Quantity.toLong() - master_inventory_rec.count();
													info quantity;
