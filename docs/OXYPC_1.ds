											// 	data_mapp.put("Screen_Pin",input.scree;
											// 	data_mapp.put("Screen_Size",input.Screen_Size);
											// 	data_mapp.put("Part_Number",input.Part_No);
											// 	data_mapp.put("Screen_Serial_Number",input.Serial_Number);
											data_mapp.put("Part_Type","Old");
											if(input.Status == "Pass")
											{
												data_mapp.put("Screen_Stage","Product Finalized");
											}
											else
											{
												data_mapp.put("Screen_Stage","Assigned to Repair");
											}
											empty_mapp = Map();
											update_inv = zoho.creator.updateRecord("protaiga","oxypc-1","All_Spare_Parts",spare_part_Rec.ID,data_mapp,empty_mapp,"creator");
											info update_inv;
										}
										else
										{
											data_mapp = Map();
											// 	data_mapp.put("Tag_Number",input.Tag_No);
											// 	data_mapp.put("Screen_Type",input.Screen_Type);
											// 	data_mapp.put("Screen_Pin",input.Screen_Pin);
											// 	data_mapp.put("Screen_Size",input.Screen_Size);
											// 	data_mapp.put("Part_Number",input.Part_No);
											// 	data_mapp.put("Screen_Serial_Number",input.Serial_Number);
											data_mapp.put("Part_Type","Old");
											if(input.Status == "Ok")
											{
												data_mapp.put("Screen_Stage","Product Finalized");
											}
											else
											{
												data_mapp.put("Screen_Stage","Assigned to Repair");
											}
											empty_mapp = Map();
											update_inv = zoho.creator.createRecord("protaiga","oxypc-1","Spare_Parts",data_mapp,empty_mapp,"creator");
											info update_inv;
										}
						)
					}
				}

			}
			Create_Items_GRN_Report as "Create Items GRN Report"
			{
				type =  form
				form = Consumables
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											for each  i in input.Item
										{
											item_consumable = Item_Wise_Consumable[ConsumableRowID == i.ID.toString()];
											cat_rec = Category_for_Consumables[Category.equalsIgnoreCase(i.Category_new)];
											sub_cat_rec = Sub_category_for_consumables[Sub_Category_for_Consumables.equalsIgnoreCase(i.Sub_Category_new)];
											if(cat_rec.count() == 0)
											{
												mapp = Map();
												mapp.put("Category",i.Category_new);
												empty_mapp = Map();
												crea = zoho.creator.createRecord("protaiga","oxypc-1","Category_for_Consumables",mapp,empty_mapp,"creator");
												i.Category=crea.get("data").get("ID");
											}
											else
											{
												i.Category=cat_rec.ID;
											}
											if(sub_cat_rec.count() == 0)
											{
												mapp = Map();
												mapp.put("Sub_Category_for_Consumables",i.Sub_Category_new);
												empty_mapp = Map();
												crea = zoho.creator.createRecord("protaiga","oxypc-1","Sub_category_for_consumables",mapp,empty_mapp,"creator");
												i.Sub_category=crea.get("data").get("ID");
											}
											else
											{
												i.Sub_category=sub_cat_rec.ID;
											}
											if(item_consumable.count() == 0)
											{
												mapp = Map();
												mapp.put("GRN_Number",input.GRN_Number);
												mapp.put("Date_field",input.Date_of_Material_Received.toString("dd-MMM-yyyy"));
												mapp.put("Customer_Name",input.Customer_Name);
												mapp.put("Vehicle_Number",input.Vehicle_Number);
												mapp.put("Invoice_Number",input.Invoice_Number);
												mapp.put("Vendor_Name",input.Vendor_Name);
												mapp.put("Invoice_Value",input.Invoice_Value);
												mapp.put("Purchase_Order",input.PO_Number);
												mapp.put("Lot_Number",i.LOT_No);
												mapp.put("Category_New",i.Category_new);
												mapp.put("Sub_Category_New",i.Sub_Category_new);
												mapp.put("Quantity",i.Quantity);
												mapp.put("Price",i.Price);
												mapp.put("Location",i.Location);
												mapp.put("ConsumableRowID",i.ID);
												mapp.put("Category",i.Category);
												mapp.put("Sub_category",i.Sub_category);
												empty_mapp = Map();
												info "Create_mapp" + mapp;
												resp = zoho.creator.createRecord("protaiga","oxypc-1","Item_Wise_Consumable",mapp,empty_mapp,"creator");
												info resp;
												sendmail
												[
													from :zoho.loginuserid
													to :"shubham.oxypc@gmail.com"
													subject :"Consumable Item - Wise Record create"
													message :"Response" + resp
												]
											}
											else
											{
												mapp = Map();
												mapp.put("GRN_Number",input.GRN_Number);
												mapp.put("Date_field",input.Date_of_Material_Received.toString("dd-MMM-yyyy"));
												mapp.put("Customer_Name",input.Customer_Name);
												mapp.put("Vehicle_Number",input.Vehicle_Number);
												mapp.put("Invoice_Number",input.Invoice_Number);
												mapp.put("Vendor_Name",input.Vendor_Name);
												mapp.put("Invoice_Value",input.Invoice_Value);
												mapp.put("Purchase_Order",input.PO_Number);
												mapp.put("Lot_Number",i.LOT_No);
												mapp.put("Category_New",i.Category_new);
												mapp.put("Sub_Category_New",i.Sub_Category_new);
												mapp.put("Quantity",i.Quantity);
												mapp.put("Price",i.Price);
												mapp.put("Location",i.Location);
												mapp.put("ConsumableRowID",i.ID);
												mapp.put("Category",i.Category);
												mapp.put("Sub_category",i.Sub_category);
												empty_mapp = Map();
												info "Update_mapp" + mapp;
												upd_resp = zoho.creator.updateRecord("protaiga","oxypc-1","Item_Wise_Consumable_Report",item_consumable.ID,mapp,empty_mapp,"creator");
												info upd_resp;
												sendmail
												[
													from :zoho.loginuserid
													to :"shubham.oxypc@gmail.com"
													subject :"Consumable Item - Wise Record update"
													message :"Response" + upd_resp
												]
											}
										}
						)
					}
				}

			}
