															mapp.put("RAM_Cover",iqc_records.RAM_Cover);
															mapp.put("HDD_Cover",iqc_records.HDD_Cover);
															mapp.put("HDD_1",iqc_records.HDD_1);
															// 	mapp.put("Touch_Pad",iqc_records.Touch_Pad.toString());
															mapp.put("DVD",iqc_records.DVD);
															// 	mapp.put("Panel",iqc_records.Panel.toString());
															mapp.put("Base",iqc_records.Base);
															mapp.put("Keyboard",iqc_records.Keyboard);
															mapp.put("Health",iqc_records.Health);
															mapp.put("Health2",iqc_records.Health2);
															mapp.put("USB",iqc_records.USB);
															mapp.put("Hinch_Cover",iqc_records.Hinch_Cover);
															mapp.put("Hinch",iqc_records.Hinch);
															mapp.put("Logic_Card",iqc_records.Logic_Card);
															mapp.put("Battery_Cable",iqc_records.Battery_Cable);
															mapp.put("Battery",iqc_records.Battery);
															mapp.put("All_OK",iqc_records.ALL_OK);
															mapp.put("Battery_Health",iqc_records.Health1);
															mapp.put("DVD_Flap",iqc_records.DVD_Flap);
															mapp.put("RAM_Cover",iqc_records.RAM_Cover);
															mapp.put("Status",iqc_records.Status);
															mapp.put("BIOS_Password",iqc_records.BIOS_Password);
															mapp.put("Sound",iqc_records.Sound);
															mapp.put("HDDCategory",iqc_records.Category);
															mapp.put("HDD_Capacity",iqc_records.HDD_Capacity);
															mapp.put("HDD_Capacity1",iqc_records.HDD_Capacity1);
															mapp.put("Defected_Side",iqc_records.Defected_Side);
															mapp.put("Health",iqc_records.Health);
