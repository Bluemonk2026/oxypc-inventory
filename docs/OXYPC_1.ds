			find_aging as "find aging"
			{
				type =  form
				form = Product_Master_Inventory1
				record event = on add or edit
					status = inactive

				on user input of Sale_Date
				{
					actions 
					{
						custom deluge script
						(
											diff = (zoho.currentdate - input.Sale_Date);
										input.Aging = diff;
						)
					}
				}

			}
			show_fields4 as "show fields"
			{
				type =  form
				form = IQC_Format_for_Laptop
				record event = on add or edit

				on user input of RAM_Type
				{
					actions 
					{
						custom deluge script
						(
											if(input.RAM_Type == "DDR 1" || input.RAM_Type == "DDR 2" || input.RAM_Type == "DDR 3" || input.RAM_Type == "DDR 4" || input.RAM_Type == "DDR 5" || input.RAM_Type == "PC3L")
										{
											show Capacity;
										}
										else
										{
											hide Capacity;
											hide RAM_Status;
										}
						)
					}
				}

			}
