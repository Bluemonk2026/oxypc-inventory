												// 	mapp.put("Spare_Part_Sub_Category",inp)
												mapp.put("Tag_No",i.Tag_No);
												mapp1 = Map();
												zoho.creator.createRecord("protaiga","oxypc-1","Harvested_Parts1",mapp,mapp1,"creator");
											}
										}
						)
					}
				}

			}
