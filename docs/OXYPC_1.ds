			Update_final_status as "Update final status"
			{
				type =  form
				form = L1_L2_Engineer_Screen
				record event = on add or edit

				on user input of faults.Status
				{
					actions 
					{
						custom deluge script
						(
											lst = {};
										for each  i in input.faults
										{
											lst.add(i.Status);
										}
										if(lst.contains("PNA"))
										{
											input.Final_Status = "PNA";
											disable Final_Status;
										}
										else
										{
											enable Final_Status;
										}
						)
					}
				}

			}
			Hide_Fields24 as "Hide Fields"
			{
				type =  form
				form = PreSales_QC
				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											// hide Updated_Make;
										// hide Updated_Model;
										// hide Updated_CPU;
										// hide Updated_HDD;
										// hide Updated_RAM;
										// hide Updated_Generation;
										disable Make;
										disable Model;
										disable CPU;
										disable Generation;
										disable RAM;
										disable HDD;
										if(input.Need_to_Change_Configuration == "Yes")
										{
											show Updated;
										}
										else if(input.Need_to_Change_Configuration == "No")
										{
											hide Updated;
										}
										hide Sales_order_ID;
										hide Sales_order_item_id;
										// hide Faults;
										hide Date_field;
										hide Zoho_Books_ID;
										hide Sales_Order_Items;
										hide Time;
										disable Product_Stage;
										// disable Product_Description;
						)
					}
				}

			}
