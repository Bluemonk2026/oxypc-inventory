			Sending_to_Final_QC as "Sending to Final QC"
			{
				type =  form
				form = L1_L2_Engineer_Screen
				record event = on add
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Final_Status = "Completed")
										{
											mapp = Map();
											mapp.put("Tag_No",input.Barcode);
											mapp.put("Faulty_Spare_Parts",input.faults);
											mapp1 = Map();
											info zoho.creator.createRecord("protaiga","oxypc-1","Final_QC",mapp,mapp1,"creator");
										}
						)
					}
				}

			}
