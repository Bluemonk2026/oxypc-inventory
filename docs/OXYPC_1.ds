			Update_Inventory_if_Skipp as "Update Inventory if Skipped"
			{
				type =  schedule
				form = GRN[Final_Check_Box == false]
				start = after 10 minutes from Modified_Time
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						for each  i in input.Item
										{
											if(i.GRN_Check1 == "")
