											show Remarks;
											show Sound;
											show Web_Cam;
											show WIFI;
											input.Does = "";
											input.BIOS_Password = "";
											//input.Microphone = "";
										}
										// if(ALL_OK == "No")
										// {
										// 	ALL_OK.deselect("Yes");
										// }
						)
					}
				}

			}
			remove_duplicity_of_gener as "remove duplicity of generation"
			{
				type =  form
				form = IQC_Format_for_Laptop
				record event = on add or edit
					status = inactive

				on load
				{
					actions 
					{
						custom deluge script
						(
											// get unique FirstName values
										Unique = Classifications_of_Make_and_Model.distinct(Generation);
										// populate lookup field
										clear Generation1;
										for each  r in Unique
										{
											input.Generation1:ui.add(Classifications_of_Make_and_Model[Generation == r].ID);
										}
						)
					}
				}

			}
			Replacing_Null_value_with as "Replacing Null value with 0"
			{
				type =  form
				form = IQC_Format_for_Laptop
				record event = on add or edit
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											lst = {input.RAM_Rate,input.Microphone_Rate,input.HDD_Rate,input.Front_Panel_Rate,input.HDD_Cover_Rate};
										for each  i in lst
										{
											if(isNull(i) is true)
											{
												i = 0;
											}
										}
						)
					}
				}

			}
			Updating_Purchase_Price as "Updating Purchase Price"
			{
				type =  form
				form = Spare_Part_Cost_LOT_Wise
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											grn_values = Items_GRN[LOT_No == input.LOT_No && Category == 164568000000716007];
										item = grn_values.Price;
										input.Purchase_Price = item;
						)
					}
				}

			}
