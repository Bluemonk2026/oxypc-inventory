	section TFT_Production
	{
		displayname= "TFT Production"
		form IQC_Format_for_TFT
		{
			displayname = "IQC - TFT"
			success message = "Data Added Successfully!"
			field alignment = left
			feature property = 256
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have unique TAG
			(
    			type = text
				displayname = "Tag Number"
				qrcode = true
				barcode = true
				camera = primary
				show gallery = true
				switch camera = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			Time
			(
    			type = time
				initial value = "${zoho.currenttime}"	
				timedisplayoptions = "hh:mm:ss" 
	 			row = 1
	 			column = 1   
				width = medium
			)
			Fill_Previous_Lot_No
			(
				type = checkboxes	
				displayname = "Fill Previous Lot No."
				values = {"Update"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Make
			(
				type = picklist
				maxchar = 100
				values = {"HP","DELL","LENOVO","HCL","SAMSUNG","FUJITSU","AOC","LG","ACER","SONY","VIEWSONIC","ZEBRONICS","ZENITH","COMPAQ","VIDEOSEVEN","BENQ","SUN","OTHERS"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Screen_Type
			(
				type = radiobuttons
				displayname = "Screen Type"
				maxchar = 100
				values = {"LED","LCD","Touchscreen","IPS"}
				layout = 3
	 			row = 1
	 			column = 1   
				width = medium
			)
			Checkbox
			(
				type = checkboxes	
				values = {"Update"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Lot_No
			(
				type = picklist	
				displayname = "Lot No"
				values  = GRN.ID
    			displayformat = [Lot_No]
				sortorder = ascending
				private = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Serial_Number
			(
    			type = text
				displayname = "Serial No."
				qrcode = true
				barcode = true
				camera = primary
				switch camera = true
	 			row = 1
	 			column = 2   
				width = medium
			)
			record_Date
			(
    			type = date
				displayname = "record Date"
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Lot_No1
			(
				type = picklist	
				displayname = "Lot No"
				values  = LOT_No_s_GRN.ID
    			displayformat = [LOT_No]
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Screen_Size
			(
				type = picklist
				displayname = "Screen Size"
				maxchar = 100
				values = {"14\"","14.5\"","15\"","15.5\"","17\"","17.5\"","18\"","18.5\"","19\"","19.5\"","20\"","20.5\"","21\"","21.5\"","22\"","22.5\"","24\"","24.5\"","26\""}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Provide_Description
			(
    			type = textarea
				displayname = "Provide Description"
				height = 100px
    			description
    			[
    				type = tooltip
    			 	message = "Please specify if any"
    			]
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Location
			(
				type = picklist
				maxchar = 100
				values = {"Manesar","BMH"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Section1
			(
				type = section
				displayname = "Section"
	 			row = 2
	 			column = 0   
				width = medium
			)
			Power
			(
				type = radiobuttons
				maxchar = 100
				values = {"ON","OFF"}
				layout = 2
	 			row = 2
	 			column = 1   
				width = medium
			)
			Menu_Button
			(
				type = radiobuttons
				displayname = "Menu Button"
				maxchar = 100
				values = {"Working","Not Working","Not Checked","Missing","Broken"}
				layout = 2
	 			row = 2
	 			column = 1   
				width = medium
			)
			HDMI_Port
			(
				type = radiobuttons
				displayname = "HDMI Port"
				maxchar = 100
				values = {"Working","Not Working","Broken","Not Checked","NA"}
				layout = 2
	 			row = 2
	 			column = 1   
				width = medium
			)
			USB_Port
			(
				type = picklist
				displayname = "USB Port"
				maxchar = 100
				values = {"Working","1 Port Faulty","Multiple Port Faulty","Not Checked","NA"}
	 			row = 2
	 			column = 1   
				width = medium
			)
			must have TFT_Stand
			(
				type = radiobuttons
				displayname = "TFT Stand"
				maxchar = 100
				values = {"Yes","No"}
	 			row = 2
	 			column = 1   
				width = medium
			)
			Power_Button
			(
				type = radiobuttons
				displayname = "Power Button"
				maxchar = 100
				values = {"OK","Faulty"}
				layout = 2
	 			row = 2
	 			column = 2   
				width = medium
			)
			VGA_Port
			(
				type = radiobuttons
				displayname = "VGA Port"
				maxchar = 100
				values = {"Working","Not Working","Not Checked","Broken","NA"}
				layout = 3
	 			row = 2
	 			column = 2   
				width = medium
			)
			DP_Port
			(
				type = radiobuttons
				displayname = "DP Port"
				maxchar = 100
				values = {"Working","Not Working","Broken","Not Checked","NA"}
				layout = 2
	 			row = 2
	 			column = 2   
				width = medium
			)
			DVI_Port
			(
				type = radiobuttons
				displayname = "DVI Port"
				maxchar = 100
				values = {"Working","Not Working","Broken","Not Checked","NA"}
				layout = 2
	 			row = 2
	 			column = 2   
				width = medium
			)
			Section3
			(
				type = section
				displayname = ""
	 			row = 3
	 			column = 0   
				width = medium
			)
			must have Status
			(
				type = picklist
				maxchar = 100
				values = {"Ok","Faulty","Scrap"}
	 			row = 3
	 			column = 1   
				width = medium
			)
			Scrap_Reason
			(
				type = picklist
				displayname = "Scrap Reason"
				maxchar = 100
				values = {"Broken"}
	 			row = 3
	 			column = 1   
				width = medium
			)
			must have R2V3_Grading_Category
			(
				type = radiobuttons
				displayname = "R2V3 Grading Category"
				maxchar = 100
				values = {"C0","C1","C2","C3","C4","C5","C6","C7","C8","C9"}
				layout = 3
	 			row = 3
	 			column = 1   
				width = medium
			)
			Remarks
			(
    			type = textarea
				height = 100px
    			description
    			[
    				type = tooltip
    			 	message = "Please specify if any"
    			]
	 			row = 3
	 			column = 1   
				width = medium
			)
			Screen_Status
			(
				type = picklist
				displayname = "Fault"
				maxchar = 100
				values = {"Line","Patch","White","Broken","Scratch","Colour","Brightness","Not Checked"}
	 			row = 3
	 			column = 2   
				width = medium
			)
			must have Grade
			(
				type = radiobuttons
				maxchar = 100
				values = {"A","B","C","D","E"}
				layout = 3
	 			row = 3
	 			column = 2   
				width = medium
			)
	
			customize
			(
				icon = "tech-tablet-button"
			)
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
