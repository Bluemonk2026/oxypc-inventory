															mapp.put("Product_Category","Repair");
															mapp.put("Screen_Size",iqc_records.Screen_Size);
															mapp.put("Purchase_Price",i.Price);
															// 	mapp.put("IQC_Faults_Subform",iqc_records.Faulty_Spare_Parts);
															empty_mapp = Map();
															create_rec_inv = zoho.creator.createRecord("protaiga","oxypc-1","Product_Master_Inventory1",mapp,empty_mapp,"creator");
															info create_rec_inv;
															sendmail
