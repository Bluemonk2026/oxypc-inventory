			Update_status_of_Product_ as "Update status of Product in Presales QC"
			{
				type =  form
				form = Sales_Orders
				record event = on add or edit

				on user input of Item_Table.Product_ready
				{
					actions 
					{
						custom deluge script
						(
											ready_lst = List();
										for each  i in Item_Table
										{
											if(i.Product_ready == "Yes")
											{
												ready_lst.add("Yes");
											}
											else
											{
												ready_lst.add("No");
											}
										}
										if(ready_lst.contains("No") is false)
										{
											input.All_Products_Ready = "Yes";
										}
										else
										{
											info "Testing CLosed";
										}
						)
					}
				}

			}
			Add_Or_Update_Make_and_Mo as "Add Or Update Make and Model"
			{
				type =  form
				form = Model
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											mapp = Map();
										make_val = input.Make.Make;
										make_rec = Make_for_GRN[Make == make_val && Category == "Laptop"];
										if(make_rec.count() == 0)
										{
											make_data = Map();
											make_data.put("Make",input.Make.Make);
											make_data.put("Category","Laptop");
											empty_mapp = Map();
											make_create = zoho.creator.createRecord("protaiga","oxypc-1","Make_for_GRN",make_data,empty_mapp,"creator");
											mapp.put("Make",make_create.get("ID"));
										}
										else
										{
											mapp.put("Make",make_rec.ID);
										}
										mapp.put("Model",input.Model);
										mapp.put("Category","Laptop");
										empty_mapp = Map();
										zoho.creator.createRecord("protaiga","oxypc-1","Product_Master_for_GRN",mapp,empty_mapp,"creator");
						)
					}
				}

			}
