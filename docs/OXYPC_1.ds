		form Desktop_L1_L2_Engineer_Screen1
		{
			displayname = "Desktop Repair"
			success message = "L1/l2 Engineer Screen Added Successfully"
			field alignment = left
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Barcode
			(
    			type = text
				displayname = "Tag No."
				qrcode = true
				barcode = true
				camera = primary
				show gallery = true
				switch camera = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			Make
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			Update_Make
			(
				type = radiobuttons
				displayname = "Update Make"
				maxchar = 100
				values = {"Yes","No"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			New_Make1
			(
				type = picklist	
				displayname = "New Make"
				values  = Make_for_Desktop.ID
    			displayformat = [Make]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			New_Make
			(
    			type = text
				displayname = "New Make"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Generation
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			Update_Generation
			(
				type = radiobuttons
				displayname = "Update Generation"
				maxchar = 100
				values = {"Yes","No"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			New_Generation_Value
			(
    			type = text
				displayname = "New Generation"
	 			row = 1
	 			column = 1   
				width = medium
			)
			New_Generation
			(
				type = picklist
				displayname = "New Generation"
				maxchar = 100
				values = {"1st","2nd","3rd","4th","5th","6th","7th","8th","9th","10th","11th","12th","13th","N series","NA"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Date_field
			(
    			type = date
				displayname = "Date"
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
				private = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			checkbox
			(
				type = checkboxes	
				displayname = "Checkbox"
				values = {"Update"}
				private = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			Serial_Number
			(
    			type = text
				displayname = "Serial Number"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Model
			(
    			type = text
	 			row = 1
	 			column = 2   
				width = medium
			)
			Update_Model
			(
				type = radiobuttons
				displayname = "Update Model"
				maxchar = 100
				values = {"Yes","No"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			New_Model
			(
				type = picklist	
				displayname = "New Model"
				values  = Model_for_Desktop.ID
    			displayformat = [Model]
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			New_Model_Value
			(
    			type = text
				displayname = "New Model"
	 			row = 1
	 			column = 2   
				width = medium
			)
			HDD
			(
    			type = text
	 			row = 1
	 			column = 2   
				width = medium
			)
			Update_HDD
			(
				type = radiobuttons
				displayname = "Update HDD"
				maxchar = 100
				values = {"Yes","No"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Removed_Capacity1
			(
				type = picklist
				displayname = "Removed Capacity HDD"
				maxchar = 100
				values = {"128 GB","250 GB","256 GB","320 GB","500 GB","512 GB","1 TB","2 TB","3 TB","4 TB","5 TB","8 TB","16 TB"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Added_Capacity1
			(
				type = picklist
				displayname = "Added Capacity HDD"
				maxchar = 100
				values = {"128 GB","250 GB","256 GB","320 GB","500 GB","512 GB","1 TB","2 TB","3 TB","4 TB","5 TB","8 TB","16 TB"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Engineer
			(
    			type = picklist
				module = users
				displayformat = [username]
	 			row = 1
	 			column = 2   
				width = medium
				personal data = true
			)
			Time
			(
    			type = time
				initial value = "${zoho.currenttime}"	
				timedisplayoptions = "hh:mm:ss" 
				private = true
	 			row = 1
	 			column = 2   
				width = medium
			)
			LOT_No
			(
    			type = text
				displayname = "LOT No."
	 			row = 1
	 			column = 3   
				width = medium
			)
			CPU
			(
    			type = text
	 			row = 1
	 			column = 3   
				width = medium
			)
			Update_CPU
			(
				type = radiobuttons
				displayname = "Update CPU"
				maxchar = 100
				values = {"Yes","No"}
	 			row = 1
	 			column = 3   
				width = medium
			)
			New_CPU
			(
				type = picklist
				displayname = "New CPU"
				maxchar = 100
				values = {"AMD","Dual Core","Pentium Dual Core","Pentium R","C2D","Celleron","P4","Atom","I3","I5","I7","I9","XEON"}
	 			row = 1
	 			column = 3   
				width = medium
			)
			New_CPU_Value
			(
    			type = text
				displayname = "New CPU"
	 			row = 1
	 			column = 3   
				width = medium
			)
			RAM
			(
    			type = text
	 			row = 1
	 			column = 3   
				width = medium
			)
			RAM_Status
			(
				type = radiobuttons
				displayname = "RAM Status"
				maxchar = 100
				values = {"Upgraded","Downgraded","Replaced","No Change"}
				layout = 2
	 			row = 1
	 			column = 3   
				width = medium
			)
			Action_Taken_RAM
			(
				type = radiobuttons
				displayname = "Action Taken(RAM) "
				maxchar = 100
				values = {"Replaced","Removed"}
				layout = 3
	 			row = 1
	 			column = 3   
				width = medium
			)
			Action_Taken_RAM1
			(
				type = radiobuttons
				displayname = "Action Taken(RAM)"
				maxchar = 100
				values = {"Added","Replaced"}
				layout = 3
	 			row = 1
	 			column = 3   
				width = medium
			)
			Removed_Capacity
			(
				type = picklist
				displayname = "Removed Capacity RAM"
				maxchar = 100
				values = {"4 GB","8 GB","16 GB","32 GB","64 GB","128 GB"}
	 			row = 1
	 			column = 3   
				width = medium
			)
			Added_Capacity
			(
				type = picklist
				displayname = "Added Capacity RAM"
				maxchar = 100
				values = {"4 GB","8 GB","16 GB","32 GB","64 GB","128 GB"}
	 			row = 1
	 			column = 3   
				width = medium
			)
			faults
			(
				type = grid
				displayname = "Faults"
				values  = Faulty_Spare_Parts_After_IQC1.ID
	 			row = 2
	 			column = 1   
				width = medium
			)
			Final_Status1
			(
				type = section
				displayname = "Final Status"
	 			row = 3
	 			column = 0   
				width = medium
			)
			must have Dust_Cleaning
			(
				type = radiobuttons
				displayname = "Dust Cleaning"
				maxchar = 100
				values = {"Done","Not Done"}
				layout = 3
	 			row = 3
	 			column = 1   
				width = medium
			)
			must have C_MOS_Battery_Change
			(
				type = radiobuttons
				displayname = "C-MOS Battery Change"
				maxchar = 100
				values = {"Done","Not Done"}
				layout = 3
	 			row = 3
	 			column = 1   
				width = medium
			)
			must have CPU_Thermal_Paste1
			(
				type = radiobuttons
				displayname = "CPU Thermal Paste"
				maxchar = 100
				values = {"Done","Not Done"}
				layout = 3
	 			row = 3
	 			column = 1   
				width = medium
			)
			Section1
			(
				type = section
				displayname = "Section"
	 			row = 4
	 			column = 0   
				width = medium
			)
			must have Final_Status
			(
				type = picklist
				displayname = "Final Status"
				maxchar = 100
				values = {"PNA","Completed","Escalate to L4","Scrap"}
				sortorder = ascending
	 			row = 4
	 			column = 1   
				width = medium
