			E_way_bill_Make_Fields_Ma as "E-way bill Make Fields Mandatory"
			{
				type =  form
				form = Spare_Part_GRN
				record event = on add or edit
					status = inactive

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.Invoice_Value > 50000)
										{
											if(input.E_Way_Bill_Date == null || input.E_Way_Bill_Image == "")
											{
												newline = hextotext("0A");
