											cp = input.CPU;
										}
										if(input.Updated_Generation != null)
										{
											gen = input.Updated_Generation;
										}
										else
										{
											gen = input.Generation;
										}
										if(input.Updated_RAM != null)
										{
											rm = input.Updated_RAM;
										}
										else
										{
											rm = input.RAM;
										}
										if(input.Updated_HDD != null)
										{
											hd = input.Updated_HDD;
										}
										else
										{
											hd = input.HDD;
										}
										model_description = mke + " " + mdl + " " + cp + " " + gen + " " + rm + " " + hd;
										if(input.Battery == "Yes")
