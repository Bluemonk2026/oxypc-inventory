	section Sales_Process
	{
		displayname= "Sales Process"
		icon = "business-businessman-03"
		form PreSales_QC
		{
			displayname = "PreSales QC"
			success message = "Data Added Successfully!"
			field alignment = left
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			Customer_Name
			(
				type = picklist	
				displayname = "Customer Name"
				values  = Customer_Database.ID
    			displayformat = [Customer_Name]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have unique Tag_Number
			(
    			type = text
				displayname = "Tag Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Zoho_Books_ID
			(
    			type = text
				displayname = "Zoho Books ID"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Sales_Order_Items
			(
				type = picklist	
				displayname = "Sales Order Items"
				values  = Sales_Order_Items.ID
    			displayformat = ["(" + SO_No + ") " + Quantity]
				advanced field search = true
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Make
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			CPU
			(
				type = picklist
				maxchar = 100
				values = {"I3","I4","I5","I7","M5","M7","celeron","C2D","AMD","AMD PRO","PENTIUM R","XEON","Other"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			HDD
			(
				type = picklist
				maxchar = 100
				values = {"64 GB","120 GB","128 GB","180 GB","240 GB","250 GB","256 GB","320 GB","500 GB","512 GB","1 TB","2 TB","No","3 TB","4 TB","5 TB","8 TB","16 TB"}
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Battery
			(
				type = radiobuttons
				maxchar = 100
				values = {"Yes","No"}
				initial value = "Yes"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Category
			(
				type = picklist
				maxchar = 100
				values = {"Laptop","Desktop"}
				initial value = "Laptop"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Sales_order_ID
			(
    			type = text
				displayname = "Sales order ID"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Sales_order_item_id
			(
    			type = text
				displayname = "Sales order item id"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Serial_Number
			(
    			type = text
				displayname = "Serial Number"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Model
			(
    			type = text
	 			row = 1
	 			column = 2   
				width = medium
			)
			Generation
			(
				type = picklist
				maxchar = 100
				values = {"1ST","2ND","3RD","4TH","5TH","6TH","7TH","8TH","9TH","10TH","11TH","12TH","A10","C2D","Other"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			RAM
			(
				type = picklist
				maxchar = 100
				values = {"2GB","4GB","6GB","8GB","12GB","16GB","32GB","64GB","Others","No"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Adapter
			(
				type = radiobuttons
				maxchar = 100
				values = {"Yes","No"}
				initial value = "Yes"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Section1
			(
				type = section
				displayname = "Section"
	 			row = 2
	 			column = 0   
				width = medium
			)
			Product_Description
			(
    			type = text
				displayname = "Product Description"
	 			row = 2
	 			column = 1   
				width = medium
			)
			Need_to_Change_Configuration
			(
				type = radiobuttons
				displayname = "Need to Change Configuration?"
				maxchar = 100
				values = {"Yes","No"}
				initial value = "No"
	 			row = 2
	 			column = 1   
				width = medium
			)
			must have Final_Status
			(
				type = picklist
				displayname = "Final Status"
				maxchar = 100
				values = {"Ok","Rejected"}
	 			row = 2
	 			column = 1   
				width = medium
			)
			Remarks
			(
    			type = textarea
				height = 100px
	 			row = 2
	 			column = 1   
				width = medium
			)
			Product_Full_Name
			(
    			type = text
				displayname = "Product Full Name"
	 			row = 2
	 			column = 2   
				width = medium
			)
			Time
			(
    			type = time
				initial value = "${zoho.currenttime}"	
				timedisplayoptions = "hh:mm:ss" 
	 			row = 2
	 			column = 2   
				width = medium
			)
			Date_field
			(
    			type = date
				displayname = "Date"
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 2
	 			column = 2   
				width = medium
			)
			Product_Stage
			(
				type = picklist
				displayname = "Product Stage"
				maxchar = 100
				values = {"Sold Out","Other","Booked"}
	 			row = 2
	 			column = 2   
				width = medium
			)
			Updated
			(
				type = section
				visibility = true
	 			row = 3
	 			column = 0   
				width = medium
			)
			Updated_Make
			(
				type = picklist	
				displayname = "Updated Make"
				values  = Make.ID
    			displayformat = [Make]
				sortorder = ascending
	 			row = 3
	 			column = 1   
				width = medium
			)
			Updated_CPU
			(
				type = picklist
				displayname = "Updated CPU"
				maxchar = 100
				values = {"I3","I4","I5","I7","M5","M7","celeron","C2D","AMD","AMD PRO","PENTIUM R","XEON","Other"}
	 			row = 3
	 			column = 1   
				width = medium
			)
			Updated_HDD
			(
				type = picklist
				displayname = "Updated HDD"
				maxchar = 100
				values = {"64 GB","120 GB","128 GB","180 GB","240 GB","250 GB","256 GB","320 GB","500 GB","512 GB","1 TB","2 TB","3 TB","4 TB","5 TB","8 TB","16 TB","No Hard disk"}
	 			row = 3
	 			column = 1   
				width = medium
			)
			Updated_Model
			(
				type = picklist	
				displayname = "Updated Model"
				values  = Model.ID
    			displayformat = [Model]
				sortorder = ascending
	 			row = 3
	 			column = 2   
				width = medium
			)
			Updated_Generation
			(
				type = picklist
				displayname = "Updated Generation"
				maxchar = 100
				values = {"1ST","2ND","3RD","4TH","5TH","6TH","7TH","8TH","9TH","10TH","11TH","12TH","A10","C2D","Other"}
	 			row = 3
	 			column = 2   
				width = medium
			)
			Updated_RAM
			(
				type = picklist
				displayname = "Updated RAM"
				maxchar = 100
				values = {"2GB","4GB","6GB","8GB","12GB","16GB","32GB","64GB","No RAM","Others"}
	 			row = 3
	 			column = 2   
				width = medium
			)
	
			customize
			(
				icon = "ui-1-bold-add"
			)
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
