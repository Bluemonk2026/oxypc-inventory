			Update_Make_and_model_of_ as "Update Make and model of Laptop according to zoho"
			{
				type =  form
				form = Copy_of_IQC_Format_for_Laptop
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Make2 != null)
										{
											output_make = input.Make2.getprefix(" ");
											make_rec = Make[Make.equalsIgnoreCase(input.Make2)].ID;
											input.Make = make_rec;
										}
										if(input.Model2 != null)
										{
											output_model = input.Model2;
											model_rec = Model[Model.equalsIgnoreCase(input.Model2)].ID;
											input.Model1 = model_rec;
										}
						)
					}
				}

			}
