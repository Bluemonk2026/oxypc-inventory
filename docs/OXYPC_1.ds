			Create_Sold_Out_Report as "Create Sold Out Report"
			{
				type =  form
				form = Sold_Out_Tag_Numbers
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											newline = hextotext("0A");
										for each  i in input.Sold_Out_Tags
										{
											info i;
											for each  j in i.Tag_Numbers.toList(newline)
											{
												info j;
												if(j != null || j != "")
												{
													sold_out_recs = Sold_Out_Report[Tag_Number.equalsIgnoreCase(j)];
													inv_rec = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(j)];
													if(sold_out_recs.count() == 0)
													{
														mapp = Map();
														mapp.put("Tag_Number",j);
														mapp.put("Make",inv_rec.Make);
														mapp.put("Model",inv_rec.Model);
														mapp.put("Lot_Number",inv_rec.LOT_No);
														mapp.put("CPU",inv_rec.CPU);
														mapp.put("Generation",inv_rec.Generation);
														mapp.put("Sales_Person",input.Sales_Person_Name);
														mapp.put("Customer_Name",input.Customer_Name);
														mapp.put("Sale_Date",input.Sale_Date.toString("dd-MMM-yyyy"));
														mapp.put("Sale_Price",i.Sales_Price);
														empty_mapp = Map();
														info zoho.creator.createRecord("protaiga","oxypc-1","Sold_Out_Report",mapp,empty_mapp,"creator");
													}
													inv_rec.Product_Stages="Sold Out";
													inv_rec.Product_Category="Sold Out";
													inv_rec.Sales_Price=i.Sales_Price;
													inv_rec.Sale_Date=input.Sale_Date.toString("dd-MMM-yyyy");
