												// 				input.Power_Panel = iqcfetchrecord.Power_Panel;
												// 				input.Touch_Pad = iqcfetchrecord.Touch_Pad;
												// 				input.Base = iqcfetchrecord.Base;
												// 				input.Keyboard = iqcfetchrecord.Keyboard;
												// 				input.Logic_Card = iqcfetchrecord.Logic_Card;
												// 				input.USB = iqcfetchrecord.USB;
												// 				input.HDD_Connector = iqcfetchrecord.HDD_Connector;
												// 				input.Sound = iqcfetchrecord.Sound;
												// 				input.HDD_Casing = iqcfetchrecord.HDD_Casing;
												// 				input.Web_Cam = iqcfetchrecord.Web_Cam;
												// 				input.HDD_Cover = iqcfetchrecord.HDD_Cover;
												// 				input.RAM_Cover = iqcfetchrecord.RAM_Cover;
												// 				input.WIFI = iqcfetchrecord.WIFI;
												// 				input.Battery = iqcfetchrecord.Battery;
												// 				input.Health1 = iqcfetchrecord.Health1;
