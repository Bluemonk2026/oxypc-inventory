			Update_Fields as "Update Fields"
			{
				type =  form
				form = L3_L4_Engineer_Screen
				record event = on add

				on user input of Barcode
				{
					actions 
					{
						custom deluge script
						(
											pending_bucket_rec = Repair_Completed_L3_L4[Tag_No1.equalsIgnoreCase(input.Barcode)];
										if(pending_bucket_rec.count() != 0)
										{
											if(pending_bucket_rec.Received_from == "L1/L2 Engineer")
											{
												barcode2 = pending_bucket_rec.Tag_No1;
												input.Problem_Reported = pending_bucket_rec.Problem_Reported1;
												input.Received_from_Engineer = pending_bucket_rec.Received_from_Engineer;
												input.Received_From = pending_bucket_rec.Received_from;
												// 		make_rec = l1_l2_var.Make;
												// 		make_record = Make[ID == make_rec.];
												l1_l2_var = L1_L2_Engineer_Screen[Barcode.equalsIgnoreCase(barcode2)];
												l1_l2_desk = Desktop_L1_L2_Engineer_Screen1[Barcode.equalsIgnoreCase(barcode2)];
												l1_l2_tft = TFT_L1_L2_Engineer_Screen[Barcode.equalsIgnoreCase(barcode2)];
												if(l1_l2_var.count() != 0)
												{
													if(l1_l2_var.New_Make == null || l1_l2_var.New_Make == "")
													{
														input.Make = l1_l2_var.Make;
													}
													else
													{
														input.Make = l1_l2_var.New_Make;
													}
													if(l1_l2_var.New_Model_Value == null || l1_l2_var.New_Model_Value == "")
													{
														input.Model = l1_l2_var.Model;
													}
													else
													{
														input.Model = l1_l2_var.New_Model_Value;
													}
													if(l1_l2_var.New_Generation_Value == null || l1_l2_var.New_Generation_Value == "")
													{
														input.Generation = l1_l2_var.Generation;
													}
													else
													{
														input.Generation = l1_l2_var.New_Generation_Value;
													}
													if(l1_l2_var.New_CPU_Value == null || l1_l2_var.New_CPU_Value == "")
													{
														input.CPU = l1_l2_var.CPU;
													}
													else
													{
														input.CPU = l1_l2_var.New_CPU_Value;
													}
													if(l1_l2_var.LOT_No != null || l1_l2_var.LOT_No != "")
													{
														input.LOT_No = l1_l2_var.LOT_No;
													}
													// 		model_id = l1_l2_var.Model1;
													// 		var1 = Model[ID == model_id];
													input.Category = "Laptop";
												}
												else if(l1_l2_desk.count() != 0)
												{
													if(l1_l2_desk.New_Make == null || l1_l2_desk.New_Make == "")
													{
														input.Make = l1_l2_desk.Make;
													}
													else
													{
														input.Make = l1_l2_desk.New_Make;
													}
													if(l1_l2_desk.New_Model_Value == null || l1_l2_desk.New_Model_Value == "")
													{
														input.Model = l1_l2_desk.Model;
													}
													else
													{
														input.Model = l1_l2_desk.New_Model_Value;
													}
													if(l1_l2_desk.New_Generation_Value == null || l1_l2_desk.New_Generation_Value == "")
													{
														input.Generation = l1_l2_desk.Generation;
													}
													else
													{
														input.Generation = l1_l2_desk.New_Generation_Value;
													}
													if(l1_l2_desk.New_CPU_Value == null || l1_l2_desk.New_CPU_Value == "")
													{
														input.CPU = l1_l2_desk.CPU;
													}
													else
													{
														input.CPU = l1_l2_desk.New_CPU_Value;
													}
													if(l1_l2_desk.LOT_No != null || l1_l2_desk.LOT_No != "")
													{
														input.LOT_No = l1_l2_desk.LOT_No;
													}
													input.Category = "Desktop";
												}
												else if(l1_l2_tft != 0)
												{
													if(l1_l2_tft.New_Make == null || l1_l2_tft.New_Make == "")
													{
														input.Make = l1_l2_tft.Make;
													}
													else
													{
														input.Make = l1_l2_tft.New_Make;
													}
													if(l1_l2_tft.LOT_No != null || l1_l2_tft.LOT_No != "")
													{
														input.LOT_No = l1_l2_tft.LOT_No;
													}
													// 		model_id = l1_l2_var.Model1;
													// 		var1 = Model[ID == model_id];
													input.Category = "TFT";
												}
											}
										}
										if(input.Category == "TFT")
										{
											input.Action_Taken:ui.add("Part replaced");
											input.Action_Taken:ui.add("Track Repair");
											input.Action_Taken:ui.add("Reflow");
											input.Action_Taken:ui.add("Re-soldering");
											input.Action_Taken:ui.add("Others");
											input.Problem_Observed:ui.add("No Display");
											input.Problem_Observed:ui.add("No Power");
											input.Problem_Observed:ui.add("USB");
											input.Problem_Observed:ui.add("VGA");
											input.Problem_Observed:ui.add("DP");
											input.Problem_Observed:ui.add("HDMI");
											input.Problem_Observed:ui.add("Menu Button");
											input.Problem_Observed:ui.add("DIM Display");
											input.Problem_Observed:ui.add("Others");
										}
										else if(input.Category == "Desktop")
										{
											input.Action_Taken:ui.add("Part replaced");
											input.Action_Taken:ui.add("BIOS Programming");
											input.Action_Taken:ui.add("Track Repair");
											input.Action_Taken:ui.add("Reflow");
											input.Action_Taken:ui.add("Re-soldering");
											input.Action_Taken:ui.add("CPU Socket PIN alignment");
											input.Action_Taken:ui.add("CMOS change");
											input.Action_Taken:ui.add("Others");
											input.Problem_Observed:ui.add("No Display");
											input.Problem_Observed:ui.add("No Power");
											input.Problem_Observed:ui.add("USB");
											input.Problem_Observed:ui.add("VGA");
											input.Problem_Observed:ui.add("DP");
											input.Problem_Observed:ui.add("HDMI");
											input.Problem_Observed:ui.add("CPU Pin Damage");
											input.Problem_Observed:ui.add("Others");
										}
										else if(input.Category == "Laptop" || input.Category == "" || input.Category == null)
										{
											input.Action_Taken:ui.add("Part Replaced");
											input.Action_Taken:ui.add("Bios Programming");
											input.Action_Taken:ui.add("Shorting removed");
											input.Action_Taken:ui.add("Resoldering");
											input.Action_Taken:ui.add("Reflow");
											input.Action_Taken:ui.add("Track repair");
											input.Action_Taken:ui.add("Others");
											input.Problem_Observed:ui.add("Not ON");
											input.Problem_Observed:ui.add("Dim Display");
											input.Problem_Observed:ui.add("No Display");
											input.Problem_Observed:ui.add("On/Off");
											input.Problem_Observed:ui.add("Hanging");
											input.Problem_Observed:ui.add("KBD Not Working");
