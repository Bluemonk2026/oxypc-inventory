			Fetch_Data_based_on_Lot_n as "Fetch Data based on Lot number"
			{
				type =  form
				form = Biding
				record event = on add or edit

				on user input of Select_Lot_Number
				{
					actions 
					{
						custom deluge script
						(
											// input.Select_Lot_Number;
										result = IQC_Format_for_Laptop[LOT_Number.equalsIgnoreCase(input.Select_Lot_Number)];
										count = 0;
										rec = Collection();
										product_count = Map();
										for each  line_item in result
										{
											count = count + 1;
											product_desc = line_item.Make.Make + " " + line_item.Model1.Model + " " + line_item.CPU + " " + line_item.Generation;
											// 	info product_desc;
											if(product_count.containKey(product_desc))
											{
												product_count.put(product_desc,product_count.get(product_desc) + 1);
											}
											else
											{
												// Initialize the count for this new product description
												product_count.put(product_desc,1);
											}
										}
										for each  product_desc in product_count.keys()
										{
											obj1 = Biding.Laptop_Details();
											obj1.Quantity=product_count.get(product_desc);
											obj1.Category="Laptop";
											obj1.Product_Description=product_desc;
											// 	obj1.Make=datax.Make.Make;
											// 	obj1.Model=datax.Model1.Model;
											// 	obj1.CPU=datax.CPU;
											// 	obj1.Generation=datax.Generation;
											// 	obj1.Ram=datax.Capacity;
											// 	if(datax.HDD_Capacity1 == null || datax.HDD_Capacity1 == "")
											// 	{
											// 		obj1.HDD=datax.HDD_Capacity;
											// 	}
											// 	else
											// 	{
											// 		obj1.HDD=datax.HDD_Capacity1;
											// 	}
											// 	obj1.Category=datax.Category;
											rec.insert(obj1);
										}
										input.Laptop_Details.clear();
										input.Laptop_Details.insert(rec);
										input.Total_Quantity = count;
						)
					}
				}

			}
