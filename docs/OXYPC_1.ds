				type =  form
				form = Battery_QC_Section
				record event = on add or edit

				on user input of Tag_Number
				{
					actions 
					{
						custom deluge script
						(
											repair_section = Battery_Repair[Tag_Number.equalsIgnoreCase(input.Tag_Number)];
										iqc_rec = IQC_Format_for_Battery[Tag_Number.equalsIgnoreCase(input.Tag_Number)];
										if(repair_section.count() > 0)
										{
											if(repair_section.Status1 != "Scrap")
											{
												// 		input.Tag_Number = repair_section.Tag_Number;
												input.Lot_Number = repair_section.Lot_Number;
												input.Make = repair_section.Make;
												input.Model = repair_section.Model;
												input.Health = repair_section.Health;
												disable Lot_Number;
												disable Make;
												disable Model;
												disable Health;
											}
											else
											{
												alert "This Battery is Scrap";
												input.Tag_Number = "";
											}
										}
										else
										{
											input.Lot_Number = iqc_rec.LOT_Number;
											input.Make = iqc_rec.Make.Make;
											input.Model = iqc_rec.Model.Model;
											// 		input.Health = repair_section.Health;
											enable Health;
										}
						)
					}
				}

			}
			Disable_and_hide_fields as "Disable and hide fields"
			{
				type =  form
				form = Battery_QC_Section
				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											disable Lot_Number;
										disable Health;
										disable Make;
										disable Model;
										hide Fail_Reasoan;
						)
					}
				}

			}
			hide_fail_reason as "hide fail reason"
			{
				type =  form
				form = Battery_QC_Section
				record event = on add or edit

				on user input of Status
				{
					actions 
					{
						custom deluge script
						(
											if(input.Status == "Fail")
										{
											show Fail_Reasoan;
										}
										else
										{
											hide Fail_Reasoan;
											input.Fail_Reasoan = "";
										}
						)
					}
				}

			}
			Make_Field_Mandatory2 as "Make Field Mandatory"
			{
				type =  form
				form = Battery_QC_Section
				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.Status == "Fail" && input.Fail_Reasoan == null)
										{
											alert "Please Fill Fail Reason";
											cancel submit;
										}
						)
					}
				}

			}
			Fetch_Data_from_Purchase_1 as "Fetch Data from Purchase Order"
			{
				type =  form
				form = GRN
				record event = on add or edit

				on user input of PO_Number
				{
					actions 
					{
						custom deluge script
						(
											if(input.PO_Number != null)
										{
											po_rec = Purchase_Order[ID == input.PO_Number];
											input.Item.clear();
											input.Vendor_Name_PO = po_rec.Vendor_Name;
											input.Invoice_Value = po_rec.Total_PO_Amount.toLong();
											input.Taxable_Amount = po_rec.Sub_Total;
											input.SGST = po_rec.SGST;
											input.CGST = po_rec.CGST;
											input.IGST = po_rec.IGST;
											input.PO_Date = po_rec.PO_date;
											input.Total_Tax_Amount = po_rec.Total_Tax_Amount;
											total_po_quantity = 0;
											total_po_value = 0.00;
											create_coll = Collection();
											for each  i in po_rec.PO_Item_Details
											{
												sbfrm = GRN.Item();
												sbfrm.Purchase_Order_Quantity=i.Quantity_Ordered;
												sbfrm.Main_Category=i.Main_Category;
												sbfrm.Category=i.Category;
												sbfrm.Books_Item_ID=i.Books_Item_Id;
												sbfrm.Sub_Category1=i.Sub_Category;
												sbfrm.Item_Name1=i.Item_Name;
												sbfrm.Lot_No=i.Lot_Number;
												sbfrm.Item_Description=i.Product_Description;
												sbfrm.Line_Item_Id=i.PO_line_item_id;
												sbfrm.Make=i.Make;
												sbfrm.Price=i.Rate;
												price_prcnt = sbfrm.Price * 0.18;
												sbfrm.Unit_Price_With_Tax_18=sbfrm.Price + price_prcnt;
												sbfrm.Tax_Percentage=i.Tax_Percentage;
												create_coll.insert(sbfrm);
												total_po_quantity = total_po_quantity + i.Quantity_Ordered;
												total_po_value = total_po_value + i.Rate * i.Quantity_Ordered;
											}
											input.Total_Purchase_Order_Quantity = total_po_quantity;
											input.Total_Purchase_Value = total_po_value;
											input.Item.insert(create_coll);
										}
						)
					}
				}

			}
