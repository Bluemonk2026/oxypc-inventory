	section Presales_QC_New
	{
		displayname= "Presales QC - New"
		form Presales_QC_New
		{
			displayname = "Presales QC - New"
			success message = "Data Added Successfully!"
			field alignment = left
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			Sales_Order_Number
			(
				type = picklist	
				displayname = "Sales Order Number"
				values  = Sales_Orders.ID
    			displayformat = [Sales_Order_Number11]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Customer_Name
			(
				type = picklist	
				displayname = "Customer Name"
				values  = Customer_Database.ID
    			displayformat = [Customer_Name]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Invoice_Created
			(
				type = picklist
				displayname = "Invoice Created"
				maxchar = 100
				values = {"Yes","No"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Tag_Number
			(
    			type = textarea
				displayname = "Tag Number"
				height = 100px
				barcode = true
				camera = primary
	 			row = 1
	 			column = 1   
				width = medium
			)
			SO_Books_ID
			(
    			type = text
				displayname = "SO Books ID"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Sales_Order_Date
			(
    			type = date
				displayname = "Sales Order Date"
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 2   
				width = medium
			)
			Expected_Shipment_Date
			(
    			type = date
				displayname = "Expected Shipment Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Salesperson
			(
				type = picklist
				maxchar = 100
				values = {"Manoj"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			All_Products_Ready
			(
				type = radiobuttons
				displayname = "All Products Ready"
				maxchar = 100
				values = {"Yes","No"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Section3
			(
				type = section
				displayname = "Section"
	 			row = 2
	 			column = 0   
				width = medium
			)
			Payment_Mode1
			(
				type = checkboxes	
				displayname = "Payment Mode"
				values = {"Cash","Cheque","UPI","Card Swipe","Bank Transfer"}
	 			row = 2
	 			column = 1   
				width = medium
			)
			CaAmount
			(
				displayname = "Cash Amount"
				type = INR
				format = commadotindian
	 			row = 2
	 			column = 2   
				width = medium
			)
			Cheque_Amount
			(
				displayname = "Cheque Amount"
				type = INR
				format = commadotindian
	 			row = 2
	 			column = 2   
				width = medium
			)
			UPI_Amount
			(
				displayname = "UPI Amount"
				type = INR
				format = commadotindian
	 			row = 2
	 			column = 2   
				width = medium
			)
			Card_Swipe_Amount
			(
				displayname = "Card Swipe Amount"
				type = INR
				format = commadotindian
	 			row = 2
	 			column = 2   
				width = medium
			)
			Bank_Transfer_Amount
			(
				displayname = "Bank Transfer Amount"
				type = INR
				format = commadotindian
	 			row = 2
	 			column = 2   
				width = medium
			)
			Section2
			(
				type = section
				displayname = "Section"
	 			row = 3
	 			column = 0   
				width = medium
			)
			Item_Table
			(
				type = grid
				displayname = "Item Table"
				values  = Sales_Order_Items.ID
				auto width = false
	 			row = 4
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		default list Presales_QC_New_Report
		{
			displayName = "Presales QC - New Report"
			show all rows from Presales_QC_New    
			(
				Customer_Name as "Customer Name"
				Sales_Order_Date as "Sales Order Date"
				Expected_Shipment_Date as "Expected Shipment Date"
				Salesperson
				Sales_Order_Number as "Sales Order Number"
				Sales_Order_Number.Total_Amount as "Total Amount"
				Sales_Order_Number.Total_Quantity as "Total Quantity"
				Sales_Order_Number.Grand_Total as "Grand Total"
				Item_Table as "Item Table"
				(
					view = Sales_Order_Items_Report
					field = Item_Table.Product_Name1 + " " + Item_Table.Quantity + " " + Item_Table.Rate + " " + Item_Table.Amount
				)
			)
			quickview
			(
				layout
				(
		 			type = -1
					datablock1
					(
						layout type = -1
						fields
						(
							Sales_Order_Number as "Sales Order Number"
							Sales_Order_Date as "Sales Order Date"
							Expected_Shipment_Date as "Expected Shipment Date"
							Customer_Name as "Customer Name"
							Salesperson
							Sales_Order_Number.Total_Quantity as "Total Quantity"
							Item_Table.Product_Name1 as "Item Table"
						)
					)
				)
				menu
    			(
    	 			header
    	 			(
    		 			Edit 
    		 			Duplicate 
    		 			Delete 
    		 			Add 
    		 			Print 
    		 			Import 
    		 			Export 
    	 			)
					record
					(
						Edit   	   
						Duplicate   	   
						Print   	   
						Delete   	   
    				)
    			)
    			action
    			(
					on click
					(
						View Record   	   
    				)
					on right click
					(
						Edit   	   
						Delete   	   
						Duplicate   	   
						Print   	   
						View Record   	   
    				)
     			)
			)
			detailview
			(
				layout
				(
		 			type = 2
					datablock1
					(
						layout type = -2
		     			title = "Overview"
						fields
						(
							Sales_Order_Number as "Sales Order Number"
							Sales_Order_Date as "Sales Order Date"
							Customer_Name as "Customer Name"
							Expected_Shipment_Date as "Expected Shipment Date"
							Salesperson
							Sales_Order_Number.Total_Quantity as "Total Quantity"
							Sales_Order_Number.Total_Amount as "Total Amount"
							Sales_Order_Number.Grand_Total as "Grand Total"
						)
					)
					datablock4
					(
						layout type = -1
		     			title = "Item Table"
		     			related field = Item_Table
						fields
						(
							Category
							Product_Name1 as "Product Name"
							Quantity
							Rate
							Amount
							HDD_Modification_Required as "HDD Modification Required"
							RAM_Modification_Required as "RAM Modification Required"
						)
					)
				)
				menu
    			(
    	 			header
    	 			(
    		 			Edit 
    		 			Duplicate 
    		 			Print 
    		 			Delete 
    	 			)
    			)
			)
		}
	}
