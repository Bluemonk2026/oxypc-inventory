			Total_Quantity as "Total Quantity"
			{
				type =  form
				form = GRN
				record event = on add or edit

				on user input of Item.Quantity
				{
					actions 
					{
						custom deluge script
						(
											total_quan = 0;
										invoice_total = 0;
										for each  i in input.Item
										{
											if(i.Quantity == null)
											{
												i.Quantity=0;
											}
											if(i.Quantity_in_Invoice == null)
											{
												i.Quantity_in_Invoice=0;
											}
											total_quan = total_quan.toLong() + i.Quantity.toLong();
											invoice_total = invoice_total.toLong() + i.Quantity_in_Invoice.toLong();
										}
										input.Total_Quantity = total_quan;
										input.Variance = invoice_total - total_quan;
						)
					}
				}

			}
			Total_Quantity1 as "Total Quantity"
			{
				type =  form
				form = Spare_Part_GRN
				record event = on add or edit

				on user input of Items.Physical_Quantity
				{
					actions 
					{
						custom deluge script
						(
											total_quan = 0;
										inv_total = 0;
										// total_quan = total_quan + row.Physical_Quantity;
										for each  i in input.Items
										{
											if(i.Physical_Quantity != null)
											{
												total_quan = total_quan + i.Physical_Quantity;
											}
											if(i.Quantity_in_Invoice != null)
											{
												inv_total = inv_total.toLong() + i.Quantity_in_Invoice.toLong();
											}
										}
										input.Total_Quantity = total_quan;
										input.Variance = inv_total - total_quan;
						)
					}
				}

			}
			Check_for_proper_Format as "Check for proper Format"
			{
				type =  form
				form = IQC_Format_for_Desktop
				record event = on add or edit
					status = inactive

				on user input of Tag_No
				{
					actions 
					{
						custom deluge script
						(
											if(input.Tag_No != null || input.Tag_No != "")
										{
											if(input.Tag_No.contains("O") || input.Tag_No.contains("o") || input.Tag_No.contains(" "))
											{
												alert "Tag Number should not contain alphabetic letter 'O'";
												input.Tag_No = "";
											}
											if(input.Tag_No.length() < 10 && input.Tag_No != "")
											{
												alert "Please Enter 10 digit Tag Number";
												input.Tag_No = "";
											}
											if(input.Tag_No.startswith("SN") is false && input.Tag_No != "")
											{
												alert "Tag Number should start with 'SN'";
												input.Tag_No = "";
											}
										}
						)
					}
				}

			}
			Check_for_proper_Format1 as "Check for proper Format"
			{
				type =  form
				form = IQC_Format_for_TFT
				record event = on add or edit
					status = inactive

				on user input of TAG
				{
					actions 
					{
						custom deluge script
						(
											if(input.TAG != null || input.TAG != "")
										{
											if(input.TAG.contains("O") || input.TAG.contains("o") || input.TAG.contains(" "))
											{
												alert "Please Correct the Tag No.!!";
												input.TAG = "";
											}
											if(input.TAG.length() < 10 && input.TAG != "")
											{
												alert "Please Enter 10 digit Tag Number";
												input.TAG = "";
											}
											if(input.TAG.startswith("SN") is false && input.TAG != "")
											{
												alert "Tag Number should start with 'SN'";
												input.TAG = "";
											}
										}
						)
					}
				}

			}
			Sending_to_Books_Inventor as "Sending to Books Inventory"
			{
				type =  form
				form = Final_QC1
				record event = on add or edit

				on success
				{
					actions  (Final_Status == "Pass")
					{
						custom deluge script
						(
											if(zoho.loginuser == zoho.adminuser)
										{
											sendmail
											[
												from :zoho.loginuserid
												to :"shubham.namdev@crm-masters.com"
												subject :"Entered Books code after final qc"
												message :"Entered successfully"
											]
											if(Updated_Make != null)
											{
												Make1 = input.Updated_Make.Make;
											}
											else
											{
												Make1 = input.Make;
											}
											if(Updated_Model != null)
											{
												Model1 = input.Updated_Model.Model;
											}
											else
											{
												Model1 = input.Model;
											}
											if(Update_CPU1 != null)
											{
												CPU1 = input.Update_CPU1;
											}
											else
											{
												CPU1 = input.CPU;
											}
											if(Updated_Generation != null)
											{
												Generation1 = input.Updated_Generation;
											}
											else
											{
												Generation1 = input.Generation;
											}
											if(Updated_RAM != null)
											{
												RAM1 = input.Updated_RAM;
											}
											else
											{
												RAM1 = input.RAM;
											}
											if(Updated_HDD != null)
