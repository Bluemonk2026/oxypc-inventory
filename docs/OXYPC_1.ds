			Update_Stage_in_inventory1 as "Update Stage in inventory"
			{
				type =  form
				form = Product_Master_Inventory1
				record event = on edit

				on update of Update1
				{
					actions 
					{
						custom deluge script
						(
											// inv_rec = Product_Master_Inventory1[ID != 0 && Used_or_not == "In-Zoho"];
										// for each  i in inv_rec
										// {
										// 	product_cat = input.Product_Category2;
										// 	if(product_cat != "" && product_cat == "Laptop")
										// 	{
										final_qc_rec = Final_QC1[Tag_Number.equalsIgnoreCase(input.Tag_No2)];
										painting_rec = Painting[Tag_No.equalsIgnoreCase(input.Tag_No2)];
										cleaning_rec = Cleaning[Tag_No.equalsIgnoreCase(input.Tag_No2)];
										qc_rec = Final_QC_for_Engineer[Tag_No.equalsIgnoreCase(input.Tag_No2)];
										l3_l4_rec = L3_L4_Engineer_Screen[Barcode.equalsIgnoreCase(input.Tag_No2)];
										l1_l2_rec = L1_L2_Engineer_Screen[Barcode.equalsIgnoreCase(input.Tag_No2)];
										iqc_rec = IQC_Format_for_Laptop[TAG_NO.equalsIgnoreCase(input.Tag_No2)];
										if(final_qc_rec.count() != 0)
										{
											input.Product_Category = "Finished Good";
											input.Product_Stages = "Inventory Finalized";
										}
										else if(painting_rec.count() != 0)
										{
											input.Product_Stages = "Assigned to Final QC";
											input.Product_Category = "Paint";
										}
										else if(cleaning_rec.count() != 0)
										{
											input.Product_Stages = "Assigned for Paint";
											input.Product_Category = "Cleaning";
										}
										else if(qc_rec.count() != 0)
										{
											if(qc_rec.Final_Status == "Pass")
											{
												input.Product_Stages = "Assigned for Cleaning";
												input.Product_Category = "QC Pass";
											}
											else if(qc_rec.Final_Status == "Fail")
											{
												input.Product_Stages = "Assigned to L1/L2 Engineer";
												input.Product_Category = "QC Fail";
											}
										}
										else if(l3_l4_rec != 0)
										{
											if(l3_l4_rec.Final_Status == "Ok")
											{
												input.Product_Stages = "Assigned to L1/L2 Engineer";
												input.Product_Category = "L4 Repair";
											}
											else if(l3_l4_rec.Final_Status == "Scrap")
											{
												input.Product_Stages = "Scrap";
												input.Product_Category = "Scrap";
											}
										}
										else if(l1_l2_rec.count() != 0)
										{
											if(l1_l2_rec.Final_Status == "Completed")
											{
												input.Product_Stages = "Assigned to QC";
												input.Product_Category = "Repair";
											}
											else if(l1_l2_rec.Final_Status == "Escalate to L4")
											{
												input.Product_Stages = "Assigned to L3/L4";
												input.Product_Category = "Repair";
											}
											else if(l1_l2_rec.Final_Status == "PNA")
											{
												input.Product_Stages = "PNA(Part not available)";
												input.Product_Category = "PNA";
											}
											else if(l1_l2_rec.Final_Status == "Scrap")
											{
												input.Product_Stages = "Scrap";
												input.Product_Category = "Scrap";
											}
										}
										else if(iqc_rec.count() != 0)
										{
											if(iqc_rec.Status == "BER")
											{
												input.Product_Stages = "BER";
												input.Product_Category = "BER";
											}
											else if(iqc_rec.Status == "Scrap")
											{
												input.Product_Stages = "Scrap";
												input.Product_Category = "Scrap";
											}
											else
											{
												input.Product_Stages = "Assigned to L1/L2 Engineer";
												input.Product_Category = "IQC Completed";
											}
										}
										// 	}
										// }
						)
					}
				}

			}
