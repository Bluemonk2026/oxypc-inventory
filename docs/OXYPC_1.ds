			Calculate_total_Invoice_Q1 as "Calculate total Invoice Quantity"
			{
				type =  form
				form = GRN
				record event = on add or edit

				on user input of Item.Quantity_in_Invoice
				{
					actions 
					{
						custom deluge script
						(
											total_inv = 0;
										total_price = 0;
										for each  i in input.Item
										{
											total_inv = total_inv + i.Quantity_in_Invoice;
											total_price = total_price + i.Price;
										}
										total_inv_value = total_price * total_inv;
										input.Total_Purchase_Value = total_inv_value;
						)
					}
				}

			}
			Item_Price_base_on_Invoic as "Item Price base on Invoice Quantity and Tax"
			{
				type =  form
				form = Spare_Part_GRN
				record event = on add or edit

				on user input of Items.Quantity_in_Invoice
				{
					actions 
					{
						custom deluge script
						(
											//Calculate Price basedon on Invoice Value item price and tax percentage
										if(row.Tax_Percentage == null && row.Quantity_in_Invoice == null && row.Price == null)
										{
											// 	
										}
										else
										{
											total_item_price = row.Quantity_in_Invoice * row.Price;
											Line_item_tax_percentage = row.Tax_Percentage / 100;
											result = total_item_price * Line_item_tax_percentage;
											row.Total_Item_Price=result + total_item_price;
										}
						)
					}
					actions 
					{
						custom deluge script
						(
											//Taxable Amount Invoice
										sum_rec = 0;
										for each  line_item in input.Items
										{
											result = ifNull(line_item.Price,0) * ifNull(line_item.Quantity_in_Invoice,0);
											sum_rec = sum_rec + result;
										}
										input.Total_Purchase_Value_Without_Tax = sum_rec;
						)
					}
				}

			}
