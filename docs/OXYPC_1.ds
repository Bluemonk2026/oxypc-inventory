			update_final_status_to_PN as "update final status to PNA"
			{
				type =  form
				form = L1_L2_Engineer_Screen
				record event = on add
					status = inactive

				on user input of faults.Status
				{
					actions 
					{
						custom deluge script
						(
											lst = {};
										for each  i in faults
										{
											lst.add(i.Status);
										}
										if(lst.contains("PNA"))
										{
											input.Final_Status = "PNA";
										}
						)
					}
				}

			}
