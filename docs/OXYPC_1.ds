			Create_record_in_IQC_form as "Create record in IQC form"
			{
				type =  form
				form = Copy_of_IQC_Format_for_Laptop
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											data_set = Map();
										// If Make is Dell Inc. then changing make value to DELL
										if(input.Make2.equalsIgnoreCase("Dell Inc."))
										{
											make = "DELL";
										}
										else
										{
											make = input.Make2;
										}
										make_rec = Make[Make.equalsIgnoreCase(make)];
										if(make_rec.count() > 0)
										{
											make_id = make_rec.ID;
										}
										else
										{
											new_make = Map();
											new_make.put("Make",make);
											empty_mapp = Map();
											new_rec = zoho.creator.createRecord("protaiga","oxypc-1","Make",new_make,empty_mapp,"creator");
											make_id = new_rec.get("data").get("ID");
										}
										data_set.put("Make",make_id);
										// // //###################----Syncing Model----##########################///
										if(input.Make2.equalsIgnoreCase("Lenovo"))
										{
											model_rec = Model[Model.equalsIgnoreCase(input.Lenovo_Model)];
											if(model_rec.count() > 0)
											{
												model_id = model_rec.ID;
											}
											else
											{
												new_model = Map();
												new_model.put("Make",make_id);
												new_model.put("Model",input.Model2);
												empty_mapp = Map();
												new_rec1 = zoho.creator.createRecord("protaiga","oxypc-1","Model",new_model,empty_mapp,"creator");
												model_id = new_rec1.get("data").get("ID");
											}
										}
										else
										{
											model_rec = Model[Model.equalsIgnoreCase(input.Model2)];
											if(model_rec.count() > 0)
											{
												model_id = model_rec.ID;
											}
											else
											{
												new_model = Map();
												new_model.put("Make",make_id);
												new_model.put("Model",input.Model2);
												empty_mapp = Map();
												new_rec1 = zoho.creator.createRecord("protaiga","oxypc-1","Model",new_model,empty_mapp,"creator");
												model_id = new_rec1.get("data").get("ID");
											}
										}
										data_set.put("Model1",model_id);
										data_set.put("CPU",input.CPU);
										data_set.put("Generation",input.Generation);
										data_set.put("BIOS_Password",input.BIOS_Password);
										data_set.put("Does",input.Does);
										data_set.put("ALL_OK",input.ALL_OK);
										// ###############----Syncing RAM----################
										data_set.put("Capacity",input.Capacity);
										data_set.put("RAM_Type",input.RAM_Type);
										if(input.Capacity == null || input.Capacity == "")
										{
											ram_val = "No";
										}
										else
										{
											ram_val = "Yes";
										}
										data_set.put("RAM_1",ram_val);
										data_set.put("LOT_Number",input.LOT_Number);
										data_set.put("Front_Panel",input.Front_Panel);
										data_set.put("Panel",input.Panelt);
										data_set.put("Logic_Card",input.Logic_Card);
										data_set.put("Base",input.Base);
										data_set.put("Keyboard",input.Keyboard);
										data_set.put("HDD_Connector",input.HDD_Connector);
										data_set.put("HDD_Cover",input.HDD_Cover);
										data_set.put("HDD_Casing",input.HDD_Casing);
										data_set.put("HDD_1",input.HDD_1);
										data_set.put("Category",input.Category);
										data_set.put("HDD_Capacity1",input.HDD_Capacity2);
										data_set.put("Health",input.Health);
										data_set.put("Boot",input.Boot);
										data_set.put("Screen_Size",input.Screen_Size);
										data_set.put("Touch_Pad",input.Touch_Pad);
										data_set.put("Screen",input.Screen);
										data_set.put("Hinch_Cover",input.Hinch_Cover);
										data_set.put("Microphone",input.Microphone);
										data_set.put("Power_Panel",input.Power_Panel);
										data_set.put("Sound",input.Sound);
										data_set.put("Web_Cam",input.Web_Cam);
										data_set.put("USB",input.USB);
										data_set.put("DVD",input.DVD);
										data_set.put("DVD_Flap",input.DVD_Flap);
										data_set.put("Battery",input.Battery);
										data_set.put("Health1",input.Health1);
										data_set.put("Int_Battery",input.Int_Battery);
										data_set.put("Health2","Good");
										data_set.put("Battery_Cable",input.Battery_Cable);
										data_set.put("Status","Power On");
										data_set.put("Grade",input.Grade);
										data_set.put("Location",input.Location);
										data_set.put("R2V3_Grading_Category",input.R2V3_Grading_Category);
										empty_data = Map();
										create_rec = zoho.creator.createRecord("protaiga","oxypc-1","IQC_Format_for_Laptop",data_set,empty_data,"creator");
										info create_rec;
						)
					}
				}

			}
