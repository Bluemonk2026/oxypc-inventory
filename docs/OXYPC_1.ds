			Change_status_in_Final_QC as "Change status in Final QC Assignment"
			{
				type =  form
				form = Final_QC1
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											recs = Final_QC_Assignment[Tag_No.equalsIgnoreCase(input.Tag_Number)];
										for each  i in recs
										{
											info i;
											i.Status="Final QC Done";
										}
										cleaning_ass = Cleaning_Assignment[Tag_No.equalsIgnoreCase(input.Tag_Number)];
										for each  j in cleaning_ass
										{
											info i;
											j.Status="Final QC Done";
										}
						)
					}
				}

			}
		}

		schedule
		{
			Update_Aging_in_Product_M as "Update Aging in Product Master Inventory"
			{
				type =  schedule
				start = "2023-11-23 00:00:00"
				frequency = daily
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						recs = Product_Master_Inventory1[ID != 0];
										for each  i in recs
										{
											if(i.Aging == null)
											{
												recs.Aging=1.00;
											}
											else
											{
												i.Aging=i.Aging + 1.00;
											}
										}
					)
					}
				}
			}
			Update_Make_and_models_in as "Update Make and models in Stock Audit Report"
			{
				type =  schedule
				form = Stock_audit
				start = after 15 minutes from Added_Time
				end   = Added_Time
				frequency = daily
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						recs = Stock_audit[Make == null];
										for each  i in recs
										{
											// ############### - Laptop - ##########################
											master_rec = Product_Master_Inventory1[Tag_No2 == i.Tag_No];
											final_qc_rec = Final_QC1[Tag_Number == i.Tag_No];
											iqc_rec = IQC_Format_for_Laptop[TAG_NO == i.Tag_No];
											if(master_rec.count() == 0)
											{
												if(final_qc_rec.count() == 0)
												{
													if(iqc_rec.count() > 0)
													{
														i.Make=iqc_rec.Make.Make;
														i.Model=iqc_rec.Model1.Model;
														i.CPU=iqc_rec.CPU;
														i.Generation=iqc_rec.Generation;
														i.RAM=iqc_rec.Capacity;
														if(iqc_rec.HDD_Capacity == "" || iqc_rec.HDD_Capacity1 == null)
														{
															i.HDD=iqc_rec.HDD_Capacity1;
														}
														else
														{
															i.HDD=iqc_rec.HDD_Capacity;
														}
														i.Category="Laptop";
													}
												}
												else
												{
													if(final_qc_rec.Updated_Make == null)
													{
														i.Make=final_qc_rec.Make;
													}
													else
													{
														i.Make=final_qc_rec.Updated_Make;
													}
													if(final_qc_rec.Updated_Model == null)
													{
														i.Model=final_qc_rec.Model;
													}
													else
													{
														i.Model=final_qc_rec.Updated_Model;
													}
													if(final_qc_rec.Update_CPU1 == "" || final_qc_rec.Update_CPU1 == null)
													{
														i.CPU=final_qc_rec.CPU;
													}
													else
													{
														i.CPU=final_qc_rec.Update_CPU1;
													}
													if(final_qc_rec.Updated_Generation == "" || final_qc_rec.Updated_Generation == null)
													{
														i.Generation=final_qc_rec.Generation;
													}
													else
													{
														i.Generation=final_qc_rec.Updated_Generation;
													}
													if(final_qc_rec.Updated_RAM == "" || final_qc_rec.Updated_RAM == null)
													{
														i.RAM=final_qc_rec.RAM;
													}
													else
													{
														i.RAM=final_qc_rec.Updated_RAM;
													}
													if(final_qc_rec.Updated_HDD == "" || final_qc_rec.Updated_HDD == null)
													{
														i.HDD=final_qc_rec.HDD;
													}
													else
													{
														i.HDD=final_qc_rec.Updated_HDD;
													}
												}
												i.Category=final_qc_rec.Category;
											}
											else
											{
												i.Make=master_rec.Make;
												i.Model=master_rec.Model;
												i.CPU=master_rec.CPU;
												i.Generation=master_rec.Generation;
												i.RAM=master_rec.RAM;
												i.HDD=master_rec.HDD;
												i.Category=master_rec.Product_Category2;
											}
											// ############### - Desktop - ##########################
											master_rec = Product_Master_Inventory1[Tag_No2 == i.Tag_No];
											final_qc_rec = Final_QC1[Tag_Number == i.Tag_No];
											iqc_rec_desk = IQC_Format_for_Desktop[Tag_No == i.Tag_No];
											if(master_rec.count() == 0)
											{
												if(final_qc_rec.count() == 0)
												{
													if(iqc_rec_desk.count() > 0)
													{
														i.Make=iqc_rec_desk.Make.Make;
														i.Model=iqc_rec_desk.Model.Model;
														i.CPU=iqc_rec_desk.CPU;
														i.Generation=iqc_rec_desk.Generation;
														i.RAM=iqc_rec_desk.Capacity;
														i.Category="Desktop";
													}
												}
												else
												{
													if(final_qc_rec.Updated_Make == null)
													{
														i.Make=final_qc_rec.Make;
													}
													else
													{
														i.Make=final_qc_rec.Updated_Make;
													}
													if(final_qc_rec.Updated_Model == null)
													{
														i.Model=final_qc_rec.Model;
													}
													else
													{
														i.Model=final_qc_rec.Updated_Model;
													}
													if(final_qc_rec.Update_CPU1 == "" || final_qc_rec.Update_CPU1 == null)
													{
														i.CPU=final_qc_rec.CPU;
													}
													else
													{
														i.CPU=final_qc_rec.Update_CPU1;
													}
													if(final_qc_rec.Updated_Generation == "" || final_qc_rec.Updated_Generation == null)
													{
														i.Generation=final_qc_rec.Generation;
													}
													else
													{
														i.Generation=final_qc_rec.Updated_Generation;
													}
													if(final_qc_rec.Updated_RAM == "" || final_qc_rec.Updated_RAM == null)
													{
														i.RAM=final_qc_rec.RAM;
													}
													else
													{
														i.RAM=final_qc_rec.Updated_RAM;
													}
													if(final_qc_rec.Updated_HDD == "" || final_qc_rec.Updated_HDD == null)
													{
														i.HDD=final_qc_rec.HDD;
													}
													else
													{
														i.HDD=final_qc_rec.Updated_HDD;
													}
												}
												i.Category=final_qc_rec.Category;
											}
											else
											{
												i.Make=master_rec.Make;
												i.Model=master_rec.Model;
												i.CPU=master_rec.CPU;
												i.Generation=master_rec.Generation;
												i.RAM=master_rec.RAM;
												i.HDD=master_rec.HDD;
												i.Category=master_rec.Product_Category2;
											}
											// ############### - TFT - ##########################
											master_rec = Product_Master_Inventory1[Tag_No2 == i.Tag_No];
											final_qc_rec = Final_QC1[Tag_Number == i.Tag_No];
											iqc_rec_tft = IQC_Format_for_TFT[TAG == i.Tag_No];
											if(master_rec.count() == 0)
											{
												if(final_qc_rec.count() == 0)
												{
													if(iqc_rec_tft.count() > 0)
													{
														i.Make=iqc_rec_tft.Make;
														i.Category="TFT";
													}
												}
												else
												{
													if(final_qc_rec.Updated_Make == null)
													{
														i.Make=final_qc_rec.Make;
													}
													else
													{
														i.Make=final_qc_rec.Updated_Make;
													}
													if(final_qc_rec.Updated_Model == null)
													{
														i.Model=final_qc_rec.Model;
													}
													else
													{
														i.Model=final_qc_rec.Updated_Model;
													}
													if(final_qc_rec.Update_CPU1 == "" || final_qc_rec.Update_CPU1 == null)
													{
														i.CPU=final_qc_rec.CPU;
													}
													else
													{
														i.CPU=final_qc_rec.Update_CPU1;
													}
													if(final_qc_rec.Updated_Generation == "" || final_qc_rec.Updated_Generation == null)
													{
														i.Generation=final_qc_rec.Generation;
													}
													else
													{
														i.Generation=final_qc_rec.Updated_Generation;
													}
													if(final_qc_rec.Updated_RAM == "" || final_qc_rec.Updated_RAM == null)
													{
														i.RAM=final_qc_rec.RAM;
													}
													else
													{
														i.RAM=final_qc_rec.Updated_RAM;
													}
													if(final_qc_rec.Updated_HDD == "" || final_qc_rec.Updated_HDD == null)
													{
														i.HDD=final_qc_rec.HDD;
													}
													else
													{
														i.HDD=final_qc_rec.Updated_HDD;
													}
													i.Category="TFT";
												}
											}
											else
											{
												i.Make=master_rec.Make;
												i.Model=master_rec.Model;
												i.CPU=master_rec.CPU;
												i.Generation=master_rec.Generation;
												i.RAM=master_rec.RAM;
												i.HDD=master_rec.HDD;
												i.Category=master_rec.Product_Category2;
											}
										}
					)
					}
				}
			}
			Update_Inventory as "Update Inventory"
			{
				type =  schedule
				form = Stock_audit
				start = after 30 minutes from Added_Time
				end   = Added_Time
				frequency = daily
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						iqc_recs = IQC_Format_for_Laptop[ID != 0 && Inv_Update == null] range from 0 to 1000;
										sendmail
										[
											from :zoho.loginuserid
											to :"shubham.oxypc@gmail.com"
											subject :"Testing schedule for inventory"
											message :"Iqc_recs_count" + iqc_recs.count()
										]
										for each  i in iqc_recs
										{
											master_inv_recs = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(i.TAG_NO)];
											// 	info "master_inv_recs" + master_inv_recs.count();
											sendmail
											[
												from :zoho.loginuserid
												to :"shubham.oxypc@gmail.com"
												subject :"Testing schedule for inventory master recs"
												message :"master_ records" + master_inv_recs.count()
											]
											if(master_inv_recs.count() == 0)
											{
												mapp = Map();
												mapp.put("LOT_No",i.LOT_Number);
												mapp.put("Tag_No2",i.TAG_NO);
												mapp.put("Make",i.Make.Make);
												mapp.put("Model",i.Model1.Model);
												mapp.put("RAM",i.Capacity);
												mapp.put("Used_or_not","In-Zoho");
												mapp.put("Product_Category2","Laptop");
												mapp.put("Product_Sub_Category","Laptop");
												if(i.Location == "Manesar")
												{
													mapp.put("Warehouse","Manesar");
												}
												else
												{
													mapp.put("Warehouse","TRC 2ND Floor");
												}
												mapp.put("Quantity",1);
												if(i.HDD_Capacity1 != null)
												{
													mapp.put("HDD",i.HDD_Capacity1);
												}
												else if(i.HDD_Capacity != null)
												{
													mapp.put("HDD",i.HDD_Capacity);
												}
												// 	mapp.put("Model",i.Model1.Model);
												mapp.put("Grade",i.Grade);
												mapp.put("Serial_No",i.Serial_No);
												mapp.put("CPU",i.CPU);
												mapp.put("Generation",i.Generation);
												mapp.put("Product_Type","Laptop");
												mapp.put("Product_Stages","Assigned to L1/L2 Engineer");
												mapp.put("RAM_Cover",i.RAM_Cover);
												mapp.put("HDD_Cover",i.HDD_Cover);
												mapp.put("HDD_1",i.HDD_1);
												// 	mapp.put("Touch_Pad",i.Touch_Pad.toString());
												mapp.put("DVD",i.DVD);
												// 	mapp.put("Panel",i.Panel.toString());
												mapp.put("Base",i.Base);
												mapp.put("Keyboard",i.Keyboard);
												mapp.put("Health",i.Health);
												mapp.put("Health2",i.Health2);
												mapp.put("USB",i.USB);
												mapp.put("Hinch_Cover",i.Hinch_Cover);
												mapp.put("Hinch",i.Hinch);
												mapp.put("Logic_Card",i.Logic_Card);
												mapp.put("Battery_Cable",i.Battery_Cable);
												mapp.put("Battery",i.Battery);
												mapp.put("All_OK",i.ALL_OK);
												mapp.put("Battery_Health",i.Health1);
												mapp.put("DVD_Flap",i.DVD_Flap);
												mapp.put("RAM_Cover",i.RAM_Cover);
												mapp.put("Status",i.Status);
												mapp.put("BIOS_Password",i.BIOS_Password);
												mapp.put("Sound",i.Sound);
												mapp.put("HDDCategory",i.Category);
												mapp.put("HDD_Capacity",i.HDD_Capacity);
												mapp.put("HDD_Capacity1",i.HDD_Capacity1);
												mapp.put("Defected_Side",i.Defected_Side);
												mapp.put("Health",i.Health);
												mapp.put("HDD_Casing",i.HDD_Casing);
												mapp.put("WIFI",i.WIFI);
												mapp.put("HDD_Connector",i.HDD_Connector);
												mapp.put("Microphone",i.Microphone);
												mapp.put("Power_Panel",i.Power_Panel);
												mapp.put("Web_Cam",i.Web_Cam);
												// 	mapp.put("Front_Panel_Bazel",i.Front_Panel.toString());
												mapp.put("Product_Category","Repair");
												mapp.put("Screen_Size",i.Screen_Size);
												// 	mapp.put("IQC_Faults_Subform",i.Faulty_Spare_Parts);
												empty_mapp = Map();
												sendmail
												[
													from :zoho.loginuserid
													to :"shubham.oxypc@gmail.com"
													subject :"Mapp for inv"
													message :"mapp for inv -- " + mapp
												]
												create_rec_inv = zoho.creator.createRecord("protaiga","oxypc-1","Product_Master_Inventory1",mapp,empty_mapp,"creator");
												info create_rec_inv;
												sendmail
												[
													from :zoho.loginuserid
													to :"shubham.oxypc@gmail.com"
													subject :"scheduler ran"
													message :"create_rec_inv" + create_rec_inv
												]
											}
											i.Inv_Update="Update";
										}
					)
					}
				}
			}
