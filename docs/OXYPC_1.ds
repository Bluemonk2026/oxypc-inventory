				 void QCAssignment()
                 {
                 	qc_ass = QC_Assignment[ID > 0];
                 	qc_rec = Final_QC_for_Engineer[ID > 0];
                 	for each  i in qc_ass
                 	{
                 		qc_rec = Final_QC_for_Engineer[Tag_No.equalsIgnoreCase(i.Tag_No)];
                 		for each  j in qc_rec
                 		{
                 			if(j.Final_Status == "Pass")
                 			{
                 				i.Status="QC Done";
                 			}
                 		}
                 	}
                 }
				 void SetCorrectStageInMasterInventory()
                 {
                 	inv_rec = Product_Master_Inventory1[ID != 0];
                 	for each  i in inv_rec
                 	{
                 		product_cat = i.Product_Category2;
                 		if(product_cat != "" && product_cat == "Laptop")
                 		{
                 			final_qc_rec = Final_QC1[Tag_Number == i.Tag_No2];
                 			painting_rec = Painting[Tag_No == i.Tag_No2];
                 			cleaning_rec = Cleaning[Tag_No == i.Tag_No2];
                 			qc_rec = Final_QC_for_Engineer[Tag_No == i.Tag_No2];
                 			l3_l4_rec = L3_L4_Engineer_Screen[Barcode == i.Tag_No2];
                 			l1_l2_rec = L1_L2_Engineer_Screen[Barcode == i.Tag_No2];
                 			iqc_rec = IQC_Format_for_Laptop[TAG_NO == i.Tag_No2];
                 			if(final_qc_rec.count() != 0)
                 			{
                 				i.Product_Category="Finished Good";
                 				i.Product_Stages="Inventory Finalized";
                 			}
                 			else if(painting_rec.count() != 0)
                 			{
                 				i.Product_Stages="Assigned to Final QC";
                 				i.Product_Category="Paint";
                 			}
                 			else if(cleaning_rec.count() != 0)
                 			{
                 				i.Product_Stages="Assigned for Paint";
                 				i.Product_Category="Cleaning";
                 			}
                 			else if(qc_rec.count() != 0)
                 			{
                 				if(qc_rec.Final_Status == "Pass")
                 				{
                 					i.Product_Stages="Assigned for Cleaning";
                 					i.Product_Category="QC Pass";
                 				}
                 				else if(qc_rec.Final_Status == "Fail")
                 				{
                 					i.Product_Stages="Assigned to L1/L2 Engineer";
                 					i.Product_Category="QC Fail";
                 				}
                 			}
                 			else if(l3_l4_rec != 0)
                 			{
                 				if(l3_l4_rec.Final_Status == "Ok")
                 				{
                 					i.Product_Stages="Assigned to L1/L2 Engineer";
                 					i.Product_Category="L4 Repair";
                 				}
                 				else if(l3_l4_rec.Final_Status == "Scrap")
                 				{
                 					i.Product_Stages="Scrap";
                 					i.Product_Category="Scrap";
                 				}
                 			}
                 			else if(l1_l2_rec.count() != 0)
                 			{
                 				if(l1_l2_rec.Final_Status == "Completed")
                 				{
                 					i.Product_Stages="Assigned to QC";
                 					i.Product_Category="Repair";
                 				}
                 				else if(l1_l2_rec.Final_Status == "Escalate to L4")
                 				{
                 					i.Product_Stages="Assigned to L3/L4";
                 					i.Product_Category="Repair";
                 				}
                 				else if(l1_l2_rec.Final_Status == "PNA")
                 				{
                 					i.Product_Stages="PNA(Part not available)";
                 					i.Product_Category="Repair";
                 				}
                 				else if(l1_l2_rec.Final_Status == "Scrap")
                 				{
                 					i.Product_Stages="Scrap";
                 					i.Product_Category="Scrap";
                 				}
                 			}
                 			else if(iqc_rec.count() != 0)
                 			{
                 				if(iqc_rec.Status == "BER")
                 				{
                 					i.Product_Stages="BER";
                 					i.Product_Category="BER";
                 				}
                 				else if(iqc_rec.Status == "Scrap")
                 				{
                 					i.Product_Stages="Scrap";
                 					i.Product_Category="Scrap";
                 				}
                 				else
                 				{
                 					i.Product_Stages="Assigned to L1/L2 Engineer";
                 					i.Product_Category="IQC Completed";
                 				}
                 			}
                 		}
                 	}
                 }
