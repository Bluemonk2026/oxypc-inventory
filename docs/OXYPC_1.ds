			Assigning_Status_change_i as "Assigning Status change in IQC"
			{
				type =  form
				form = L4_Support_Pending_Bucket
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											ids = input.IQC_Ids1;
										for each  i in ids.toList()
										{
											mapp = Map();
											mapp.put("Tag_No",i);
											mapp.put("Engineer_Name",input.Engineer_Name);
											mapp1 = Map();
											zoho.creator.createRecord("protaiga","oxypc-1","L4_Support_Pending_Bucket",mapp,mapp1,"creator");
											// 	if(input.Final_Status == "Completed")
											// 	{
											// 		rec = Product_Master_Inventory1[Tag_No2 == input.Tag_No1];
											// 		mapp = Map();
											// 		mapp.put("Product_Stages","Assigned to L1/L2 Engineer");
											// 		mapp1 = Map();
											// 		zoho.creator.updateRecord("protaiga","oxypc-1","All_Product_Master_Inventories1",rec.ID,mapp,mapp1,"creator");
											// 	}
											iqc_rec = IQC_Format_for_Laptop[TAG_NO == i];
											iqc_rec.Assign_Status="Assigned";
										}
										if(input.Make != null || input.Make != "")
										{
											delete from L4_Support_Pending_Bucket[Make != ""];
										}
						)
					}
				}

			}
