			Update_Stage_in_product_m as "Update Stage in product master Inventory"
			{
				type =  form
				form = Cleaning
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											mapp = Map();
										mapp.put("Tag_Number",input.Tag_No);
										mapp1 = Map();
										zoho.creator.createRecord("protaiga","oxypc-1","Painting_Pending_Bucket",mapp,mapp1,"creator");
										rec = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(input.Tag_No)];
										rec.Product_Stages="Assigned for Dry Sanding";
										rec.Product_Category="Dry Sanding";
										rec.Warehouse="TRC 2ND Floor";
										rec.Cleaning_Submission="Submitted";
						)
					}
					actions 
					{
						custom deluge script
						(
											//-----Amazon Inventory---//
										//Search record in Amazon inventory 
										Tag_number_result = invokeurl
										[
											url :"https://creator.zoho.in/api/v2.1/protaiga/amazon-inventory/report/All_Amazon_Assets?Tag_Number=" + input.Tag_No
											type :GET
											connection:"creator"
										];
										info "Amazon Inventory Record" + Tag_number_result;
										//Data mapping 
										Data_map = Map();
										optional_map = Map();
										Data_map.put("Status","Dry Sanding");
										Data_map.put("Stage","Assigned for Dry Sanding");
										// update Record if already present in Amazon inventory
										Tag_code = Tag_number_result.getJSON("code");
										Tag_msg = Tag_number_result.getJSON("message");
										if(Tag_code == 3000)
										{
											// info "update Record";
											Tag_data = Tag_number_result.getJSON("data");
											record_ID = Tag_data.getJSON("ID");
											update_rec = zoho.creator.updateRecord("protaiga","amazon-inventory","All_Amazon_Assets",record_ID,Data_map,optional_map,"creator");
											info update_rec;
										}
										else
										{
											info "record not present";
										}
						)
					}
				}

			}
