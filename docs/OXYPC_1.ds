		 functions
		 {
			 Deluge
			 {
				 void AssigningEngineerforFinalQC(Final_QC final_qc)
                 {
                 }
				 void AssigningL3Engineer(IQC_Format_for_Laptop iqc_laptop)
                 {
                 	lst = list();
                 	for each  i in iqc_laptop
                 	{
                 		lst.add(i.ID);
                 	}
                 	make = Make[ID == iqc_laptop.Make];
                 	laptop_make = make.Make;
                 	model = Model[ID == iqc_laptop.Model1];
                 	laptop_model = model.Model;
                 	CPU = CPU_Master[ID == iqc_laptop.CPU1];
                 	laptop_cpu = CPU.CPU;
                 	generation = Classifications_of_Make_and_Model[ID == iqc_laptop.Generation1];
                 	laptop_gen = generation.Generation;
                 	model_description = iqc_laptop.Model_Description;
                 	tag_no = iqc_laptop.ID;
                 	// 	lot_no = GRN[ID == iqc_laptop.Lot_No];
                 	laptop_lot_no = iqc_laptop.LOT_Number;
                 	serial_no = iqc_laptop.Serial_No;
                 	required_replacements = iqc_laptop.Required_Replacements;
                 	// 	openUrl("#Form:Repair_Completed_L3_L4?Make=" + laptop_make + "&Model=" + laptop_model + "&CPU=" + laptop_cpu + "&Generation=" + laptop_gen + "&Product_Description=" + model_description + "&Tag_No=" + tag_no + "&LOT_No=" + laptop_lot_no + "&laptop_Serial_Number=" + serial_no + "&Consumed_Part=" + required_replacements + "&IQCs=" + lst,"Popup window","height=200,width=500");
                 	openUrl("#Form:Repair_Completed_L3_L4?Make=" + laptop_make + "&Model=" + laptop_model + "&CPU=" + laptop_cpu + "&Generation=" + laptop_gen + "&Product_Description=" + model_description + "&Tag_No=" + tag_no + "&LOT_No=" + laptop_lot_no + "&IQCs=" + lst,"Popup window","height=200,width=500");
                 }
				 void Assigning_Engineer(IQC_Format_for_Laptop iqc_laptop)
                 {
                 	lst = list();
                 	for each  i in iqc_laptop
                 	{
                 		if(i.Assign_Status == "Not Assigned" || i.Assign_Status == "" || i.Assign_Status == null)
                 		{
                 			lst.add(i.TAG_NO);
                 		}
                 		else if(i.Assign_Status == "Assigned")
                 		{
                 			info "Laptop Already Assigned";
                 		}
                 	}
                 	// 	make = Make[ID == iqc_laptop.Make];
                 	// 	laptop_make = make.Make;
                 	// 	model = Model[ID == iqc_laptop.Model1];
                 	// 	laptop_model = model.Model;
                 	// 	CPU = CPU_Master[ID == iqc_laptop.CPU1];
                 	// 	laptop_cpu = CPU.CPU;
                 	// 	generation = Classifications_of_Make_and_Model[ID == iqc_laptop.Generation1];
                 	// 	laptop_gen = generation.Generation;
                 	// 	model_description = iqc_laptop.Model_Description;
                 	// 	tag_no = iqc_laptop.ID;
                 	// 	lot_no = LOT_No_s_GRN[ID == iqc_laptop.LOT_No2];
                 	// 	if(isNull(iqc_laptop.HDD_Capacity1))
                 	// 	{
                 	// 		hdd = iqc_laptop.Category + " " + iqc_laptop.HDD_Capacity1;
                 	// 	}
