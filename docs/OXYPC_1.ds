			Update_Warehouse_in_Zoho_ as "Update Warehouse in Zoho Books Inventory"
			{
				type =  form
				form = Stock_tranfer_TRC_to_Showroom
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											mapp = Map();
										mapp.put("date",zoho.currentdate.toString("yyyy-MM-dd"));
										mapp.put("from_warehouse_id",1243157000002593007);
										mapp.put("to_warehouse_id",1243157000000163010);
										line_items = List();
										line_item = Map();
										line_item.put("item_id",input.Zoho_Books_Item_ID);
										line_item.put("name",input.Zoho_Books_Item_Name);
										// line_item.put("description","Laptop - Testing Serial Number");
										line_item.put("quantity_transfer",1);
										line_item.put("serial_numbers",{input.Tag_Number});
										line_item.put("unit","qty");
										line_items.add(line_item);
										mapp.put("line_items",line_items);
										transfer_order = invokeurl
										[
											url :"https://www.zohoapis.in/inventory/v1/transferorders?organization_id=60020430422"
											type :POST
											parameters:mapp.toString()
											connection:"zoho_books"
										];
										info transfer_order;
						)
					}
				}

			}
			Production_Tracker_Update2 as "Production Tracker Update"
			{
				type =  form
				form = IQC_Format_for_Desktop
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											fgh = IQC_Format_for_Desktop[ID == input.ID];
										User = fgh.Added_User;
										info User;
										Today_Production_Tracker = Production_Tracker[Engineer_Name == User.toString() && Date_field == zoho.currentdate];
										Tracker_Size = Today_Production_Tracker.count();
										info Tracker_Size;
										if(Tracker_Size == 0)
										{
											Create_map = Map();
											Create_map.put("IQC_Completed",1);
											Create_map.put("Date_field",zoho.currentdate.toString("dd-MMM-yyyy"));
											Create_map.put("L1_L2",0);
											Create_map.put("L3_L4",0);
											Create_map.put("L4_Support",0);
											Create_map.put("Final_QC",0);
											Create_map.put("Cleaning",0);
											Create_map.put("Painting",0);
											Create_map.put("Engineer_Name",User);
											Create_map.put("Assigned_to_L1_L2",0);
											Create_map.put("Assigned_to_L4_Support",0);
											empty_map = Map();
											Create_record = zoho.creator.createRecord("protaiga","oxypc-1","Production_Tracker",Create_map,empty_map,"creator");
											info Create_record;
										}
										else
										{
											Today_Production_Tracker = zoho.creator.getRecords("protaiga","oxypc-1","All_Production_Trackers","Date_field == \"" + zoho.currentdate + "\" && Engineer_Name== \"" + User + "\"",1,200,"creator");
											info Today_Production_Tracker;
											IQC_Completed_Count = Today_Production_Tracker.get("data").get("0").get("IQC_Completed");
											update_map = Map();
											update_map.put("IQC_Completed",IQC_Completed_Count.toNumber() + 1);
											emptymap = Map();
											update_map1 = zoho.creator.updateRecord("protaiga","oxypc-1","All_Production_Trackers",Today_Production_Tracker.get("data").get("0").get("ID").toLong(),update_map,emptymap,"creator");
										}
						)
					}
				}

			}
