			Create_and_Update_Record_ as "Create and Update Record in Amazon Inventory"
			{
				type =  form
				form = Final_QC1
				record event = on add or edit
					status = inactive

				on success
				{
					actions  (Warehouse == "Amazon")
					{
						custom deluge script
						(
											if(Warehouse == "Amazon")
										{
											//Search record in Amazon inventory 
											Tag_number_result = invokeurl
											[
												url :"https://creator.zoho.in/api/v2.1/protaiga/amazon-inventory/report/All_Amazon_Assets?Tag_Number=" + input.Tag_Number
												type :GET
												connection:"creator"
											];
											info "Amazon Inventory Record" + Tag_number_result;
											//Data mapping 
											Data_map = Map();
											optional_map = Map();
											Data_map.put("Make",input.Make);
											Data_map.put("Model",input.Model);
											Data_map.put("CPU",input.CPU);
											Data_map.put("Genration",input.Generation);
											Data_map.put("RAM",input.RAM);
											Data_map.put("HDD",input.HDD);
											Data_map.put("Warehouse",input.Warehouse);
											Data_map.put("LOT_Number",input.LOT_Number);
											Data_map.put("Serial_Number",input.Serial_Number);
											Data_map.put("Tag_Number",input.Tag_Number);
											Data_map.put("Category",input.Category);
											// update Record if already present in Amazon inventory
											Tag_code = Tag_number_result.getJSON("code");
											Tag_msg = Tag_number_result.getJSON("message");
											// 	info Tag_msg;
											// 	info Tag_code;
											if(Tag_code == "9220" && Tag_msg == "No records exist in this report.")
											{
												// 		info "create record";
												create_rec = zoho.creator.createRecord("protaiga","amazon-inventory","Amazon_Asset",Data_map,optional_map,"creator");
												info create_rec;
											}
											else if(Tag_code == 3000)
											{
												// 		info "update Record";
												Tag_data = Tag_number_result.getJSON("data");
												record_ID = Tag_data.getJSON("ID");
												update_rec = zoho.creator.updateRecord("protaiga","amazon-inventory","All_Amazon_Assets",record_ID,Data_map,optional_map,"creator");
												info update_rec;
											}
										}
						)
					}
				}

			}
			Create_and_Update_Record_1 as "Create and Update Record in Amazon Inventory"
			{
				type =  form
				form = Amazon_Assignment_Screen
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											//Search record in Amazon inventory 
										Tag_number_result = invokeurl
										[
											url :"https://creator.zoho.in/api/v2.1/protaiga/amazon-inventory/report/All_Amazon_Assets?Tag_Number=" + input.Tag_No
											type :GET
											connection:"creator"
										];
										info "Amazon Inventory Record" + Tag_number_result;
										//Data mapping 
										Data_map = Map();
										optional_map = Map();
										Data_map.put("Make",input.Make);
										Data_map.put("Model",input.Model);
										Data_map.put("CPU",input.CPU);
										Data_map.put("Genration",input.Generation);
										Data_map.put("RAM",input.RAM);
										Data_map.put("HDD",input.HDD);
										//Data_map.put("Warehouse",input.Warehouse);
										Data_map.put("LOT_Number",input.LOT_Number);
										Data_map.put("Serial_Number",input.Serial_Number);
										Data_map.put("Tag_Number",input.Tag_No);
										Data_map.put("Category",input.Category);
										Data_map.put("Status","IQC Completed");
										Data_map.put("Stage","Ready for Engineer Assignment");
										// update Record if already present in Amazon inventory
										Tag_code = Tag_number_result.getJSON("code");
										Tag_msg = Tag_number_result.getJSON("message");
										// 	info Tag_msg;
										// 	info Tag_code;
										if(Tag_code == "9220" && Tag_msg == "No records exist in this report.")
										{
											// 		info "create record";
											create_rec = zoho.creator.createRecord("protaiga","amazon-inventory","Amazon_Asset",Data_map,optional_map,"creator");
											info create_rec;
										}
										else if(Tag_code == 3000)
										{
											// 		info "update Record";
											Tag_data = Tag_number_result.getJSON("data");
											record_ID = Tag_data.getJSON("ID");
											update_rec = zoho.creator.updateRecord("protaiga","amazon-inventory","All_Amazon_Assets",record_ID,Data_map,optional_map,"creator");
											info update_rec;
										}
						)
					}
				}

			}
			Show_Fields_at_IN as "Show Fields at IN"
			{
				type =  form
				form = Spare_Part_In_Out1
				record event = on add or edit

				field rules
				{
					actions  (Spare_Part_In_Out == "IN")
					{
						show IN_field;
					}
					actions  (Spare_Part_In_Out == "OUT")
					{
						show OUT;
					}
					actions  (Spare_Part_In_Out == "Transfer")
					{
						show Transfer_Details;
					}
					actions  (Part_Type is not null)
					{
						show Quantity;
					}
				}

			}
			Update_Inventory_when_OUT as "Update Inventory when OUT"
			{
				type =  form
				form = Spare_Part_In_Out1
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Spare_Part_In_Out == "OUT")
										{
											if(input.Part_Number_Available == "Yes")
											{
												inv_rec = Spare_Parts[Part_Number.equalsIgnoreCase(input.Part_Number)];
												if(inv_rec.count() > 0)
												{
													inv_rec.Availability="Not Available";
												}
											}
											else
											{
												inv_rec = Spare_Parts[Make == input.Make_Spare_Part && Model == input.Model_Spare_Part && Spare_Part_Name1 == input.Spare_Parts_Name];
												if(inv_rec.count() > 0)
												{
													if(input.Part_Type == "New")
													{
														inv_rec.Available_SOH=inv_rec.Available_SOH - input.Quantity;
													}
													else if(input.Part_Type == "Harvested")
													{
														inv_rec.Cannablized=inv_rec.Cannablized - input.Quantity;
													}
												}
											}
										}
						)
					}
				}

			}
