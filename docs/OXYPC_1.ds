				 void Update_time_difference()
                 {
                 	recs = IQC_Format_for_Laptop[TAG_NO == "SN00124018"];
                 	start_time = recs.Time;
                 	end_time = recs.Added_Time.getTime(24,true);
                 	// 	differecne = timeBetween(start_time,end_time);
