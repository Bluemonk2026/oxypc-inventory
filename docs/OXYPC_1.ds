	section RMA_IQC_Format_for_Laptop
	{
		displayname= "RMA - IQC Format for Laptop"
		form RMA_IQC_Format_for_Laptop
		{
			displayname = "RMA - IQC Format for Laptop"
			store data in zc = false
			field alignment = left
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Sub_Category
			(
				type = picklist	
				displayname = "Sub-Category"
				values  = Sub_Category_database_for_GRN[Product_Master.Item_Name23 == "Laptop"].ID
    			displayformat = [Sub_Category]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have unique TAG_NO
			(
    			type = text
				displayname = "Tag No"
				maxchar = 15
				qrcode = true
				barcode = true
				camera = primary
				show gallery = true
				switch camera = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			Date_field
			(
    			type = date
				displayname = "Date"
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
				private = true
	 			row = 1
	 			column = 1   
				width = small
			)
			LOT_Number
			(
    			type = text
				displayname = "LOT Number"
	 			row = 1
	 			column = 1   
				width = small
			)
			must have Model1
			(
				type = picklist	
				displayname = "Model"
				values  = Model[Make.ID == input.Make].ID
    			displayformat = [Model]
	 			row = 1
	 			column = 1   
				width = small
			)
			must have CPU
			(
				type = picklist
				maxchar = 100
				values = {"I3","I4","I5","I7","I9","M1","M2","M5","M7","celeron","C2D","AMD","AMD PRO","PENTIUM R","XEON","Centrino","Other"}
	 			row = 1
	 			column = 1   
				width = small
			)
			must have Generation
			(
				type = picklist
				maxchar = 100
				values = {"1ST","2ND","3RD","4TH","5TH","6TH","7TH","8TH","9TH","10TH","11TH","12TH","A10","C2D","Other"}
	 			row = 1
	 			column = 1   
				width = small
			)
			CPU1
			(
				type = radiobuttons	
				displayname = "CPU"
				values  = CPU_Master[Make.ID == input.Make && Model.ID == input.Model1].ID
    			displayformat = [CPU]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Generation1
			(
				type = radiobuttons	
				displayname = "Generation"
				values  = Classifications_of_Make_and_Model[Make.ID == input.Make && Model.ID == input.Model1 && CPU.ID == input.CPU1].ID
    			displayformat = [Generation]
				sortorder = ascending
				layout = 3
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have HDD_1
			(
				type = radiobuttons
				displayname = "HDD"
				maxchar = 100
				values = {"Yes","No"}
				layout = 2
	 			row = 1
	 			column = 1   
				width = medium
			)
			Category
			(
				type = radiobuttons
				maxchar = 100
				values = {"HDD","SSD SATA","SSD MSATA","NVNE","M.2"}
				layout = 3
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			HDD_Capacity
			(
				type = radiobuttons
				displayname = "SSD Capacity"
				maxchar = 100
				values = {"256 GB","500 GB","512 GB","1 TB","2 TB","Others","128 GB","250 GB","320 GB","3 TB","4 TB","5 TB","8 TB","16 TB"}
				layout = 3
	 			row = 1
	 			column = 1   
				width = medium
			)
			HDD_Capacity1
			(
				type = radiobuttons
				displayname = "HDD Capacity"
				maxchar = 100
				values = {"120 GB","180 GB","240 GB","256 GB","500 GB","512 GB","1 TB","2 TB","Others","128 GB","250 GB","320 GB","3 TB","4 TB","5 TB","8 TB","16 TB"}
				layout = 3
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Health
			(
				type = radiobuttons
				displayname = "HDD Health %"
				maxchar = 100
				values = {"Excellent","Good","Fair","Poor"}
				layout = 2
	 			row = 1
	 			column = 1   
				width = medium
			)
			HDD_Serial_Numbers
			(
    			type = textarea
				displayname = "HDD Serial Numbers"
				height = 100px
				manual input  =  true
				barcode = true
				show onload = true
				camera = primary
	 			row = 1
	 			column = 1   
				width = medium
			)
			Touch_Pad
			(
				type = checkboxes	
				displayname = "Touch Pad"
