			update_final_status_to_PN2 as "update final status to PNA"
			{
				type =  form
				form = Desktop_L1_L2_Engineer_Screen1
				record event = on add

				on user input of faults.Status
				{
					actions 
					{
						custom deluge script
						(
											for each  i in faults
										{
											if(i.Status == "PNA")
											{
												input.Final_Status = "PNA";
												disable Final_Status;
											}
											else
											{
												input.Final_Status = "";
												enable Final_Status;
											}
										}
						)
					}
				}

			}
