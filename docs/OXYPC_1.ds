			(
    			type = plaintext
				value = "<div class=\"align-center\" style=\"text-align: center\"><b style=\"font-size: 16px\">Tests to be Done</b><br /></div><div><table cellpadding=\"2\" cellspacing=\"2\" border=\"0\" style=\"font-size: 10pt; font-family: DejaVuSans, sans-serif; border: 1px solid black; color: black\"><tbody><tr><td style=\"width: 214.5px\"><div>COSMETIC CHECK <br /></div></td><td style=\"width: 214.5px\"><div>POWER BUTTON <br /></div></td></tr><tr><td style=\"width: 214.5px\"><div>AUDIO TEST <br /></div></td><td style=\"width: 214.5px\"><div>SPEAKER TEST <br /></div></td></tr><tr><td style=\"width: 214.5px\"><div>BLUETOOTH <br /></div></td><td style=\"width: 214.5px\"><div>START UP &amp; CRITICAL UPDATES TEST (All Drivers) <br /></div></td></tr><tr><td style=\"width: 214.5px\"><div>CHARGING PORT <br /></div></td><td style=\"width: 214.5px\"><div>FRAME <br /></div></td></tr><tr><td style=\"width: 214.5px\"><div>CPU / VIDEOS TEST <br /></div></td><td style=\"width: 214.5px\"><div>SCREEN <br /></div></td></tr><tr><td style=\"width: 214.5px\"><div>DIAGNOSTIC CLEANING TEST <br /></div></td><td style=\"width: 214.5px\"><div>PERIPHERALS <br /></div></td></tr><tr><td style=\"width: 214.5px\"><div>FINGERPRINT TEST (LAPTOP) <br /></div></td><td style=\"width: 214.5px\"><div>TOUCH SCREEN TEST <br /></div></td></tr><tr><td style=\"width: 214.5px\"><div>HDD DIAGNOSTIC TEST <br /></div></td><td style=\"width: 214.5px\"><div>VOLUME BUTTON <br /></div></td></tr><tr><td style=\"width: 214.5px\"><div>KEYBOARD &amp; TRACKPAD TEST <br /></div></td><td style=\"width: 214.5px\"><div>WEBCAM TEST <br /></div></td></tr><tr><td style=\"width: 214.5px\"><div>BATTERY LIFE TEST <br /></div></td><td style=\"width: 214.5px\"><div>Wi-Fi CONNECTIVITY <br /></div></td></tr><tr><td style=\"width: 214.5px\"><div>MEMORY RAM TEST <br /></div></td><td style=\"width: 214.5px\"><div>All LED test <br /></div></td></tr><tr><td style=\"width: 214.5px\"><div>MICROPHONE TEST <br /></div></td><td style=\"width: 214.5px\"><div>CMOS Checking <br /></div></td></tr><tr><td style=\"width: 214.5px\"><div>NETWORK LAN <br /></div></td><td style=\"width: 214.5px\"><div>Software License/ Key Check <br /></div></td></tr><tr><td style=\"width: 214.5px\"><div>PORTS CHECK TEST <br /></div></td><td style=\"width: 214.5px\"><div><br /></div></td></tr></tbody></table><div><br /></div></div><div><br /></div>"
	 			row = 1
	 			column = 3   
				width = medium
			)
	
			customize
			(
				icon = "users-2-a-time"
			)
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
