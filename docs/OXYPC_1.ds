			Update_Warehouse_in_recor as "Update Warehouse in records in master"
			{
				type =  form
				form = GRN
				record event = on edit
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											for each  i in Item
										{
											mstr_updt_recs = Product_Master_Inventory1[LOT_No == i.Lot_No && Make == i.Make.Make && Model == i.Model.Model];
											for each  j in mstr_updt_recs
											{
												j.Warehouse=i.Location;
												j.LOT_No=i.Lot_No;
												j.Customer_Name=i.Customer_Name;
												j.Purchase_Price=i.Price;
											}
										}
						)
					}
				}

			}
