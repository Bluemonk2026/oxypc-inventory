			Update_Details2 as "Update Details"
			{
				type =  form
				form = Desktop_L1_L2_Engineer_Screen1
				record event = on add or edit

				on user input of Barcode
				{
					actions 
					{
						custom deluge script
						(
											l1_l2_rec = Desktop_L1_L2_Engineer_Screen1[Barcode.equalsIgnoreCase(input.Barcode)];
										// l1_l2_screen = L1_L2_Engineer_Screen[Barcode == input.Barcode];
										// if(l1_l2_screen.count(Final_Status) < 0)
										// {
										if(l1_l2_rec.count() == 0)
										{
											Barcode1 = input.Barcode;
											// inven_rec = Product_Master_Inventory1[Tag_No2 == Barcode1];
											rec = IQC_Format_for_Desktop[Tag_No.equalsIgnoreCase(Barcode1)];
											input.Make = rec.Make.Make;
											input.Model = rec.Model.Model;
											input.CPU = rec.Processors;
											input.Generation = rec.Generation;
											input.RAM = rec.Capacity;
											input.HDD = rec.HDD_Capacity;
											input.LOT_No = rec.LOT_No1.LOT_No;
											input.Serial_Number = rec.Serial_No;
											rowww = Collection();
											recss = Faulty_Spare_Parts_After_IQC1[Tag_No1.equalsIgnoreCase(input.Barcode) && Category == "Desktop"];
											info recss;
											for each  i in recss
											{
												row1 = Desktop_L1_L2_Engineer_Screen1.faults();
												// 		recs = Spare_Parts2[Spare_Part_Name == i.Spare_Part];
												row1.Spare_Part_Desktop=i.Spare_Part_Desktop;
												row1.Spare_Part=i.Spare_Part;
												row1.Tag_No1=i.Tag_No1;
												// 		row1.Model_Description=i.Model_Description;
												row1.Quantity=i.Quantity;
												row1.Lot_No=i.Lot_No;
												row1.Status=i.Status;
												row1.Category=i.Category;
												row1.Model=i.Model;
												row1.Make=i.Make;
												row1.Price=i.Price;
												rowww.insert(row1);
												// 	input.faults.insert(i.ID);
											}
											input.faults.insert(rowww);
										}
										else
										{
											faulty_recs = Faulty_Spare_Parts_After_IQC1[Tag_No1.equalsIgnoreCase(input.Barcode)];
											ids_lst = List();
											for each  i in faulty_recs
											{
												input.faults.insert(i.ID);
											}
										}
										///////////////////////////////////////////////////////////////////////////////////////
										// l1_l2_screen = L1_L2_Engineer_Screen[Barcode == input.Barcode];
										// if(l1_l2_screen.count(Final_Status) < 0)
										// {
										Barcode1 = input.Barcode;
										// inven_rec = Product_Master_Inventory1[Tag_No2 == Barcode1];
										l1_l2_engg_rec = Desktop_L1_L2_Engineer_Screen1[Barcode.equalsIgnoreCase(Barcode1)];
										// product_master_rec = Product_Master_Inventory1[Tag_No2 == Barcode1];
										iqc_data = IQC_Format_for_Desktop[Tag_No.equalsIgnoreCase(input.Barcode)];
										if(l1_l2_engg_rec.count() == 0)
										{
											rec = IQC_Format_for_Desktop[Tag_No.equalsIgnoreCase(Barcode1)];
											input.Make = rec.Make.Make;
											input.Model = rec.Model.Model;
											input.CPU = rec.Processors;
											input.Engineer = rec.Added_User;
											input.Generation = rec.Generation;
											input.RAM = rec.Capacity;
											input.HDD = rec.HDD_Capacity;
											input.LOT_No = rec.LOT_No1.LOT_No;
											input.Serial_Number = rec.Serial_No;
											if(rec.count() > 0)
											{
												faults_s = rec.SubForm;
												rowww = Collection();
												recss = Faulty_Spare_Parts_After_IQC1[Tag_No.equalsIgnoreCase(rec.ID.toString())];
												info recss;
												for each  i in recss
												{
													row1 = L1_L2_Engineer_Screen.faults();
													recs = Spare_Parts2[Spare_Part_Name == i.Spare_Part];
													row1.Spare_Part1=recs.ID;
													row1.Spare_Part=i.Spare_Part;
													row1.Tag_No1=i.Tag_No1;
													row1.Model_Description=i.Model_Description;
													row1.Quantity=i.Quantity;
													row1.Lot_No=i.Lot_No;
													row1.Status=i.Status;
													rowww.insert(row1);
												}
												input.faults.insert(rowww);
											}
										}
										else
										{
											alert "This Desktop already got repaired!!";
											openurl("https://creator.zoho.in" + zoho.appuri + "Desktop_L1_L2_Engineer_Screen1/record-edit/Desktop_L1_L2_Engineer_Screen1_Report/" + l1_l2_engg_rec.ID + "/","same window");
										}
						)
					}
				}

			}
