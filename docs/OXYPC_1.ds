			Update_Make_and_Model as "Update Make and Model"
			{
				type =  form
				form = Spare_Part_Cost_LOT_Wise
				record event = on add or edit
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											input.Make1 = input.Make.Make;
										input.Model1 = input.Model.Model;
										input.CPU1 = input.CPU.CPU;
										input.Generation1 = input.Generation.Generation;
						)
					}
				}

			}
			tst1 as "tst"
			{
				type =  form
				form = IQC_Format_for_Laptop
				record event = on edit
					status = inactive

				on update of checkbox1
				{
					actions 
					{
						custom deluge script
						(
											model = input.Model1.Model;
										make = input.Make.Make;
										if(input.Hinch_Cover_replace == "yes")
										{
											rec = Spare_Parts_Costing_Report[Part == "Hinch Cover" && Make == make && Model == model];
											input.Required_Replacements = rec;
											input.Hinch_Cover_Rate = rec.Rate;
										}
										if(input.Hinch_replace == "yes")
										{
											rec = Spare_Parts_Costing_Report[Part == "Hinch" && Make == make && Model == model];
											input.Required_Replacements = rec;
											input.Hinch_Rate = rec.Rate;
										}
