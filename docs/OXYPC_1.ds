			Update_Status_In_RMA_Inve as "Update Status In RMA Inventory"
			{
				type =  form
				form = RMA_Repair
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											//Updated Code
										//Staus Form Inventory 
										result = Inventory_of_RMA[RMA_Number == input.RMA_Number];
										if(result.count() > 0)
										{
											result.Final_Status=input.Final_Status;
											result.Serial_Number=input.Serial_Number;
											result.Tag_Number=input.Tag_Number;
											// 	result.Make=input.Make;
											// 	result.Model=input.Model;
											// 	result.CPU=input.CPU;
											// 	result.Generation=input.Generation;
											// 	result.RAM=input.RAM;
											if(input.Final_Status == "Escalate to L4" || input.Final_Status == "Escalate to Plastic Repair" || input.Final_Status == "PNA" || input.Final_Status == "Pending for Approval")
											{
												result.Stage="In Repair";
											}
											else if(input.Final_Status == "Replacement Required" || input.Final_Status == "CN Required")
											{
												result.Stage="Pending for Approval";
											}
											else if(input.Final_Status == "CN Issued")
											{
												result.Stage="CN Issued";
											}
											else if(input.Final_Status == "Replacement Issued" || input.Final_Status == "Repair Completed" || input.Final_Status == "Return without Repair")
											{
												result.Stage="Ready to Ship";
											}
										}
						)
					}
				}

			}
			Update_Status_In_RMA_Inve1 as "Update Status In RMA Inventory"
			{
				type =  form
				form = RMA_Ship_to_Customer
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											result = Inventory_of_RMA[RMA_Number == input.RMA_Number];
										result.Final_Status=input.Final_Status;
										if(input.Final_Status == "Replacement Issue" || input.Final_Status == "Return without Repair" || input.Final_Status == "Repaired & Shipped" || input.Final_Status == "NTF/Same Return")
										{
											result.Stage="Shipping Completed";
										}
										else if(input.Final_Status == "CN Issue")
										{
											result.Stage="CN Issued";
										}
						)
					}
				}

			}
