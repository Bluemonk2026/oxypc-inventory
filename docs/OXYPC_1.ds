			Sold_Out_cHECK as "Sold Out cHECK"
			{
				type =  form
				form = Sold_Out_Tag_Numbers
				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											lst = list();
										for each  j in input.Sold_Out_Tags
										{
											newline = hextotext("0A");
											for each  i in j.toList(newline)
											{
												sold_out_rec = Sold_Out_Report[Tag_Number.equalsIgnoreCase(i)];
												if(sold_out_rec.count() > 0)
												{
													lst.add(i);
												}
											}
										}
										if(lst.size() > 0)
										{
											alert "Tag Numbers: " + lst.toString() + "already Exists !!!";
											cancel submit;
										}
						)
					}
				}

			}
			Update_values2 as "Update values"
			{
				type =  form
				form = Raw_Data_Sales
				record event = on add

				on user input of Tag_Number
				{
					actions 
					{
						custom deluge script
						(
											qc_rec = Final_QC1[Tag_Number.equalsIgnoreCase(input.Tag_Number)];
										if(qc_rec.count() != 0)
										{
											info qc_rec.Category;
											input.Serial_Number = qc_rec.Serial_Number;
											input.LOT_Number = qc_rec.LOT_Number;
											input.Category = qc_rec.Category;
											if(qc_rec.Updated_Make == null || qc_rec.Updated_Make == null)
											{
												input.Make = qc_rec.Make;
											}
											else
											{
												input.Make = qc_rec.Updated_Make.Make;
											}
											if(qc_rec.Updated_Model == null || qc_rec.Updated_Model == null)
											{
												input.Model = qc_rec.Model;
											}
											else
											{
												input.Model = qc_rec.Updated_Model.Model;
											}
											if(qc_rec.Updated_RAM == null || qc_rec.Updated_RAM == null)
											{
												input.RAM = qc_rec.RAM;
											}
											else
											{
												input.RAM = qc_rec.Updated_RAM;
											}
											if(qc_rec.Updated_HDD == null || qc_rec.Updated_HDD == null)
											{
												input.HDD = qc_rec.HDD;
											}
											else
											{
												input.HDD = qc_rec.Updated_HDD;
											}
											if(qc_rec.Updated_Generation == null || qc_rec.Updated_Generation == null)
											{
												input.Generation = qc_rec.Generation;
											}
											else
											{
												input.Generation = qc_rec.Updated_Generation;
											}
											if(qc_rec.Update_CPU1 == null || qc_rec.Update_CPU1 == null)
											{
												input.CPU = qc_rec.CPU;
											}
											else
											{
												input.CPU = qc_rec.Update_CPU1;
											}
										}
										else
										{
											alert "Final QC not done for this Tag Number";
										}
						)
					}
				}

			}
