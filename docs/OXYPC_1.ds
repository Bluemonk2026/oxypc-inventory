			Create_Committed_Stock_Re as "Create Committed Stock Report"
			{
				type =  form
				form = Presales_QC_New
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											for each  i in Item_Table
										{
											newline = hextotext("0A");
											for each  j in i.Tag_Numbers.toList(newline)
											{
												mapp = Map();
												mapp.put("Tag_Number",j);
												recs = Stock_tranfer_TRC_to_Showroom[Tag_Number == j];
												recs.Committed_or_Sold="Committed";
												mapp.put("Serial_Number",recs.Serial_Number);
												mapp.put("Make",recs.Make);
												mapp.put("Model",recs.Model);
												mapp.put("CPU",recs.CPU);
												mapp.put("Category",recs.Category);
												mapp.put("Generation",recs.Generation);
												mapp.put("RAM",recs.RAM);
												mapp.put("HDD",recs.HDD);
												mapp.put("Required_HDD",i.Required_HDD_Capacity);
												mapp.put("Required_RAM",i.Required_RAM_Capacity);
												mapp.put("Product_Description",i.Product_Name1.Product_Description);
												mapp.put("Sales_Order_Number",input.Sales_Order_Number);
												mapp.put("Presales_QC_Row_ID",i.ID);
												final_mapp = Map();
												final_mapp.put("data",mapp);
												create_recs = invokeurl
												[
													url :"https://creator.zoho.in/api/v2.1/protaiga/oxypc-1/form/Committed_Stock_Presales_QC"
													type :POST
													parameters:final_mapp.toString()
													headers:{'environment':'development'}
													connection:"creator"
												];
												info create_recs;
											}
										}
						)
					}
				}

			}
			Hide_Updated_RAM_and_HDD_ as "Hide Updated RAM and HDD fields"
			{
				type =  form
