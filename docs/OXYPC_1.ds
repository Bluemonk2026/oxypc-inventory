				{
					actions 
					{
						custom deluge script
						(
											inv_recs = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(input.Tag_Number)];
										if(inv_recs.count() > 0 && input.Warehouse == "Bluemonk House Showroom")
