				 void Delete_duplicate_records_from_report()
                 {
                 	myList = list();
                 	duplicateRecordIDList = list();
                 	for each  record in Model_Spare_Part[ID != 0]
                 	{
                 		if(myList.contains(record.Model))
                 		{
                 			duplicateRecordIDList.add(record.ID);
                 		}
                 		else
                 		{
                 			myList.add(record.Model);
                 		}
                 	}
                 	delete from Model_Spare_Part[ID in duplicateRecordIDList];
                 }
