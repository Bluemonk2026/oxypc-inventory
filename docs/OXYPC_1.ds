															mapp.put("Product_Sub_Category",iqc_records.Sub_Category.Sub_Category);
															mapp.put("Zoho_Books_ID",i.Books_Item_ID);
															mapp.put("Warehouse",i.Location);
															mapp.put("Quantity",1);
															mapp.put("Used_or_not","In-Zoho");
															mapp.put("GRN_Date",input.Date_field.toString("dd-MMM-yyyy"));
															mapp.put("GRN_Number",input.GRN_Number);
															mapp.put("Invoice_Number",input.Invoice_Number);
															mapp.put("PO_Number",input.PO_Number.PO_Number);
															if(iqc_records.HDD_Capacity1 != null)
															{
																mapp.put("HDD",iqc_records.HDD_Capacity1);
															}
															else if(iqc_records.HDD_Capacity != null)
															{
																mapp.put("HDD",iqc_records.HDD_Capacity);
															}
