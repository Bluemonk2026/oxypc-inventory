			Fetch_customers_from_Pres as "Fetch customers from Presales"
			{
				type =  form
				form = Sales_Form
				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											result = PreSales_QC[Customer_Name != null && Product_Stage != "Sold Out"].distinct(Customer_Name);
										// Step 2: Prepare data for dropdown
										dropdownData = List();
										for each  line_item in result
										{
											customerRecord = Customer_Database[ID == line_item];
											if(customerRecord != null)
											{
												dropdownData.add(customerRecord.Customer_Name);
											}
										}
										input.Customer:ui.add(dropdownData);
						)
					}
				}

			}
