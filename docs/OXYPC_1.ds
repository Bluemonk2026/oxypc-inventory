															mapp.put("Make",tft_rec.Make);
															mapp.put("Screen_Size1",tft_rec.Screen_Size);
															mapp.put("Purchase_Price",i.Price);
															mapp.put("Screen_Type",tft_rec.Screen_Type);
															mapp.put("Power",tft_rec.Power);
															mapp.put("Power_Button",tft_rec.Power_Button);
															mapp.put("Menu_Button",tft_rec.Menu_Button);
															mapp.put("VGA_Port",tft_rec.VGA_Port);
															mapp.put("HDMI_Port",tft_rec.HDMI_Port);
															mapp.put("Status1",tft_rec.Status);
															mapp.put("Remarks",tft_rec.Remarks);
															mapp.put("DP_Port",tft_rec.DP_Port);
															mapp.put("USB_Port",tft_rec.USB_Port);
															mapp.put("DVI_Port",tft_rec.DVI_Port);
															mapp.put("Product_Category2","TFT");
															mapp.put("Product_Sub_Category","TFT");
															mapp.put("Quantity",1);
															mapp.put("Product_Stages","Assigned to L1/L2 Engineer");
															mapp.put("Product_Category","Repair");
															mapp.put("Warehouse",i.Location);
															mapp.put("Zoho_Books_ID",i.Books_Item_ID);
															mapp.put("GRN_Date",input.Date_field.toString("dd-MMM-yyyy"));
															mapp.put("GRN_Number",input.GRN_Number);
															mapp.put("Invoice_Number",input.Invoice_Number);
															mapp.put("PO_Number",input.PO_Number.PO_Number);
															empty_mapp = Map();
															create_rec = zoho.creator.createRecord("protaiga","oxypc-1","Product_Master_Inventory1",mapp,empty_mapp,"creator");
															info create_rec;
															sendmail
															[
																from :zoho.loginuserid
																to :"shubham.oxypc@gmail.com"
																subject :"TFT IQC Create record in inventory"
																message :"Create_rec" + create_rec
															]
														}
														else
														{
															mapp = Map();
