			Find_Time_Difference as "Find Time Difference"
			{
				type =  form
				form = IQC_Format_for_Laptop
				record event = on add or edit
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											input.Time_Difference = input.Added_Time.toTime().timeBetween(input.Time.toTime());
						)
					}
				}

			}
			Time_Difference_between_s as "Time Difference between submission and start time"
			{
				type =  form
				form = IQC_Format_for_Laptop
				record event = on add or edit
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											start_date_time = input.Date_field.toString("dd-MMM-yyyy") + " " + input.Time.toString();
										sendmail
										[
											from :zoho.loginuserid
											to :"shubham.oxypc@gmail.com"
											subject :"Time difference funcgtion for LAtpop IQC"
											message :"start_date_time" + start_date_time
										]
										// info start_date_time;
										diff = start_date_time.toDateTime().timeBetween(input.Added_Time);
										sendmail
										[
											from :zoho.loginuserid
											to :"shubham.oxypc@gmail.com"
											subject :"Time difference funcition testing the calculation of diff"
											message :"Time diffrence" + diff
										]
										// info diff;
										input.Time_Difference = diff;
						)
					}
				}

			}
