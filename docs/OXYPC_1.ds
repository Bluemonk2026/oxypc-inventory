	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Pin
			(
				type = radiobuttons
				maxchar = 100
				values = {"30 pin","20 pin","40 pin"}
	 			row = 1
	 			column = 1   
				width = medium
