			Finding_Pricing as "Finding Pricing"
			{
				type =  form
				form = Faulty_Spare_Parts_After_IQC1
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											make_id = input.Tag_No.Make;
										var = Make[ID == make_id];
										make = var.Make;
										model_id = input.Tag_No.Model1;
										var1 = Model[ID == model_id];
										model = var1.Model;
										spare_part = input.Spare_Part;
										model_descriptionnn = make + " " + model + " " + spare_part;
										rec = Spare_Parts_Costing_Report[Part_Description == model_descriptionnn];
										input.Price = rec.Rate;
						)
					}
				}

			}
