	section Final_QC
	{
		displayname= "Final QC"
		icon = "sport-tennis-ball"
		form Final_QC1
		{
			displayname = "Final QC"
			success message = "Data Added Successfully!"
			field alignment = left
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Tag_Number
			(
    			type = text
				displayname = "Tag Number"
				qrcode = true
				barcode = true
				camera = primary
	 			row = 1
	 			column = 1   
				width = medium
			)
			LOT_Number
			(
    			type = text
				displayname = "LOT Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Time
			(
    			type = time
				initial value = "${zoho.currenttime}"	
				timedisplayoptions = "hh:mm:ss" 
	 			row = 1
	 			column = 1   
				width = medium
			)
			Model
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			Update_Model
			(
				type = checkboxes	
				displayname = "Need to Update Model?"
				values = {"Yes"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Updated_Model
			(
				type = picklist	
				displayname = "Updated Model"
				values  = Model.ID
    			displayformat = [Model]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Generation
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			Update_Generation
			(
				type = checkboxes	
				displayname = "Need to Update Generation?"
				values = {"Yes"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Updated_Generation
			(
				type = picklist
				displayname = "Updated Generation"
				maxchar = 100
				values = {"1ST","2ND","3RD","4TH","5TH","6TH","7TH","8TH","9TH","10TH","11TH","12TH","A10","C2D","Other"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			HDD
			(
				type = picklist
				maxchar = 100
				values = {"120 GB","180 GB","240 GB","250 GB","256 GB","500 GB","512 GB","1 TB","2 TB","No Hard Disk"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			Need_to_Update_HDD
			(
				type = checkboxes	
				displayname = "Need to Update HDD?"
				values = {"Yes"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Updated_HDD
			(
				type = picklist
				displayname = "Updated HDD"
				maxchar = 100
				values = {"120 GB","180 GB","240 GB","250 GB","256 GB","500 GB","512 GB","1 TB","2 TB","No Hard Disk"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			Grade
			(
				type = picklist
				maxchar = 100
				values = {"Box Packed"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Final_Status
			(
				type = picklist
				displayname = "Final Status"
				maxchar = 100
				values = {"Fail","Pass"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Failure_Reason
			(
				type = picklist
				displayname = "Failure Reason"
				maxchar = 100
				values = {"Paint","Functional","Plastic Part"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Faults
			(
				type = picklist
				maxchar = 100
				values = {"COSMETIC CHECK","AUDIO TEST","BLUETOOTH","CHARGING PORT","CPU / VIDEOS TEST","DIAGNOSTIC CLEANING TEST","FINGERPRINT TEST (LAPTOP)","HDD DIAGNOSTIC TEST","KEYBOARD & TRACKPAD TEST","BATTERY LIFE TEST","MEMORY RAM TEST","MICROPHONE TEST","NETWORK LAN","PORTS CHECK TEST","POWER BUTTON","SPEAKER TEST","START UP & CRITICAL UPDATES TEST (All Drivers)","FRAME","SCREEN","PERIPHERALS","TOUCH SCREEN TEST","VOLUME BUTTON","WEBCAM TEST","Wi-Fi CONNECTIVITY","All LED test","CMOS Checking","Software License/ Key Check","Base Broken","Wi-Fi Not working","Keyboard Not working","Auto On","Speaker Faulty","Upper Click Not working","Panel Broken","Usb Faulty","Touch Pad Colour fade","Click Hard Press","Screen Faulty","keybord key hard Press","Click Not Work","Camera not working","Screen patch","Power Key Light","Logic Card Not Working","CPU fan Error","USB Not Working","Blue Dump Error","Mic Not Working","Bazel Broken","T.paid Broken","AC Adaptor unknown","BIOS Password","No Display","Not On"}
				sortorder = ascending
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			Remarks
			(
    			type = textarea
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Warehouse
			(
				type = picklist
				maxchar = 100
				values = {"Bluemonk House Showroom","Manesar","TRC 2ND Floor","Amazon"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Product_Description
			(
    			type = text
				displayname = "Product Description"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Category
			(
				type = picklist
				maxchar = 100
				values = {"Laptop","Desktop","TFT"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Date_field
			(
    			type = date
				displayname = "Date"
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 2   
				width = medium
			)
			Serial_Number
			(
    			type = text
				displayname = "Serial Number"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Make
			(
    			type = text
	 			row = 1
	 			column = 2   
				width = medium
			)
			Update_Make
			(
				type = checkboxes	
				displayname = "Need to update Make?"
				values = {"Yes"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Updated_Make
			(
				type = picklist	
				displayname = "Updated Make"
				values  = Make.ID
    			displayformat = [Make]
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			CPU
			(
    			type = text
	 			row = 1
	 			column = 2   
				width = medium
			)
			Update_CPU
			(
				type = checkboxes	
				displayname = "Need to Update CPU?"
				values = {"Yes"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Update_CPU1
			(
				type = picklist
				displayname = "Updated CPU"
				maxchar = 100
				values = {"I3","I4","I5","I7","M5","M7","celeron","C2D","AMD","AMD PRO","PENTIUM R","XEON","Other","No CPU"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			RAM
			(
				type = picklist
				maxchar = 100
				values = {"2GB","4GB","6GB","8GB","12GB","16GB","32GB","64GB","No Ram"}
				others option = true
	 			row = 1
	 			column = 2   
				width = medium
			)
			Need_to_Update_RAM
			(
				type = checkboxes	
				displayname = "Need to Update RAM?"
				values = {"Yes"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Updated_RAM
			(
				type = picklist
				displayname = "Updated RAM"
				maxchar = 100
				values = {"2GB","4GB","6GB","8GB","12GB","16GB","32GB","64GB","No Ram"}
				others option = true
	 			row = 1
	 			column = 2   
				width = medium
			)
			Zoho_Books_Product_ID
			(
    			type = text
				displayname = "Zoho Books Product ID"
				private = true
	 			row = 1
	 			column = 2   
				width = medium
			)
	
			customize
			(
				icon = "sport-tennis-ball"
			)
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
