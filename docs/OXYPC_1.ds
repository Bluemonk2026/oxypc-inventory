			Fetch_data_base_on_RMA_nu as "Fetch data base on RMA number"
			{
				type =  form
				form = RMA_Ship_to_Customer
				record event = on add or edit

				on user input of RMA_Number
				{
					actions 
					{
						custom deluge script
						(
											if(input.Serial_Number == "" && input.Tag_Number == "")
										{
											job_detail = RMA_Repair[RMA_Number.equalsIgnoreCase(input.RMA_Number)];
											if(job_detail.count() == 0)
											{
												newline = hextotext("0A");
												alert "Record has not entered in RMA Repair" + newline + "रिकॉर्ड RMA Repair में दर्ज नहीं किया गया है";
												job_detail1 = RMA_Create_Job[RMA_Number.equalsIgnoreCase(input.RMA_Number)];
												if(job_detail1.count() == 0)
												{
													alert "Job Not Created for this Tag Number !!";
												}
												else
												{
													input.Tag_Number = job_detail1.Tag_Number;
													input.Make = job_detail1.Make;
													input.Model = job_detail1.Model;
													input.CPU = job_detail1.CPU;
													input.Problem_Reported = job_detail1.Problem_Reported;
													input.RAM = job_detail1.RAM;
													input.HDD = job_detail1.HDD;
													input.Generation = job_detail1.Generation;
													input.Serial_Number = job_detail1.Serial_Number;
													input.Sales_Person = job_detail1.Sales_Person;
													input.Sale_Date = job_detail1.Sale_Date.toString("dd-MMM-yyyy");
													input.Party_Name = job_detail1.Party_Name;
													input.Action_Needed = job_detail1.Action_Needed;
													input.Physical_Condition = job_detail1.Physical_Condition;
													input.Job_Remarks = job_detail1.Remarks;
													input.Party_Contact_Number = job_detail1.Party_Contact_Number;
													input.Warranty_Status = job_detail1.Warranty_Status;
												}
											}
											else
											{
												input.Tag_Number = job_detail.Tag_Number;
												input.Make = job_detail.Make;
												input.Model = job_detail.Model;
												input.CPU = job_detail.CPU;
												input.Problem_Reported = job_detail.Problem_Reported;
												input.RAM = job_detail.RAM;
												input.HDD = job_detail.HDD;
												input.Generation = job_detail.Generation;
												input.Serial_Number = job_detail.Serial_Number;
												input.Sales_Person = job_detail.Sales_Person;
												input.Sale_Date = job_detail.Sale_Date.toString("dd-MMM-yyyy");
												input.Party_Name = job_detail.Party_Name;
												input.Action_Needed = job_detail.Action_Needed;
												input.Physical_Condition = job_detail.Physical_Condition;
												input.Job_Remarks = job_detail.Job_Remarks;
												input.Party_Contact_Number = job_detail.Party_Contact_Number;
												input.Warranty_Status = job_detail.Warranty_Status;
												input.Extra_Charges = job_detail.Extra;
												input.Charges = job_detail.Charges;
												// 		input.RMA_Number = job_detail.RMA_Number;
												input.Problem_Observed = job_detail.Problem_Observed;
												input.Final_Status1 = job_detail.Final_Status;
												input.Status_Remark = job_detail.Status_Remark;
												if(job_detail.Extra == "Yes")
												{
													show Charges;
												}
												else
												{
													hide Charges;
												}
												sbfrm_coll = Collection();
												for each  i in job_detail.Replaced_Parts
												{
													sbfrm = RMA_Ship_to_Customer.Replaced_Parts();
													sbfrm.RAM=i.RAM;
													sbfrm.Spare_Part_Name=i.Spare_Part_Name;
													sbfrm.Model=i.Model;
													sbfrm.Serial_Number=i.Serial_Number;
													sbfrm.Generation=i.Generation;
													sbfrm.Party_Name=i.Party_Name;
													sbfrm.Make=i.Make;
													sbfrm.CPU=i.CPU;
													sbfrm.Status=i.Status;
													sbfrm.Quantity=i.Quantity;
													sbfrm.HDD=i.HDD;
													sbfrm.Tag_Number=i.Tag_Number;
													sbfrm_coll.insert(sbfrm);
												}
												input.Replaced_Parts.clear();
												input.Replaced_Parts.insert(sbfrm_coll);
											}
										}
						)
					}
				}

			}
