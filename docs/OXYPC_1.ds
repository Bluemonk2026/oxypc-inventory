				}
			}
		}
		form Consumables
		{
			displayname = "Consumables GRN"
			success message = "Data Added Successfully!"
			field alignment = left
			feature property = 256
			Section1
			(
				type = section
				displayname = "Section"
	 			row = 1
	 			column = 0   
				width = medium
			)
			PO_Number
			(
				type = picklist	
				displayname = "PO Number"
				values  = Purchase_Order[PO_Item_Type == "Consumables"].ID
    			displayformat = [PO_Number]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Date_of_Material_Received
			(
    			type = date
				displayname = "Date of Material Received"
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			unique GRN_Number_System
			(
    			type = text
				displayname = "GRN Number (System)"
	 			row = 1
	 			column = 1   
				width = medium
			)
			PO_Date1
			(
    			type = date
				displayname = "PO Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Vendor_Name
			(
				type = picklist
				displayname = "Vendor Name"
				maxchar = 100
				values = {"Deshwal Waste Management Pvt Limited","Amdocs","Centura Technologies","Lehar Solutions","MK Power Steel","Tucuxi Global Solutions Private Limited","URFI RECYCLING & TRADING CO-Delhi","Yours computers","Others"}
				others option = true
	 			row = 1
	 			column = 2   
				width = medium
			)
			Section2
			(
				type = section
				displayname = ""
				visibility = true
	 			row = 2
	 			column = 0   
				width = medium
			)
			must have Invoice_Number
			(
    			type = text
				displayname = "Invoice Number"
	 			row = 2
	 			column = 1   
				width = medium
			)
			E_Way_Bill_Number
			(
    			type = text
				displayname = "E-Way Bill Number"
	 			row = 2
	 			column = 1   
				width = medium
			)
			must have Vehicle_Number
			(
    			type = text
				displayname = "Vehicle Number"
	 			row = 2
	 			column = 1   
				width = medium
			)
			GRN
			(
				type = number
				displayname = "GRN Number"
	 			row = 2
	 			column = 1   
				width = medium
			)
			Freight_Cost
			(
				displayname = "Freight Cost"
				type = INR
				format = commadotindian
	 			row = 2
	 			column = 1   
				width = medium
			)
			Pickup_Cost
			(
				displayname = "Pickup Cost"
				type = INR
				format = commadotindian
	 			row = 2
	 			column = 1   
				width = medium
			)
			must have Invoice_Date
			(
    			type = date
				displayname = "Invoice Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 2
	 			column = 2   
				width = medium
			)
			E_Way_Bill_Date
			(
    			type = date
				displayname = "E-Way Bill Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 2
	 			column = 2   
				width = medium
			)
			Vehicle_Seal_Image
			(
    			type = image
				displayname = "Vehicle Seal Image"
				source  = public_url,file,camera
				aspect ratio = original
				camera = primary
				show gallery = true
				switch camera = true
	 			row = 2
	 			column = 2   
				width = medium
			)
			GRN_Number
			(
    			type = autonumber
				displayname = "GRN Number"
				start index = 1
	 			row = 2
	 			column = 2   
				width = medium
			)
			must have Customer_Name
			(
    			type = text
				displayname = "Customer Name"
	 			row = 2
	 			column = 2   
				width = medium
			)
			Invoice_Image
			(
    			type = image
				displayname = "Invoice Image"
				source  = public_url,file,camera
				aspect ratio = original
				camera = primary
				show gallery = true
				switch camera = true
	 			row = 2
	 			column = 3   
				width = medium
			)
			E_way_Bill
			(
    			type = image
				displayname = "E-Way Bill Image"
				source  = public_url,file,camera
				aspect ratio = original
				camera = primary
				show gallery = true
				switch camera = true
	 			row = 2
	 			column = 3   
				width = medium
			)
			Vehicle_Image
			(
    			type = image
				displayname = "Vehicle Image"
				source  = file
				aspect ratio = original
				camera = primary
				show gallery = true
				switch camera = true
	 			row = 2
	 			column = 3   
				width = medium
			)
			Section3
			(
				type = section
				displayname = "Purchase Order Tax Details"
				visibility = true
	 			row = 3
	 			column = 0   
				width = medium
			)
			SGST
			(
				type = INR
				format = commadotindian
	 			row = 3
	 			column = 1   
				width = medium
			)
			Taxable_Amount
			(
				type = number
				displayname = "Taxable Amount"
	 			row = 3
	 			column = 1   
				width = medium
			)
			CGST
			(
				type = INR
				format = commadotindian
	 			row = 3
	 			column = 2   
				width = medium
			)
			Tax_Amount
			(
				type = number
				displayname = "Tax Amount"
	 			row = 3
	 			column = 2   
				width = medium
			)
			IGST
			(
				type = INR
				format = commadotindian
	 			row = 3
	 			column = 3   
				width = medium
			)
			must have Invoice_Value
			(
				type = number
				displayname = "Invoice Value"
	 			row = 3
	 			column = 3   
				width = medium
			)
			Item
			(
				type = grid
				LOT_No
				(
    				type = text
					displayname = "LOT No."
					width = medium
				)
				must have Location
				(
					type = picklist
					maxchar = 100
					values = {"Basement","Ground Floor","2nd Floor","5th Floor"}
					width = medium
				)
				Item_Name
				(
    				type = text
					displayname = "Item Name"
					width = medium
				)
				Category_new
				(
    				type = text
					displayname = "Category"
					width = medium
				)
				Sub_Category_new
				(
    				type = text
					displayname = "Sub-Category"
					width = medium
				)
				must have Quantity
				(
    				type = text
					width = medium
				)
				Quantity_in_Invoice
				(
					type = number
					displayname = "Quantity in Invoice"
					width = medium
				)
				Physical_Quantity
				(
					type = number
					displayname = "Physical Quantity"
					width = medium
				)
				must have Price
				(
					type = INR
					format = commadotindian
					decimalplace = 8
					maxchar = 16
					width = medium
				)
				Product_Description
				(
    				type = text
					displayname = "Product Description"
					width = medium
				)
				Category
				(
					type = picklist	
					values  = Category_for_Consumables.ID
    				displayformat = [Category]
					allow new entries
					[
						displayname = "Add New"
					]
					sortorder = ascending
					width = medium
				)
				Sub_category
				(
					type = picklist	
					displayname = "Sub-category"
					values  = Sub_category_for_consumables[Category_for_Consumables.ID == input.Category].ID
    				displayformat = [Sub_Category_for_Consumables]
					allow new entries
					[
						displayname = "Add New"
					]
					sortorder = ascending
					width = medium
				)
				Tax_Percentage
				(
					type = decimal
					displayname = "Tax Percentage"
					width = medium
				)
				Total_Item_Price
				(
					type = decimal
					displayname = "Total Item Price"
					width = medium
				)
	 			row = 4
	 			column = 1   
				width = medium
			)
			Section4
			(
				type = section
				displayname = "Invoice Quantity/Tax Details "
				visibility = true
	 			row = 5
	 			column = 0   
				width = medium
			)
			Total_PO_Quantity
			(
				type = number
				displayname = "Total PO Quantity"
	 			row = 5
	 			column = 1   
				width = medium
			)
			Variance
			(
				type = number
	 			row = 5
	 			column = 1   
				width = medium
			)
			SGST_Invoice
			(
				displayname = "SGST Invoice"
				type = INR
				format = commadotindian
	 			row = 5
	 			column = 1   
				width = medium
			)
			Total_Purchase_Value_Without_Tax
			(
				displayname = "Total Purchase Value (Without Tax)"
				type = INR
				format = commadotindian
	 			row = 5
	 			column = 1   
				width = medium
			)
			Total_Invoice_Quantity
			(
				type = number
				displayname = "Total Invoice Quantity"
	 			row = 5
	 			column = 2   
				width = medium
			)
			Taxable_Amount_Invoice
			(
				displayname = "Taxable Amount Invoice"
				type = INR
				format = commadotindian
	 			row = 5
	 			column = 2   
				width = medium
			)
			CGST_Invoice
			(
				displayname = "CGST Invoice"
				type = INR
				format = commadotindian
	 			row = 5
	 			column = 2   
				width = medium
			)
			Total_Physical_Quantity
			(
				type = number
				displayname = "Total Physical Quantity"
	 			row = 5
	 			column = 3   
				width = medium
			)
			Total_Invoice_Value
			(
				displayname = "Total Invoice Value"
				type = INR
				format = commadotindian
	 			row = 5
	 			column = 3   
				width = medium
			)
			IGST_Invoice
			(
				displayname = "IGST Invoice"
				type = INR
				format = commadotindian
	 			row = 5
	 			column = 3   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
