										// 		]
										// 	}
										// }
										model_desc = input.Make.Make + " " + input.Model1.Model + " " + input.CPU + " " + input.Generation;
										input.Model_Description1 = model_desc;
										// ###################- Profit & Loss -#######################
										grn_rec = Items_GRN[LOT_No == input.LOT_Number];
										total_costt = input.Total_Cost;
										info grn_rec;
										purchase_price = grn_rec.Price;
										sales_price = Sales_Price_Laptop[Product_Description == input.Model_Description1];
										sales_priceee = sales_price.Sales_Price;
										info sales_price;
										pnl_rec = Spare_Part_Cost_LOT_Wise[LOT_No == input.LOT_Number && Product_Description1 == input.Model_Description1];
										info pnl_rec;
										if(pnl_rec.count() == 0)
										{
											pnl_data = Map();
											pnl_data.put("LOT_No",input.LOT_Number);
											pnl_data.put("Category","Laptop");
											pnl_data.put("Make1",input.Make.Make);
											pnl_data.put("Model1",input.Model1.Model);
											pnl_data.put("CPU1",input.CPU);
											pnl_data.put("Generation1",input.Generation);
											if(input.Number_of_replacements != null)
											{
												pnl_data.put("Number_of_replacements",input.Number_of_replacements);
											}
											pnl_data.put("Total_Cost",total_costt);
											pnl_data.put("Sales_Price",sales_priceee);
											pnl_data.put("Customer_Name",grn_rec.Customer_Name);
											pnl_data.put("Purchase_Price",purchase_price);
											pnl_data.put("Product_Description1",input.Model_Description1);
											pnl_data.put("Model_Count",1);
											empty_map = Map();
											info pnl_data;
											info zoho.creator.createRecord("protaiga","oxypc-1","Spare_Part_Cost_LOT_Wise",pnl_data,empty_map,"creator");
										}
										else
										{
											if(pnl_rec.Purchase_Price != null && purchase_price != null)
											{
												pnl_rec.Purchase_Price=pnl_rec.Purchase_Price + purchase_price;
												if(input.Number_of_replacements != null)
												{
													pnl_rec.Number_of_replacements=pnl_rec.Number_of_replacements + input.Number_of_replacements;
												}
												if(input.Total_Cost != null)
												{
													pnl_rec.Total_Cost=pnl_rec.Total_Cost + input.Total_Cost;
												}
												pnl_rec.Model_Count=pnl_rec.Model_Count + 1;
												pnl_rec.Sales_Price=pnl_rec.Sales_Price + sales_priceee;
											}
										}
						)
					}
				}

			}
			AutofillSubmittedRecordOn as "AutofillSubmittedRecordOnUserInput"
			{
				type =  form
				form = IQC_Format_for_Laptop
				record event = on add

				on user input of Copy_Previous_Submitted_Data
				{
					actions 
					{
						custom deluge script
						(
											if(input.Copy_Previous_Submitted_Data == "Update")
										{
											iqcfetchrecord = IQC_Format_for_Laptop[ID != 0 && Added_User == zoho.loginuser] sort by Added_Time desc;
											if(iqcfetchrecord != null)
											{
												show LOT_No2;
												hide LOT_Number;
												input.LOT_Number = iqcfetchrecord.LOT_Number;
												input.LOT_No2 = iqcfetchrecord.LOT_No2;
												input.Make = iqcfetchrecord.Make;
												input.RAM_1 = iqcfetchrecord.RAM_1;
												input.RAM_Type = iqcfetchrecord.RAM_Type;
												input.Capacity = iqcfetchrecord.Capacity;
												input.RAM_Status = iqcfetchrecord.RAM_Status;
												input.HDD = iqcfetchrecord.HDD;
												input.Category = iqcfetchrecord.Category;
												input.HDD_Capacity = iqcfetchrecord.HDD_Capacity;
												input.CPU = iqcfetchrecord.CPU;
												input.Generation = iqcfetchrecord.Generation;
												model_id = iqcfetchrecord.Model1;
												model_rec = Model[ID == model_id];
												input.Model1 = model_rec.ID;
												// 				input.Health = iqcfetchrecord.Health;
												// 				input.Does = iqcfetchrecord.Does;
												// 				input.BIOS_Password = iqcfetchrecord.BIOS_Password;
												// 				input.Microphone = iqcfetchrecord.Microphone;
												// 				input.Front_Panel = iqcfetchrecord.Front_Panel;
