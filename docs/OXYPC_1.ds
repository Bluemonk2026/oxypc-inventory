			Update_Make_and_Model2 as "Update Make and Model"
			{
				type =  form
				form = Data_Sales
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Make.contains("164568"))
										{
											make_rec = Make[ID == input.Make.toLong()];
											input.Make = make_rec.Make;
											sendmail
											[
												from :zoho.loginuserid
												to :"shubham.namdev@crm-masters.com"
												subject :"Testing inout.make"
												message :"Stock Transfer make" + input.Make
											]
										}
										if(input.Model.contains("164568"))
										{
											Model_rec = Model[ID == input.Model.toLong()];
											input.Model = Model_rec.Model;
										}
						)
					}
				}

			}
			Change_warehouse_in_Inven1 as "Change warehouse in Inventory"
			{
				type =  form
				form = Data_Sales
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											inv_recs = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(input.Tag_Number)];
										if(inv_recs.count() > 0 && input.Warehouse == "Bluemonk House Showroom")
										{
											inv_recs.Product_Category="Finished Good";
											inv_recs.Product_Stages="Inventory Finalized";
											inv_recs.Warehouse="Bluemonk House Showroom";
											inv_recs.Make=input.Make;
											inv_recs.Model=input.Model;
											inv_recs.CPU=input.CPU;
											inv_recs.Generation=input.Generation;
											inv_recs.RAM=input.RAM;
											inv_recs.HDD=input.HDD;
											inv_recs.Model_Description=input.Product_Description;
										}
										else
										{
											inv_recs.Product_Category="Finished Good";
											inv_recs.Product_Stages="Inventory Finalized";
											inv_recs.Warehouse="Amazon";
											inv_recs.Make=input.Make;
											inv_recs.Model=input.Model;
											inv_recs.CPU=input.CPU;
											inv_recs.Generation=input.Generation;
											inv_recs.RAM=input.RAM;
											inv_recs.HDD=input.HDD;
											inv_recs.Model_Description=input.Product_Description;
										}
						)
					}
				}

			}
			Update_Warehouse_in_Zoho_1 as "Update Warehouse in Zoho Books Inventory"
			{
				type =  form
				form = Data_Sales
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											mapp = Map();
										mapp.put("date",zoho.currentdate.toString("yyyy-MM-dd"));
										mapp.put("from_warehouse_id",1243157000002593007);
										mapp.put("to_warehouse_id",1243157000000163010);
										line_items = List();
										line_item = Map();
										line_item.put("item_id",input.Zoho_Books_Item_ID);
										line_item.put("name",input.Zoho_Books_Item_Name);
										// line_item.put("description","Laptop - Testing Serial Number");
										line_item.put("quantity_transfer",1);
										line_item.put("serial_numbers",{input.Tag_Number});
										line_item.put("unit","qty");
										line_items.add(line_item);
										mapp.put("line_items",line_items);
										transfer_order = invokeurl
										[
											url :"https://www.zohoapis.in/inventory/v1/transferorders?organization_id=60020430422"
											type :POST
											parameters:mapp.toString()
											connection:"zoho_books"
										];
										info transfer_order;
						)
					}
				}

			}
