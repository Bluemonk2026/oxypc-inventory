				 void Test_Generateion()
                 {
                 	get_rec = Copy_of_Classifications_of_Make_and_Model[ID != null];
                 	for each  rec in get_rec
                 	{
                 		get_make = Make[Make == rec.Make];
                 		get_model = Model[Make == get_make.ID && Model == rec.Model];
                 		get_cpu = CPU_Master[Make == get_model.Make && Model == get_model.ID && CPU == rec.CPU];
                 		if(get_cpu.Make != null && get_cpu.Model != null && get_cpu.ID != null)
                 		{
                 			resp = insert into Classifications_of_Make_and_Model
                 			[
                 				Added_User=zoho.loginuser
                 				Make=get_cpu.Make
                 				Model=get_cpu.Model
                 				CPU=get_cpu.ID
                 				Generation=rec.Generation
                 			];
                 		}
                 	}
                 }
