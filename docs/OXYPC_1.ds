					on click
					(
						View Record   	   
    				)
					on right click
					(
						Edit   	   
						Delete   	   
						Duplicate   	   
						View Record   	   
    				)
     			)
			)
			detailview
			(
				layout
				(
		 			type = 1
					datablock1
					(
						layout type = -2
						fields
						(
							Tag_No as "Tag No."
							Final_Status as "Final Status"
							Faults
							Make
							Model
							CPU
							Generation
							HDD
							RAM
							Date_field as "Date"
							Time
