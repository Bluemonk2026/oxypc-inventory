	section IQC1
	{
		displayname= "IQC"
		icon = "tech-ram"
		page IQC_format_for_laptop1
		{
			displayname = "IQC format for laptop"
			icon = "tech-ram"
			hide =  true
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet3' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet3()\ncontent\n&lt;%{\n\tAdded_User = thisapp.permissions.loginUserName();\n\t%&gt;\n&lt;!DOCTYPE html&gt;\n&lt;html lang=&quot;en&quot;&gt;\n&lt;head&gt;\n    &lt;meta charset=&quot;UTF-8&quot;&gt;\n    &lt;meta name=&quot;viewport&quot; content=&quot;width=device-width, initial-scale=1.0&quot;&gt;\n    &lt;title&gt;Document&lt;\/title&gt;\n    &lt;style&gt;\n\n        body{\n    font-family: &apos;Roboto&apos;,sans-serif;\n    \/* font-size: 25px;  *\/\n    background: black;\n}\np{\n    background-color: white;\n    display:inline-flex;\n    align-items: center;\n    justify-items: center;\n    margin: 0px;\n    width: 200px;\n    height: 70px;\n    font-size: 50px;\n}\n.img{\n    \/* display: flex;\n    margin: 4px 400px 20px;\n    position:relative;\n    left: 210px; *\/\n    float: right;\n    \/* background-color: red; *\/\n    \/* transition-delay: 5s; *\/\n    animation:colorAnimate  700s normal;\n    \n}\n\/* .img:hover{\n     transition-delay:300s;\n    background: red;\n    \n} *\/\n@keyframes  colorAnimate{\n    from{\n        background-color:white;\n    }\n    to{\n        background-color: red;\n    }\n\n}\n\n\n    &lt;\/style&gt;\n&lt;\/head&gt;\n&lt;body&gt;\n    &lt;!-- &lt;iframe src=&quot;https:\/\/workdrive.zohopublic.in\/embed\/cbb201148e450fcc04511817b718d77daa0cb?toolbar=false&amp;appearance=light&amp;themecolor=green&quot; scrolling=&quot;no&quot; frameborder=&quot;0&quot; allowfullscreen=true width=&quot;100&quot; height=&quot;520&quot; &gt;&lt;\/iframe&gt; --&gt;\n   &lt;!-- &lt;p id=&quot;countdown&quot;&gt;5:00&lt;\/p&gt; --&gt;\n   &lt;div class=&quot;img&quot;&gt;\n   &lt;img src=&quot;https:\/\/timertopia.files.wordpress.com\/2017\/04\/5-minute.gif&quot; height=&quot;90px&quot; alt=&quot;Error&quot;&gt;&lt;\/div&gt;\n    &lt;!-- &lt;script&gt;\n        const startingMinutes =5;\nlet time = startingMinutes *60;\n\nconst countdownEl = document.getElementById(&apos;countdown&apos;);\n setInterval(updateCountdown,1000);\n \nfunction updateCountdown(){\n    const minutes = Math.floor(time\/60);\n    let seconds = time%60;\n    seconds = seconds &lt;5?&apos;0&apos;+ seconds : seconds;\n    countdownEl.innerHTML = `${minutes}:${seconds}`;\n    time--;\n}\n    &lt;\/script&gt; --&gt;\n&lt;\/body&gt;\n&lt;\/html&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row><row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<form \n\telementName=\"Form\"\n\n\tappLinkName = 'thisapp'\n\tlinkName = 'IQC_Format_for_Laptop'\n\theightType = 'auto'\n\turlType = 'none'\n\tzc_Header = 'false'\n\/> \n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		form IQC_Format_for_Laptop
