			Test_delete_after_copying as "Test-delete after copying data"
			{
				type =  form
				form = IQC_Format_for_Laptop
				record event = on edit
					status = inactive

				on update of checkbox1
				{
					actions 
					{
						custom deluge script
						(
											mapp = Map();
										mapp.put("LOT_No",input.LOT_No2.LOT_No);
										mapp.put("Tag_No2",input.TAG_NO);
										mapp.put("Make",input.Make.Make);
										mapp.put("Model",input.Model1.Model);
										mapp.put("CPU",input.CPU1.CPU);
										mapp.put("Generation",input.Generation1.Generation);
										mapp.put("Model_Description",input.Model_Description1);
										mapp.put("Product_Type","Laptop");
										if(input.ALL_OK == "Yes")
										{
											mapp.put("Product_Category","OK");
										}
										else if(input.ALL_OK == "No")
