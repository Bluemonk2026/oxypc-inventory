	section Category_Sub_Category_for_GRN
	{
		displayname= "Category & Sub-Category for GRN"
		icon = "education-book-open"
		form Product_Master
		{
			displayname = "Categories for Items GRN"
			success message = "Product Master Added Successfully"
			field alignment = left
					hide = true
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			Item_Name23
			(
    			type = text
				displayname = "Category"
	 			row = 1
	 			column = 1   
				width = medium
			)
			HSN_Code
			(
    			type = text
				displayname = "HSN Code"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			customize
			(
				icon = "sport-crown"
			)
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
