			Add_record_to_Product_Mas as "Add record to Product Master"
			{
				type =  form
				form = IQC_Format_for_TFT
				record event = on add
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											recs = Product_Master_Inventory1[LOT_No == input.Lot_No1.LOT_No && Product_Category2 == "TFT" && Tag_No2 == "" || Tag_No2 == null];
										if(recs.count() != 0)
										{
											recs.Tag_No2=input.TAG;
											recs.IQC_Submitted="Submitted";
											recs.Make=input.Make;
											recs.Screen_Size1=input.Screen_Size;
											recs.Screen_Type=input.Screen_Type;
											// 	recs.Power=input.Power;
											// 	recs.Power_Button=input.Power_Button;
											// 	recs.Menu_Button=input.Menu_Button;
											// 	recs.VGA_Port=input.VGA_Port;
											// 	recs.HDMI_Port=input.HDMI_Port;
											// 	recs.Status=input.Status;
											recs.Remarks=input.Remarks;
											// 	recs.DP_Port=input.DP_Port;
											// 	recs.USB_Port=input.USB_Port;
											// 	recs.DVI_Port=input.DVI_Port;
											recs.Product_Category2="TFT";
											recs.Product_Sub_Category="TFT";
											recs.Product_Stages="IQC Completed";
										}
										else
										{
											mapp = Map();
											mapp.put("TFT_Make",input.Make);
											mapp.put("LOT_No",input.Lot_No1.LOT_No);
											mapp.put("Tag_No2",input.TAG);
											mapp.put("IQC_Submitted","Submitted");
											mapp.put("Screen_Size1",input.Screen_Size);
											// 	mapp.put("Screen_Status",input.Screen_Status);
											mapp.put("Screen_Type",input.Screen_Type);
											// 	mapp.put("Power",input.Power);
											// 	mapp.put("Power_Button",input.Power_Button);
											// 	mapp.put("Menu_Button",input.Menu_Button);
											// 	mapp.put("VGA_Port",input.VGA_Port);
											// 	mapp.put("HDMI_Port",input.HDMI_Port);
											// 	mapp.put("Status",input.Status);
											mapp.put("Remarks",input.Remarks);
											// 	mapp.put("DP_Port",input.DP_Port);
											// 	mapp.put("USB_Port",input.USB_Port);
											// 	mapp.put("DVI_Port",input.DVI_Port);
											mapp.put("Product_Category2","TFT");
											mapp.put("Product_Sub_Category","TFT");
											mapp.put("Product_Stages","IQC Completed");
											mapp1 = Map();
											info zoho.creator.createRecord("protaiga","oxypc-1","Product_Master_Inventory1",mapp,mapp1,"creator");
										}
						)
					}
				}

			}
