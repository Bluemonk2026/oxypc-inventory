			Show_status as "Show status"
			{
				type =  form
				form = Final_QC_for_Engineer
				record event = on add

				on user input of Final_Status
				{
					actions 
					{
						custom deluge script
						(
											if(input.Final_Status == "Fail")
										{
											show Faults;
										}
										else
										{
											hide Faults;
											input.Faults = "";
										}
						)
					}
				}

			}
			Update_SOH_in_Spare_Part_ as "Update SOH in Spare Part Planning"
			{
				type =  form
				form = Spare_Parts
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											Spare_part_Make = input.Make.Make;
										Spare_part_Model = input.Model.Model;
										Spare_part_Name = input.Spare_Part_Name;
										Spare_Part_Planning_Data = Spare_Part_Planning[Make = Spare_part_Make && Model == Spare_part_Model];
										if(input.Spare_Part_Name.toLowerCase() == "panel")
										{
											Spare_Part_Planning_Data.Panel_SOH=input.Available_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "wifi")
										{
											Spare_Part_Planning_Data.Wifi_SOH=input.Available_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "web cam")
										{
											Spare_Part_Planning_Data.Web_Cam_SOH=input.Available_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "usb card")
										{
											Spare_Part_Planning_Data.USB_SOH=input.Available_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "touchpad")
										{
											Spare_Part_Planning_Data.Touch_Pad_SOH=input.Available_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "screen faulty" || input.Spare_Part_Name.toLowerCase() == "screen 30 pin" || input.Spare_Part_Name.toLowerCase() == "screen")
										{
											Spare_Part_Planning_Data.Screen_SOH=input.Available_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "ram cover")
										{
											Spare_Part_Planning_Data.RAM_Cover_SOH=input.Available_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "ram")
										{
											Spare_Part_Planning_Data.RAM_SOH=input.Available_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "logic card")
										{
											Spare_Part_Planning_Data.Logic_Card_SOH=input.Available_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "keyboard")
										{
											Spare_Part_Planning_Data.Keyboard_SOH=input.Available_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "hinge cover")
										{
											Spare_Part_Planning_Data.Hinge_Cover_SOH=input.Available_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "hinge")
										{
											Spare_Part_Planning_Data.Hinge_SOH=input.Available_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "hdd cover")
										{
											Spare_Part_Planning_Data.HDD_Cover_SOH=input.Available_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "hdd connector")
										{
											Spare_Part_Planning_Data.HDD_Connector_SOH=input.Available_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "hdd")
										{
											Spare_Part_Planning_Data.HDD_SOH=input.Available_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "dvd flap")
										{
											Spare_Part_Planning_Data.DVD_Flap_SOH=input.Available_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "base")
										{
											Spare_Part_Planning_Data.Base_SOH=input.Available_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "battery cable")
										{
											Spare_Part_Planning_Data.Battery_Cable_SOH=input.Available_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "battery")
										{
											Spare_Part_Planning_Data.Battery_SOH=input.Available_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "base")
										{
											Spare_Part_Planning_Data.Base_SOH=input.Available_SOH;
										}
						)
					}
				}

			}
