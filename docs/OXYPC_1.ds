			Update_GRN_inventory as "Update GRN inventory"
			{
				type =  schedule
				start = "2024-08-20 15:50:13"
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						grn_rec = GRN[Invoice_Number == "DWM2425/124I0272"];
										for each  i in grn_rec.Item
										{
											if(i.Tag_Numbers != null)
											{
												newline = hextotext("0A");
												for each  j in i.Tag_Numbers.toList(newline)
												{
