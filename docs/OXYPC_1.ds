			Add_to_Presales_qc as "Add to Presales qc"
			{
				type =  form
				form = Final_QC1
				record event = on add or edit
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Final_Status == "Pass")
										{
											PreSalesQC_rec = PreSales_QC[Tag_Number == input.Tag_Number];
											if(PreSalesQC_rec.count() != 0)
											{
												if(input.Updated_Make != null)
												{
													PreSalesQC_rec.Make=input.Updated_Make.Make;
												}
												else if(input.Updated_Make == null)
												{
													PreSalesQC_rec.Make=input.Make;
												}
												if(input.Updated_Model != null)
												{
													PreSalesQC_rec.Model=input.Updated_Model.Model;
												}
												else if(input.Updated_Model == null)
												{
													PreSalesQC_rec.Model=input.Model;
												}
												if(input.Update_CPU1 != "")
												{
													PreSalesQC_rec.CPU=input.Update_CPU1;
												}
												else if(input.Update_CPU1 == "")
												{
													PreSalesQC_rec.CPU=input.CPU;
												}
												if(input.Updated_Generation != "")
												{
													PreSalesQC_rec.Generation=input.Updated_Generation;
												}
												else if(input.Updated_Generation == "")
												{
													PreSalesQC_rec.Generation=input.Generation;
												}
												if(input.Updated_HDD != "")
												{
													PreSalesQC_rec.HDD=input.Updated_HDD;
												}
												else if(input.Updated_HDD == "")
												{
													PreSalesQC_rec.HDD=input.HDD;
												}
												if(input.Updated_RAM != "")
												{
													PreSalesQC_rec.RAM=input.Updated_RAM;
												}
												else if(input.Updated_RAM == "")
												{
													PreSalesQC_rec.RAM=input.RAM;
												}
											}
											else
											{
												mapp = Map();
												mapp.put("Tag_Number",input.Tag_Number);
												if(input.Updated_Make != null)
												{
													mapp.put("Make",input.Updated_Make.Make);
												}
												else if(input.Updated_Make == null)
												{
													mapp.put("Make",input.Make);
												}
												if(input.Updated_Model != null)
												{
													mapp.put("Model",input.Updated_Model.Model);
												}
												else if(input.Updated_Model == null)
												{
													mapp.put("Model",input.Model);
												}
												if(input.Update_CPU1 != "")
												{
													mapp.put("CPU",input.Update_CPU1);
												}
												else if(input.Update_CPU1 == "")
												{
													mapp.put("CPU",input.CPU);
												}
												if(input.Updated_Generation != "")
												{
													mapp.put("Generation",input.Updated_Generation);
												}
												else if(input.Updated_Generation == "")
												{
													mapp.put("Generation",input.Generation);
												}
												if(input.Updated_HDD != "")
												{
													mapp.put("HDD",input.Updated_HDD);
												}
												else if(input.Updated_HDD == "")
												{
													mapp.put("HDD",input.HDD);
												}
												if(input.Updated_RAM != "")
												{
													mapp.put("RAM",input.Updated_RAM);
												}
												else if(input.Updated_RAM == "")
												{
													mapp.put("RAM",input.RAM);
												}
												mapp.put("Final_Status","On Hold");
												mapp1 = Map();
												creating_record = zoho.creator.createRecord("protaiga","oxypc-1","PreSales_QC",mapp,mapp1,"creator");
												sendmail
												[
													from :zoho.loginuserid
													to :"shubham.oxypc@gmail.com"
													subject :"Presalesqc record"
													message :"Presaled QC create record= " + creating_record
												]
												info creating_record;
											}
										}
						)
					}
				}

			}
			creating_product_full_nam as "creating product full name"
			{
				type =  form
				form = PreSales_QC
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Updated_Make != null)
										{
											mke = input.Updated_Make.Make;
										}
										else
										{
											mke = input.Make;
										}
										if(input.Updated_Model != null)
										{
											mdl = input.Updated_Model.Model;
										}
										else
										{
											mdl = input.Model;
