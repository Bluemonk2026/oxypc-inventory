			Update_Production_Tracker9 as "Update Production Tracker"
			{
				type =  form
				form = Amazon_Assignment_Screen
				record event = on add
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											fgh = Cleaning[ID == input.ID];
										User = fgh.Added_User;
										info User;
										Today_Production_Tracker = Production_Tracker[Engineer_Name == User.toString() && Date_field == zoho.currentdate];
										Tracker_Size = Today_Production_Tracker.count();
										info Tracker_Size;
										if(Tracker_Size == 0)
										{
											Create_map = Map();
											Create_map.put("IQC_Completed",0);
											Create_map.put("Date_field",zoho.currentdate.toString("dd-MMM-yyyy"));
											Create_map.put("L1_L2",0);
											Create_map.put("L3_L4",0);
											Create_map.put("L4_Support",0);
											Create_map.put("Final_QC",0);
											Create_map.put("Cleaning",1);
											Create_map.put("Painting",0);
											Create_map.put("Engineer_Name",User);
											empty_map = Map();
											Create_record = zoho.creator.createRecord("protaiga","oxypc-1","Production_Tracker",Create_map,empty_map,"creator");
											info Create_record;
											info "testing";
										}
										else
										{
											Today_Production_Count = Production_Tracker[Engineer_Name == User.toString() && Date_field == zoho.currentdate];
											Cleaning_count = Today_Production_Count.Cleaning;
											Today_Production_Count.Cleaning=Cleaning_count.toNumber() + 1;
											info "testing2";
										}
						)
					}
				}

			}
