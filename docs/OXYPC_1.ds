											else
											{
												input.HDD = final_qc.Updated_HDD;
											}
											// 	#################-----------CPU--------
											if(final_qc.Update_CPU1 == "" || final_qc.Update_CPU1 == null)
											{
												input.CPU = final_qc.CPU;
											}
											else
											{
												input.CPU = final_qc.Update_CPU1;
											}
											// 	#################-----------GEN--------
											if(final_qc.Updated_Generation == "" || final_qc.Updated_Generation == null)
											{
												input.Generation = final_qc.Generation;
											}
											else
											{
												input.Generation = final_qc.Updated_Generation;
											}
											// 	#################-----------Make--------
											if(final_qc.Updated_Make == null)
											{
												input.Make = final_qc.Make;
											}
											else
											{
												input.Make = final_qc.Updated_Make.Make;
											}
											// 	#################-----------Model--------
											if(final_qc.Updated_Model == null)
