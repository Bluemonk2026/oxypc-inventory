   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		default list Final_QC_for_Engineer_Report
		{
			displayName = "QC for Engineer Report"
