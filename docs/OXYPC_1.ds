			Show_IQC_Laptop_Form as "Show_IQC_Laptop_Form"
			{
				type =  form
				form = IQC
				record event = on add or edit

				on user input of Location
				{
					actions 
					{
						custom deluge script
						(
											if(IQC_for == "Laptop")
										{
											if(Location != null && Location == "Manesar")
											{
												openUrl("#Form:IQC_Format_for_Laptop" + "?Location=Manesar&Sub_Category=164568000000714151","same window");
											}
											else if(Location != null && Location == "TRC 2ND Floor")
											{
												openUrl("#Form:IQC_Format_for_Laptop" + "?Location=BMH&Sub_Category=164568000000714151","same window");
											}
										}
										if(IQC_for == "Desktop")
										{
											if(Location != null && Location == "Manesar")
											{
												openUrl("#Form:IQC_Format_for_Desktop" + "?Location=Manesar","same window");
											}
											else if(Location != null && Location == "TRC 2ND Floor")
											{
												openUrl("#Form:IQC_Format_for_Desktop" + "?Location=BMH","same window");
											}
										}
										if(IQC_for == "TFT")
										{
											if(Location != null && Location == "Manesar")
											{
												openUrl("#Form:IQC_Format_for_TFT" + "?Location=Manesar","same window");
											}
											else if(Location != null && Location == "TRC 2ND Floor")
											{
												openUrl("#Form:IQC_Format_for_TFT" + "?Location=BMH","same window");
											}
										}
						)
					}
				}

			}
