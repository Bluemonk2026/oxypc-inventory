						custom deluge script
						(
											if(input.RAM_Status == "Upgraded")
										{
											if(input.Action_Taken_RAM1 == "")
											{
												alert "Please Fill Action Taken(RAM)";
												cancel submit;
											}
											if(input.Action_Taken_RAM1 == "Added" && input.Added_Capacity == "")
											{
												alert "Please Enter the Added Capacity for RAM";
												cancel submit;
											}
										}
										if(input.RAM_Status == "Downgraded")
										{
											if(input.Action_Taken_RAM == "")
											{
												alert "Please Fill Action Taken(RAM)";
												cancel submit;
											}
											if(input.Action_Taken_RAM == "Removed" && input.Removed_Capacity == "")
											{
												alert "Please Fill Removed RAM Capacity";
												cancel submit;
											}
										}
						)
					}
				}

			}
			update_field_in_engineer_ as "update field in engineer day in form"
