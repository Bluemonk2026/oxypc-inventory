	section L4_Support_Screens
	{
		displayname= "L4 Support Screens"
		icon = "objects-support-17"
		form L4_Support_Screen
		{
			displayname = "L4 Support Screen"
			success message = "L4 Support Screen Added Successfully"
			field alignment = left
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Tag_No
			(
    			type = text
				displayname = "Tag No."
	 			row = 1
	 			column = 1   
				width = medium
			)
			Date_field
			(
    			type = date
				displayname = "Date"
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			LOT_Number
			(
    			type = text
				displayname = "LOT Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Time
			(
    			type = time
				initial value = "${zoho.currenttime}"	
				timedisplayoptions = "hh:mm:ss" 
	 			row = 1
	 			column = 1   
				width = medium
			)
			Make
			(
				type = picklist	
				values  = Make.ID
    			displayformat = [Make]
				searchable = true
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Model
			(
				type = picklist	
				values  = Model.ID
    			displayformat = [Model]
				searchable = true
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			CPU
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			Generation
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			RAM
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			HDD
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Final_Status
			(
				type = picklist
				displayname = "Final Status"
				maxchar = 100
				values = {"Motherboard (Ok)","Scrap","Escalate to L4"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Fault
			(
				type = picklist
				maxchar = 100
				values = {"No Display","Not ON","Dim Display","On/Off","Hanging","KBD Not Working","Usb Not Working","VGA Port Not Working","HDMI Port Notworking","ON /OFF Switch Issue","KBD Some Key Not Working","Blue Dum Error","Wifi Not Working","Date Time issue","Audio Jack Not Working","Battery Not Charging","Battery Not detect","HDD Not detect","BIOS Password","LAN Port Not Working","T.pad Not Working","Sound issue","Auto Restart/Shut Down","OS Not Installed","C Type Connector Not Working","T.Pad Click Not working","Camera Not working","Microphone Not Working","Ram Slot Not Working","Power Button LED Issue","CPU Fan Error","Other Problem"}
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			customize
			(
				icon = "objects-support-17"
			)
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
