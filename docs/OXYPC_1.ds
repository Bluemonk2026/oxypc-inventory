			Update_values1 as "Update values"
			{
				type =  form
				form = Final_QC1
				record event = on add

				on user input of Tag_Number
				{
					actions 
					{
						custom deluge script
						(
											rec = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(input.Tag_Number)];
										qc_rec = Final_QC_for_Engineer[Tag_No.equalsIgnoreCase(input.Tag_Number)];
										Final_qc = Final_QC1[Tag_Number.equalsIgnoreCase(input.Tag_Number)] sort by Added_Time desc;
										if(Final_qc.count() > 0)
										{
											input.RAM = Final_qc.RAM;
											input.Updated_Make = Final_qc.Updated_Make;
											input.Model = Final_qc.Model;
											input.Zoho_Books_Product_ID = Final_qc.Zoho_Books_Product_ID;
											input.Generation = Final_qc.Generation;
											input.Faults = Final_qc.Faults;
											input.Date_field = Final_qc.Date_field;
											input.Make = Final_qc.Make;
											input.Product_Description = Final_qc.Product_Description;
											input.Updated_RAM = Final_qc.Updated_RAM;
											input.Update_Model = Final_qc.Update_Model;
											input.Updated_Model = Final_qc.Updated_Model;
											input.Need_to_Update_RAM = Final_qc.Need_to_Update_RAM;
											input.Update_CPU1 = Final_qc.Update_CPU1;
											input.Update_Generation = Final_qc.Update_Generation;
											input.Serial_Number = Final_qc.Serial_Number;
											input.Remarks = Final_qc.Remarks;
											input.Need_to_Update_HDD = Final_qc.Need_to_Update_HDD;
											input.Updated_HDD = Final_qc.Updated_HDD;
											input.Update_Make = Final_qc.Update_Make;
											input.LOT_Number = Final_qc.LOT_Number;
											input.Time = Final_qc.Time;
											input.CPU = Final_qc.CPU;
											input.HDD = Final_qc.HDD;
											input.Failure_Reason = Final_qc.Failure_Reason;
											input.Category = Final_qc.Category;
											input.Warehouse = Final_qc.Warehouse;
											input.Updated_Generation = Final_qc.Updated_Generation;
											input.Update_CPU = Final_qc.Update_CPU;
										}
										//Change Warehouse on rejection of Final QC from showroom
										//Update record on tag number scan, whether its fail or pass
										//All Product Master Inventory
										else
										{
											if(qc_rec.count() != 0)
											{
												info qc_rec.Category;
												input.Serial_Number = qc_rec.Serial_Number;
												input.LOT_Number = qc_rec.LOT_Number;
												input.Category = qc_rec.Category;
												input.Make = qc_rec.Make;
												if(qc_rec.Category == "Laptop" || qc_rec.Category == "Desktop" || qc_rec.Category == null)
												{
													info "in empty vala loop";
													input.Model = qc_rec.Model;
													input.CPU = qc_rec.CPU;
													input.Generation = qc_rec.Generation;
													info qc_rec.RAM;
													info qc_rec.HDD;
													if(qc_rec.RAM != null)
													{
														input.RAM = qc_rec.RAM.remove(" ");
													}
													if(qc_rec.HDD != null)
													{
														input.HDD = qc_rec.HDD;
													}
												}
												else if(qc_rec.Category == "TFT")
												{
													input.Make = rec.Make;
													input.LOT_Number = qc_rec.LOT_Number;
													hide Model;
													hide CPU;
													hide Generation;
													hide Update_Model;
													hide Update_CPU1;
													hide Update_Generation;
													// 	hide Updated_CPU1;
													hide Updated_Generation;
													hide Updated_Model;
													hide Update_CPU;
													hide HDD;
													hide RAM;
												}
											}
											else if(qc_rec.count() == 0)
											{
												input.Serial_Number = rec.Serial_No;
												input.Category = rec.Product_Category2;
												if(rec.Product_Category2 == "Desktop")
												{
													// 			make_id = rec.Desktop.Make;
													// 			make_rec = Make_for_Desktop[ID == make_id];
													input.Make = rec.Make;
													// 			model_id = rec.Desktop.Model;
													// 			model_rec = Model_for_Desktop[ID == model_id];
													input.Model = rec.Model;
													input.LOT_Number = rec.LOT_No;
													input.CPU = rec.CPU;
													input.Generation = rec.Generation;
													input.RAM = rec.RAM.remove(" ");
												}
												else if(rec.Product_Category2 == "Laptop")
												{
													input.Make = rec.Make;
													input.Model = rec.Model;
													input.Generation = rec.Generation;
													input.CPU = rec.CPU;
													input.RAM = rec.RAM.remove(" ");
													input.Generation = rec.Generation;
													input.LOT_Number = rec.LOT_No;
													input.HDD = rec.HDD;
													input.CPU = rec.CPU;
												}
												else if(rec.Product_Category2 == "TFT")
												{
													input.Make = rec.Make;
													input.LOT_Number = rec.LOT_No;
													hide Model;
													hide CPU;
													hide Generation;
													hide Update_Model;
													hide Update_CPU1;
													hide Update_Generation;
													// 	hide Updated_CPU1;
													hide Updated_Generation;
													hide Updated_Model;
													hide Update_CPU;
													hide HDD;
													hide RAM;
												}
											}
										}
						)
					}
				}

			}
