				 void Assign_L4_Support_after_IQC(IQC_Format_for_Laptop iqc_laptop)
                 {
                 	lst = list();
                 	for each  i in iqc_laptop
                 	{
                 		if(i.Assign_Status == "Not Assigned" || i.Assign_Status == "" || i.Assign_Status == null)
                 		{
                 			lst.add(i.TAG_NO);
                 		}
                 		else if(i.Assign_Status == "Assigned")
                 		{
                 			info "Laptop Already Assigned";
                 		}
                 	}
                 	info lst;
                 	if(lst.size() != 0)
                 	{
                 		openUrl("#Form:L4_Support_Pending_Bucket?Make=" + iqc_laptop.Make.Make + "&IQC_Ids1=" + lst + "","popup window","height=500,width=500");
                 	}
                 }
