				type = radiobuttons
				maxchar = 100
				values = {"Power On","No Power/Power Cut(Motherboard)","Ok","BER","Scrap","No Display"}
				layout = 2
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Grade
			(
				type = radiobuttons
				maxchar = 100
				values = {"A","B","C","D","E"}
				layout = 3
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Location
			(
				type = picklist
				maxchar = 100
				values = {"Manesar","BMH"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Serial_No
			(
    			type = text
				displayname = "Serial No"
				qrcode = true
				barcode = true
				camera = primary
				show gallery = true
				switch camera = true
    			description
    			[
    				type = help_text
    			 	message = "Please enter NA if no serial number available"
    			]
	 			row = 1
	 			column = 2   
				width = small
			)
			must have Make
			(
				type = radiobuttons	
				values  = Make.ID
    			displayformat = [Make]
				sortorder = ascending
				layout = 3
	 			row = 1
	 			column = 2   
				width = small
			)
			Time
			(
    			type = time
				initial value = "${zoho.currenttime}"	
				timedisplayoptions = "hh:mm:ss" 
