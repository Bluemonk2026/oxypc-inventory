			Update_data as "Update data"
			{
				type =  form
				form = Painting
				record event = on add or edit

				on user input of Tag_No
				{
					actions  (Tag_No is not null)
					{
						custom deluge script
						(
											if(input.Tag_No != null || input.Tag_No != "")
										{
											cleaning_recs = Masking[Tag_No.equalsIgnoreCase(input.Tag_No)];
											if(input.Tag_No != "" && cleaning_recs.count() == 0)
											{
												alert "Masking Not Done for this Laptop";
												input.Tag_No = "";
											}
											else
											{
												input.Make = cleaning_recs.Make;
												input.Model = cleaning_recs.Model;
												input.CPU = cleaning_recs.CPU;
												input.Generation = cleaning_recs.Generation;
												input.Lot_Number = cleaning_recs.LOT_Number;
												input.RAM1 = cleaning_recs.RAM;
												input.HDD = cleaning_recs.HDD;
												input.Cleaning_Completion_Date = cleaning_recs.QC_Completion_Date;
												input.Cleaning_Engineer = cleaning_recs.Added_User;
												input.Serial_Number = cleaning_recs.Serial_Number;
											}
										}
						)
					}
				}

			}
