			Fill_details_of_the_produ as "Fill details of the product"
			{
				type =  form
				form = Cleaning
				record event = on add or edit

				on user input of Tag_No
				{
					actions 
					{
						custom deluge script
						(
											if(input.Tag_No != "")
										{
											qc_rec = Final_QC_for_Engineer[Tag_No.equalsIgnoreCase(input.Tag_No)] sort by Added_Time desc;
											clean_assgn = Cleaning_Assignment[Tag_No.equalsIgnoreCase(input.Tag_No)];
											info qc_rec.count();
											final_qc = Final_QC1[Tag_Number.equalsIgnoreCase(input.Tag_No)];
											// 	if(final_qc.count() > 0)
											// 	{
											// 		status = final_qc.Final_Status;
											// 		if(status == "Fail" && qc_rec.Final_Status == "Fail")
											// 		{
											// 			alert "This Laptop got Failed at Final QC and assigned to L1/L2";
											// 			input.Tag_No = "";
											// 		}
											// // 	}
											if(qc_rec.count() == 0)
											{
												// 		alert "QC Not Done for this Laptop!";
												// 		input.Tag_No = "";
											}
											else
											{
												if(clean_assgn.count() > 0)
												{
													input.Make = qc_rec.Make;
													input.Model = qc_rec.Model;
													input.RAM = qc_rec.RAM;
													input.HDD = qc_rec.HDD;
													input.CPU = qc_rec.CPU;
													input.LOT_Number = qc_rec.LOT_Number;
													input.Generation = qc_rec.Generation;
													input.Category = qc_rec.Category;
													input.Engineer_Name = qc_rec.Added_User;
													input.QC_Completion_Date = qc_rec.QC_Completion_Date;
													input.Serial_Number = qc_rec.Serial_Number;
												}
												else
												{
													// 			alert "Laptop is not Assigned to Cleaning and Pending in QC!!";
													// 			input.Tag_No = "";
												}
											}
										}
						)
					}
				}

			}
