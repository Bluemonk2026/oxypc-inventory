			Take_Lot_Number_from_tag_ as "Take Lot Number from tag number"
			{
				type =  form
				form = IQC_Format_for_TFT
				record event = on add or edit

				on user input of TAG
				{
					actions 
					{
						custom deluge script
						(
											if(input.TAG != "" || input.TAG != null)
										{
											if(input.TAG.startswith("SN") || input.TAG.startswith("sn"))
											{
												enable Lot_No1;
											}
											else
											{
												lot_num = input.TAG.subtext(0,4);
												info lot_num;
												lot_num_rec = LOT_No_s_GRN[LOT_No == lot_num];
												if(lot_num_rec.count() == 0)
												{
													mapp = Map();
													mapp.put("LOT_No",lot_num);
													empty_mapp = Map();
													record_create = zoho.creator.createRecord("protaiga","oxypc-1","LOT_No_s_GRN",mapp,empty_mapp,"creator");
													info record_create;
													if(record_create.get("code") == "3000")
													{
														input.Lot_No1 = record_create.get("data").get("ID");
													}
												}
												else
												{
													input.Lot_No1 = lot_num_rec.ID;
													disable Lot_No1;
												}
											}
										}
						)
					}
				}

			}
