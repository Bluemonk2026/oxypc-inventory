			Make_Field_Mandatory as "Make Field Mandatory"
			{
				type =  form
				form = Battery_Repair
				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.Repairable == "No" && input.Not_Repairable_reason == null)
										{
											alert "Please Mention Non-Repairable Reason";
											cancel submit;
										}
										if(input.Action_Taken == "New Cell Change" && input.Cell_Capacity1 == null)
										{
											alert "Please Fill the Cell Capacity";
											cancel submit;
										}
										if(input.Repairable == "Yes")
										{
											if(input.Battery_Backup == null)
											{
												alert "Please Fill Battery Backup";
												cancel submit;
											}
											if(input.Action_Taken == null)
											{
												alert "Please Fill Action Taken";
												cancel submit;
											}
											if(input.Health == null)
											{
												alert "Please Fill Health %";
												cancel submit;
											}
										}
						)
					}
				}

			}
