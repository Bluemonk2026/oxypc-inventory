			Show_error_if_qc_fail as "Show error if qc fail"
			{
				type =  form
				form = Cleaning
				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.Tag_No != "")
										{
											qc_rec = Final_QC_for_Engineer[Tag_No.equalsIgnoreCase(input.Tag_No)] sort by Modified_Time desc;
											clean_ass = Cleaning_Assignment[Tag_No.equalsIgnoreCase(input.Tag_No)] sort by Modified_Time desc;
											if(qc_rec.count() == 0)
											{
												newLine = hexToText("0A");
												alert "Warning: QC not done for this Laptop" + newLine + "चेतावनी: इस लैपटॉप के लिए QC नहीं किया गया है";
												cancel submit;
												// 	alert "Warning: QC not done for this Laptop";
											}
											else
											{
												if(qc_rec.Final_Status == "Fail")
												{
													alert "Warning: QC is Fail for this Laptop";
													cancel submit;
												}
												if(clean_ass.count() == 0)
												{
													alert "Warning: Product is not assigned for Cleaning and Pending in QC";
													cancel submit;
												}
											}
										}
						)
					}
				}

			}
