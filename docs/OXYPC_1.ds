			Spare_part_inventory as "Spare part inventory"
			{
				type =  form
				form = Spare_Parts_GRN
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											Spare_Part_GRN_Data = Spare_Part_GRN[ID == input.ID];
										info Spare_Part_GRN_Data;
										Spare_Part_Items = Spare_Part_GRN_Data.Items;
										for each  Spare_Part_Item in Spare_Part_Items
										{
											Make_Data = Make_Spare_Part[ID = Spare_Part_Item.Make1];
											Model_Data = Model_Spare_Part[ID = Spare_Part_Item.Model];
											Spare_Part = Spare_Parts2[ID = Spare_Part_Item.Spare_Part_Name];
											Spare_Part_Master = Spare_Parts[Make == Make_Data.ID && Model == Model_Data.ID && Spare_Part_Name == Spare_Part.Spare_Part_Name];
											info Spare_Part_Master;
											Available_SOH1 = Spare_Part_Master.Available_SOH;
											info "out of the condition";
											if(Available_SOH1 == null)
											{
												Available_SOH1 = 0;
											}
											else
											{
												Available_SOH1 = Spare_Part_Master.Available_SOH;
												info "out of the condition";
											}
											Spare_Part_Master.Available_SOH=Available_SOH1 + Spare_Part_Item.Physical_Quantity.toLong();
											Spare_Part_Master.Rate_New=Spare_Part_Item.Price;
											info Spare_Part_Item.Physical_Quantity;
											info Available_SOH1;
											sendmail
											[
												from :zoho.adminuserid
												to :"shubham.namdev@crm-masters.com"
												subject :"Spare Part GRN Form"
												message :"Available_SOH1" + Available_SOH1
											]
										}
						)
					}
				}

			}
			Tag_No_Digit_size as "Tag No. Digit size"
			{
				type =  form
				form = Final_QC_for_Engineer
				record event = on add or edit
					status = inactive

				on user input of Tag_No
				{
					actions 
					{
						custom deluge script
						(
											if(input.Tag_No.length() > 10 || input.Tag_No.contains("O") || input.Tag_No.contains("o"))
										{
											alert "Please Enter Valid Tag Number";
											input.Tag_No = "";
										}
										qc_rec = Final_QC_for_Engineer[Tag_No.equalsIgnoreCase(input.Tag_No)];
										if(qc_rec.count() > 0)
										{
											if(qc_rec.Final_Status == "Pass")
											{
												alert "Laptop Already got Passed";
												input.Tag_No = "";
											}
										}
						)
					}
				}

			}
