			Change_status_in_L1_L2_as as "Change status in L1/L2 assignment Screen"
			{
				type =  form
				form = L1_L2_Engineer_Screen
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Final_Status.equalsIgnoreCase("Completed"))
										{
											rec = L1_L2_Assignment_Screen[Tag_No.equalsIgnoreCase(input.Barcode)];
											if(rec.count() > 0)
											{
												rec.Status="Repaired";
											}
										}
										else
										{
											rec = L1_L2_Assignment_Screen[Tag_No.equalsIgnoreCase(input.Barcode)];
											if(rec.count() > 0)
											{
												rec.Status="Pending";
											}
										}
						)
					}
				}

			}
			Update_Product_inventory_ as "Update Product inventory Status as Sold"
			{
				type =  form
				form = Sales_Form
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											// // for each  data_item in Line_Items
										// // {
										// // 	
										// // 	result.Product_Stages="Sold Out";
										// // 	result.Product_Category="Sold Out";
										// // 	presales_record = PreSales_QC[Tag_Number == tagnumber];
										// // 	presales_record.Product_Stage="Sold Out";
										// // }
										// count = 0;
										// // list_data = List();
										// for each  rex1 in Line_Items
										// {
										// 	comma_smb = hextotext("2C");
										// 	list_data = List();
										// 	for each  i in rex1.Tag_Numbers.toList(comma_smb)
										// 	{
										// 		//update status in Product Master inventory 
										// 		result = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(i.trim())];
										// 		result.Product_Stages="Sold Out";
										// 		result.Product_Category="Sold Out";
										// 		result.Invoice_Number=input.Invoice_Number;
										// 		result.Invoice_Date=input.Invoice_Date;
										// 		result.Sales_Person_Name=input.Sales_Person_Name;
										// 		//result.Customer_location= input.Customer_location;
										// 		//Update status in Presales QC
										// 		presales_record = PreSales_QC[Tag_Number.equalsIgnoreCase(i.trim())];
										// 		presales_record.Product_Stage="Sold Out";
										// 	}
										// }
										// info count;
						)
					}
					actions 
					{
						custom deluge script
						(
											// for each  data_item in Line_Items
										// {
										// 	
										// 	result.Product_Stages="Sold Out";
										// 	result.Product_Category="Sold Out";
										// 	presales_record = PreSales_QC[Tag_Number == tagnumber];
										// 	presales_record.Product_Stage="Sold Out";
										// }
										count = 0;
										// list_data = List();
										for each  rex1 in input.Line_Items
										{
											comma_smb = hextotext("2C");
											list_data = List();
											for each  i in rex1.Tag_Numbers.toList(comma_smb)
											{
												//update status in Product Master inventory 
												presales_record = PreSales_QC[Tag_Number.equalsIgnoreCase(i.trim())];
												result = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(i.trim())];
												result.Product_Stages="Sold Out";
												result.Product_Category="Sold Out";
												result.Invoice_Number=input.Invoice_Number;
												result.Invoice_Date=input.Invoice_Date;
												result.Sales_Person_Name=input.Sales_Person_Name;
												// 		Update Make Model Cpu
												// 		re = presales_record.Make;
												if(presales_record.Need_to_Change_Configuration == "No")
												{
													result.Make=presales_record.Make;
													result.Model=presales_record.Model;
													result.CPU=presales_record.CPU;
													result.Generation=presales_record.Generation;
													//New update code for SSD and HDD
													if(result.HDD_Capacity == "" || result.HDD_Capacity == null)
													{
														result.HDD=presales_record.HDD;
													}
													else
													{
														result.HDD_Capacity=presales_record.HDD;
													}
													result.RAM=presales_record.RAM;
												}
												if(presales_record.Need_to_Change_Configuration == "Yes")
												{
													result.Make=ifNull(presales_record.Updated_Make.Make,presales_record.Make);
													result.Model=ifNull(presales_record.Updated_Model.Model,presales_record.Model);
													result.CPU=ifNull(presales_record.Updated_CPU,presales_record.CPU);
													result.Generation=ifNull(presales_record.Updated_Generation,presales_record.Generation);
													//New update code for SSD and HDD
													if(result.HDD_Capacity == "" || result.HDD_Capacity == null)
													{
														result.HDD=ifNull(presales_record.Updated_HDD,presales_record.HDD);
													}
													else
													{
														result.HDD_Capacity=ifNull(presales_record.Updated_HDD,presales_record.HDD);
													}
													//result.HDD=ifNull(presales_record.Updated_HDD,presales_record.HDD);
													result.RAM=ifNull(presales_record.Updated_RAM,presales_record.RAM);
												}
												make_data = ifNull(presales_record.Updated_Make.Make,presales_record.Make);
												Model_data = ifNull(presales_record.Updated_Model.Model,presales_record.Model);
												Cpu_data = ifNull(presales_record.Updated_CPU,presales_record.CPU);
												Generation_data = ifNull(presales_record.Updated_Generation,presales_record.Generation);
												HDD_data = ifNull(presales_record.Updated_HDD,presales_record.HDD);
												RAM_data = ifNull(presales_record.Updated_RAM,presales_record.RAM);
												//result.Customer_location= input.Customer_location;
												//Update status in Presales QC
												presales_record.Product_Stage="Sold Out";
												resx_data = insert into Sales_Form_Booked_Records
												[
													Added_User=zoho.loginuser
													Customer_Name=input.Customer
													Customer_location=input.Customer_location
													Sales_Person_Name=input.Sales_Person_Name
													Invoice_Number=input.Invoice_Number
													Invoice_Date=input.Invoice_Date
													Gate_Pass_Number=input.Gate_Pass_Number
													TCS_Amount=input.TCS_Amount
													Tag_Numbers=i
													Serial_Number=result.Serial_No
													Quantity=1
													Unit_Price_With_Tax=rex1.Taxable_Amount
													Taxable_Amount=rex1.Unit_Price
													Tax_Amount=rex1.Tax_Amount
													Category=rex1.Category
													Make=make_data
													Model=Model_data
													CPU=Cpu_data
													Generation=Generation_data
													HDD=HDD_data
													RAM=RAM_data
													Adapter=presales_record.Adapter
													Battery=presales_record.Battery
													Remarks=input.Remarks
												];
											}
										}
										// info count;
						)
					}
				}

			}
			Fetch_customers_from_Pres1 as "Fetch customers from Presales"
			{
				type =  form
				form = Sales_Form
				record event = on add
					status = inactive

				on load
				{
					actions 
					{
						custom deluge script
						(
											result = PreSales_QC[Customer_Name != null].distinct(Customer_Name);
										// Step 2: Prepare data for dropdown
										dropdownData = List();
										for each  line_item in result
										{
											customerRecord = Customer_Database[ID == line_item];
											if(customerRecord != null)
											{
												dropdownData.add(customerRecord.Customer_Name);
											}
										}
										input.Customer:ui.add(dropdownData);
						)
					}
				}

			}
			Update_Inventory_Status as "Update Inventory Status"
			{
				type =  form
				form = Stock_Transfer_Showroom_to_TRC
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											result = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(input.Tag_Number)];
										result.Warehouse=input.Tranfer_To;
										if(input.Department == "Assign to Lot")
										{
											result.Product_Stages="Assign to Lot";
											result.Product_Category="Lot";
										}
										else if(input.Department == "L1/L2 Engineer")
										{
											result.Product_Stages="Assigned to L1/L2 Engineer";
											result.Product_Category="Repair";
										}
										else if(input.Department == "Cleaning")
										{
											result.Product_Stages="Assigned for Cleaning";
											result.Product_Category="Cleaning";
										}
										else if(input.Department == "Painting")
										{
											result.Product_Stages="Painting";
											result.Product_Category="Paint";
										}
										else if(input.Department == "Assigned to QC")
										{
											result.Product_Stages="Assigned to QC";
											result.Product_Category="QC";
										}
						)
					}
				}

			}
