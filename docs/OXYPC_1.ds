											show Tag_No;
										}
										else
										{
											hide Location;
											hide Tag_No;
										}
										input.Location = stock_audit.Location;
										// info stock_audit.Location;
						)
					}
				}

			}
			Edit_the_old_record as "Edit the old record"
			{
				type =  form
				form = L1_L2_Assignment_Screen
				record event = on add or edit

				on user input of Tag_No
				{
					actions 
					{
						custom deluge script
						(
											if(input.Tag_No != "" || input.Tag_No != null)
										{
											recs = L1_L2_Assignment_Screen[Tag_No.equalsIgnoreCase(input.Tag_No)];
											if(recs.count() == 0)
											{
												// 		
											}
											else
											{
												openurl("https://creator.zoho.in" + zoho.appuri + "L1_L2_Assignment_Screen/record-edit/All_L1_l2_Assignment_Screens/" + recs.ID + "/","same window");
											}
											inv_rec = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(input.Tag_No)];
											input.Make = inv_rec.Make;
											input.Model = inv_rec.Model;
											input.CPU = inv_rec.CPU;
											input.Generation = inv_rec.Generation;
										}
						)
					}
				}

			}
			Open_Form_again as "Open Form again"
			{
				type =  form
				form = L1_L2_Assignment_Screen
				record event = on edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											openUrl("#Form:L1_L2_Assignment_Screen","same window");
						)
					}
