	section Spare_Part_In_Out1
	{
		displayname= "Spare Part In/Out"
		icon = "shopping-tag-sale"
		form Spare_Part_In_Out1
		{
			displayname = "Spare Part In/Out"
			success message = "Data Added Successfully!"
			field alignment = left
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Spare_Part_In_Out
			(
				type = radiobuttons
				displayname = "Spare Part In/Out?"
				maxchar = 100
				values = {"IN","OUT","Transfer"}
				layout = 3
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Make_Spare_Part
			(
				type = picklist	
				displayname = "Make - Spare Part"
				values  = Make_Spare_Part.ID
    			displayformat = [Make]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Part_Type
			(
				type = radiobuttons
				displayname = "Part Type"
				maxchar = 100
				values = {"New","Harvested","Faulty"}
				layout = 3
	 			row = 1
	 			column = 1   
				width = medium
			)
			Quantity_NEW
			(
				type = number
				displayname = "Quantity(NEW)"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Available_SOH
			(
				type = number
				displayname = "Available SOH"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Quantity_Harvested
			(
				type = number
				displayname = "Quantity(Harvested)"
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Part_Number_Available
			(
				type = radiobuttons
				displayname = "Part Number Available "
				maxchar = 100
				values = {"Yes","No"}
				layout = 2
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Spare_Part
			(
				type = picklist	
				displayname = "Spare Part"
				values  = Spare_Parts2.ID
    			displayformat = [Spare_Part_Name]
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Quantity
			(
				type = number
	 			row = 1
	 			column = 2   
				width = medium
			)
			Spare_Part_Consumption_Today
			(
				type = number
				displayname = "Spare Part Consumption(Today)"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Assigned_to
			(
				type = picklist
				displayname = "Assigned to/Received From"
				maxchar = 100
				values = {"Team 1","Team 2","Team 3","Team 4","Team 5"}
				sortorder = ascending
	 			row = 1
	 			column = 3   
				width = medium
			)
			Part_Number
			(
    			type = text
				displayname = "Part Number"
	 			row = 1
	 			column = 3   
				width = medium
			)
			must have Model_Spare_Part
			(
				type = picklist	
				displayname = "Model - Spare Part"
				values  = Model_Spare_Part[Make.ID == input.Make_Spare_Part].ID
    			displayformat = [Model]
				sortorder = ascending
	 			row = 1
	 			column = 3   
				width = medium
			)
			Harvested_SOH
			(
				type = number
				displayname = "Harvested SOH"
	 			row = 1
	 			column = 3   
				width = medium
			)
			Spare_Parts_Name
			(
				type = picklist	
				displayname = " Spare Part Name"
				values  = Spare_Parts.ID
    			displayformat = [Spare_Part_Name]
				sortorder = ascending
	 			row = 1
	 			column = 3   
				width = medium
			)
			IN_field
			(
				type = section
				displayname = "IN"
				visibility = true
	 			row = 2
	 			column = 0   
				width = medium
			)
			Received_From
			(
    			type = picklist
				displayname = "Received From"
				module = users
				displayformat = [username]
	 			row = 2
	 			column = 1   
				width = medium
				personal data = true
			)
			Carate_Barcode
			(
    			type = text
				displayname = "Carat Barcode"
	 			row = 2
	 			column = 2   
				width = medium
			)
			OUT
