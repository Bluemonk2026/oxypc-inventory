			Get_previous_record_DATA as "Get previous record DATA"
			{
				type =  form
				form = L1_L2_Assignment_Screen
				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											recs = L1_L2_Assignment_Screen[ID != 0] sort by Added_Time desc;
										if(recs != null)
										{
											input.Assigned_to = recs.Assigned_to;
											if(input.Assigned_to == "L1/L2 Engineers")
											{
												show Team_Lead;
												show Engineer_Name;
												input.Team_Lead = recs.Team_Lead;
												input.Engineer_Name = recs.Engineer_Name;
											}
											else
											{
												hide Team_Lead;
												hide Engineer_Name;
												input.Team_Lead = "";
												input.Engineer_Name = "";
											}
										}
						)
					}
				}

			}
