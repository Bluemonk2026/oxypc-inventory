			Update_today_consumption_ as "Update today consumption in Spare Part in/out"
			{
				type =  form
				form = Spare_Part_In_Out1
				record event = on add or edit
					status = inactive

				on user input of Assigned_to
				{
					actions 
					{
						custom deluge script
						(
											info "Team Data";
										Team_Data = User_Data_With_Team[Team == input.Assigned_to];
										info Team_Data;
										Member_list = List();
										for each  Member in Team_Data
										{
											User_name = Member.User_Name.toLowerCase() + "." + Member.Last_Name.toLowerCase() + "_oxypc1";
											User_name2 = Member.User_Name.toLowerCase() + "." + Member.Last_Name.toLowerCase() + "_oxypc";
											User_name6 = Member.User_Name.toLowerCase() + "." + Member.Last_Name.toLowerCase() + "_oxypc91";
											if(Member.Last_Name == null)
											{
												User_name3 = Member.User_Name.toLowerCase() + "_oxypc1";
												User_name4 = Member.User_Name.toLowerCase() + "_oxypc";
												User_name5 = Member.User_Name.toLowerCase() + "_oxypc91";
											}
											else
											{
												User_name3 = Member.User_Name.toLowerCase() + Member.Last_Name.toLowerCase() + "_oxypc1";
												User_name4 = Member.User_Name.toLowerCase() + Member.Last_Name.toLowerCase() + "_oxypc";
												User_name5 = Member.User_Name.toLowerCase() + Member.Last_Name.toLowerCase() + "_oxypc91";
											}
											Member_list.add(User_name);
											Member_list.add(User_name2);
											Member_list.add(User_name3);
											Member_list.add(User_name4);
											Member_list.add(User_name5);
											Member_list.add(User_name6);
											info Member_list;
										}
										Cunsumption_Count = 0;
										for each  Member in Member_list
										{
											L1_L2_Data = L1_L2_Engineer_Screen[Added_User == Member.toString() && Added_Time is Today];
											for each  engineer in L1_L2_Data
											{
												Subform_data = engineer.faults;
												for each  dataset in Subform_data
												{
													Faulty_Form_Data = Faulty_Spare_Parts_After_IQC1[ID == dataset];
													Make_L1 = L1_L2_Data.Make;
													Model_L1 = L1_L2_Data.Model;
													info Faulty_Form_Data.Spare_Part1;
													Spare_Parts = Spare_Parts2[ID = Faulty_Form_Data.Spare_Part1];
													Spare_Part = Spare_Parts.Spare_Part_Name;
													if(Make_L1 == input.Make_Spare_Part.Make && Model_L1 == input.Model_Spare_Part.Model && Spare_Part == input.Spare_Parts_Name.Spare_Part_Name)
													{
														info "Entered";
														Cunsumption_Count = Cunsumption_Count + 1;
													}
												}
												info Cunsumption_Count + "testing" + Member;
											}
										}
										input.Spare_Part_Consumption_Today = Cunsumption_Count;
						)
					}
				}

			}
