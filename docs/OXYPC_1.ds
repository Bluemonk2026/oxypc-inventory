			Break_Tax_amount_and_base as "Break Tax amount and base amount"
			{
				type =  form
				form = Raw_Data_Sales
				record event = on add or edit

				on user input of Tax_Including_Amount
				{
					actions 
					{
						custom deluge script
						(
											if(input.Tax_Including_Amount == null)
										{
											// 	
										}
										else
										{
											input.Tax_Amount = input.Tax_Including_Amount - input.Tax_Including_Amount * 0.8474576271186441;
											input.Taxable_Amount = input.Tax_Including_Amount - input.Tax_Amount;
											disable Tax_Amount;
											disable Taxable_Amount;
										}
						)
					}
				}

			}
