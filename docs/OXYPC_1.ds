			Add_to_Product_Master_Inv6 as "Add to Product Master Inventory"
			{
				type =  form
				form = TFT_L1_L2_Engineer_Screen
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											product_master = Product_Master_Inventory1[Tag_No2 == input.Barcode];
										NewMake = input.New_Make.toList("");
										if(NewMake.size() == 0)
										{
											// 	product_master.L1Make=input.New_Make;
											product_master.Make=input.New_Make;
											info "===============----------" + product_master.Make;
										}
										else
										{
											product_master.Make=input.Make;
											info input.Make;
										}
										// product_master.Final_Status=input.Final_Status;
										// product_master.L1_L2_Engineer="Submitted";
										product_master.Date_L3_L4_Engineer=zoho.currentdate;
										product_master.Time_L3_L4_Engineer=zoho.currenttime;
										if(input.Final_Status == "Completed")
										{
											product_master.Product_Stages="Assigned to Final QC";
											product_master.Product_Category="Final QC";
										}
										else if(input.Final_Status == "Escalate to L4")
										{
											product_master.Product_Stages="Assigned to L3/L4";
											product_master.Product_Category="L4 Repair";
										}
										else if(input.Final_Status == "PNA")
										{
											product_master.Product_Stages="PNA(Part not available)";
											product_master.Product_Category="Repair";
										}
										else
										{
											product_master.Product_Stages="Scrap";
											product_master.Product_Category="Scrap";
										}
										info "testing done ";
						)
					}
				}

			}
