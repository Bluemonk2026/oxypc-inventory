												input.DVD_Flap_replace = "yes";
												num = num + 1;
												lst.add("DVD FLAP");
											}
											else if(DVD_flap_value == "NA")
											{
												input.DVD_Flap_replace = "no";
												input.DVD_Flap_Rate = 0;
											}
											else if(DVD_flap_value == "No")
											{
												input.DVD_Flap_replace = "yes";
