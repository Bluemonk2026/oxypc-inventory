			Get_data_from_final_qc as "Get data from final qc"
			{
				type =  form
				form = PreSales_QC
				record event = on add or edit
					status = inactive

				on user input of Tag_Number
				{
					actions 
					{
						custom deluge script
						(
											disable Make;
										disable Model;
										disable CPU;
										disable Generation;
										disable RAM;
										disable HDD;
										final_qc_rec = Final_QC1[Tag_Number == input.Tag_Number];
										/////---Updating Make---/////
										if(final_qc_rec.Updated_Make == null)
										{
											input.Make = final_qc_rec.Make;
										}
										else
										{
											input.Make = final_qc_rec.Updated_Make.Make;
										}
										/////---Updating Model---/////
										if(final_qc_rec.Updated_Model == null)
										{
											input.Model = final_qc_rec.Model;
										}
										else
										{
											input.Model = final_qc_rec.Updated_Model.Model;
										}
										/////---Updating CPU---/////
										if(final_qc_rec.Update_CPU1 == null)
										{
											input.CPU = final_qc_rec.CPU;
										}
										else
										{
											input.CPU = final_qc_rec.Update_CPU1;
										}
										/////---Updating Gen---/////
										if(final_qc_rec.Updated_Generation == null)
										{
											input.Generation = final_qc_rec.Generation;
										}
										else
										{
											input.Generation = final_qc_rec.Updated_Generation;
										}
										/////---Updating RAM---/////
										if(final_qc_rec.Updated_RAM == null)
										{
											input.RAM = final_qc_rec.RAM;
										}
										else
										{
											input.RAM = final_qc_rec.Updated_RAM;
										}
										/////---Updating HDD---/////
										if(final_qc_rec.Updated_HDD == null)
										{
											input.HDD = final_qc_rec.HDD;
										}
										else
										{
											input.HDD = final_qc_rec.Updated_HDD;
										}
										//serial number
										input.Serial_Number = final_qc_rec.Serial_Number;
						)
					}
				}

			}
			Adding_product_in_Zoho_bo as "Adding product in Zoho books"
			{
				type =  form
				form = Final_QC1
				record event = on add or edit
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Final_Status == "Pass")
										{
											if(input.Make != null && input.Model != null && input.CPU != null && input.Generation != null && input.CPU != null && input.RAM != null)
											{
												product_name = input.Make + " " + input.Model + " " + input.CPU + " " + input.Generation + " " + input.RAM + " " + input.HDD;
											}
											mapp = Map();
											mapp.put("name",product_name);
											mapp.put("unit","pcs");
