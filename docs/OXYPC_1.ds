	section Internal_Stock_tranfer
	{
		displayname= "Internal Stock tranfer"
		icon = "shopping-stock"
		form Stock_tranfer_TRC_to_Showroom
		{
			displayname = "Stock tranfer - TRC to Showroom/B2"
			success message = "Data Added Successfully!"
			field alignment = left
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			unique Tag_Number
			(
    			type = text
				displayname = "Tag Number"
				qrcode = true
				barcode = true
				camera = primary
				switch camera = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			LOT_Number
			(
    			type = text
				displayname = "LOT Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Serial_Number
			(
    			type = text
				displayname = "Serial Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Category
			(
				type = picklist
				maxchar = 100
				values = {"Laptop","Desktop","TFT"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Model
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			Generation
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			HDD
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			Date_field
			(
    			type = date
				displayname = "Date"
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			Committed_or_Sold
			(
				type = picklist
				displayname = "Committed or Sold"
				maxchar = 100
				values = {"Committed","Not Committed"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Zoho_Books_Item_ID
			(
    			type = text
				displayname = "Zoho Books Item ID"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Zoho_Books_Item_Name
			(
    			type = text
				displayname = "Zoho Books Item Name"
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Warehouse
			(
				type = picklist
				maxchar = 100
				values = {"Bluemonk House Showroom","Amazon","Bluemonk House Basement"}
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			Make
			(
    			type = text
	 			row = 1
	 			column = 2   
				width = medium
			)
			CPU
			(
    			type = text
	 			row = 1
	 			column = 2   
				width = medium
			)
			RAM
			(
    			type = text
	 			row = 1
	 			column = 2   
				width = medium
			)
			Product_Description
			(
    			type = formula
				displayname = "Product Description"
				value =  input.Make + " " + input.Model + " " + input.CPU + " " + input.Generation + " " + input.RAM + " " + input.HDD
				visibility = false
				format = plaintext
	 			row = 1
	 			column = 2   
				width = medium
			)
			Time
			(
    			type = time
				initial value = "${zoho.currenttime}"	
				timedisplayoptions = "hh:mm:ss" 
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Product_Category
			(
				type = picklist
				displayname = "Product Stage"
				maxchar = 100
				values = {"Scrap","Lot","Finished Good"}
				sortorder = ascending
	 			row = 1
	 			column = 3   
				width = medium
			)
			Product_Sub_Category
			(
    			type = text
				displayname = "Product Sub-Category"
	 			row = 1
	 			column = 3   
				width = medium
			)
	
			customize
			(
				icon = "shopping-stock"
			)
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
