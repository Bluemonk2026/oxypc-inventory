		page Faulty_Assets(recid)
		{
			displayname = "Faulty Assets"
			icon = "business-stock"
			hide =  true
			Content="<zml    \t\t\n\t\t\tisPrintEnabled='true'\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet11' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet11()\ncontent\n&lt;%{\n\tfect_rec = IQC_Format_for_Laptop[ID == input.recid.toLong()];\n\t%&gt;\n&lt;head&gt;\n&lt;style&gt;\ntable {\n  font-family: arial, sans-serif;\n  border-collapse: collapse;\n  width: 10%;\n}\n\ntd, th {\n  border: 1px solid #dddddd;\n  text-align: left;\n  padding: 8px;\n}\n\ntr:nth-child(even) {\n  background-color: #dddddd;\n}\n&lt;\/style&gt;\n&lt;\/head&gt;\n&lt;body&gt;\n&lt;h2&gt;&lt;%=fect_rec.Serial_No%&gt;&lt;\/h2&gt;\n&lt;table&gt;\n  &lt;tr&gt;\n    &lt;th&gt;Key&lt;\/th&gt;\n    &lt;th&gt;Value&lt;\/th&gt;\n  &lt;\/tr&gt;\n&lt;%\n\tif(fect_rec.RAM_1 != &quot;Yes&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;RAM&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.RAM_1%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.HDD != &quot;Yes&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;HDD&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.HDD%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.Does != &quot;Yes&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;Does the Laptop Switch on?&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.Does%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.BIOS_Password != &quot;Yes&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;BIOS Password&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.BIOS_Password%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.Microphone != &quot;Working&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;Microphone&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.Microphone%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.Front_Panel != &quot;Ok&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;Front Panel&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.Front_Panel%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.Panel != &quot;Ok&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;Panel&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.Panel%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.Screen != &quot;Ok&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;Screen&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.Screen%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.Hinch != &quot;Ok&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;Hinch&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.Hinch%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.Hinch_Cover != &quot;Ok&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;Hinch Cover&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.Hinch_Cover%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.Power_Panel != &quot;Ok&quot; &amp;&amp; fect_rec.Power_Panel != &quot;NA&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;Power Panel&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.Power_Panel%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.Touch_Pad != &quot;Ok&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;Touch Pad&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.Touch_Pad%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.Base != &quot;Ok&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;Base&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.Base%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.Keyboard != &quot;Ok&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;Keyboard&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.Keyboard%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.Logic_Card != &quot;Ok&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;Logic Card&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.Logic_Card%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.USB != &quot;Ok&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;USB&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.USB%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.HDD_Connector != &quot;Yes&quot; &amp;&amp; fect_rec.HDD_Connector != &quot;NA&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;HDD Connector&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.HDD_Connector%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.Sound != &quot;Ok&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;Sound&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.Sound%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.HDD_Casing != &quot;Yes&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;HDD Casing&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.HDD_Casing%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.Web_Cam != &quot;Working&quot; &amp;&amp; fect_rec.Web_Cam != &quot;NA&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;Web Cam&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.Web_Cam%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.HDD_Cover != &quot;Ok&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;HDD Cover&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.HDD_Cover%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.RAM_Cover != &quot;Ok&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;RAM Cover&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.RAM_Cover%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.WIFI != &quot;Working&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;WIFI&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.WIFI%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.Battery != &quot;Yes&quot; &amp;&amp; fect_rec.Battery != &quot;NA&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;Battery&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.Battery%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.Int_Battery != &quot;Yes&quot; &amp;&amp; fect_rec.Int_Battery != &quot;NA&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;Int. Battery&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.Int_Battery%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.Battery_Cable != &quot;Yes&quot; &amp;&amp; fect_rec.Battery_Cable != &quot;NA&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;Battery Cable&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.Battery_Cable%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.DVD != &quot;Yes&quot; &amp;&amp; fect_rec.DVD != &quot;NA&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;DVD&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.DVD%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.DVD_Flap != &quot;Yes&quot; &amp;&amp; fect_rec.DVD_Flap != &quot;NA&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;DVD Flap&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.DVD_Flap%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\tif(fect_rec.Status != &quot;Ok&quot; &amp;&amp; fect_rec.Status != &quot;Power On&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n    &lt;td&gt;Status&lt;\/td&gt;\n    &lt;td&gt;&lt;%=fect_rec.Status%&gt;&lt;\/td&gt;\n  &lt;\/tr&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/table&gt;\n&lt;\/body&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
