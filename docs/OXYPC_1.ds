			Update_Item_Value1 as "Update Item Value"
			{
				type =  form
				form = GRN
				record event = on add or edit

				on user input of Item.Quantity
				{
					actions 
					{
						custom deluge script
						(
											for each  i in Item
										{
											if(i.Price != null && i.Quantity != null)
											{
												i.Item_Value=(i.Price * i.Quantity.toLong()).toLong();
											}
										}
						)
					}
				}

			}
			Update_Item_Value2 as "Update Item Value"
			{
				type =  form
				form = GRN
				record event = on add or edit

				on user input of Item.Price
				{
					actions 
					{
						custom deluge script
						(
											for each  j in Item
										{
											if(j.Price != null && j.Quantity != null)
											{
												j.Item_Value=(j.Price * j.Quantity.toLong()).round(0).toLong();
											}
										}
						)
					}
				}

			}
