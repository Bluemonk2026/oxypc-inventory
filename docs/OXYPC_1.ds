			Fetch_Customer_Location_a as "Fetch Customer Location and GST IN"
			{
				type =  form
				form = Sales_Orders
				record event = on add or edit

				on user input of Customer_Name
				{
					actions 
					{
						custom deluge script
						(
											if(input.Customer_Name != null)
										{
											cust_rec = Customer_Database[ID == input.Customer_Name];
											if(cust_rec.count() > 0)
											{
												input.Customer_Location = cust_rec.Billing_Full_Address;
												input.GSTIN_UIN = cust_rec.GST;
												input.Customer_State = cust_rec.Billing_Address1.state_province;
