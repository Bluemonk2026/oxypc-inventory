			Alert_on_Duplicate_Tag_nu as "Alert on Duplicate Tag number in desktop & TFT"
			{
				type =  form
				form = IQC_Format_for_Laptop
				record event = on add or edit

				on user input of TAG_NO
				{
					actions 
					{
						custom deluge script
						(
											desktop_recs = IQC_Format_for_Desktop[Tag_No == input.TAG_NO];
										tft_recs = IQC_Format_for_TFT[TAG == input.TAG_NO];
										newline = hextoText("0A");
										if(desktop_recs.count() != 0)
										{
											alert "This Tag Number is already assigned to Desktop" + newline + "यह टैग नंबर पहले से ही डेस्कटॉप पर टैग किया गया है";
											input.TAG_NO = "";
										}
										if(tft_recs.count() != 0)
										{
											alert "This Tag Number is already assigned to TFT" + newline + "यह टैग नंबर पहले से ही टीएफटी पर टैग किया गया है";
											input.TAG_NO = "";
										}
						)
					}
				}

			}
