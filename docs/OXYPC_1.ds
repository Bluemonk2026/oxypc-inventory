										// List of month names
										months = {"1":"Jan","2":"Feb","3":"Mar","4":"Apr","5":"May","6":"Jun","7":"Jul","8":"Aug","9":"Sep","10":"Oct","11":"Nov","12":"Dec"};
										months_name = months.get(current_month.toString());
										input.RMA_Number = months_name + "-" + current_year + "-" + "00" + result.RMA_Create_Job_Count;
