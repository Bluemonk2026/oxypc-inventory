			tst as "tst"
			{
				type =  form
				form = IQC_Format_for_Laptop
				record event = on edit
					status = inactive

				on update of checkbox1
				{
					actions 
					{
						custom deluge script
						(
											model = input.Model1.Model;
										make = input.Make.Make;
										if(input.Hinch_Cover_replace == "yes")
										{
											rec = Spare_Parts_Costing_Report[Part == "Hinch Cover" && Make == make && Model == model];
											input.Required_Replacements = rec;
											input.Hinch_Cover_Rate = rec.Rate;
										}
										if(input.Hinch_replace == "yes")
										{
											rec = Spare_Parts_Costing_Report[Part == "Hinch" && Make == make && Model == model];
											input.Required_Replacements = rec;
											input.Hinch_Rate = rec.Rate;
										}
										// if(input.RAM_replace == "yes")
										// {
										// 	rec = Spare_Parts_Costing_Report[Part == "RAM" && Make == make && Model == model];
										// 	input.Required_Replacements = rec;
										// 	input.RAM_Rate = rec.Rate;
										// }
										if(input.DVD_replace == "yes")
										{
											rec = Spare_Parts_Costing_Report[Part == "DVD" && Make == make && Model == model];
											input.Required_Replacements = rec;
											input.DVD_Rate = rec.Rate;
										}
										if(input.DVD_Flap_replace == "yes")
										{
											rec = Spare_Parts_Costing_Report[Part == "DVD Flap" && Make == make && Model == model];
											input.Required_Replacements = rec;
											input.DVD_Flap_Rate = rec.Rate;
										}
										if(input.RAM_Cover_replace == "yes")
										{
											rec = Spare_Parts_Costing_Report[Part == "RAM Cover" && Make == make && Model == model];
											input.Required_Replacements = rec;
											input.RAM_Cover_Rate = rec.Rate;
										}
										if(input.Keyboard_replace == "yes")
										{
											rec = Spare_Parts_Costing_Report[Part == "Keyboard" && Make == make && Model == model];
											input.Required_Replacements = rec;
											input.Keyboard_Rate = rec.Rate;
										}
										if(input.Base_replace == "yes")
										{
											rec = Spare_Parts_Costing_Report[Part == "Base" && Make == make && Model == model];
											input.Required_Replacements = rec;
											input.Base_Rate = rec.Rate;
										}
										if(input.Touch_Pad_replace == "yes")
										{
											rec = Spare_Parts_Costing_Report[Part == "Touch pad" && Make == make && Model == model];
											input.Required_Replacements = rec;
											input.Touch_Pad_Rate = rec.Rate;
										}
										if(input.Screen_replace == "yes")
										{
											rec = Spare_Parts_Costing_Report[Part == "Screen" && Make == make && Model == model];
											input.Required_Replacements = rec;
											input.Screen_Rate = rec.Rate;
										}
										if(input.Microphone_replace == "yes")
										{
											rec = Spare_Parts_Costing_Report[Part == "Microphone" && Make == make && Model == model];
											input.Required_Replacements = rec;
											input.Screen_Rate = rec.Rate;
										}
										if(input.USB_replace == "yes")
										{
											rec = Spare_Parts_Costing_Report[Part == "USB" && Make == make && Model == model];
											input.Required_Replacements = rec;
											input.USB_Rate = rec.Rate;
										}
										//  RAM_Rate + HDD_Rate + Microphone_Rate + Front_Panel_Rate +  + Screen_Rate + Hinch_Rate + Hinch_Cover_Rate +  + Touch_Pad_Rate + Base_Rate + Keyboard_Rate + Logic_Card_Rate + USB_Rate + HDD_Connector_Rate + Sound_Rate + HDD_Casing_Rate + Web_Cam_Rate + HDD_Cover_Rate + RAM_Cover_Rate  + DVD_Flap_Rate
										if(input.WIFI_replace == "yes")
										{
											rec = Spare_Parts_Costing_Report[Part == "Wifi" && Make == make && Model == model];
											input.Required_Replacements = rec;
											input.WIFI_Rate = rec.Rate;
										}
										if(input.HDD_Cover_replace == "yes")
										{
											rec = Spare_Parts_Costing_Report[Part == "Hdd Cover" && Make == make && Model == model];
											input.Required_Replacements = rec;
											input.HDD_Cover_Rate = rec.Rate;
										}
										if(input.Web_Cam_replace == "yes")
										{
											rec = Spare_Parts_Costing_Report[Part == "Web Cam" && Make == make && Model == model];
											input.Required_Replacements = rec;
											input.Web_Cam_Rate = rec.Rate;
										}
										if(input.Sound_replace == "yes")
										{
											rec = Spare_Parts_Costing_Report[Part == "Speaker" && Make == make && Model == model];
											input.Required_Replacements = rec;
											input.Sound_Rate = rec.Rate;
										}
										if(input.HDD_Connector_replace == "yes")
										{
											rec = Spare_Parts_Costing_Report[Part == "HDD Connector" && Make == make && Model == model];
											input.Required_Replacements = rec;
											input.HDD_Connector_Rate = rec.Rate;
										}
										if(input.HDD_Casing_replace == "yes")
										{
											rec = Spare_Parts_Costing_Report[Part == "Hdd Casing" && Make == make && Model == model];
											input.Required_Replacements = rec;
											input.HDD_Casing_Rate = rec.Rate;
										}
										if(input.Logic_Card_replace == "yes")
										{
											rec = Spare_Parts_Costing_Report[Part == "Logic" && Make == make && Model == model];
											input.Required_Replacements = rec;
											input.HDD_Casing_Rate = rec.Rate;
										}
										if(input.Panel_replace == "yes")
										{
											rec = Spare_Parts_Costing_Report[Part == "Panel" && Make == make && Model == model];
											input.Required_Replacements = rec;
											input.Panel_Rate = rec.Rate;
										}
										if(input.Power_Panel_replace == "yes")
										{
											rec = Spare_Parts_Costing_Report[Part == "Power Panel" && Make == make && Model == model];
											input.Required_Replacements = rec;
											input.Power_Panel_Rate = rec.Rate;
										}
										if(input.Front_panel_replace == "yes")
										{
											rec = Spare_Parts_Costing_Report[Part == "Front Panel" && Make == make && Model == model];
											input.Required_Replacements = rec;
											input.Front_Panel_Rate = rec.Rate;
										}
										// if(input.HDD_replace == "yes"){
										// 	rec = Spare_Parts_Costing_Report[Part == "Panel" && Make == make && Model == model];
										// 	input.Required_Replacements = rec;
										// 	input.Panel_Rate = rec.Rate;
										// }
										// if(input.Microphone_replace == "yes"){
										// 	rec = Spare_Parts_Costing_Report[Part == "Logic" && Make == make && Model == model];
										// 	input.Required_Replacements = rec;
										// 	input.HDD_Casing_Rate = rec.Rate;
										// }
										grn_rec = Items_GRN[LOT_No == input.LOT_Number && Category == 164568000000716007];
										total_costt = input.Total_Cost;
										info grn_rec;
										purchase_price = grn_rec.Price;
										sales_price = Sales_Price_Laptop[Product_Description == input.Model_Description1];
										sales_priceee = sales_price.Sales_Price;
										info sales_price;
										pnl_rec = Spare_Part_Cost_LOT_Wise[LOT_No == input.LOT_Number && Product_Description1 == input.Model_Description1];
										info pnl_rec;
										if(pnl_rec.count() == 0)
										{
											pnl_data = Map();
											pnl_data.put("LOT_No",input.LOT_Number);
											pnl_data.put("Category","Laptop");
											pnl_data.put("Make1",input.Make.Make);
											pnl_data.put("Model1",input.Model1.Model);
											pnl_data.put("CPU1",input.CPU);
											pnl_data.put("Generation1",input.Generation);
											if(input.Number_of_replacements != null)
											{
												pnl_data.put("Number_of_replacements",input.Number_of_replacements);
											}
											pnl_data.put("Total_Cost",total_costt);
											pnl_data.put("Sales_Price",sales_priceee);
											pnl_data.put("Customer_Name",grn_rec.Customer_Name);
											pnl_data.put("Purchase_Price",purchase_price);
											pnl_data.put("Product_Description1",input.Model_Description1);
											pnl_data.put("Model_Count",1);
											empty_map = Map();
											info pnl_data;
											info zoho.creator.createRecord("protaiga","oxypc-1","Spare_Part_Cost_LOT_Wise",pnl_data,empty_map,"creator");
										}
										else
										{
											pnl_rec.Purchase_Price=pnl_rec.Purchase_Price + purchase_price;
											if(input.Number_of_replacements != null)
											{
												pnl_rec.Number_of_replacements=pnl_rec.Number_of_replacements + input.Number_of_replacements;
											}
											if(input.Total_Cost != null)
											{
												pnl_rec.Total_Cost=pnl_rec.Total_Cost + input.Total_Cost;
											}
											pnl_rec.Model_Count=pnl_rec.Model_Count + 1;
											pnl_rec.Sales_Price=pnl_rec.Sales_Price + sales_priceee;
										}
										// // mapp = Map();
