																mapp.put("Purchase_Price",i.Price);
																mapp.put("Quantity",1);
																mapp.put("Unique_Lot_No",i.ID);
																// 						mapp.put("Aging",0.00);
																bulk_create_list.add(mapp);
															}
															data_map = Map();
															data_map.put("data",bulk_create_list);
															empty_map = Map();
															sendmail
															[
