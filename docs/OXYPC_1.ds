															mapp.put("GRN_Date",input.Date_field.toString("dd-MMM-yyyy"));
															mapp.put("GRN_Number",input.GRN_Number);
															mapp.put("Invoice_Number",input.Invoice_Number);
															mapp.put("PO_Number",input.PO_Number.PO_Number);
															empty_mapp = Map();
															create_rec = zoho.creator.createRecord("protaiga","oxypc-1","Product_Master_Inventory1",mapp,empty_mapp,"creator");
															info create_rec;
															sendmail
															[
																from :zoho.loginuserid
																to :"shubham.oxypc@gmail.com"
																subject :"TFT IQC Create record in inventory"
																message :"Create_rec" + create_rec
															]
															if(create_rec.get("code") == 3000)
															{
																count_tag_number = count_tag_number + 1;
															}
														}
														else
														{
															info "TFT found in product master inventory" + prdct_mstr_inv.Tag_No2;
															mapp = Map();
															mapp.put("Product_Category2","TFT");
															mapp.put("Product_Sub_Category","TFT");
															mapp.put("Zoho_Books_ID",i.Books_Item_ID);
															mapp.put("Purchase_Price",i.Price);
															mapp.put("Quantity",1);
															mapp.put("GRN_Date",input.Date_field.toString("dd-MMM-yyyy"));
															mapp.put("GRN_Number",input.GRN_Number);
															if(i.Location == "Bluemonk House Showroom")
															{
																mapp.put("Showroom_Inventory_Date",zoho.currentdate.toString("dd-MMM-yyyy"));
															}
															mapp.put("Invoice_Number",input.Invoice_Number);
															mapp.put("PO_Number",input.PO_Number.PO_Number);
															if(prdct_mstr_inv.Warehouse == "Manesar")
															{
																mapp.put("Warehouse","TRC 2ND Floor");
															}
															empty_mapp = Map();
															updt_rec = zoho.creator.updateRecord("protaiga","oxypc-1","All_Product_Master_Inventories1",prdct_mstr_inv.ID,mapp,empty_mapp,"creator");
															if(updt_rec.get("code") == 3000)
															{
																count_tag_number = count_tag_number + 1;
															}
														}
													}
													// 			info "count of loop" + count_tag_number;
												}
											}
											info "count_tag_number ------->>>>> " + count_tag_number;
											info "size_of_list ---------->>>>>>>> " + size_of_list;
											if(count_tag_number == size_of_list)
											{
												info "GRN_Check ---->>> " + i.GRN_Check;
												i.GRN_Check1="Yes";
												i.GRN_Check=true;
												info "GRN_Check after Update ---->>> " + i.GRN_Check;
											}
										}
						)
					}
				}

			}
