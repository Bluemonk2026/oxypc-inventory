			User_cant_add_one_Tag_Num as "User cant add one Tag Number in single Day"
			{
				type =  form
				form = Stock_tranfer_TRC_to_Showroom
				record event = on add

				on validate
				{
					actions 
					{
						custom deluge script
						(
											result = Stock_tranfer_TRC_to_Showroom[Tag_Number.equalsIgnoreCase(input.Tag_Number)] sort by Added_Time desc;
										if(result.count() > 0)
										{
											Record_Date = result.Added_Time;
											Final_date = Record_Date.toDate().toString("dd-MMM-yyyy");
											currentDate = zoho.currentdate;
											currentDate_rec = currentDate.toString("dd-MMM-yyyy");
											if(Final_date == currentDate_rec)
											{
												alert "रिकॉर्ड पहले ही दर्ज किया जा चुका है।";
												cancel submit;
											}
										}
						)
					}
				}

			}
			Fetch_Information as "Fetch Information"
			{
				type =  form
				form = Delamination
				record event = on add or edit

				on user input of Tag_Number
				{
					actions  (Tag_Number is not null)
					{
						custom deluge script
						(
											if(input.Serial_Number1 == "" || input.Serial_Number1 == null)
										{
										}
										else
										{
											iqc_screen_rec = IQC_format_for_Screen[Serial_Number.equalsIgnoreCase(input.Serial_Number1)];
											if(iqc_screen_rec.count() > 0)
											{
												if(iqc_screen_rec.Status == "OK")
												{
													alert "Screen is Ok and doesn't need Delamination";
													input.Serial_Number1 = "";
												}
												else
												{
													input.Pin = iqc_screen_rec.Screen_Pin;
													input.Tag_Number = iqc_screen_rec.Tag_No;
													input.Lot_Number = iqc_screen_rec.Lot_Number;
													input.Serial_Number = iqc_screen_rec.Part_No;
													input.Screen_Size = iqc_screen_rec.Screen_Size;
													input.Problem_Reported = iqc_screen_rec.Problem_Reported;
													input.Screen_Type = iqc_screen_rec.Screen_Type;
												}
											}
											else
											{
												alert "IQC not done for this Tag !!";
												input.Pin = "";
												input.Lot_Number = "";
												input.Tag_Number = "";
												input.Serial_Number = "";
												input.Screen_Size = "";
												input.Problem_Reported = "";
												input.Screen_Type = "";
											}
										}
						)
					}
				}

			}
