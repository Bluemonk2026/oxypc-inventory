										// 		sales_date = prdct_master_inv.Sale_Date.toString("dd-MMM-yyyy");
										// 		current_date = zoho.currentdate;
										// 		if(sales_date != null)
										// 		{
										// 			numberOfDays = daysBetween(sales_date.toDate(),current_date);
										// 			alert numberOfDays;
										// 			if(numberOfDays <= 30)
										// 			{
										// 				input.Warranty_Status = "In-Warranty";
										// 			}
										// 			else
										// 			{
										// 				input.Warranty_Status = "Out-of-Warranty";
										// 			}
										// 		}
										// 		input.Party_Name = prdct_master_inv.Customer_Name_Sale;
										// 		input.Invoice_Number = prdct_master_inv.Invoice_Number_Sale;
										// 		if(rma_repair.count() > 0)
										// 		{
										// 			input.Repair_History = "Yes";
										// 		}
										// 		else
										// 		{
										// 			input.Repair_History = "No";
										// 		}
										// 	}
										// }
						)
					}
					actions 
					{
						custom deluge script
						(
											//Update code
										if(input.Serial_Number != null && input.Make == "")
										{
											ship_to_customer = RMA_Ship_to_Customer[Serial_Number.endsWithIgnoreCase(input.Serial_Number)] sort by Added_Time desc;
											if(ship_to_customer.count() > 0)
											{
												if(ship_to_customer.Final_Status == "Repaired & Shipped" || ship_to_customer.Final_Status == "Return without Repair" || ship_to_customer.Final_Status == "Replacement Issue" || ship_to_customer.Final_Status == "NTF/Same Return")
												{
													prdct_master_inv = Product_Master_Inventory1[Serial_No.equalsIgnoreCase(input.Serial_Number)];
													rma_repair = RMA_Repair[Serial_Number.equalsIgnoreCase(input.Serial_Number)];
													if(prdct_master_inv.count() == 0)
													{
														alert "Product not Found in Inventory";
													}
													else
													{
														input.Tag_Number = prdct_master_inv.Tag_No2;
														input.Make = prdct_master_inv.Make;
														input.Model = prdct_master_inv.Model;
														input.CPU = prdct_master_inv.CPU;
														input.RAM = prdct_master_inv.RAM;
														input.HDD = prdct_master_inv.HDD;
														input.Generation = prdct_master_inv.Generation;
														input.Serial_Number = prdct_master_inv.Serial_No;
														input.Sales_Person = prdct_master_inv.Sales_Person_Name;
														input.Sale_Date = prdct_master_inv.Sale_Date.toString("dd-MMM-yyyy");
														sales_date = prdct_master_inv.Sale_Date.toString("dd-MMM-yyyy");
														current_date = zoho.currentdate;
														if(sales_date != null)
														{
															numberOfDays = daysBetween(sales_date.toDate(),current_date);
															alert numberOfDays;
															if(numberOfDays <= 30)
															{
																input.Warranty_Status = "In-Warranty";
															}
															else
															{
																input.Warranty_Status = "Out-of-Warranty";
															}
														}
														input.Party_Name = prdct_master_inv.Customer_Name_Sale;
														input.Invoice_Number = prdct_master_inv.Invoice_Number_Sale;
														if(rma_repair.count() > 0)
														{
															input.Repair_History = "Yes";
														}
														else
														{
															input.Repair_History = "No";
														}
													}
												}
												else
												{
													alert "The serial number is already exited in the customer shipment. Please proceed with the process";
												}
											}
											else
											{
												prdct_master_inv = Product_Master_Inventory1[Serial_No.equalsIgnoreCase(input.Serial_Number)];
												rma_repair = RMA_Repair[Serial_Number.equalsIgnoreCase(input.Serial_Number)];
												if(prdct_master_inv.count() == 0)
												{
													alert "Product not Found in Inventory";
												}
												else
												{
													input.Tag_Number = prdct_master_inv.Tag_No2;
													input.Make = prdct_master_inv.Make;
													input.Model = prdct_master_inv.Model;
													input.CPU = prdct_master_inv.CPU;
													input.RAM = prdct_master_inv.RAM;
													input.HDD = prdct_master_inv.HDD;
													input.Generation = prdct_master_inv.Generation;
													input.Serial_Number = prdct_master_inv.Serial_No;
													input.Sales_Person = prdct_master_inv.Sales_Person_Name;
													input.Sale_Date = prdct_master_inv.Sale_Date.toString("dd-MMM-yyyy");
													sales_date = prdct_master_inv.Sale_Date.toString("dd-MMM-yyyy");
													current_date = zoho.currentdate;
													if(sales_date != null)
													{
														numberOfDays = daysBetween(sales_date.toDate(),current_date);
														alert numberOfDays;
														if(numberOfDays <= 30)
														{
															input.Warranty_Status = "In-Warranty";
														}
														else
														{
															input.Warranty_Status = "Out-of-Warranty";
														}
													}
													input.Party_Name = prdct_master_inv.Customer_Name_Sale;
													input.Invoice_Number = prdct_master_inv.Invoice_Number_Sale;
													if(rma_repair.count() > 0)
													{
														input.Repair_History = "Yes";
													}
													else
													{
														input.Repair_History = "No";
													}
												}
											}
										}
						)
					}
				}

			}
