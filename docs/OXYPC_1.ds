			Push_to_the_tracker as "Push to the tracker"
			{
				type =  form
				form = Final_QC1
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											User = input.Added_User;
										info User;
										if(User == null || User == "")
										{
											Today_Production_Tracker = Production_Tracker[Date_field == zoho.currentdate];
										}
										else
										{
											Today_Production_Tracker = Production_Tracker[Date_field == zoho.currentdate && Engineer_Name == User];
										}
										info Today_Production_Tracker.Engineer_Name;
										Tracker_Size = Today_Production_Tracker.count();
										info Tracker_Size;
										if(Tracker_Size == 0)
										{
											Create_map = Map();
											Create_map.put("IQC_Completed",0);
											Create_map.put("Date_field",zoho.currentdate.toString("dd-MMM-yyyy"));
											Create_map.put("L1_L2",0);
											Create_map.put("L3_L4",0);
											Create_map.put("L4_Support",0);
											Create_map.put("Final_QC",0);
											Create_map.put("Cleaning",0);
											Create_map.put("Painting",0);
											Create_map.put("Engineer_Name",User);
											Create_map.put("Assigned_to_L1_L2",0);
											Create_map.put("Assigned_to_L4_Support",0);
											Create_map.put("Department","L1/L2");
											Create_map.put("Finalized_Inventory",1);
											empty_map = Map();
											Create_record = zoho.creator.createRecord("protaiga","oxypc-1","Production_Tracker",Create_map,empty_map,"creator");
											info Create_record;
										}
										else
										{
											if(Today_Production_Tracker.Finalized_Inventory.toString() == "" || Today_Production_Tracker.Finalized_Inventory == null)
											{
												Finalized_Inventory_count = Today_Production_Tracker.Finalized_Inventory;
												Today_Production_Tracker.Finalized_Inventory=1;
											}
											else
											{
												Finalized_Inventory_count = Today_Production_Tracker.Finalized_Inventory;
												Today_Production_Tracker.Finalized_Inventory=Finalized_Inventory_count.toNumber() + 1;
											}
										}
						)
					}
				}

			}
