			Calculate_tax_amount_and_ as "Calculate tax amount and taxable amount"
			{
				type =  form
				form = Sales_Form
				record event = on add or edit

				on user input of Line_Items.Taxable_Amount
				{
					actions 
					{
						custom deluge script
						(
											if(input.Customer != null)
										{
											if(row.Quantity != null)
											{
												result = ifNull(row.Taxable_Amount,0) * row.Quantity;
												tax_ammount = row.Taxable_Amount * 0.152542373;
												row.Unit_Price=row.Taxable_Amount * 0.847457627;
												row.Tax_Amount=tax_ammount;
											}
										}
						)
					}
				}

			}
			calculate_grade_according as "calculate grade according to Answers"
			{
				type =  form
				form = IQC_form_for_New_APP
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											// --------------------------------------------------------------
										// Single-Pass Grading in One Script (No separate functions)
										// --------------------------------------------------------------
										// 1) Initialize booleans to track the worst severity found
										hasB = false;
										hasC = false;
										hasD = false;
										// 2) Check each field according to your table
										//    If a field's value triggers a B-level issue, set hasB = true
										//    If it triggers C-level, set hasC = true
										//    If it triggers D-level, set hasD = true
										//    (Adjust conditions as needed)
										// --- Examples below. Replace "input.Dot" etc. with your real field names. ---
										// Dot: A/B => "No", C/D => "Yes"
										if(input.Dot == "Yes")
										{
											// The table says "Yes" under both C and D, ambiguous. 
											// We'll assume it's at least C. 
											hasC = true;
										}
										// Patch: A/B => "No", C/D => "Yes"
										if(input.Patch == "Yes")
										{
											hasC = true;
										}
										// Line: A/B/C => "No", D => "Yes"
										if(input.Line == "Yes")
										{
											hasD = true;
										}
										// Broken: A/B/C => "No", D => "Yes"
										if(input.Broken == "Yes")
										{
											hasD = true;
										}
										// Functional: A/B/C => "Yes", D => "No"
										if(input.Functional == "No")
										{
											hasD = true;
										}
										// Flickering: A/B/C => "No", D => "Yes"
										if(input.Flickering == "Yes")
										{
											hasD = true;
										}
										// Color_Discoloration: A/B => "No", C/D => "Yes"
										if(input.Color_Discoloration == "Yes")
										{
											// Could be C or D. We'll treat it as C for now.
											hasC = true;
										}
										// Scratch: 
										//   A => "No", 
										//   B => "Minor Scratch", 
										//   C => "Major scratch", 
										//   D => "Major scratch" (ambiguous in table).
										if(input.Scratch == "Minor Scratch")
										{
											hasB = true;
										}
										else if(input.Scratch == "Major scratch")
										{
											// Could be C or D. We'll treat it as C by default.
											hasC = true;
										}
										// Scratch_A
										if(input.Scratch_A == "Minor Scratch")
										{
											hasB = true;
										}
										else if(input.Scratch_A == "Major Scrach" || input.Scratch_A == "Major scratch")
										{
											hasC = true;
										}
										// Dent_A => A/B => "No", C/D => "Yes"
										if(input.Dent_A == "Yes")
										{
											hasC = true;
										}
										// Broken_Crack_A => A/B => "No", C/D => "Yes"
										if(input.Broken_Crack_A == "Yes")
										{
											hasC = true;
										}
										// Colour_fade_A => A/B => "No", C/D => "Yes"
										if(input.Colour_fade_A == "Yes")
										{
											hasC = true;
										}
										// Missing_A => "No" in all columns in your table, so presumably never "Yes" 
										// If you do handle "Yes", decide if it's D, etc.
										// Rubber_Cut_B => A/B => "No", C/D => "Yes"
										if(input.Rubber_Cut_B == "Yes")
										{
											hasC = true;
										}
										// Scratch_B
										if(input.Scratch_B == "Minor Scratch")
										{
											hasB = true;
										}
										else if(input.Scratch_B == "Major Scrach" || input.Scratch_B == "Major scratch")
										{
											hasC = true;
										}
										// Broken_Crack_B => A/B => "No", C/D => "Yes"
										if(input.Broken_Crack_B == "Yes")
										{
											hasC = true;
										}
										// Colour_fade_B => A/B => "No", C/D => "Yes"
										if(input.Colour_fade_B == "Yes")
										{
											hasC = true;
										}
										// Missing_B => A/B/C => "No", D => "Yes"
										if(input.Missing_B == "Yes")
										{
											hasD = true;
										}
										// Repeat similarly for Scratch_C, Dent_C, Broken_Crack_C, ...
										// (omitted here for brevity—same pattern)
										// Touch_Pad_Working => A/B => "Yes", C/D => "No"
										if(input.Touch_Pad_Working == "No")
										{
											hasC = true;
										}
										if(input.Click_Function_Working == "No")
										{
											hasC = true;
										}
										// Scratch1 => A => "No", B => "Minor Scratch", C/D => "Major scratch"
										if(input.Scratch1 == "Minor Scratch")
										{
											hasB = true;
										}
										else if(input.Scratch1 == "Major scratch")
										{
											hasC = true;
										}
										// Colour_Fade1 => A/B => "No", C/D => "Yes"
										if(input.Colour_Fade1 == "Yes")
										{
											hasC = true;
										}
										// Missing_Touchpad => A/B/C => "No", D => "Yes"
										if(input.Missing_Touchpad == "Yes")
										{
											hasD = true;
										}
										// Battery_Health => A/B => ">70%", C => between 50% to 70%, D => Below 30%
										// This means you should parse or store numeric. Example:
										if(input.Battery_Health.contains("%"))
										{
											health_num = ifnull(input.Battery_Health.toString().trim().remove("%").toLong(),0);
											if(health_num < 30)
											{
												hasD = true;
											}
											else if(health_num >= 50 && health_num <= 70)
											{
												hasC = true;
											}
											else if(health_num > 70)
											{
												// It's either A or B. If you want to treat 70-80 as B, you can do so. 
												// For simplicity, do nothing => stays A or B. 
											}
										}
										else
										{
											//
										}
										// Is_Keyboard_Working => A/B => "Working", C/D => "Not Working"
										if(input.Is_Keyboard_Working == "No")
										{
											hasC = true;
										}
										// Key_Missing => A/B/C => "No", D => "Yes"
										if(input.Key_Missing == "Yes")
										{
											hasD = true;
										}
										// Colour_Fade => A/B => "No", C/D => "Yes"
										if(input.Colour_Fade == "Yes")
										{
											hasC = true;
										}
										// Hard_Press => A/B => "No", C/D => "Yes"
										if(input.Hard_Press == "Yes")
										{
											hasC = true;
										}
										// Speaker_Status => A/B => "Both speakers working", C/D => "Both speakers faulty"
										if(input.Speaker_Status == "Both speakers faulty")
										{
											hasC = true;
										}
										// HDMI_Port => A/B => "Working", C/D => "Not Working"
										if(input.HDMI_Port == "No")
										{
											hasC = true;
										}
										// USB_Ports_Working => A/B/C => "No", D => "Yes"
										if(input.USB_Ports_Working == "Yes")
										{
											hasD = true;
										}
										// Audio_Jack_Working => A/B => "No", C/D => "Yes"
										if(input.Audio_Jack_Working == "Yes")
										{
											hasC = true;
										}
										// Loose => A/B => "No", C/D => "Yes"
										if(input.Loose == "Yes")
										{
											hasC = true;
										}
										// Missing => A/B/C => "No", D => "Yes"
										if(input.Missing == "Yes")
										{
											hasD = true;
										}
										// Hinge_Broken => A/B => "No", C/D => "Yes"
										if(input.Hinge_Broken == "Yes")
										{
											hasC = true;
										}
										// RAM => A/B => not null, C/D => null
										if(input.RAM == null || input.RAM == "")
										{
											hasC = true;
										}
										// HDD => A/B => not null, C/D => null
										if(input.HDD == null || input.HDD == "")
										{
											hasC = true;
										}
										// 3) Decide final grade based on the booleans
										//    D outranks everything, then C, then B, else A
										finalGrade = "A";
										if(hasD)
										{
											finalGrade = "D";
										}
										else if(hasC)
										{
											finalGrade = "C";
										}
										else if(hasB)
										{
											finalGrade = "B";
										}
										else
										{
											finalGrade = "A";
										}
										// 4) Assign the final grade to your form field
										input.Grade = finalGrade;
						)
					}
				}

			}
