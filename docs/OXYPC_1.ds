													}
													else if(desk_rec.count() > 0)
													{
														master_recs = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(desk_rec.Tag_No)];
														info "master_recs_search " + master_recs;
														if(master_recs.count() == 0)
														{
															info "entered loop";
															mapp = Map();
															mapp.put("Product_Sub_Category",desk_rec.Sub_Category.Sub_Category);
															mapp.put("Serial_No",desk_rec.Serial_No);
															mapp.put("LOT_No",desk_rec.LOT_No1.LOT_No);
															mapp.put("Grade",desk_rec.Grade);
															mapp.put("Tag_No2",desk_rec.Tag_No);
															// 	mapp.put("Desktop",desk_rec.ID);
															mapp.put("Make",desk_rec.Make.Make);
															mapp.put("Model",desk_rec.Model.Model);
															mapp.put("CPU",desk_rec.Processors);
															mapp.put("Generation",desk_rec.Generation);
															mapp.put("Product_Category2","Desktop");
															mapp.put("Quantity",1);
															mapp.put("Used_or_not","In-Zoho");
															mapp.put("Product_Stages","Assigned to L1/L2 Engineer");
															mapp.put("Product_Category","Repair");
															mapp.put("Warehouse",i.Location);
															mapp.put("Purchase_Price",i.Price);
															mapp.put("Zoho_Books_ID",i.Books_Item_ID);
															mapp.put("GRN_Date",input.Date_field.toString("dd-MMM-yyyy"));
															mapp.put("GRN_Number",input.GRN_Number);
															mapp.put("Invoice_Number",input.Invoice_Number);
															mapp.put("PO_Number",input.PO_Number.PO_Number);
															empty_mapp = Map();
															create_rec = zoho.creator.createRecord("protaiga","oxypc-1","Product_Master_Inventory1",mapp,empty_mapp,"creator");
															sendmail
															[
																from :zoho.loginuserid
																to :"shubham.oxypc@gmail.com"
																subject :"Create record in Product Master Inventory map plus response"
																message :"Create record in Inventory after Desktop" + create_rec + "Mapp " + mapp
															]
															info "Inventory_records" + create_rec;
														}
														else
														{
															master_recs.Used_or_not="In-Zoho";
															master_recs.Purchase_Price=i.Price;
															master_recs.Customer_Name=i.Customer_Name;
															master_recs.GRN_Date=input.Date_field.toString("dd-MMM-yyyy");
															master_recs.GRN_Number=input.GRN_Number;
															master_recs.Invoice_Number=input.Invoice_Number;
															master_recs.PO_Number=input.PO_Number.PO_Number;
															if(master_recs.Warehouse == "Manesar")
															{
																master_recs.Warehouse="TRC 2ND Floor";
															}
														}
													}
													else if(tft_rec.count() > 0)
													{
														prdct_mstr_inv = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(tft_rec.TAG)];
														if(prdct_mstr_inv.count() == 0)
														{
															mapp = Map();
															mapp.put("Tag_No2",tft_rec.TAG);
															mapp.put("LOT_No",tft_rec.Lot_No1.LOT_No);
															// 	mapp.put("IQC_Submitted","Submitted");
