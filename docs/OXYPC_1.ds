    	{
            menu color = "#433d5a"
            header color = "#398ef3"
            name = "custom_color"
            brand color = "#398ef3"
            type = "custom"
            sub menu color = "#342e48"
            secondaryColor = "#433d5a"
    	}
    	logo
    	{
        	preference = "app_icon"
        	placement = "left"
    	}
	}

