			(
    			type = text
				displayname = "Part Type"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Lot_Number
			(
    			type = text
				displayname = "Lot Number"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Model
			(
    			type = text
	 			row = 1
	 			column = 2   
				width = medium
			)
			Part_Name
			(
    			type = text
				displayname = "Part Name"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Fill_section
			(
				type = section
				displayname = ""
				visibility = true
	 			row = 2
	 			column = 0   
				width = medium
			)
			Start_Time
			(
    			type = time
				displayname = "Start Time"
				initial value = "${zoho.currenttime}"	
				timedisplayoptions = "hh:mm:ss" 
	 			row = 2
	 			column = 1   
				width = medium
			)
			must have Paint
			(
				type = radiobuttons
				maxchar = 100
				values = {"Yes","No"}
				sortorder = ascending
	 			row = 2
	 			column = 1   
				width = medium
			)
			must have Status
			(
				type = picklist
				maxchar = 100
				values = {"Pass","Fail"}
				sortorder = ascending
	 			row = 2
	 			column = 1   
				width = medium
			)
			fail_Reason
			(
				type = picklist
				displayname = "Fail Reason"
				maxchar = 100
				values = {"Major Broken","Scrap"}
				sortorder = ascending
	 			row = 2
	 			column = 1   
				width = medium
			)
			Repair_date
			(
    			type = date
				displayname = "Date"
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 2
	 			column = 2   
				width = medium
			)
			must have Take_Action1
			(
				type = radiobuttons
				displayname = "Take Action"
				maxchar = 100
				values = {"Repairable","Not Repairable"}
				sortorder = ascending
	 			row = 2
	 			column = 2   
				width = medium
			)
			Remarks
			(
    			type = textarea
				displayname = " Remarks"
				height = 100px
	 			row = 2
	 			column = 2   
				width = medium
			)
	
			customize
			(
				icon = "tech-2-l-check"
			)
