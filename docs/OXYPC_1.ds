			Update_Product_Descriptio4 as "Update Product Description"
			{
				type =  form
				form = Raw_Data_Sales
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Make == "" || input.Make == null)
										{
											make_var = input.Updated_Make.Make;
										}
										else
										{
											make_var = input.Make;
										}
										if(input.Model == "" || input.Model == null)
										{
											model_var = input.Updated_Model.Model;
										}
										else
										{
											model_var = input.Model;
										}
										if(input.CPU == "" || input.CPU == null)
										{
											cpu_var = input.Update_CPU1;
										}
										else
										{
											cpu_var = input.CPU;
										}
										if(input.Generation == "" || input.Generation == null)
										{
											gen_var = input.Updated_Generation;
										}
										else
										{
											gen_var = input.Generation;
										}
										if(input.RAM == "" || input.RAM == null)
										{
											ram_var = input.Updated_RAM;
										}
										else
										{
											ram_var = input.RAM;
										}
										if(input.HDD == "" || input.HDD == null)
										{
											hdd_var = input.Updated_HDD;
										}
										else
										{
											hdd_var = input.HDD;
										}
										model_desc = make_var + " " + model_var + " " + cpu_var + " " + gen_var + " " + ram_var + " " + hdd_var;
										input.Product_Description = model_desc;
						)
					}
				}

			}
			Check_if_Final_QC_passed1 as "Check if Final QC passed"
			{
				type =  form
				form = Data_Sales
				record event = on add or edit

				on user input of Tag_Number
				{
					actions 
					{
						custom deluge script
						(
											// ##############------ Fetch data from Raw Data - Sales -------###############
										raw_data_rec = Raw_Data_Sales[Tag_Number.equalsIgnoreCase(input.Tag_Number)];
										if(raw_data_rec.count() > 0)
										{
											if(raw_data_rec.Updated_Make == null || raw_data_rec.Updated_Make == null)
											{
												input.Make = raw_data_rec.Make;
											}
											else
											{
												input.Make = raw_data_rec.Updated_Make.Make;
											}
											if(raw_data_rec.Updated_Model == null || raw_data_rec.Updated_Model == null)
											{
												input.Model = raw_data_rec.Model;
											}
											else
											{
												input.Model = raw_data_rec.Updated_Model.Model;
											}
											if(raw_data_rec.Updated_RAM == null || raw_data_rec.Updated_RAM == null)
											{
												input.RAM = raw_data_rec.RAM;
											}
											else
											{
												input.RAM = raw_data_rec.Updated_RAM;
											}
											if(raw_data_rec.Updated_HDD == null || raw_data_rec.Updated_HDD == null)
											{
												input.HDD = raw_data_rec.HDD;
											}
											else
											{
												input.HDD = raw_data_rec.Updated_HDD;
											}
											if(raw_data_rec.Updated_Generation == null || raw_data_rec.Updated_Generation == null)
											{
												input.Generation = raw_data_rec.Generation;
											}
											else
											{
												input.Generation = raw_data_rec.Updated_Generation;
											}
											if(raw_data_rec.Update_CPU1 == null || raw_data_rec.Update_CPU1 == null)
											{
												input.CPU = raw_data_rec.CPU;
											}
											else
											{
												input.CPU = raw_data_rec.Update_CPU1;
											}
											input.LOT_Number = raw_data_rec.LOT_Number;
											input.Serial_Number = raw_data_rec.Serial_Number;
										}
										else
										{
											alert "Tag Number Not Found in Raw Data";
											input.Tag_Number = null;
										}
						)
					}
				}

			}
			Hide_Fileds1 as "Hide Fileds"
			{
				type =  form
				form = Data_Sales
				record event = on add or edit

				on load
				{
