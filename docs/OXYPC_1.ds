			Update_L3_L4_Bucket_if_es2 as "Update L3/L4 Bucket if escalate to l4"
			{
				type =  form
				form = Desktop_L1_L2_Engineer_Screen1
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Final_Status == "Escalate to L4")
										{
											mapp = Map();
											mapp.put("Tag_No1",input.Barcode);
											mapp.put("Problem_Reported1",input.Problem_Reported);
											mapp.put("Received_from_Engineer",zoho.loginuser);
											mapp.put("Received_from","L1/L2 Engineer");
											mapp.put("Make",input.Make);
											mapp.put("Model",input.Model);
											mapp.put("CPU",input.CPU);
											mapp.put("Generation",input.Generation);
											mapp.put("Received_from_Engineer",input.Added_User);
											mapp.put("Problem_Reported",input.Problem_Reported);
											mapp1 = Map();
											create_rec = zoho.creator.createRecord("protaiga","oxypc-1","Repair_Completed_L3_L4",mapp,mapp1,"creator");
											newline = hextotext("0A");
											sendmail
											[
												from :zoho.loginuserid
												to :"shubham.oxypc@gmail.com"
												subject :"Creating record in L3/L4 Pending Bucket - Desktop"
												message :"Create REC MAP=> " + mapp + newline + "Create record response =>" + create_rec
											]
											info create_rec;
											// 	delete from Repair_Completed_L1_L2[Tag_No1 == input.Barcode];
										}
						)
					}
				}

			}
