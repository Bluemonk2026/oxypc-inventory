			Update_the_PC_Doctor_Valu as "Update the PC Doctor Values"
			{
				type =  form
				form = PC_Doctor_Sample
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											PC_Doctor_Sample = PC_Doctor_Sample[ID = input.ID];
										Serial_Number = PC_Doctor_Sample.System_serial_number;
										PC_Doctor_Sample_data = PC_Doctor_Sample[System_serial_number = Serial_Number];
										i = 0;
										for each  Data in PC_Doctor_Sample_data
										{
											Make = Data.System_oem.toList(" ").get(0).toUpperCase();
											input.System_model = Data.System_model;
											if(Data.device_type == "NVMe")
											{
												HDD1 = Data.device_select_details.toList(" ").get(0);
												HDD2 = Data.device_select_details.toList(" ").get(1);
												HDD = HDD1 + " " + HDD2;
											}
											else if(Data.device_type == "Memory" && Data.device_name == "System Memory")
											{
												Memory_RAM = Data.device_select_details;
											}
											else if(Data.device_type == "CPU")
											{
												CPU1 = Data.device_name.toList(" ").get(2);
											}
										}
										info Make;
										info input.System_model;
										info HDD.toString();
										info Memory_RAM;
										info CPU1.toList("-").get(0);
						)
					}
				}

			}
