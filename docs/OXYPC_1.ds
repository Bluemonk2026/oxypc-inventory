					{
						custom deluge script
						(
											if(Category == "HDD")
										{
											input.HDD_Capacity1:ui.add("128 GB");
											input.HDD_Capacity1:ui.add("250 GB");
											input.HDD_Capacity1:ui.add("64 GB");
											input.HDD_Capacity1:ui.add("320 GB");
											input.HDD_Capacity1:ui.add("500 GB");
											input.HDD_Capacity1:ui.add("1 TB");
											input.HDD_Capacity1:ui.add("2 TB");
											input.HDD_Capacity1:ui.add("3 TB");
											input.HDD_Capacity1:ui.add("4 TB");
											input.HDD_Capacity1:ui.add("5 TB");
											show HDD_Capacity1;
											hide HDD_Capacity;
										}
										if(Category == "SSD SATA" || Category == "SSD MSATA" || Category == "M.2")
										{
											input.HDD_Capacity:ui.add("128 GB");
											input.HDD_Capacity:ui.add("256 GB");
											input.HDD_Capacity:ui.add("64 GB");
											input.HDD_Capacity:ui.add("512 GB");
											input.HDD_Capacity:ui.add("1 TB");
											input.HDD_Capacity:ui.add("2 TB");
											input.HDD_Capacity:ui.add("4 TB");
											input.HDD_Capacity:ui.add("8 TB");
											input.HDD_Capacity:ui.add("16 TB");
											show HDD_Capacity;
											hide HDD_Capacity1;
										}
										if(Category == "NVNE")
										{
											input.HDD_Capacity:ui.add("128 GB");
											input.HDD_Capacity:ui.add("256 GB");
											input.HDD_Capacity:ui.add("512 GB");
											input.HDD_Capacity:ui.add("64 GB");
											input.HDD_Capacity:ui.add("1 TB");
											input.HDD_Capacity:ui.add("2 TB");
											input.HDD_Capacity:ui.add("4 TB");
											input.HDD_Capacity:ui.add("8 TB");
											show HDD_Capacity;
											hide HDD_Capacity1;
										}
										// if(Category == "HDD" || Category == "SSD" || Category == "SSD SATA" || Category == "NVNE" || Category == "M.2")
										// {
										// // 	hide Provide_Description1;
