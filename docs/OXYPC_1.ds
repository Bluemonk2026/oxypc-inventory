										mp.put("RAM_Cover_Rate",input.RAM_Cover_Rate);
										mp.put("WIFI",input.WIFI);
										mp.put("WIFI_replace",input.WIFI_replace);
										mp.put("WIFI_Rate",input.WIFI_Rate);
										mp.put("Battery",input.Battery);
										mp.put("Health_Battery",input.Health1);
										mp.put("Int_Battery",input.Int_Battery);
										mp.put("Health_Int_Battery",input.Health2);
										mp.put("Battery_Cable",input.Battery_Cable);
