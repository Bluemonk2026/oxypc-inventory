		form Spare_Parts_Costing_Report
		{
			displayname = "Spare Parts Rate List"
			success message = "Data Added Successfully!"
			field alignment = left
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			Date_field
			(
    			type = date
				displayname = "Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			Make
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			Model
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			Part
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			Part_Description
			(
    			type = formula
				displayname = "Part Description"
				value =  input.Make + input.Model + input.Part
				visibility = true
				format = plaintext
	 			row = 1
	 			column = 1   
				width = medium
			)
			Model_Description
			(
    			type = text
				displayname = "Model Description"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Rate
			(
				type = number
				displayname = "Current Rate"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Previous_Rate
			(
				type = number
				displayname = "Previous Rate"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Category
			(
				type = picklist
				maxchar = 100
				values = {"Laptop","Desktop","TFT"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Part_Type_New_Old
			(
				type = picklist
				displayname = "Part Type(New/Old)"
				maxchar = 100
				values = {"New","Old"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Udpate
			(
				type = checkboxes	
				values = {"Update"}
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			customize
			(
				icon = "shopping-cash-register"
			)
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
	}
