		default list TFT_L1_L2_Engineer_Screen_Report
		{
			displayName = "Repair - TFT Report"
			show all rows from TFT_L1_L2_Engineer_Screen    
			(
				Barcode as "Tag No."
				Time as "Start Time"
				LOT_No as "LOT No."
				checkbox as "Checkbox"
				Make
				Update_Make as "Update Make"
				New_Make as "New Make Value"
				Date_field as "Date"
				Engineer as "IQC Engineer"
				Final_Status as "Final Status"
				Problem_Reported as "Problem Reported"
				Remarks
				Screen_Size as "Screen Size"
				Screen_Type as "Screen Type"
				Serial_Number as "Serial Number"
				Modified_User as "Modified User"
				Modified_Time as "Submission Time"
			)
			conditional formatting
			(
				"Completed"
				{
				condition = (Final_Status == "Completed")
				fields = [Final_Status]
				format = "font-weight:bold;color:#ffffff;background-color:#5dc35a;"
				}
				"Not Completed"
				{
				condition = (Final_Status == "Escalate to L4" || Final_Status == "PNA" || Final_Status == "Scrap")
				fields = [Final_Status]
				format = "font-weight:bold;color:#ffffff;background-color:#ef1616;"
				}
			)
			quickview
			(
				layout
				(
		 			type = -1
					datablock1
