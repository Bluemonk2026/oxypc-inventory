			Create_Purchase_Receive_i as "Create Purchase Receive in ZOHO Books"
			{
				type =  form
				form = GRN_vs_IQC
				record event = on edit

				on update of IQC_Completed
				{
					actions 
					{
						custom deluge script
						(
											// if (IQC_Completed==True)
										// {
										GRN_Form = GRN_vs_IQC[ID = input.ID];
										Purchase_Order_Id = GRN_Form.Purchase_Order.Books_PO;
										PO_Number = GRN_Form.Purchase_Order.PO_Number;
										GRN_Form = GRN_vs_IQC[ID = input.ID];
										line_items = GRN_Form.Category_Wise_IQC_GRN;
										info line_items;
										item_list = List();
										for each  item in line_items
										{
											Item_Name = item.Category;
											Search_Product_Map = Map();
											Search_Product_Map.put("name",Item_Name);
											info Search_Product_Map;
											paramMap = {"organization_id":"60020430422"};
											get_record = invokeurl
											[
												url :"https://www.zohoapis.in/inventory/v1/items?name=" + Item_Name
												type :GET
												parameters:paramMap.toString()
												connection:"zoho_books"
												content-type:"application/json"
											];
											info get_record;
											// 		name=" + Item_Name + "&organization_id=60020430422
											Item_id = get_record.get("items").get(0).get("item_id");
											info Item_id;
											item_map = Map();
											item_map.put("item_id",Item_id);
											item_map.put("name",Item_Name);
											item_map.put("quantity",item.GRN_Count);
											item_map.put("serial_numbers",item.Tag_Numbers.toList());
											item_list.add(item_map);
										}
										info item_list;
										Main_Map = Map();
										// 	Main_Map.put("purchaseorder_id", Purchase_Order_Id);
										// 	Main_Map.put("purchaseorder", Purchase_Order_Id);
										// 	Main_Map.put("purchaseorder_number",PO_Number);
										Main_Map.put("receive_number",GRN_Form.GRN_Number);
										Main_Map.put("date",today.toDate().toString("yyyy-MM-dd"));
										Main_Map.put("line_items",item_list);
										// 	Main_Map.put("organization_id","60020430422");
										// 	Final_Map=Map();
										// 	Final_list=List();Final_list.add(Main_Map);
										// 	Final_Map.put("purchase_receive",Final_list);
										create_PR_in_Books = invokeurl
										[
											url :"https://www.zohoapis.in/inventory/v1/purchasereceives?purchaseorder_id=" + 1243157000000718057 + "&organization_id=60020430422"
											type :POST
											parameters:Main_Map.toString()
											connection:"zoho_books"
											content-type:"application/json"
										];
										info "Main_Map";
										info Main_Map;
										info create_PR_in_Books;
						)
					}
				}

			}
