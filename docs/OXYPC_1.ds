		default list GRN_Report
		{
			displayName = "GRN Report"
			template = Quantity_Variance
			show all rows from GRN    
			(
				Date_field as "Date"
				Vehicle_Number as "Vehicle Number"
				Invoice_Number as "Invoice Number"
				Invoice_Value as "Invoice Value"
				Added_User as "Added User"
				GRN_Number as "GRN Number"
				Lot_No as "Lot No."
				Invoice_Image as "Invoice Image"
				Vendor_Name as "Vendor Name"
				E_way_Bill as "E-Way Bill Image"
				Vehicle_Seal_Image as "Vehicle Seal Image"
				GRN as "GRN Number"
				Checkbox
				ID
				PO_Number as "PO Number"
				Added_Time as "Added Time"
				Total_Quantity as "Total Physical Quantity"
				For_Scheduler as "For Scheduler"
				Invoice_Date as "Invoice Date"
				Date_of_Material_Received as "Date of Material Received"
				PR_Books_ID as "PR Books ID"
				GRN_Number1 as "GRN Number_New"
				Vendor_Name_PO as "Vendor Name (PO)"
				Total_Purchase_Order_Quantity as "Total PO Quantity"
				Total_Purchase_Value as "Taxable Amount Invoice"
				Item
				(
					field = Item.Item_Name_Unused + " " + Item.Quantity + " " + Item.Price + " " + Item.Item_Value + " " + Item.Customer_Name + " " + Item.Sub_Category + " " + Item.Sub_Total + " " + Item.Lot_No + " " + Item.Location + " " + Item.ID + " " + Item.Tag_Numbers
				)
				GRN_Number_System as "GRN Number (System)"
				Total_Invoice as "Total Invoice Value"
				SGST_Invoice as "SGST Invoice"
				CGST_Invoice as "CGST Invoice"
				IGST_Invoice as "IGST Invoice"
			)
			options
			(
				icon = "design-bullet-list-67"
	 		)
			quickview
			(
				layout
				(
		 			type = -1
					datablock1
					(
						layout type = -1
						fields
						(
							GRN_Number_System as "GRN Number (System)"
							GRN_Number as "GRN Number"
							Date_field as "Date"
							Added_Time as "Added Time"
							Vehicle_Number as "Vehicle Number"
							Invoice_Number as "Invoice Number"
							Invoice_Value as "Invoice Value"
							Added_User as "Added User"
							Invoice_Image as "Invoice Image"
							Vendor_Name as "Vendor Name"
							E_way_Bill as "E-Way Bill Image"
							Vehicle_Seal_Image as "Vehicle Seal Image"
							Item.Item_Name_Unused as "Item"
							ID
							GRN as "GRN Number"
						)
					)
				)
				menu
    			(
    	 			header
    	 			(
    		 			Edit 
    		 			Duplicate 
    		 			Delete 
    	 			)
					record
					(
						Edit   	   
						Duplicate   	   
						Delete   	   
    				)
    			)
    			action
    			(
					on click
					(
						View Record   	   
    				)
					on right click
					(
						Edit   	   
						Delete   	   
						Duplicate   	   
						View Record   	   
    				)
     			)
			)
			detailview
			(
				layout
				(
		 			type = 1
					datablock1
					(
						layout type = -2
						fields
						(
							Date_field as "Date"
							Vehicle_Number as "Vehicle Number"
							Invoice_Number as "Invoice Number"
							Invoice_Value as "Invoice Value"
							GRN_Number as "GRN Number"
							Lot_No as "Lot No."
							Invoice_Image as "Invoice Image"
							Vendor_Name as "Vendor Name"
							E_way_Bill as "E-Way Bill Image"
							Vehicle_Seal_Image as "Vehicle Seal Image"
							GRN as "GRN Number"
							Checkbox
							PO_Number as "PO Number"
							Total_Quantity as "Total Physical Quantity"
							For_Scheduler as "For Scheduler"
							Invoice_Date as "Invoice Date"
							Date_of_Material_Received as "Date of Material Received"
							PR_Books_ID as "PR Books ID"
							GRN_Number1 as "GRN Number_New"
							Vendor_Name_PO as "Vendor Name (PO)"
							Total_Purchase_Order_Quantity as "Total PO Quantity"
							Total_Purchase_Value as "Taxable Amount Invoice"
							Total_Invoice as "Total Invoice Value"
							SGST_Invoice as "SGST Invoice"
							CGST_Invoice as "CGST Invoice"
							IGST_Invoice as "IGST Invoice"
						)
					)
				)
				menu
    			(
    	 			header
    	 			(
    		 			Edit 
    		 			Duplicate 
    		 			Delete 
    	 			)
    			)
			)
		}
		form Spare_Part_GRN
		{
			displayname = "Spare Part GRN"
			success message = "Data Added Successfully!"
			field alignment = left
			feature property = 64
			Section2
			(
				type = section
				displayname = "Section"
	 			row = 1
	 			column = 0   
				width = medium
			)
			PO_Number
			(
				type = picklist	
				displayname = " PO Number"
				values  = Purchase_Order[PO_Item_Type == "Spares"].ID
    			displayformat = [PO_Number]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Date_field
			(
    			type = date
				displayname = "Date of Material Received"
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			unique GRN_Number_System
			(
    			type = text
				displayname = "GRN Number."
	 			row = 1
	 			column = 1   
				width = medium
			)
			PO_Date
			(
    			type = date
				displayname = "PO Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Vendor_Name
			(
				type = picklist	
				displayname = "Vendor Name (PO)"
				values  = Vendors_Database.ID
    			displayformat = [Vendor_Name]
				allow new entries
				[
					displayname = "Enter Vendor Name"
				]
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			Section3
			(
				type = section
				displayname = ""
				visibility = true
	 			row = 2
	 			column = 0   
				width = medium
			)
			must have Invoice_Number
			(
    			type = text
				displayname = "Invoice Number    "
	 			row = 2
	 			column = 1   
				width = medium
			)
			E_Way_Bill_Number
			(
    			type = text
				displayname = "E-Way Bill Number"
	 			row = 2
	 			column = 1   
				width = medium
			)
			Vehicle_Number
			(
    			type = text
				displayname = "Vehicle Number"
	 			row = 2
	 			column = 1   
				width = medium
			)
			Grn_Autonumber
			(
    			type = autonumber
				displayname = "Grn Autonumber"
				start index = 1
	 			row = 2
	 			column = 1   
				width = medium
			)
			GRN_Number
			(
    			type = autonumber
				displayname = "GRN Number Creation"
				start index = 1
	 			row = 2
	 			column = 1   
				width = medium
			)
			GRN_Number3
			(
    			type = formula
				displayname = "GRN Number"
				value =  "SPI-" + input.Grn_Autonumber
				visibility = false
				format = plaintext
	 			row = 2
	 			column = 1   
				width = medium
			)
			GRN_Number2
			(
    			type = text
				displayname = "GRN Number"
	 			row = 2
	 			column = 1   
				width = medium
			)
			Pickup_cost
			(
				displayname = "Pickup cost"
				type = INR
				format = commadotindian
	 			row = 2
	 			column = 1   
				width = medium
			)
			must have Invoice_Date
			(
    			type = date
				displayname = "Invoice Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 2
	 			column = 2   
				width = medium
			)
			E_Way_Bill_Date
			(
    			type = date
				displayname = "E - Way Bill Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 2
	 			column = 2   
				width = medium
			)
			Vehicle_Seal_Image
			(
    			type = image
				displayname = "Vehicle Seal Image"
				source  = file
				aspect ratio = original
				camera = primary
				show gallery = true
				switch camera = true
	 			row = 2
	 			column = 2   
				width = medium
			)
			Freight_Cost
			(
				displayname = "Freight Cost"
				type = INR
				format = commadotindian
	 			row = 2
	 			column = 2   
				width = medium
			)
			Data_to_sbfrm
			(
				type = checkboxes	
				displayname = "Data to sbfrm"
				values = {"1"}
	 			row = 2
	 			column = 2   
				width = medium
			)
			must have Invoice_Image
			(
    			type = image
				displayname = "Invoice Image"
				source  = file
				aspect ratio = original
				camera = primary
				show gallery = true
				switch camera = true
	 			row = 2
	 			column = 3   
				width = medium
			)
			E_Way_Bill_Image
			(
    			type = image
				displayname = "E-Way Bill Image"
				source  = file
				aspect ratio = original
				camera = primary
				show gallery = true
				switch camera = true
	 			row = 2
	 			column = 3   
				width = medium
			)
			Vehicle_Image
			(
    			type = image
				displayname = "Vehicle Image"
				source  = file
				aspect ratio = original
				camera = primary
				show gallery = true
				switch camera = true
	 			row = 2
	 			column = 3   
				width = medium
			)
			Section4
			(
				type = section
				displayname = "Purchase Order Tax Details"
				visibility = true
	 			row = 3
	 			column = 0   
				width = medium
			)
			SGST
			(
				type = INR
				format = commadotindian
	 			row = 3
	 			column = 1   
				width = medium
			)
			Taxable_Amount
			(
				displayname = "Taxable Amount"
				type = INR
				format = commadotindian
	 			row = 3
	 			column = 1   
				width = medium
			)
			CGST
			(
				type = INR
				format = commadotindian
	 			row = 3
	 			column = 2   
				width = medium
			)
			Tax_Amount
			(
				displayname = "Tax Amount"
				type = INR
				format = commadotindian
	 			row = 3
	 			column = 2   
				width = medium
			)
			IGST
			(
				type = INR
				format = commadotindian
	 			row = 3
	 			column = 3   
				width = medium
			)
			Invoice_Value
			(
				displayname = "Invoice Value"
				type = INR
				format = commadotindian
	 			row = 3
	 			column = 3   
				width = medium
			)
			Items
			(
				type = grid
				values  = Spare_Parts_GRN.ID
				auto width = false
	 			row = 4
	 			column = 1   
				width = medium
			)
			Invoice_Quantity_Tax_Details
			(
				type = section
				displayname = "Invoice Quantity/Tax Details "
				visibility = true
	 			row = 5
	 			column = 0   
				width = medium
			)
			Total_PO_Quantity
			(
				type = number
				displayname = "Total PO Quantity"
	 			row = 5
	 			column = 1   
				width = medium
			)
			Variance
			(
				type = number
	 			row = 5
	 			column = 1   
				width = medium
			)
			SGST_Invoice
			(
				displayname = "SGST Invoice"
				type = INR
				format = commadotindian
	 			row = 5
	 			column = 1   
				width = medium
			)
			Total_Invoice_Quantity
			(
				type = number
				displayname = "Total Invoice Quantity"
	 			row = 5
	 			column = 2   
				width = medium
			)
			Total_Purchase_Value_Without_Tax
			(
				displayname = "Taxable Amount Invoice"
				type = INR
				format = commadotindian
	 			row = 5
	 			column = 2   
				width = medium
			)
			CGST_Invoice
			(
				displayname = "CGST Invoice"
				type = INR
				format = commadotindian
	 			row = 5
	 			column = 2   
				width = medium
			)
			Total_Quantity
			(
				type = number
				displayname = "Total Physical Quantity"
	 			row = 5
	 			column = 3   
				width = medium
			)
			Total_Invoice_Value
			(
				displayname = "Total Invoice Value"
				type = INR
				format = commadotindian
	 			row = 5
	 			column = 3   
				width = medium
			)
			IGST_Invoice
			(
				displayname = "IGST Invoice"
				type = INR
				format = commadotindian
	 			row = 5
	 			column = 3   
				width = medium
			)
	
			customize
			(
				icon = "sport-energy-supplement"
			)
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
