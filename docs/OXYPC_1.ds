		form Faulty_Spare_Parts_After_IQC1
		{
			displayname = "Faulty Spare Parts After IQC1"
			success message = "Data Added Successfully!"
			field alignment = left
					hide = true
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			Lot_No1
			(
				type = picklist	
				displayname = "Lot No."
				values  = LOT_No_s_GRN.ID
    			displayformat = [LOT_No]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Lot_No
			(
    			type = text
				displayname = "Lot No."
	 			row = 1
	 			column = 1   
				width = medium
			)
			Make
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			Model
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			Aging
			(
    			type = formula
				value =  daysBetween(input.Modified_Time,zoho.currenttime).toLong().abs()
				visibility = false
	 			row = 1
	 			column = 1   
				width = medium
			)
			Checkbox
			(
				type = checkboxes	
				values = {"Update"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Model_Description
			(
    			type = text
				displayname = "Model Description"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Category
			(
				type = picklist
				maxchar = 100
				values = {"Desktop","Laptop","TFT"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Spare_Part
			(
    			type = text
				displayname = "Spare Part"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Spare_Part_Desktop
			(
				type = picklist	
				displayname = "Spare Part - Desktop"
				values  = Spare_Parts2[Category == "Desktop"].ID
    			displayformat = [Spare_Part_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Spare_Part1
			(
				type = picklist	
				displayname = "Spare Part - Laptop"
				values  = Spare_Parts2[Category == "Laptop"].ID
    			displayformat = [Spare_Part_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Price
			(
				type = INR
				format = commadotindian
	 			row = 1
	 			column = 1   
				width = medium
			)
			Tag_No
			(
				type = picklist	
				displayname = "Tag No. - Laptop"
				values  = IQC_Format_for_Laptop.ID
    			displayformat = [TAG_NO]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Tag_No1
			(
    			type = text
				displayname = "Tag No. - Desktop"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Quantity
			(
				type = number
				initial value = 1
	 			row = 1
	 			column = 1   
				width = medium
			)
			Status
			(
				type = picklist
				maxchar = 100
				values = {"Repaired","Replaced","OK","PNA"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Consumed_By
			(
    			type = picklist
				displayname = "L1/L2 Engineer Name"
				module = users
				displayformat = [username]
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			L1_L2_Engineer_Date
			(
    			type = date
				displayname = "L1/L2 Engineer Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			L1_L2_Engineer_Time
			(
    			type = time
				displayname = "L1/L2 Engineer Time"
				timedisplayoptions = "hh:mm:ss" 
	 			row = 1
	 			column = 1   
				width = medium
			)
			Final_QC
			(
				type = picklist
				displayname = "Final QC"
				maxchar = 100
				values = {"Pass","Fail"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Replaced_Part_Updated
			(
				type = checkboxes	
				displayname = "Replaced Part Updated"
				values = {"Done","True"}
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			customize
			(
				icon = "sport-energy-supplement"
			)
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
