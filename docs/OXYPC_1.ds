						(
											iqc_rec = IQC_Format_for_Laptop[TAG_NO.equalsIgnoreCase(input.Barcode)];
										if(iqc_rec.count() != 0 && iqc_rec.ALL_OK == "Ok" && iqc_rec.HDD_1 == "Yes" && iqc_rec.RAM_1 == "Yes")
										{
											alert "Warning : This Laptop assigned for QC";
											input.Barcode = "";
