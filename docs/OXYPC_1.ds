				displayname = "Tag Number"
	 			row = 6
	 			column = 1   
				width = medium
			)
			Make2
			(
    			type = text
				displayname = "Make"
	 			row = 6
	 			column = 1   
				width = medium
			)
			CPU1
			(
    			type = text
				displayname = "CPU"
	 			row = 6
	 			column = 1   
				width = medium
			)
			RAM1
			(
    			type = text
				displayname = "RAM"
	 			row = 6
	 			column = 1   
				width = medium
