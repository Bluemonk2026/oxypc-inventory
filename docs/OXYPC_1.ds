	section Desktop_Production
	{
		displayname= "Desktop Production"
		form IQC_Format_for_Desktop
		{
			displayname = "IQC Form - Desktop"
			success message = "Data Added Successfully!"
			field alignment = left
			feature property = 256
			Tagging_Section
			(
				type = section
				displayname = "Basic Information"
				visibility = true
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have unique Tag_No
			(
    			type = text
				displayname = "Tag No"
				maxchar = 15
				qrcode = true
				barcode = true
				camera = primary
				show gallery = true
				switch camera = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Make
			(
				type = picklist	
				values  = Make_for_Desktop.ID
    			displayformat = [Make]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have LOT_No1
			(
				type = picklist	
				displayname = "LOT No."
				values  = LOT_No_s_GRN.ID
    			displayformat = [LOT_No]
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
