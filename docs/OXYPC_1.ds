				type = picklist
				displayname = "Problem Reported"
				maxchar = 100
				values = {"No Display","No Power","USB","VGA","DP","HDMI","CPU Pin Damage","Others"}
				sortorder = ascending
	 			row = 4
	 			column = 2   
				width = medium
