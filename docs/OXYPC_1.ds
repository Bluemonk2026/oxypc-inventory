						custom deluge script
						(
											// // Last working code  
										// result = PreSales_QC[Customer_Name.Customer_Name == input.Customer && Final_Status == "Ok" && Product_Stage != "Sold Out"];
										// customer_master = Customer_Database[Customer_Name == input.Customer];
										// input.Customer_location = customer_master.Customer_location;
										// data_rec = Collection();
										// product_count = Map();
										// tag_numbers_map = Map();
										// // New map to store tag numbers for each product description
										// // Loop through the filtered results to count occurrences of each product description
										// for each  line_item in result
										// {
										// 	product_desc = line_item.Product_Description;
										// 	// Check if the product description is already in the map
										// 	if(product_count.containKey(product_desc))
										// 	{
										// 		// Increment the count for this product description
										// 		product_count.put(product_desc,product_count.get(product_desc) + 1);
										// 		// Add the tag number to the list in tag_numbers_map
										// 		tag_numbers_map.put(product_desc,tag_numbers_map.get(product_desc) + ", " + line_item.Tag_Number);
										// 	}
										// 	else
										// 	{
										// 		// Initialize the count for this new product description
										// 		product_count.put(product_desc,1);
										// 		// Initialize the tag number for this new product description
										// 		tag_numbers_map.put(product_desc,line_item.Tag_Number);
										// 	}
										// }
										// // Create line items based on the counted products
										// for each  product_desc in product_count.keys()
										// {
										// 	obj = Sales_Form.Line_Items();
										// 	obj.Product_Name=product_desc;
										// 	obj.Quantity=product_count.get(product_desc);
										// 	obj.Tag_Numbers=tag_numbers_map.get(product_desc);
										// 	// Store all tag numbers in a multiline field
										// 	// Set the Category from the first occurrence of the product description
										// 	for each  line_itemx in result
										// 	{
										// 		if(line_itemx.Product_Description == product_desc)
										// 		{
										// 			obj.Category=line_itemx.Category;
										// 		}
										// 	}
										// 	data_rec.insert(obj);
										// }
										// // info data_rec.size();
										// if(data_rec.size() == 0)
										// {
										// 	alert "Product havent added in presales";
										// }
										// input.Line_Items.clear();
										// input.Line_Items.insert(data_rec);
						)
					}
					actions 
					{
						custom deluge script
						(
											// Updated code based on product description 
										result = PreSales_QC[Customer_Name.Customer_Name == input.Customer && Final_Status == "Ok" && Product_Stage != "Sold Out"];
										customer_master = Customer_Database[Customer_Name == input.Customer];
										input.Customer_location = customer_master.Customer_location;
										data_rec = Collection();
										product_count = Map();
										tag_numbers_map = Map();
										// New map to store tag numbers for each product description
										// Loop through the filtered results to count occurrences of each product description
										for each  line_item in result
										{
											product_desc = line_item.Product_Description;
											// Check if the product description is already in the map
											if(product_count.containKey(product_desc))
											{
												// Increment the count for this product description
												product_count.put(product_desc,product_count.get(product_desc) + 1);
												// Add the tag number to the list in tag_numbers_map
												tag_numbers_map.put(product_desc,tag_numbers_map.get(product_desc) + ", " + line_item.Tag_Number);
											}
											else
											{
												// Initialize the count for this new product description
												product_count.put(product_desc,1);
												// Initialize the tag number for this new product description
												tag_numbers_map.put(product_desc,line_item.Tag_Number);
											}
										}
										// Create line items based on the counted products
										for each  product_desc in product_count.keys()
										{
											obj = Sales_Form.Line_Items();
											obj.Product_Name=product_desc;
											obj.Quantity=product_count.get(product_desc);
											obj.Tag_Numbers=tag_numbers_map.get(product_desc);
											// Store all tag numbers in a multiline field
											// Set the Category from the first occurrence of the product description
											for each  line_itemx in result
											{
												if(line_itemx.Product_Description == product_desc)
												{
													obj.Category=line_itemx.Category;
												}
											}
											data_rec.insert(obj);
										}
										// info data_rec.size();
										if(data_rec.size() == 0)
										{
											alert "Product havent added in presales";
										}
										input.Line_Items.clear();
										input.Line_Items.insert(data_rec);
						)
					}
				}

			}
