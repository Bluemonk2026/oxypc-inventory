			Check_if_the_HDD_and_RAM_ as "Check if the HDD and RAM sub-fields are empty"
			{
				type =  form
				form = IQC_Format_for_Laptop
				record event = on add or edit
					status = inactive

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.HDD_1 == "Yes" && input.Category == "" || input.HDD_Capacity1 == "" || input.HDD_Capacity == "")
										{
											alert "Please Fill the HDD Fields";
											cancel submit;
										}
										if(input.RAM_1 == "Yes" && input.RAM_Type == "" || input.Capacity == "" || RAM_Status == "")
										{
											alert "Please Fill the RAM Fields";
											cancel submit;
										}
						)
					}
				}

			}
			Send_harvested_Parts_to_H as "Send harvested Parts to Harvest inventory"
			{
				type =  form
				form = L1_L2_Engineer_Screen
				record event = on add
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											row1 = L1_L2_Engineer_Screen.faults();
										for each  i in faults
										{
											if(i.Status == "Replaced")
											{
												mapp = Map();
												mapp.put("Spare_Part_Name",i.Spare_Part);
												make_val = Make[Make == input.Make];
												mapp.put("Make",make_val.ID);
												Model_val = Model[Model == input.Model];
												mapp.put("Model",Model_val.ID);
												mapp.put("In_Quantity",i.Quantity);
												mapp.put("Spare_Part_Category","IT");
												// 	mapp.put("Spare_Part_Sub_Category",inp)
												mapp.put("Tag_No",i.Tag_No);
												mapp1 = Map();
												zoho.creator.createRecord("protaiga","oxypc-1","Harvested_Parts1",mapp,mapp1,"creator");
											}
										}
						)
					}
				}

			}
