			Updaet_data_in_SPP as "Updaet data in SPP"
			{
				type =  form
				form = Spare_Parts
				record event = on edit

				on update of data_change
				{
					actions 
					{
						custom deluge script
						(
											Spare_part_Make = input.Make.Make;
										Spare_part_Model = input.Model.Model;
										Spare_part_Name = input.Spare_Part_Name;
										Spare_Part_Planning_Data = Spare_Part_Planning[Make = Spare_part_Make && Model == Spare_part_Model];
										if(input.Spare_Part_Name.toLowerCase() == "panel")
										{
											Spare_Part_Planning_Data.Panel_SOH=input.Total_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "wifi")
										{
											Spare_Part_Planning_Data.Wifi_SOH=input.Total_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "web cam")
										{
											Spare_Part_Planning_Data.Web_Cam_SOH=input.Total_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "usb card")
										{
											Spare_Part_Planning_Data.USB_SOH=input.Total_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "touchpad")
										{
											Spare_Part_Planning_Data.Touch_Pad_SOH=input.Total_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "screen faulty" || input.Spare_Part_Name.toLowerCase() == "screen 30 pin" || input.Spare_Part_Name.toLowerCase() == "screen")
										{
											Spare_Part_Planning_Data.Screen_SOH=input.Total_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "ram cover")
										{
											Spare_Part_Planning_Data.RAM_Cover_SOH=input.Total_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "ram")
										{
											Spare_Part_Planning_Data.RAM_SOH=input.Total_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "logic card")
										{
											Spare_Part_Planning_Data.Logic_Card_SOH=input.Total_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "keyboard")
										{
											Spare_Part_Planning_Data.Keyboard_SOH=input.Total_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "hinge cover")
										{
											Spare_Part_Planning_Data.Hinge_Cover_SOH=input.Total_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "hinge")
										{
											Spare_Part_Planning_Data.Hinge_SOH=input.Total_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "hdd cover")
										{
											Spare_Part_Planning_Data.HDD_Cover_SOH=input.Total_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "hdd connector")
										{
											Spare_Part_Planning_Data.HDD_Connector_SOH=input.Total_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "hdd")
										{
											Spare_Part_Planning_Data.HDD_SOH=input.Total_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "dvd flap")
										{
											Spare_Part_Planning_Data.DVD_Flap_SOH=input.Total_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "base")
										{
											Spare_Part_Planning_Data.Base_SOH=input.Total_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "battery cable")
										{
											Spare_Part_Planning_Data.Battery_Cable_SOH=input.Total_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "battery")
										{
											Spare_Part_Planning_Data.Battery_SOH=input.Total_SOH;
										}
										else if(input.Spare_Part_Name.toLowerCase() == "base")
										{
											Spare_Part_Planning_Data.Base_SOH=input.Total_SOH;
										}
						)
					}
				}

			}
			Proper_formatting_of_tag_ as "Proper formatting of tag number"
			{
				type =  form
				form = L1_L2_Engineer_Screen
				record event = on add or edit
					status = inactive

				on user input of Barcode
				{
					actions 
					{
						custom deluge script
						(
											if(input.Barcode != null || input.Barcode != "")
										{
											if(input.Barcode.contains("O") || input.Barcode.contains("o") || input.Barcode.contains(" "))
											{
												alert "Please Correct the Barcode No.!!";
												input.Barcode = "";
											}
											if(input.Barcode.length() < 10 && input.Barcode != "")
											{
												alert "Please Enter 10 digit Barcode Number";
												input.Barcode = "";
											}
											if(input.Barcode.startswith("SN") is false && input.Barcode != "")
											{
												alert "Barcode Number should start with 'SN'";
												input.Barcode = "";
											}
										}
						)
					}
				}

			}
