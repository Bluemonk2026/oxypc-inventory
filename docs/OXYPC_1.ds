										info price_prcnt;
										row.Unit_Price_With_Tax_18=row.Price + price_prcnt;
										// for each  i in input.Item
										// {
										// 	price_prcnt = i.Price * 0.18;
										// 	i.Unit_Price_With_Tax_18=i.Price + price_prcnt;
										// }
						)
					}
				}

			}
			Update_Spare_Part_Invento as "Update Spare Part Inventory"
			{
				type =  form
				form = Spare_Part_GRN
				record event = on add
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											for each  i in input.Items
										{
											info "Makeee_id ===>> " + i.Make1;
											make_val = Make_Spare_Part[ID == i.Make1].Make;
											model_val = Model_Spare_Part[ID == i.Model].Model;
											spare_part_name_val = Spare_Parts2[ID == i.Spare_Part_Name].Spare_Part_Name;
											info make_val;
											info model_val;
											info spare_part_name_val;
											recs = Spare_Parts[Make == i.Make1 && Model == i.Model && Spare_Part_Name.equalsIgnoreCase(spare_part_name_val)];
											info "Inventory_recs ==>" + recs;
											if(recs.count() == 0)
											{
												data_mapp = Map();
												data_mapp.put("Make",i.Make1);
												data_mapp.put("Model",i.Model);
												data_mapp.put("Spare_Part_Name1",i.Spare_Part_Name);
												data_mapp.put("Spare_Part_Name",i.Spare_Part_Name.Spare_Part_Name);
												data_mapp.put("Available_SOH",i.Physical_Quantity);
												data_mapp.put("Rate_New",i.Price);
												product_description = i.Make1.Make + " " + i.Model.Model + " " + i.Spare_Part_Name.Spare_Part_Name;
												data_mapp.put("Part_Description",product_description);
												empty_mapp = Map();
												create_rec = zoho.creator.createRecord("protaiga","oxypc-1","Spare_Parts",data_mapp,empty_mapp,"creator");
												info "Creating record in SP Inv ++++= > " + create_rec;
											}
											else
											{
												info recs.Available_SOH;
												if(recs.Available_SOH == null)
												{
													recs.Available_SOH=0 + i.Physical_Quantity;
													recs.Rate_New=i.Price;
												}
												else
												{
													info "entered in else --> " + (recs.Available_SOH + i.Physical_Quantity);
													recs.Available_SOH=recs.Available_SOH + i.Physical_Quantity;
													recs.Rate_New=i.Price;
												}
											}
										}
						)
					}
				}

			}
			Update_Inventory_after_GR as "Update Inventory after GRN"
			{
				type =  form
				form = GRN
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											for each  i in input.Item
										{
											info "Tagggggggggg ------ >>>>> " + i.Tag_Numbers;
											if(i.Tag_Numbers == null)
											{
												// 		
