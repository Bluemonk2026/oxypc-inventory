										if(input.Generation == null || input.Generation == "" && input.CPU != null || input.CPU != "")
										{
											model_desc = input.Make.Make + " " + input.Model1.Model + " " + input.CPU;
											input.Model_Description1 = model_desc;
										}
										if(input.Generation == null || input.Generation == "" && input.CPU == null || input.CPU == "")
										{
											model_desc = input.Make.Make + " " + input.Model1.Model;
											input.Model_Description1 = model_desc;
										}
										else
										{
											model_desc = input.Make.Make + " " + input.Model1.Model + " " + input.CPU + " " + input.Generation;
											input.Model_Description1 = model_desc;
										}
						)
					}
				}

