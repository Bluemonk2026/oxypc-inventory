			Update_Master_Inventory as "Update Master Inventory"
			{
				type =  schedule
				form = L1_L2_Engineer_Screen
				start = after 5 minutes from Added_Time
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						product_master = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(input.Barcode)];
										if(product_master.count() != 0)
										{
											NewMake = input.New_Make;
											if(input.New_Make == "" || input.New_Make == null)
											{
												product_master.Make=input.Make;
												// 		product_master.Make = input.Make;
												// 		info input.Make;
											}
											else
											{
												// 		product_master.Make=input.New_Make;
												product_master.Make=input.New_Make;
												info "===============----------" + product_master.Make;
											}
											if(input.New_Model_Value == "" || input.New_Model_Value == null)
											{
												// 		product_master.Model=input.Model;
												product_master.Model=input.Model;
											}
											else
											{
												// 		product_master.Model=input.New_Model_Value;
												product_master.Model=input.New_Model_Value;
											}
											if(input.New_Generation_Value == "" || input.New_Generation_Value == null)
											{
												product_master.Generation=input.Generation;
											}
											else
											{
												// 		product_master.L1Generation=input.New_Generation_Value;
												product_master.Generation=input.New_Generation_Value;
											}
											if(input.New_CPU_Value == "" || input.New_CPU_Value == null)
											{
												product_master.CPU=input.CPU;
											}
											else
											{
												// 		product_master.L1CPU=input.New_CPU_Value;
												product_master.CPU=input.New_CPU_Value;
											}
											if(input.Removed_Capacity == "" || input.Removed_Capacity == null)
											{
												if(input.Added_Capacity == "" || input.Added_Capacity == null)
												{
													product_master.RAM=input.RAM;
												}
												else
												{
													product_master.RAM=input.Added_Capacity;
												}
											}
											else
											{
												product_master.RAM=input.Removed_Capacity;
											}
											if(input.Removed_Capacity1 == "" || input.Removed_Capacity1 == null)
											{
												if(input.Added_Capacity1 == "" || input.Added_Capacity1 == null)
												{
													product_master.HDD=input.HDD;
												}
												else
												{
													product_master.HDD=input.Added_Capacity1;
												}
											}
											else
											{
												product_master.HDD=input.Removed_Capacity1;
											}
											// 	product_master.Dust_Cleaning=input.Dust_Cleaning;
											// 	product_master.C_MOS_Battery_Change=input.C_MOS_Battery_Change;
											// 	product_master.CPU_Thermal_Paste=input.CPU_Thermal_Paste1;
											// 	product_master.Final_Status=input.Final_Status;
											// 	product_master.L1_L2_Engineer="Submitted";
											// 	product_master.Action_Taken_RAM=input.Action_Taken_RAM;
											// 	product_master.Added_Capacity=input.Added_Capacity;
											product_master.L1_L2_Date=zoho.currentdate.toString("dd-MMM-yyyy");
											// 	product_master.Time_L3_L4_Engineer=zoho.currenttime;
											if(input.Final_Status == "Completed")
											{
												product_master.Product_Stages="Assigned to QC";
												product_master.Product_Category="QC";
											}
											else if(input.Final_Status == "Escalate to L4")
											{
												product_master.Product_Stages="Assigned to L3/L4";
												product_master.Product_Category="L4 Repair";
											}
											else if(input.Final_Status == "PNA")
											{
												product_master.Product_Stages="PNA(Part not available)";
												product_master.Product_Category="PNA";
											}
											else if(input.Final_Status == "Scrap")
											{
												product_master.Product_Stages="Scrap";
												product_master.Product_Category="Scrap";
											}
											else if(input.Final_Status == "BER")
											{
												product_master.Product_Stages="BER";
												product_master.Product_Category="BER";
											}
											else if(input.Final_Status == "Escalate to Plastic Repair")
											{
												product_master.Product_Stages="Assigned to L1/L2 Engineer";
												product_master.Product_Category="Plastic Repair";
											}
											info "testing done ";
											product_master.Used_or_not="In-Zoho";
											product_master.Warehouse="TRC 2ND Floor";
										}
										else
										{
										}
					)
					}
				}
			}
