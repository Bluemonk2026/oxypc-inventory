	section Classifications_of_Make_and_Model
	{
		displayname= "Classifications of Make and Model"
		icon = "travel-world"
		form Classifications_of_Make_and_Model
		{
			displayname = "Classifications of Make and Model"
			success message = "Data Added Successfully!"
			field alignment = left
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			Make
			(
				type = picklist	
				values  = Make.ID
    			displayformat = [Make]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Model
			(
				type = picklist	
				values  = Model[Make.ID == input.Make].ID
    			displayformat = [Model]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			CPU
			(
				type = picklist	
				values  = CPU_Master[Make.ID == input.Make && Model.ID == input.Model].ID
    			displayformat = [CPU]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Generation
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			customize
			(
				icon = "travel-world"
			)
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
