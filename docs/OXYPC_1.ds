			Change_options_for_Wareho as "Change options for Warehouse"
			{
				type =  form
				form = Sales_Orders
				record event = on add or edit

				on user input of Branch
				{
					actions 
					{
						custom deluge script
						(
											if(input.Branch != null)
										{
											if(input.Branch == "Nehru Place")
											{
												input.Warehouse:ui.add("Nehru Place (Delhi)");
											}
											else if(input.Branch == "Gurgaon")
											{
												input.Warehouse:ui.add("TRC 2ND Floor");
												input.Warehouse:ui.add("Bluemonk House Showroom");
												input.Warehouse:ui.add("Bluemonk House Basement");
												input.Warehouse:ui.add("Manesar");
											}
											else if(input.Branch == "Mumbai")
											{
												input.Warehouse:ui.add("Mumbai");
											}
										}
						)
					}
				}

			}
