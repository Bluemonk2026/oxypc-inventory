				 void UpdateModelDescription()
                 {
                 	final_qc_rec = Final_QC1[ID != 0];
                 	for each  i in final_qc_rec
                 	{
                 		if(i.Make == "" || i.Make == null)
                 		{
                 			make_var = i.Updated_Make.Make;
                 		}
                 		else
                 		{
                 			make_var = i.Make;
                 		}
                 		if(i.Model == "" || i.Model == null)
                 		{
                 			model_var = i.Updated_Model.Model;
                 		}
                 		else
                 		{
                 			model_var = i.Model;
                 		}
                 		if(i.CPU == "" || i.CPU == null)
                 		{
                 			cpu_var = i.Update_CPU1;
                 		}
                 		else
                 		{
                 			cpu_var = i.CPU;
                 		}
                 		if(i.Generation == "" || i.Generation == null)
                 		{
                 			gen_var = i.Updated_Generation;
                 		}
                 		else
                 		{
                 			gen_var = i.Generation;
                 		}
                 		if(i.RAM == "" || i.RAM == null)
                 		{
                 			ram_var = i.Updated_RAM;
                 		}
                 		else
                 		{
                 			ram_var = i.RAM;
                 		}
                 		if(i.HDD == "" || i.HDD == null)
                 		{
                 			hdd_var = i.Updated_HDD;
                 		}
                 		else
                 		{
                 			hdd_var = i.HDD;
                 		}
                 		model_desc = make_var + " " + model_var + " " + cpu_var + " " + gen_var + " " + ram_var + " " + hdd_var;
                 		i.Product_Description=model_desc;
                 	}
                 }
				 void UpdateRAM()
                 {
                 	fet = IQC_Format_for_Laptop[ID != 0];
                 	for each  rec in fet
                 	{
                 		for each  Selection in rec.HDD
                 		{
                 			var = Selection.tostring();
                 		}
                 		rec.HDD_1=var;
                 	}
                 }
