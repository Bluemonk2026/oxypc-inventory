			Create_Sales_Order_in_Zoh as "Create Sales Order in Zoho Books"
			{
				type =  form
				form = Sales_Orders
				record event = on add
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											// ################## - Creating SO in Books - #########################
										mapp = Map();
										mapp.put("customer_id","1243157000003697001");
										line_items_lst = List();
										for each  i in Item_Table
										{
											line_item_mapp = Map();
											line_item_mapp.put("item_id",i.Product_Books_ID);
											line_item_mapp.put("rate",i.Rate);
											line_item_mapp.put("name",i.Product_Name.Product_Description);
											line_item_mapp.put("description",i.Product_Name.Product_Description);
											line_item_mapp.put("quantity",i.Quantity);
											line_item_mapp.put("product_type","goods");
											line_item_mapp.put("warehouse_id","1243157000002593007");
											line_item_mapp.put("warehouse_name","Finalized Inventory");
											// 	line_item_mapp.put();
											line_items_lst.add(line_item_mapp);
										}
										mapp.put("line_items",line_items_lst);
										books_so = invokeurl
										[
											url :"https://www.zohoapis.in/books/v3/salesorders?organization_id=60020430422"
											type :POST
											parameters:mapp.toString()
											connection:"zoho_books"
										];
										info books_so;
										input.Sales_Order_Number11 = books_so.get("salesorder").get("salesorder_number");
										input.SO_Books_ID = books_so.get("salesorder").get("salesorder_id");
										//--#############################-- Creating Invoice --####################################################
										salesorderID = input.SO_Books_ID;
										items_mapp = Map();
										// items_mapp.put("serial_numbers",input.Item_Table.)
										// salesorderdate = input.Sales_Order_Date;
										organizationID = "60020430422";
										// customerID = salesorder.get("customer_id");
										mp = Map();
										mp.put("organization_id",organizationID);
										// 	mp.put("line_items",line_items_lst);
										// 	mp.put("serial_numbers",serial_numb_lst);
										sendmail
										[
											from :zoho.loginuserid
											to :"shubham.namdev@crm-masters.com"
											subject :"Mapp for creating invoice"
											message :"mp" + mp
										]
										result = invokeurl
										[
											url :"https://books.zoho.in/api/v3/invoices/fromsalesorder?salesorder_id=" + salesorderID
											type :POST
											parameters:mp
											connection:"zoho_books"
										];
										sendmail
										[
											from :zoho.loginuserid
											to :"shubham.namdev@crm-masters.com"
											subject :"Testing Convert to Invoice button"
											message :result
										]
										// 	##############################--- Updating Serial Numbers in Invoice -- #######################################
										invoice_id = result.get("invoice").get("invoice_id");
										mapp = Map();
										line_items_lst = List();
										for each  k in input.Item_Table
										{
											itm_mapp = Map();
											itm_mapp.put("item_id",k.Product_Books_ID);
											itm_mapp.put("track_serial_for_package",true);
											itm_mapp.put("serial_numbers",k.Serial_Number);
											line_items_lst.add(itm_mapp);
										}
										mapp.put("line_items",line_items_lst);
										update_inv = invokeurl
										[
											url :"https://www.zohoapis.in/books/v3/invoices/" + invoice_id + "?organization_id=60020430422"
											type :PUT
											parameters:mapp.toString()
											connection:"zoho_books"
										];
										sendmail
										[
											from :zoho.loginuserid
											to :"shubham.namdev@crm-masters.com"
											subject :"Testing Update invoice"
											message :"Update_Invoice : " + update_inv
										]
						)
					}
				}

			}
			Make_Fields_Mandatory as "Make Fields Mandatory"
			{
				type =  form
				form = IQC_Format_for_TFT
				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.Power == "" || input.Power == null)
										{
											alert "Please Fill Power";
											cancel submit;
										}
										if(input.Power_Button == "" || input.Power_Button == null)
										{
											alert "Please Fill Power_Button";
											cancel submit;
										}
										if(input.USB_Port == "" || input.USB_Port == null)
										{
											alert "Please Fill USB_Port";
											cancel submit;
										}
										if(input.Menu_Button == "" || input.Menu_Button == null)
										{
											alert "Please Fill Menu_Button";
											cancel submit;
										}
										if(input.VGA_Port == "" || input.VGA_Port == null)
										{
											alert "Please Fill VGA_Port";
											cancel submit;
										}
										if(input.HDMI_Port == "" || input.HDMI_Port == null)
										{
											alert "Please Fill HDMI_Port";
											cancel submit;
										}
										if(input.DP_Port == "" || input.DP_Port == null)
										{
											alert "Please Fill DP_Port";
											cancel submit;
										}
										if(input.DVI_Port == "" || input.DVI_Port == null)
										{
											alert "Please Fill DVI_Port";
											cancel submit;
										}
										if(input.Status == "Scrap" && input.Scrap_Reason == "")
										{
											alert "Please Fill Scrap Reason!!";
											cancel submit;
										}
										if(input.Status == "Faulty" && input.Screen_Status == "")
										{
											alert "Please Fill Faults!!";
											cancel submit;
										}
						)
					}
				}

			}
			Update_Warehouse_in_recor1 as "Update Warehouse in records in master"
			{
				type =  form
				form = GRN
				record event = on add or edit
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											for each  i in Item
										{
											make = Make_for_GRN[ID == i.Make].Make;
											model = Product_Master_for_GRN[ID == i.Model].Model;
											info "GRN_Make =" + make;
											info "GRN_Model =" + model;
											info "Lot_no =" + i.Lot_No;
											mstr_updt_recs = Product_Master_Inventory1[LOT_No == i.Lot_No && Make.equalsIgnoreCase(make) && Model.equalsIgnoreCase(model)];
											info "Masteerrrrrrrrrrrrrrrrrrrrrrrrrr reccccccccccccccc countttttttttttttttttttt ----->" + mstr_updt_recs.count();
											for each  j in mstr_updt_recs
											{
												j.Warehouse=i.Location;
												// 		j.LOT_No=i.Lot_No;
												j.Customer_Name=i.Customer_Name;
												j.Purchase_Price=i.Price;
											}
										}
						)
					}
				}

			}
			Update_Product_Descriptio3 as "Update Product Description"
			{
				type =  form
				form = Final_QC1
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Make == "" || input.Make == null)
										{
											make_var = input.Updated_Make.Make;
										}
										else
										{
											make_var = input.Make;
										}
										if(input.Model == "" || input.Model == null)
										{
											model_var = input.Updated_Model.Model;
										}
										else
										{
											model_var = input.Model;
										}
										if(input.CPU == "" || input.CPU == null)
										{
											cpu_var = input.Update_CPU1;
										}
										else
										{
											cpu_var = input.CPU;
										}
										if(input.Generation == "" || input.Generation == null)
										{
											gen_var = input.Updated_Generation;
										}
										else
										{
											gen_var = input.Generation;
										}
										if(input.RAM == "" || input.RAM == null)
										{
											ram_var = input.Updated_RAM;
										}
										else
										{
											ram_var = input.RAM;
										}
										if(input.HDD == "" || input.HDD == null)
										{
											hdd_var = input.Updated_HDD;
										}
										else
										{
											hdd_var = input.HDD;
										}
										model_desc = make_var + " " + model_var + " " + cpu_var + " " + gen_var + " " + ram_var + " " + hdd_var;
										input.Product_Description = model_desc;
						)
					}
				}

			}
			Update_Product_name_in_Sa as "Update Product name in Sales order form"
			{
				type =  form
				form = Sales_Order_Items
				record event = on add or edit

				on user input of Tag_Number
				{
					actions 
					{
						custom deluge script
						(
											if(input.Tag_Number != null || input.Tag_Number != "")
										{
											finalqcRec = Final_QC1[Tag_Number.equalsIgnoreCase(input.Tag_Number)];
											info finalqcRec.ID;
											if(finalqcRec.count() > 0)
											{
												input.Product_Name = finalqcRec.ID;
											}
											else
											{
												alert "Tag Number Not Found in Finalized Inventory";
											}
										}
						)
					}
				}

			}
			Get_Product_Name_in_Subfo as "Get Product Name in Subform"
			{
				type =  form
				form = Sales_Orders
				record event = on add or edit
					status = inactive

				on user input of Item_Table.Tag_Number
				{
					actions 
					{
						custom deluge script
						(
											for each  i in Item_Table
										{
											if(i.Tag_Number != null || i.Tag_Number != "")
											{
												final_qc_rec = Final_QC1[Tag_Number == i.Tag_Number];
												if(final_qc_rec.count() > 0)
												{
													i.Product_Name=final_qc_rec.ID;
													i.Product_Books_ID=final_qc_rec.Zoho_Books_Product_ID;
													i.Serial_Number=final_qc_rec.Serial_Number;
												}
												else
												{
													alert "Final QC not done for this product";
													i.Tag_Number="";
												}
											}
										}
						)
					}
				}

			}
