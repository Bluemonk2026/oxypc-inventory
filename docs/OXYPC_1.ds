		form L1_L2_Engineer_Screen
		{
			displayname = "L1/L2 Engineer Screen"
			success message = "L1/l2 Engineer Screen Added Successfully"
			field alignment = left
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Barcode
			(
    			type = text
				displayname = "Tag No."
				qrcode = true
				barcode = true
				camera = primary
				show gallery = true
				switch camera = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			Time
			(
    			type = time
				initial value = "${zoho.currenttime}"	
				timedisplayoptions = "hh:mm:ss" 
	 			row = 1
	 			column = 1   
				width = medium
			)
			LOT_No
			(
    			type = text
				displayname = "LOT No."
	 			row = 1
	 			column = 1   
				width = medium
			)
			checkbox
			(
				type = checkboxes	
				displayname = "Checkbox"
				values = {"Update"}
				private = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			Make
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Update_Make
			(
				type = radiobuttons
				displayname = "Update Make"
				maxchar = 100
				values = {"Yes","No"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			New_Make
			(
    			type = text
				displayname = "New Make Value"
	 			row = 1
	 			column = 1   
				width = medium
			)
			CPU
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Update_CPU
			(
				type = radiobuttons
				displayname = "Update CPU"
				maxchar = 100
				values = {"Yes","No"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			New_CPU_Value
			(
    			type = text
				displayname = "New CPU Value"
	 			row = 1
	 			column = 1   
				width = medium
			)
			RAM
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			RAM_Status
			(
				type = radiobuttons
				displayname = "RAM Status"
				maxchar = 100
				values = {"Upgraded","Downgraded","Replaced","No Change"}
				layout = 2
	 			row = 1
	 			column = 1   
				width = medium
			)
			Action_Taken_RAM
			(
				type = radiobuttons
				displayname = "Action Taken(RAM) "
				maxchar = 100
				values = {"Replaced","Removed"}
				layout = 3
	 			row = 1
	 			column = 1   
				width = medium
			)
			Action_Taken_RAM1
			(
				type = radiobuttons
				displayname = "Action Taken(RAM)"
				maxchar = 100
				values = {"Added","Replaced"}
				layout = 3
	 			row = 1
	 			column = 1   
				width = medium
			)
			Removed_Capacity
			(
				type = picklist
				displayname = "Removed Capacity RAM"
				maxchar = 100
				values = {"4GB","8GB","16GB","32GB","64GB","128GB"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Added_Capacity
			(
				type = picklist
				displayname = "Added Capacity RAM"
				maxchar = 100
				values = {"4GB","8GB","16GB","32GB","64GB","128GB"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			IQC_Completion_Date
			(
    			type = date
				displayname = "IQC Completion Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			Date_field
			(
    			type = date
				displayname = "Date"
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 2   
				width = medium
			)
			Model
			(
    			type = text
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Update_Model
			(
				type = radiobuttons
				displayname = "Update Model"
				maxchar = 100
				values = {"Yes","No"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			New_Model_Value
			(
    			type = text
				displayname = "New Model Value"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Serial_Number
			(
    			type = text
				displayname = "Serial Number"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Generation
			(
    			type = text
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Update_Generation
			(
				type = radiobuttons
				displayname = "Update Generation"
				maxchar = 100
				values = {"Yes","No"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			New_Generation_Value
			(
    			type = text
				displayname = "New Generation Value"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Engineer
			(
    			type = picklist
				displayname = "IQC Engineer"
				module = users
				displayformat = [username]
	 			row = 1
	 			column = 2   
				width = medium
				personal data = true
			)
			HDD
			(
    			type = text
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Update_HDD
			(
				type = radiobuttons
				displayname = "Update HDD"
				maxchar = 100
				values = {"Yes","No"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Removed_Capacity1
			(
				type = picklist
				displayname = "Removed Capacity HDD"
				maxchar = 100
				values = {"128 GB","250 GB","256 GB","320 GB","500 GB","512 GB","1 TB","2 TB","3 TB","4 TB","5 TB","8 TB","16 TB"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Added_Capacity1
			(
				type = picklist
				displayname = "Added Capacity HDD"
				maxchar = 100
				values = {"128 GB","250 GB","256 GB","320 GB","500 GB","512 GB","1 TB","2 TB","3 TB","4 TB","5 TB","8 TB","16 TB","WITHOUT HARDDISK"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Completion_Date
			(
    			type = date
				displayname = "Completion Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 2   
				width = medium
			)
			Completion_Date1
			(
    			type = time
				displayname = "Completion Time"
				timedisplayoptions = "hh:mm:ss" 
	 			row = 1
	 			column = 2   
				width = medium
			)
			Completed_By
			(
    			type = picklist
				displayname = "Completed By"
				module = users
				displayformat = [username]
	 			row = 1
	 			column = 2   
				width = medium
				personal data = true
			)
			faults
			(
				type = grid
				displayname = "Faults"
				values  = Faulty_Spare_Parts_After_IQC1.ID
	 			row = 2
	 			column = 1   
				width = medium
			)
			Final_Status1
			(
				type = section
				displayname = "Final Status"
	 			row = 3
	 			column = 0   
				width = medium
			)
			must have Dust_Cleaning
			(
				type = radiobuttons
				displayname = "Dust Cleaning"
				maxchar = 100
				values = {"Done","Not Done"}
				layout = 3
	 			row = 3
	 			column = 1   
				width = medium
			)
			must have C_MOS_Battery_Change
			(
				type = radiobuttons
				displayname = "C-MOS Battery Change"
				maxchar = 100
				values = {"Done","Not Done"}
				layout = 3
	 			row = 3
	 			column = 1   
				width = medium
			)
			must have CPU_Thermal_Paste1
			(
				type = radiobuttons
				displayname = "CPU Thermal Paste"
				maxchar = 100
				values = {"Done","Not Done"}
				layout = 3
	 			row = 3
	 			column = 1   
				width = medium
			)
			must have Final_Status
			(
				type = picklist
				displayname = "Final Status"
				maxchar = 100
				values = {"PNA","Completed","Escalate to L4","Escalate to Plastic Repair","Scrap","BER","Dismantling/Screen/Paint/Plastic/Keyboard"}
				sortorder = ascending
				others option = true
	 			row = 3
	 			column = 1   
				width = medium
			)
			Problem_Reported
			(
				type = picklist
				displayname = "Problem Reported"
				maxchar = 100
				values = {"No Display","Not ON","Dim Display","On/Off","Remote Management Error","Hanging","KBD Not Working","Usb Not Working","VGA Port Not Working","HDMI Port Notworking","ON /OFF Switch Issue","KBD Some Key Not Working","Blue Dum Error","Wifi Not Working","Date Time issue","Audio Jack Not Working","Battery Not Charging","Battery Not detect","HDD Not detect","BIOS Password","LAN Port Not Working","T.pad Not Working","Sound issue","Auto Restart/Shut Down","OS Not Installed","C Type Connector Not Working","T.Pad Click Not working","Camera Not working","Microphone Not Working","Ram Slot Not Working","Power Button LED Issue","CPU Fan Error","Other Problem"}
				sortorder = ascending
	 			row = 3
	 			column = 1   
				width = medium
			)
			Remarks
			(
    			type = textarea
				height = 100px
	 			row = 3
	 			column = 1   
				width = medium
			)
	
			customize
			(
				icon = "tech-tablet-button"
			)
			actions
			{
				on add
				{
					submit
