			Add_record_in_presales_qc as "Add record in presales qc"
			{
				type =  form
				form = Sales_Orders
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											mapp = Map();
										mapp.put("Sales_Order_Number",input.ID);
										mapp.put("Sales_Order_Date",zoho.currentdate.toDate().toString("dd-MMM-yyyy"));
										mapp.put("Expected_Shipment_Date",input.Expected_Shipment_Date);
										mapp.put("Salesperson",input.Salesperson);
										mapp.put("Customer_Name",input.Customer_Name);
										mapp.put("Payment_Terms",input.Payment_Terms);
										coll = Collection();
										lst = List();
										for each  i in Item_Table
										{
											// 	input.Item_Table.insert(rec.ID);
											sbfrm_mapp = Map();
											sbfrm_mapp.put("Quantity",i.Quantity);
											sbfrm_mapp.put("Product_Name1",i.Product_Name1);
											sbfrm_mapp.put("Rate",i.Rate);
											sbfrm_mapp.put("HDD_Modification_Required",i.HDD_Modification_Required);
											sbfrm_mapp.put("RAM_Modification_Required",i.RAM_Modification_Required);
											sbfrm_mapp.put("Category",i.Category);
											sbfrm_mapp.put("Required_RAM_Capacity",i.Required_RAM_Capacity);
											sbfrm_mapp.put("Required_HDD_Capacity",i.Required_HDD_Capacity);
											sbfrm_mapp.put("Quantity_Available",i.Quantity_Available);
											sbfrm_mapp.put("Amount",i.Amount);
											lst.add(sbfrm_mapp);
											// 	sbfrm = Presales_QC_New.Item_Table();
											// 	sbfrm.Quantity = i.Quantity;
											// 	sbfrm.Product_Name = i.Product_Name;
											// 	sbfrm.Rate = i.Rate;
											// 	sbfrm.HDD_Modification_Required = i.HDD_Modification_Required;
											// 	sbfrm.RAM_Modification_Required = i.RAM_Modification_Required;
											// // 	sbfrm
											// 	coll.insert(sbfrm);
										}
										mapp.put("Item_Table",lst);
										header = Map();
										header.put("environment","development");
										final_mapp = Map();
										final_mapp.put("data",mapp);
										empty_mapp = Map();
										create_rec = invokeurl
										[
											url :"https://creator.zoho.in/api/v2.1/protaiga/oxypc-1/form/Presales_QC_New"
											type :POST
											parameters:final_mapp.toString()
											headers:{'environment':'development'}
											connection:"creator"
										];
										info create_rec;
										// coll = Collection();
										// for each i in Item_Table{
										// 	sbfrm = Presales_QC_New.Item_Table();
										// // 	input.Item_Table.ID= i.ID;
										// 	sbfrm.Product_Name = i.Product_Name;
										// 	sbfrm.Required_HDD_Capacity = i.Required_HDD_Capacity;
										// 	sbfrm.Required_RAM_Capacity = i.Required_RAM_Capacity;
										// 	sbfrm.
										// 	coll.insert(sbfrm);
										// }
										// input.Item_Table.insert(coll);
						)
					}
				}

			}
