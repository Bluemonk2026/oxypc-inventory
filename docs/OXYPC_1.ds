			UpdatePreviousRecordLotNo as "UpdatePreviousRecordLotNo"
			{
				type =  form
				form = IQC_Format_for_TFT
				record event = on add

				on user input of Fill_Previous_Lot_No
				{
					actions 
					{
						custom deluge script
						(
											if(input.Fill_Previous_Lot_No == "Update")
										{
											iqcfetchrecord = IQC_Format_for_TFT[ID != 0] sort by Added_Time desc;
											if(iqcfetchrecord != null)
											{
												input.Lot_No = iqcfetchrecord.Lot_No;
											}
										}
										else
										{
											input.Lot_No = null;
										}
						)
					}
				}

			}
