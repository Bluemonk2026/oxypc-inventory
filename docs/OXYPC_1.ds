	section GRN
	{
		icon = "tech-desktop"
		form GRN
		{
			success message = "Data Added Successfully!"
			field alignment = left
			feature property = 448
			Section3
			(
				type = section
				displayname = ""
	 			row = 1
	 			column = 0   
				width = medium
			)
			PO_Number
			(
				type = picklist	
				displayname = "PO Number"
				values  = Purchase_Order[Is_received == "false" || Is_received == "In-Progress" && PO_Item_Type == "Hardware (Laptop/Desktop/TFT)"].ID
    			displayformat = [PO_Number]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Date_of_Material_Received
			(
    			type = date
				displayname = "Date of Material Received"
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			unique GRN_Number_System
			(
    			type = text
				displayname = "GRN Number (System)"
	 			row = 1
	 			column = 1   
				width = medium
			)
			PO_Date
			(
    			type = date
				displayname = "PO Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 2   
				width = medium
			)
			Vendor_Name_PO
			(
				type = picklist	
				displayname = "Vendor Name (PO)"
				values  = Vendors_Database.ID
    			displayformat = [Vendor_Name]
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			Section2
			(
				type = section
				displayname = ""
				visibility = true
	 			row = 2
	 			column = 0   
				width = medium
			)
			Invoice_Number
			(
    			type = text
				displayname = "Invoice Number"
	 			row = 2
	 			column = 1   
				width = medium
			)
			E_Way_Bill_Number
			(
    			type = text
				displayname = "E-Way Bill Number"
	 			row = 2
	 			column = 1   
				width = medium
			)
			Vehicle_Number
			(
    			type = text
				displayname = "Vehicle Number"
	 			row = 2
	 			column = 1   
				width = medium
			)
			For_Scheduler
			(
				type = checkboxes	
				displayname = "For Scheduler"
				values = {"Update"}
				private = true
	 			row = 2
	 			column = 1   
				width = medium
			)
			Checkbox
			(
				type = checkboxes	
				values = {"Update"}
				private = true
	 			row = 2
	 			column = 1   
				width = medium
			)
			GRN
			(
				type = number
				displayname = "GRN Number"
				private = true
	 			row = 2
	 			column = 1   
				width = medium
			)
			Lot_No
			(
    			type = text
				displayname = "Lot No."
	 			row = 2
	 			column = 1   
				width = medium
			)
			Invoice_Date
			(
    			type = date
				displayname = "Invoice Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 2
	 			column = 2   
				width = medium
			)
			E_Way_Bill_Date
			(
    			type = date
				displayname = "E-Way Bill Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 2
	 			column = 2   
				width = medium
			)
			Vehicle_Seal_Image
			(
    			type = image
				displayname = "Vehicle Seal Image"
				source  = public_url,file,camera
				aspect ratio = original
				camera = primary
				show gallery = true
				switch camera = true
	 			row = 2
	 			column = 2   
				width = medium
			)
			PR_Books_ID
			(
