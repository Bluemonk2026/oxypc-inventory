			Get_Data_from_IQC1 as "Get Data from IQC"
			{
				type =  form
				form = Plastic_Repair
				record event = on add or edit

				on user input of Tag_Number
				{
					actions 
					{
						custom deluge script
						(
											if(input.Tag_Number != "" || input.Tag_Number != null)
										{
											iqc_rec = IQC_Format_for_Plastic[Tag_No.equalsIgnoreCase(input.Tag_Number)];
											if(iqc_rec.count() > 0)
											{
												if(iqc_rec.Status == "Repair")
												{
													input.Lot_Number = iqc_rec.Lot_Number;
													input.Part_Type = iqc_rec.Part_Type;
													input.Model = iqc_rec.Model.Model;
													input.Make = iqc_rec.Make.Make;
													if(iqc_rec.Part_Repair == "Body A")
													{
														input.Part_Name = "Panel";
														input.Problem_Reported = iqc_rec.Body_A;
													}
													if(iqc_rec.Part_Repair == "Body B")
													{
														input.Part_Name = "Bazel";
														input.Problem_Reported = iqc_rec.Body_B;
													}
													if(iqc_rec.Part_Repair == "Body C")
													{
														input.Part_Name = "Touch Pad";
														input.Problem_Reported = iqc_rec.Body_C1;
													}
													if(iqc_rec.Part_Repair == "Body D")
													{
														input.Part_Name = "Base";
														input.Problem_Reported = iqc_rec.Body_D1;
													}
													if(iqc_rec.Part_Repair == "Body E")
													{
														input.Part_Name = "RAM Cover";
														input.Problem_Reported = iqc_rec.Body_E1;
													}
												}
												else
												{
													alert "The Part Status is " + iqc_rec.Status + " in IQC";
													input.Tag_Number = "";
												}
											}
										}
						)
					}
				}

			}
