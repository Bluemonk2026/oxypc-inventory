				Make
				CPU
				Model
				Generation
				RAM
				HDD
				Tag_Number as "Tag Number"
				Serial_Number as "Serial Number"
			)
			quickview
			(
				layout
				(
		 			type = -1
					datablock1
					(
						layout type = -1
						fields
						(
							Date_field as "Date"
							Tag_Number as "Tag Number"
							Serial_Number as "Serial Number"
							Make
							Model
							CPU
							Generation
							RAM
							HDD
							Status
						)
					)
				)
				menu
    			(
    	 			header
    	 			(
    		 			Edit 
    		 			Duplicate 
    		 			Delete 
    		 			Add 
    		 			Print 
    		 			Import 
    		 			Export 
    	 			)
					record
					(
						Edit   	   
						Duplicate   	   
						Print   	   
						Delete   	   
    				)
    			)
    			action
    			(
					on click
					(
						View Record   	   
    				)
					on right click
					(
						Edit   	   
						Delete   	   
						Duplicate   	   
						Print   	   
						View Record   	   
    				)
     			)
			)
			detailview
			(
				layout
				(
		 			type = 1
					datablock1
					(
						layout type = -2
						fields
						(
							Date_field as "Date"
							Status
							Make
							CPU
							Model
							Generation
							RAM
							HDD
							Tag_Number as "Tag Number"
							Serial_Number as "Serial Number"
						)
					)
				)
				menu
    			(
    	 			header
    	 			(
    		 			Edit 
    		 			Duplicate 
    		 			Print 
    		 			Delete 
    	 			)
    			)
			)
		}
