			Insert_Tag_Numbers_in_Sub as "Insert Tag Numbers in Subform"
			{
				type =  form
				form = Sales_Orders
				record event = on add

				on user input of Tag_Number
				{
					actions 
					{
						custom deluge script
						(
											newline = hextotext("0A");
										for each  i in input.Tag_Number.toList(newline)
										{
											if(i != " ")
											{
												final_qc_rec = Final_QC1[Tag_Number == i];
												frm = Sales_Orders.Item_Table();
												frm.Product_Name=final_qc_rec.ID;
												frm.SO_ID_Creator=input.ID;
												frm.Serial_Number=final_qc_rec.Serial_Number;
												frm.Tag_Number=i;
												coll = Collection();
												coll.insert(frm);
												input.Item_Table.insert(coll);
											}
										}
						)
					}
				}

			}
