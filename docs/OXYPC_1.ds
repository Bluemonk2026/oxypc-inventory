			Sending_replace_items_for as "Sending replace items for report"
			{
				type =  form
				form = IQC_Format_for_Laptop
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											// parts = input.Required_Replacements;
										// // alert input.Required_Replacements ;
										// // hide Faulty_Spare_Parts.Lot_No;
										// // hide Faulty_Spare_Parts.
										// parts = parts.toList();
										// rows = Collection();
										// for each  i in parts
										// {
										// 	row1 = IQC_Format_for_Laptop.Faulty_Spare_Parts();
										// 	row1.Spare_Part=i;
										// 	row1.Lot_No=input.Lot_No.Lot_No;
										// 	row1.Tag_No=input.ID;
										// 	row1.Model_Description=input.Model_Description;
										// 	rows.insert(row1);
										// }
										// input.Faulty_Spare_Parts.insert(rows);
										if(Required_Replacements != "" || Required_Replacements != null)
										{
											parts = List();
											parts.add(input.Required_Replacements);
											info "parts==" + parts;
											// 	parts = input.Required_Replacements.toList();
											// 	parts = parts.toList();
											already_in_sbfrm = List();
											for each  j in input.Faulty_Spare_Parts
											{
												already_in_sbfrm.add(j.Spare_Part);
											}
											// 	parts
											info "already_in_sbfrm==" + already_in_sbfrm;
											if(already_in_sbfrm.size() == 0)
											{
												for each  i in parts.toList(",")
												{
													row1 = IQC_Format_for_Laptop.Faulty_Spare_Parts();
													recs = Spare_Parts2[Spare_Part_Name == i];
													row1.Spare_Part1=recs.ID;
													row1.Spare_Part=i;
													row1.Lot_No=input.LOT_Number;
													// 		row1.Lot_No1=input.LOT_No2;
													row1.Make=input.Make.Make;
													row1.Model=input.Model1.Model;
													row1.Tag_No=input.ID;
													row1.Model_Description=input.Model_Description;
													row1.Category="Laptop";
													row1.Quantity=1;
													tst = Spare_Parts_Costing_Report[Part == i && Make == input.Make.Make && Model == input.Model1.Model];
													if(tst.count() != 0)
													{
														row1.Price=tst.Rate;
													}
													// 		row1.Lot_No=input.Lot_No.Lot_No;
													row1.Tag_No=input.ID;
													rows = Collection();
													rows.insert(row1);
													input.Faulty_Spare_Parts.insert(rows);
												}
											}
											else
											{
												parts_new = input.Required_Replacements.toList(",");
												info parts_new;
												for each  i in parts_new
												{
													for each  j in already_in_sbfrm.toList(",")
													{
														if(i == j)
														{
															info "part to be removed=" + i;
															parts_new.removeElement(i);
														}
													}
												}
												for each  i in parts_new
												{
													info "new_part" + i;
													row1 = IQC_Format_for_Laptop.Faulty_Spare_Parts();
													recs = Spare_Parts2[Spare_Part_Name == i];
													row1.Spare_Part1=recs.ID;
													row1.Spare_Part=i;
													row1.Lot_No=input.LOT_Number;
													// 	row1.Lot_No1=input.LOT_No2;
													row1.Make=input.Make.Make;
													row1.Model=input.Model1.Model;
													row1.Tag_No=input.ID;
													row1.Model_Description=input.Model_Description;
													row1.Category="Laptop";
													row1.Quantity=1;
													tst = Spare_Parts_Costing_Report[Part == i && Make == input.Make.Make && Model == input.Model1.Model];
													if(tst.count() != 0)
													{
														row1.Price=tst.Rate;
													}
													// 		row1.Lot_No=input.Lot_No.Lot_No;
													row1.Tag_No=input.ID;
													rows = Collection();
													rows.insert(row1);
													input.Faulty_Spare_Parts.insert(rows);
												}
											}
										}
						)
					}
				}

			}
