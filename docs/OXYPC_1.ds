			Update_Warehouse_in_Zoho_2 as "Update Warehouse in Zoho Books Inventory"
			{
				type =  form
				form = Stock_Transfer_B2_to_Showroom_TRC_2nd_Floor
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											mapp = Map();
										mapp.put("date",zoho.currentdate.toString("yyyy-MM-dd"));
										mapp.put("from_warehouse_id",1243157000002593007);
										mapp.put("to_warehouse_id",1243157000000163010);
										line_items = List();
										line_item = Map();
										line_item.put("item_id",input.Zoho_Books_Item_ID);
										line_item.put("name",input.Zoho_Books_Item_Name);
										// line_item.put("description","Laptop - Testing Serial Number");
										line_item.put("quantity_transfer",1);
										line_item.put("serial_numbers",{input.Tag_Number});
										line_item.put("unit","qty");
										line_items.add(line_item);
										mapp.put("line_items",line_items);
										transfer_order = invokeurl
										[
											url :"https://www.zohoapis.in/inventory/v1/transferorders?organization_id=60020430422"
											type :POST
											parameters:mapp.toString()
											connection:"zoho_books"
										];
										info transfer_order;
						)
					}
				}

			}
