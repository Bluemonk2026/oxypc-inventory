			Add_to_product_Master_Inv2 as "Add to product Master Inventory"
			{
				type =  form
				form = GRN
				record event = on add or edit
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											for each  i in Item
										{
											// 	item_detail = Product_Master[ID == i.Item_Name_Unused];
											if(i.Sub_Category1 == "Laptop" || i.Sub_Category1 == "LAPTOP" || i.Sub_Category1 == "Desktop" || i.Sub_Category1 == "DESKTOP" || i.Sub_Category1 == "TFT" || i.Sub_Category1 == "Tft" || i.Sub_Category1 == "Monitors")
											{
												master_inventory_rec = Product_Master_Inventory1[LOT_No == i.Lot_No && Unique_Lot_No == i.ID];
												if(master_inventory_rec.count() == 0)
												{
													quantity = i.Quantity.toLong();
													if(quantity % 200 == 0)
													{
														Loop_iteration = quantity / 200;
													}
													else if(quantity % 200 != 0)
													{
														Loop_iteration = (quantity / 200).toLong() + 1;
													}
													// 		genratedlst2 = leftpad(" ",Loop_iteration.toLong() - 1).replaceAll(" ",",");
													genratedlst2 = "".leftPad(Loop_iteration.toLong()).replaceAll(" ",",").toList().subList(0,Loop_iteration.toLong());
													// 		lst2 = genratedlst2.toList();
													lst2 = genratedlst2;
													quantity2 = 0;
													for each  k in lst2
													{
														if(quantity > 0)
														{
															if(quantity >= 200)
															{
																quantity2 = 200;
															}
															else if(quantity < 200)
															{
																quantity2 = quantity;
															}
															genratedlst = leftpad(" ",quantity2 - 1).replaceAll(" ",",");
															lst = genratedlst.toList();
															info lst.size();
															sendmail
															[
																from :zoho.loginuserid
																to :"shivam.kountey@bluemonk.in"
																subject :"testlst"
																message :"lst " + lst.size()
															]
															bulk_create_list = List();
															for each  j in lst
															{
																sendmail
																[
																	from :zoho.loginuserid
																	to :"shubham.namdev@crm-masters.com"
																	subject :"Testing GRN Product master inventory"
																	message :"category records GRN" + j
																]
																mapp = Map();
																mapp.put("LOT_No",i.Lot_No);
																vendor_rec = Vendors_Database[Vendor_Name == input.Vendor_Name];
																mapp.put("Vendor_Name",vendor_rec.ID);
																mapp.put("Customer_Name",i.Customer_Name);
