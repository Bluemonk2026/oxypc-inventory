				values = {"Not ON","Dim Display","On/Off","Hanging","KBD Not Working","Usb Not Working","VGA Port Not Working","HDMI Port Notworking","ON /OFF Switch Issue","KBD Some Key Not Working","Blue Dum Error","Wifi Not Working","Date Time issue","Audio Jack Not Working","Battery Not Charging","Battery Not detect","HDD Not detect","BIOS Password","LAN Port Not Working","T.pad Not Working","Sound issue","Auto Restart/Shut Down","OS Not Installed","C Type Connector Not Working","T.Pad Click Not working","Camera Not working","Microphone Not Working","Ram Slot Not Working","Power Button LED Issue","CPU Fan Error","Other Problem","No Display","No Power","USB","VGA","DP","HDMI","CPU Pin Damage","Others"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Received_from
			(
				type = picklist
				displayname = "Received from"
				maxchar = 100
				values = {"L1/L2 Engineer","L4 Support"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Received_from_Engineer
			(
    			type = picklist
				displayname = "Received from Engineer"
				module = users
				displayformat = [username]
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			IQCs
			(
    			type = textarea
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			Faults
			(
				type = grid
				values  = Faulty_Spare_Parts_After_IQC1.ID
	 			row = 2
	 			column = 1   
				width = medium
			)
	
			customize
			(
				icon = "transportation-tractor"
			)
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
	}
