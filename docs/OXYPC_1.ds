		form IQC_format_for_Screen
		{
			displayname = "IQC Form"
			success message = "Format Iqc Screen Added Successfully"
			field alignment = left
			Section2
			(
				type = section
				displayname = ""
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have unique Serial_Number
			(
    			type = text
				displayname = "Serial Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Lot_Number
			(
    			type = text
				displayname = "Lot Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have unique Tag_No
			(
    			type = text
				displayname = "Tag No"
				qrcode = true
				barcode = true
				camera = primary
				switch camera = true
	 			row = 1
	 			column = 2   
				width = medium
			)
			IQC_Done_By
			(
    			type = picklist
				displayname = "IQC Done By"
				module = users
				displayformat = [username]
	 			row = 1
	 			column = 2   
				width = medium
				personal data = true
			)
			Start_Date
			(
    			type = date
				displayname = "Date"
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 3   
				width = medium
			)
			Update_Invemtory_TBDeleted
			(
				type = picklist
				displayname = "Update Invemtory(TBDeleted)"
				maxchar = 100
				values = {"Yes","No"}
				private = true
	 			row = 1
	 			column = 3   
				width = medium
			)
			Section3
			(
				type = section
				displayname = "Screen and Part Details"
				visibility = true
	 			row = 2
	 			column = 0   
				width = medium
			)
			must have Part_No
			(
    			type = text
				displayname = "Screen Part No"
	 			row = 2
	 			column = 1   
				width = medium
			)
			must have Screen_Type
			(
				type = radiobuttons
				displayname = "Screen Type"
				maxchar = 100
				values = {"LCD","LED","PAPER","IPS"}
				layout = 2
	 			row = 2
	 			column = 1   
				width = medium
			)
			plain
			(
    			type = plaintext
				value = "<div> <br /></div>"
	 			row = 2
	 			column = 2   
				width = medium
			)
			must have Screen_Size
			(
				type = radiobuttons
				displayname = "Screen Size"
				maxchar = 100
				values = {"12.5","13.3","14.0","15.6","17.6"}
				layout = 3
	 			row = 2
	 			column = 2   
				width = medium
			)
			plain1
			(
    			type = plaintext
				value = "<div> <br /></div>"
	 			row = 2
	 			column = 3   
				width = medium
			)
			Section1
			(
				type = section
				displayname = "Screen Connector Detail"
				visibility = true
	 			row = 3
	 			column = 0   
				width = medium
			)
			Start_Time
			(
    			type = time
				displayname = "Start Time"
				initial value = "${zoho.currenttime}"	
				timedisplayoptions = "hh:mm:ss" 
	 			row = 3
	 			column = 1   
				width = medium
			)
			must have Opposite_VGA_Connector
			(
				type = radiobuttons
				displayname = "Opposite VGA Connector"
				maxchar = 100
				values = {"Yes","No"}
				layout = 3
	 			row = 3
	 			column = 1   
				width = medium
			)
			must have Screen_Pin
			(
				type = radiobuttons
				displayname = "Screen Pin"
				maxchar = 100
				values = {"30 pin","20 pin","40 pin"}
				layout = 3
	 			row = 3
	 			column = 2   
				width = medium
			)
			must have Side_Screw
			(
				type = radiobuttons
				displayname = "Side Screw"
				maxchar = 100
				values = {"Yes","No"}
				layout = 3
	 			row = 3
	 			column = 3   
				width = medium
			)
			Section4
			(
				type = section
				displayname = "Status and Remarks"
				visibility = true
	 			row = 4
	 			column = 0   
				width = medium
			)
			must have Status
			(
				type = picklist
				maxchar = 100
				values = {"OK","Non-Repairable","Repair","Scrap"}
	 			row = 4
	 			column = 1   
				width = medium
			)
			IQC_Remarks
			(
    			type = textarea
				displayname = "IQC Remarks"
				height = 100px
	 			row = 4
	 			column = 1   
				width = medium
			)
			Problem_Reported
			(
				type = picklist
				displayname = "Problem Reported"
				maxchar = 100
				values = {"Keyboad Mark","Blank Display","Ok","Minor Patch & Keyboard Mark","Major Patch & Keyboard Mark","Broken","Patch","Minor Patch","Major Patch","Line","H-Line","V-Line","Pixel Missing (Dot)","Dim Display","Flickering","Half Display","Hair Line Display","Multiple Lines Display","Keyboard Mark","Scratch","White Display","No Display","Colour Spread","Missing","Not Checked","Yellow Screen"}
	 			row = 4
	 			column = 2   
				width = medium
			)
			Non_Repairable_Reason
			(
				type = picklist
				displayname = "Non-Repairable Reason"
				maxchar = 100
				values = {"Paper","Line","Yellow Screen"}
	 			row = 4
	 			column = 2   
				width = medium
			)
			Scrap_Reason
			(
				type = picklist
				displayname = "Scrap Reason"
				maxchar = 100
				values = {"Line","Broken"}
	 			row = 4
	 			column = 3   
				width = medium
			)
	
			customize
			(
				icon = "arrows-4-format-right"
			)
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
