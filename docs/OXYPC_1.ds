			Fetching_record_in_Final_ as "Fetching record in Final QC"
			{
				type =  form
				form = Final_QC_for_Engineer
				record event = on add

				on user input of Tag_No
				{
					actions 
					{
						custom deluge script
						(
											// bucket_rec = Final_QC[Tag_No == input.Tag_No];
										// if(bucket_rec.count(Tag_No) != 0)
										// {
										// final_qc = Final_QC1[Tag_Number == input.Tag_No];
										// if(final_qc.count() > 0)
										// {
										// // 	status = final_qc.Final_Status;
										// // 	if(status == "Fail")
										// // 	{
										// // 		alert "This Laptop Failed in Final QC and got assigned to L1/L2";
										// // 		input.Tag_No = "";
										// // 	}
										// }
										// else
										// {
										l1_l2_rec = IQC_Format_for_Laptop[TAG_NO.equalsIgnoreCase(input.Tag_No)];
										iqc_desk = IQC_Format_for_Desktop[Tag_No.equalsIgnoreCase(input.Tag_No)];
										iqc_tft = IQC_Format_for_TFT[TAG.equalsIgnoreCase(input.Tag_No)];
										iqc_rec = L1_L2_Engineer_Screen[Barcode.equalsIgnoreCase(input.Tag_No)];
										desk_rec = Desktop_L1_L2_Engineer_Screen1[Barcode.equalsIgnoreCase(input.Tag_No)];
										tft_rec = TFT_L1_L2_Engineer_Screen[Barcode.equalsIgnoreCase(input.Tag_No)];
										if(iqc_rec.count() != 0)
										{
											if(iqc_rec.Final_Status == "Completed")
											{
												input.Engineer = iqc_rec.Modified_User;
												if(iqc_rec.New_Make == "" || iqc_rec.New_Make == null)
												{
													input.Make = iqc_rec.Make;
												}
												else
												{
													input.Make = iqc_rec.New_Make;
												}
												if(iqc_rec.New_Model_Value == "" || iqc_rec.New_Model_Value == null)
												{
													input.Model = iqc_rec.Model;
												}
												else
												{
													input.Model = iqc_rec.New_Model_Value;
												}
												if(iqc_rec.New_CPU_Value == "" || iqc_rec.New_CPU_Value == null)
												{
													input.CPU = iqc_rec.CPU;
												}
												else
												{
													input.CPU = iqc_rec.New_CPU_Value;
												}
												if(iqc_rec.New_Generation_Value == "" || iqc_rec.New_Generation_Value == null)
												{
													input.Generation = iqc_rec.Generation;
												}
												else
												{
													input.Generation = iqc_rec.New_Generation_Value;
												}
												if(iqc_rec.Removed_Capacity1 == "" || iqc_rec.Removed_Capacity1 == null)
												{
													if(iqc_rec.Added_Capacity1 == "" || iqc_rec.Added_Capacity1 == null)
													{
														input.HDD = iqc_rec.HDD;
													}
													else
													{
														input.HDD = iqc_rec.Added_Capacity1;
													}
												}
												else
												{
													if(iqc_rec.Removed_Capacity1 != null && iqc_rec.Added_Capacity1 != null)
													{
														input.HDD = iqc_rec.Added_Capacity1;
													}
													// 			input.HDD = iqc_rec.Removed_Capacity1;
												}
												if(iqc_rec.Removed_Capacity == "" || iqc_rec.Removed_Capacity == null)
												{
													if(iqc_rec.Added_Capacity == "" || iqc_rec.Added_Capacity == null)
													{
														input.RAM = iqc_rec.RAM;
													}
													else
													{
														input.RAM = iqc_rec.Added_Capacity;
													}
												}
												else
												{
													input.RAM = iqc_rec.Removed_Capacity;
												}
												input.LOT_Number = iqc_rec.LOT_No;
												input.Category = "Laptop";
												input.Serial_Number = iqc_rec.Serial_Number;
												input.L1_L2_Completion_Date = iqc_rec.Completion_Date;
											}
											else
											{
												newline = hextotext("0A");
												alert "Warning : Repair Not completed for this Laptop" + newline + "चेतावनी: इस लैपटॉप की मरम्मत पूरी नहीं हुई है";
												input.Tag_No = "";
											}
										}
										else if(l1_l2_rec.count() > 0)
										{
											input.Engineer = l1_l2_rec.Modified_User;
											input.Make = l1_l2_rec.Make.Make;
											input.Model = l1_l2_rec.Model1.Model;
											input.CPU = l1_l2_rec.CPU;
											input.Generation = l1_l2_rec.Generation;
											if(l1_l2_rec.HDD_Capacity == null || l1_l2_rec.HDD_Capacity == "")
											{
												input.HDD = l1_l2_rec.HDD_Capacity1;
											}
											else
											{
												input.HDD = l1_l2_rec.HDD_Capacity;
											}
											input.RAM = l1_l2_rec.Capacity;
											input.LOT_Number = l1_l2_rec.LOT_Number;
											input.Category = "Laptop";
											input.Serial_Number = l1_l2_rec.Serial_No;
										}
										//#########-- TFT Tag --############
										else if(tft_rec.count() != 0)
										{
											if(tft_rec.Final_Status == "Completed")
											{
												input.Engineer = tft_rec.Modified_User;
												if(tft_rec.New_Make == null || tft_rec.New_Make == "")
												{
													input.Make = tft_rec.Make;
												}
												else
												{
													input.Make = tft_rec.New_Make;
												}
												if(tft_rec.LOT_No != null || tft_rec.LOT_No != "")
												{
													input.LOT_Number = tft_rec.LOT_No;
												}
												hide CPU;
												hide Generation;
												hide Model;
												input.Category = "TFT";
												hide Serial_Number;
											}
											else
											{
												newline = hextotext("0A");
												alert "Warning : Repair Not completed for this TFT" + newline + "चेतावनी: इस टीएफटी की मरम्मत पूरी नहीं हुई है";
												input.Tag_No = "";
											}
										}
										else if(tft_rec.count() != 0)
										{
											input.Engineer = iqc_tft.Modified_User;
											input.Make = iqc_tft.Make;
											input.LOT_Number = iqc_tft.Lot_No1.LOT_No;
											hide CPU;
											hide Generation;
											input.Model = iqc_tft.Screen_Size;
											input.Category = "TFT";
											input.Serial_Number = iqc_tft.Serial_Number;
										}
										//#########-- Desktop Tag --##############
										else if(desk_rec.count() != 0)
										{
											info "entered in Desktop";
											if(desk_rec.Final_Status == "Completed")
											{
												input.Engineer = desk_rec.Modified_User;
												if(desk_rec.New_Make != "")
												{
													input.Make = desk_rec.New_Make;
												}
												else if(desk_rec.New_Make == "")
												{
													input.Make = desk_rec.Make;
												}
												if(desk_rec.New_Model_Value != "")
												{
													input.Model = desk_rec.New_Model_Value;
												}
												else if(desk_rec.New_Model_Value == "")
												{
													input.Model = desk_rec.Model;
												}
												if(desk_rec.New_CPU_Value != "")
												{
													input.CPU = desk_rec.New_CPU_Value;
												}
												else if(desk_rec.New_CPU_Value == "")
												{
													input.CPU = iqc_rec.CPU;
												}
												if(desk_rec.New_Generation_Value != "")
												{
													input.Generation = desk_rec.New_Generation_Value;
												}
												else if(desk_rec.New_Generation_Value == "")
												{
													input.Generation = desk_rec.Generation;
												}
												if(desk_rec.Added_Capacity1 != "")
												{
													input.HDD = desk_rec.Added_Capacity1;
												}
												else if(desk_rec.Added_Capacity1 == "")
												{
													input.HDD = desk_rec.HDD;
												}
												if(desk_rec.Added_Capacity != "")
												{
													input.RAM = desk_rec.Added_Capacity;
												}
												else if(desk_rec.Added_Capacity == "")
												{
													input.RAM = desk_rec.RAM;
												}
												if(desk_rec.LOT_No != null || desk_rec.LOT_No != "")
												{
													input.LOT_Number = desk_rec.LOT_No;
												}
												input.Category = "Desktop";
												input.Serial_Number = desk_rec.Serial_Number;
											}
											else
											{
												newline = hextotext("0A");
												alert "Warning : Repair Not completed for this Desktop" + newline + "चेतावनी: इस डेस्कटॉप की मरम्मत पूरी नहीं हुई है";
												input.Tag_No = "";
											}
										}
										else if(iqc_desk.count() != 0)
										{
											input.Engineer = iqc_desk.Modified_User;
											input.Make = iqc_desk.Make.Make;
											input.Model = iqc_desk.Model.Model;
											input.CPU = iqc_desk.Processors;
											input.Generation = iqc_desk.Generation;
											if(iqc_desk.HDD_Capacity != null || iqc_desk.HDD_Capacity != "")
											{
												input.HDD = iqc_desk.HDD_Capacity;
											}
											if(iqc_desk.Capacity != null || iqc_desk.Capacity != "")
											{
												input.RAM = iqc_desk.Capacity;
											}
											input.LOT_Number = iqc_desk.LOT_No1.LOT_No;
											input.Category = "Desktop";
											input.Serial_Number = iqc_desk.Serial_No;
										}
						)
					}
				}

			}
