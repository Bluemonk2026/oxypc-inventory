			Update_Inventory_When_IN as "Update Inventory When IN"
			{
				type =  form
				form = Spare_Part_In_Out1
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Spare_Part_In_Out == "IN")
										{
											inv_rec = Spare_Parts[Make == input.Make_Spare_Part && Model == input.Model_Spare_Part && Spare_Part_Name1 == input.Spare_Part || Spare_Part_Name == input.Spare_Part.Spare_Part_Name];
											if(inv_rec.count() > 0)
											{
												if(input.Part_Type == "New")
												{
													inv_rec.Available_SOH=inv_rec.Available_SOH + input.Quantity;
												}
												else if(input.Part_Type == "Harvested")
												{
													inv_rec.Cannablized=inv_rec.Cannablized + input.Quantity;
												}
											}
											else
											{
												data_mapp = Map();
												data_mapp.put("Spare_Part_Name1",input.Spare_Part);
												data_mapp.put("Make",input.Make_Spare_Part);
												data_mapp.put("Model",input.Model_Spare_Part);
												if(input.Part_Type == "New")
												{
													data_mapp.put("Available_SOH",input.Quantity);
													data_mapp.put("CARATES_BARCODE",input.Carate_Barcode);
												}
												else if(input.Part_Type == "Harvested")
												{
													data_mapp.put("Cannablized",input.Quantity);
													data_mapp.put("CARATES_BARCODE_Old",input.Carate_Barcode);
												}
												data_mapp.put("Spare_Part_Name",input.Spare_Part.Spare_Part_Name);
												empty_mapp = Map();
												create_rec = zoho.creator.createRecord("protaiga","oxypc-1","Spare_Parts",data_mapp,empty_mapp,"creator");
												info create_rec;
											}
										}
						)
					}
				}

			}
			Show_Alert as "Show Alert"
			{
				type =  form
				form = Spare_Part_In_Out1
				record event = on add or edit
					status = inactive

				on user input of Quantity_NEW
				{
					actions 
					{
						custom deluge script
						(
											Spare_Part_Master_Data = Spare_Parts[ID = input.Spare_Parts_Name];
										if(input.Spare_Part_In_Out == "" && input.Quantity_NEW != null)
										{
											alert "Please Select IN/OUT/Transfer First";
											input.Quantity_NEW = null;
										}
										if(Spare_Part_Master_Data.Available_SOH < input.Quantity_NEW && input.Spare_Part_In_Out == "OUT")
										{
											alert "No Stock Available. Available stock is:-" + Spare_Part_Master_Data.Available_SOH;
											input.Quantity_NEW = 0;
										}
						)
					}
				}

			}
