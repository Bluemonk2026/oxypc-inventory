				 void Day_In_Function()
                 {
                 	day_in = Engineer_day_In_Out[Engineer_Name == zoho.loginuser && Day_In_Date == zoho.currentdate.toString("dd-MMM-yyyy")];
                 	if(day_in.count() == 0)
                 	{
                 		mapp = Map();
                 		mapp.put("Engineer_Name",zoho.loginuser);
                 		mapp.put("Day_In_Date",zoho.currentdate.toString("dd-MMM-yyyy"));
                 		mapp.put("Day_In_Time",zoho.currenttime.getTime().toString("HH:mm:ss"));
                 		empty_mapp = Map();
                 		zoho.creator.createRecord("protaiga","oxypc-1","Engineer_day_In_Out",mapp,empty_mapp,"creator");
                 	}
                 	else
                 	{
                 		newline = hextotext("0A");
                 		info "Warning: You have already Checked In" + newline + "चेतावनी: आप पहले ही चेक इन कर चुके हैं";
                 	}
                 }
