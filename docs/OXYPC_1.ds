			Fetch_Data_in_Presales_QC as "Fetch Data in Presales QC"
			{
				type =  form
				form = Presales_QC_New
				record event = on add or edit

				on user input of Sales_Order_Number
				{
					actions 
					{
						custom deluge script
						(
											if(input.Sales_Order_Number != null)
										{
											so_rec = Sales_Orders[ID == input.Sales_Order_Number];
											if(so_rec.count() > 0)
											{
												input.Customer_Name = so_rec.Customer_Name;
												input.Sales_Order_Date = so_rec.Sales_Order_Date;
												Payment_Terms = so_rec.Payment_Terms;
												input.Salesperson = so_rec.Salesperson;
												input.Expected_Shipment_Date = so_rec.Expected_Shipment_Date.toString("dd-MMM-yyyy");
												so_sbfrm = so_rec.Item_Table;
												rows_collection = Collection();
												for each  i in so_sbfrm
												{
													row1 = Presales_QC_New.Item_Table();
													row1.Product_Name1=i.Product_Name1;
													row1.Quantity=i.Quantity;
													row1.RAM_Modification_Required=i.RAM_Modification_Required;
													row1.Required_HDD_Capacity=i.Required_HDD_Capacity;
													row1.Required_RAM_Capacity=i.Required_RAM_Capacity;
													row1.Rate=i.Rate;
													row1.HDD_Modification_Required=i.HDD_Modification_Required;
													row1.Category=i.Category;
													rows_collection.insert(row1);
												}
												input.Item_Table.insert(rows_collection);
											}
										}
						)
					}
				}

			}
			Make_each_field_mandatory as "Make each field mandatory"
			{
				type =  form
				form = Sales_Orders
				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.Payment_Mode1.toList().contains("Cash") && input.CaAmount == null)
										{
											alert "Please Fill Cash Amount";
											cancel submit;
										}
										if(input.Payment_Mode1.toList().contains("Cheque") && input.Cheque_Amount == null)
										{
											alert "Please Fill Cheque Amount";
											cancel submit;
										}
										if(input.Payment_Mode1.toList().contains("UPI") && input.UPI_Amount == null)
										{
											alert "Please Fill UPI Amount";
											cancel submit;
										}
										if(input.Payment_Mode1.toList().contains("Card Swipe") && input.Card_Swipe_Amount == null)
										{
											alert "Please Fill Card Swipe Amount";
											cancel submit;
										}
										if(input.Payment_Mode1.toList().contains("Bank Transfer") && input.Bank_Transfer_Amount == null)
										{
											alert "Please Fill Bank Transfer Amount";
											cancel submit;
										}
						)
					}
				}

			}
			Calculate_Total_Amount as "Calculate Total Amount"
			{
				type =  form
				form = Sales_Orders
				record event = on add or edit

				on user input of CaAmount
				{
					actions 
					{
						custom deluge script
						(
											if(input.Payment_Mode1.toList().contains("Cash") && input.CaAmount != null)
										{
											if(input.CaAmount != null)
											{
												cash_amount = input.CaAmount;
											}
											else
											{
												cash_amount = 0;
											}
											if(input.Cheque_Amount != null)
											{
												cheque_amnt = input.Cheque_Amount;
											}
											else
											{
												cheque_amnt = 0;
											}
											if(input.UPI_Amount != null)
											{
												UPI_Amnt = input.UPI_Amount;
											}
											else
											{
												UPI_Amnt = 0;
											}
											if(input.Bank_Transfer_Amount != null)
											{
												Bank_Transfer_Amnt = input.Bank_Transfer_Amount;
											}
											else
											{
												Bank_Transfer_Amnt = 0;
											}
											if(input.Card_Swipe_Amount != null)
											{
												Card_Swipe_Amnt = input.Card_Swipe_Amount;
											}
											else
											{
												Card_Swipe_Amnt = 0;
											}
											input.Total_Amount = cash_amount + cheque_amnt + UPI_Amnt + Card_Swipe_Amnt + Bank_Transfer_Amnt;
											// 	if(input.CaAmount != null && input.Cheque_Amount != null && input.UPI_Amount != null && input.Bank_Transfer_Amount != null && input.Card_Swipe_Amount!= null){
