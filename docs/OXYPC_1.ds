			Add_to_Sold_Out_Report as "Add to Sold Out Report"
			{
				type =  form
				form = Sold_Out_Tags
				record event = on add or edit
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											newline = hextotext("0A");
										for each  i in input.Tag_Numbers.toList(newline)
										{
											sold_out_recs = Sold_Out_Report[Tag_Number.equalsIgnoreCase(i)];
											inv_rec = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(i)];
											if(sold_out_recs.count() == 0)
