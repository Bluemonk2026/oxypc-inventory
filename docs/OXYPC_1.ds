	section Biding
	{
		icon = "tech-desktop"
		form Biding
		{
			success message = "Data Added Successfully!"
			field alignment = left
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			Select_Lot_Number
			(
				type = picklist
				displayname = "Select Lot Number"
				maxchar = 100
				values = {"Choice 1","Choice 2","Choice 3"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Laptop_Details
			(
				type = grid
				displayname = "Laptop Details"
				Product_Description
				(
    				type = text
					displayname = "Product Description"
					width = medium
				)
				Make
				(
    				type = text
					width = medium
				)
				Model
				(
    				type = text
					width = medium
				)
				CPU
				(
    				type = text
					width = medium
				)
				Generation
				(
    				type = text
					width = medium
				)
				Ram
				(
    				type = text
					width = medium
				)
				HDD
				(
    				type = text
					width = medium
				)
				Category
				(
    				type = text
					width = medium
				)
				Quantity
				(
					type = number
					width = medium
				)
				Unit_Price1
				(
					type = decimal
					displayname = "Unit Price"
					width = medium
				)
				Unit_Price2
				(
					type = decimal
					displayname = "Unit Price"
					width = medium
				)
				Unit_Price3
				(
					type = decimal
					displayname = "Unit Price"
					width = medium
				)
				Unit_Price4
				(
					type = decimal
					displayname = "Unit Price"
					width = medium
				)
	 			row = 2
	 			column = 1   
				width = medium
			)
			Section2
			(
				type = section
				displayname = "Total Quantity"
	 			row = 3
	 			column = 0   
				width = medium
			)
			Total_Quantity
			(
				type = number
				displayname = "Total Quantity"
	 			row = 3
	 			column = 1   
				width = medium
			)
			Unit_1_Grand_Total
			(
				type = decimal
				displayname = "Unit 1 Grand Total"
	 			row = 3
	 			column = 2   
				width = medium
			)
	
			customize
			(
				icon = "ui-1-bold-add"
			)
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		default list Biding_Report
		{
			displayName = "Biding Report"
			show all rows from Biding    
			(
				Select_Lot_Number as "Select Lot Number"
				Total_Quantity as "Total Quantity"
				Laptop_Details as "Laptop Details"
				(
					field = Laptop_Details.Product_Description + " " + Laptop_Details.Quantity + " " + Laptop_Details.Unit_Price4 + " " + Laptop_Details.Unit_Price3 + " " + Laptop_Details.Unit_Price2 + " " + Laptop_Details.Unit_Price1
				)
				Unit_1_Grand_Total as "Unit 1 Grand Total"
			)
			options
			(
				icon = "business-laptop-71"
	 		)
			quickview
			(
				layout
				(
		 			type = -1
					datablock1
					(
						layout type = -1
						fields
						(
							Select_Lot_Number as "Select Lot Number"
							Laptop_Details.Product_Description as "Laptop Details"
							Total_Quantity as "Total Quantity"
							Unit_1_Grand_Total as "Unit 1 Grand Total"
						)
					)
				)
				menu
    			(
    	 			header
    	 			(
    		 			Edit 
    		 			Duplicate 
    		 			Delete 
    	 			)
					record
					(
						Edit   	   
						Duplicate   	   
						Delete   	   
    				)
    			)
    			action
    			(
					on click
					(
						View Record   	   
    				)
					on right click
					(
						Edit   	   
						Delete   	   
						Duplicate   	   
						View Record   	   
    				)
     			)
			)
			detailview
			(
				layout
				(
		 			type = 2
					datablock1
					(
						layout type = -2
		     			title = "Overview"
						fields
						(
							Select_Lot_Number as "Select Lot Number"
							Laptop_Details.Product_Description as "Laptop Details"
							Total_Quantity as "Total Quantity"
						)
					)
					datablock2
					(
						layout type = -1
		     			title = "Laptop Details"
		     			related field = Laptop_Details
						fields
						(
							Product_Description as "Product Description"
							Category
							Quantity
							Unit_Price1 as "Unit Price"
							Unit_Price2 as "Unit Price"
							Unit_Price3 as "Unit Price"
							Unit_Price4 as "Unit Price"
						)
					)
				)
				menu
    			(
    	 			header
    	 			(
    		 			Edit 
    		 			Duplicate 
    		 			Delete 
    	 			)
    			)
			)
		}
	}
