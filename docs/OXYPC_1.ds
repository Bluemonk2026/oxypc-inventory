			Validation_for_duplicate as "Validation for duplicate"
			{
				type =  form
				form = RMA_Create_Job
				record event = on add

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.Tag_Number != "")
										{
											result_data = RMA_Create_Job[Tag_Number.equalsIgnoreCase(input.Tag_Number)] sort by Added_Time desc;
											if(result_data.count() > 0)
											{
												invetory_result = Inventory_of_RMA[Tag_Number.equalsIgnoreCase(input.Tag_Number)] sort by Added_Time desc;
												if(invetory_result.Stage != "Shipping Completed")
												{
													alert "This job has already been created and has not yet shipped.";
													cancel submit;
												}
												else
												{
												}
											}
										}
										if(input.Serial_Number != "")
										{
											result_data = RMA_Create_Job[Serial_Number.equalsIgnoreCase(input.Serial_Number)] sort by Added_Time desc;
											if(result_data.count() > 0)
											{
												invetory_result = Inventory_of_RMA[Serial_Number.equalsIgnoreCase(input.Serial_Number)] sort by Added_Time desc;
												if(invetory_result.Stage != "Shipping Completed")
												{
													alert "This job has already been created and has not yet shipped.";
													cancel submit;
												}
												else
												{
												}
											}
										}
						)
					}
				}

			}
