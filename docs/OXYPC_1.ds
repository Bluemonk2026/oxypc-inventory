			Update_Purchase_Price_and as "Update Purchase Price and Location in Inventory"
			{
				type =  schedule
				form = GRN
				start = after 10 minutes from Added_Time
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						for each  i in Item
										{
											if(i.Tag_Numbers != null)
											{
												newline = hextotext("0A");
												for each  j in i.Tag_Numbers.toList(newline)
												{
													iqc_records = IQC_Format_for_Laptop[TAG_NO.equalsIgnoreCase(j)];
													desk_rec = IQC_Format_for_Desktop[Tag_No.equalsIgnoreCase(j)];
