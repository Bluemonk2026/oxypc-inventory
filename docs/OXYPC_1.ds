			Fillallthedetails as "Fillallthedetails"
			{
				type =  form
				form = IQC_Format_for_Laptop
				record event = on add

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.Model1 == null)
										{
											alert "Please fill all the details before submit the form";
											cancel submit;
										}
										// if(input.Does == "Yes" && input.CPU == null || input.Generation == null || input.Sound == null || input.Web_Cam == null || input.WIFI == null)
										// {
										// 	alert "Please select the value for fields CPU, Generation, Sound, Web Cam and WIFI";
										// 	cancel submit;
										// }
										if(input.RAM_1 == "Yes" && input.Capacity == null || input.RAM_Status == null)
										{
											alert "Please select the value for fields Capacity and Ram Status";
											cancel submit;
										}
										if(input.HDD == "Yes" && input.Category == null || input.HDD_Capacity == null || input.Health == null)
										{
											alert "Please select the value for fields Category, HDD Capacity and Health %";
											cancel submit;
										}
										lst = list();
										if(input.Front_Panel == null || input.Front_Panel == "")
										{
											lst.add("Front Panel(Bazel)");
											alert "Please check Front Panel once";
											cancel submit;
										}
										if(input.Touch_Pad == null || input.Touch_Pad == "")
										{
											lst.add("Touch Pad");
											alert "Please check Touch Pad once";
											cancel submit;
										}
										if(input.Panel == null || input.Panel == "")
										{
											lst.add("Panel");
											alert "Please check Panel once";
											cancel submit;
										}
										if(input.Logic_Card == null || input.Logic_Card == "")
										{
											lst.add("Logic Card");
											alert "Please check Logic Card once";
											cancel submit;
										}
										if(input.Base == null || input.Base == "")
										{
											lst.add("Base");
											alert "Please check Base once";
											cancel submit;
										}
										if(input.Keyboard == null || input.Keyboard == "")
										{
											lst.add("Keyboard");
											alert "Please check Keyboard once";
											cancel submit;
										}
										if(input.HDD_Connector == null || input.HDD_Connector == "")
										{
											lst.add("HDD Connector");
											alert "Please check HDD Connector once";
											cancel submit;
										}
										if(input.HDD_Cover == null || input.HDD_Cover == "")
										{
											lst.add("HDD Cover");
											alert "Please check HDD Cover once";
											cancel submit;
										}
										if(input.HDD_Casing == null || input.HDD_Casing == "")
										{
											lst.add("HDD Casing");
											alert "Please check HDD Casing once";
											cancel submit;
										}
										if(input.WIFI == null || input.WIFI == "")
										{
											lst.add("WIFI");
											alert "Please check WIFI once";
											cancel submit;
										}
										if(input.Microphone == null || input.Microphone == "")
										{
											lst.add("Microphone");
											alert "Please check Microphone once";
											cancel submit;
										}
										if(input.Power_Panel == null || input.Power_Panel == "")
										{
											lst.add("Power Panel");
											alert "Please check Power Panel once";
											cancel submit;
										}
										if(input.Sound == null || input.Sound == "")
										{
											lst.add("Sound");
											alert "Please check Sound once";
											cancel submit;
										}
										if(input.Web_Cam == null || input.Web_Cam == "")
										{
											lst.add("Web Cam");
											alert "Please check Web Cam once";
											cancel submit;
										}
										if(input.USB == null || input.USB == "")
										{
											lst.add("USB");
											alert "Please check USB once";
											cancel submit;
										}
										if(input.DVD == null || input.DVD == "")
										{
											lst.add("DVD");
											alert "Please check DVD once";
											cancel submit;
										}
										if(input.DVD_Flap == null || input.DVD_Flap == "")
										{
											lst.add("DVD Flap");
											alert "Please check DVD Flap once";
											cancel submit;
										}
										if(input.Battery == null || input.Battery == "")
										{
											lst.add("Battery");
											alert "Please check Battery once";
											cancel submit;
										}
										if(input.Battery_Cable == null || input.Battery_Cable == "")
										{
											lst.add("Battery Cable");
											alert "Please check Battery Cable once";
											cancel submit;
										}
										if(input.Hinch == null || input.Hinch == "")
										{
											lst.add("Hinge");
											alert "Please check Hinge once";
											cancel submit;
										}
										if(input.Hinch_Cover == null || input.Hinch_Cover == "")
										{
											lst.add("Hinge Cover");
											alert "Please check Hinge Cover once";
											cancel submit;
										}
										if(input.Int_Battery == null || input.Int_Battery == "")
										{
											lst.add("Int Battery");
											alert "Please check Int Battery once";
											cancel submit;
										}
										if(input.Status == "" || input.Status == null)
										{
											alert "Please Fill value for status";
											cancel submit;
										}
										// if(lst.size() != 0)
										// {
										// 	alert "Fields " + lst.toString() + " are not filled. Please fill all the fields to move forward.";
										// 	cancel submit;
										// }
						)
					}
				}

			}
			FiilAllDesktopFormDetails as "FiilAllDesktopFormDetails"
			{
				type =  form
				form = IQC_Format_for_Desktop
				record event = on add

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.Model == null)
										{
											alert "Please fill all the details before submit the form";
											cancel submit;
										}
										if(input.Motherboard == "Yes")
										{
											if(input.Generation == "" || input.Generation == null)
											{
												alert "Please Fill value for Generation";
												cancel submit;
											}
											if(input.Motherboard_Status == "" || input.Motherboard_Status == null)
											{
												alert "Please Fill value for Motherboard Status";
												cancel submit;
											}
											if(input.CPU == "")
											{
												alert "Please Fill the value for CPU";
												cancel submit;
											}
											if(input.CPU == "Yes")
											{
												if(input.CPU_Status == "" || input.CPU_Status == null)
												{
													alert "Please Fill value for CPU Status";
													cancel submit;
												}
												if(input.Processors == "" || input.Processors == null)
												{
													alert "Please Fill value for Processors";
													cancel submit;
												}
											}
											if(input.Ram_Slot == "" || input.Ram_Slot == null)
											{
												alert "Please Fill value for Ram Slot";
												cancel submit;
											}
											if(input.Slot_No == "")
											{
												alert "Please Fill value for Slot No.";
												cancel submit;
											}
											if(input.RAM == "")
											{
												alert "Please Fill the value for RAM";
												cancel submit;
											}
											if(input.RAM == "Yes")
											{
												if(input.Capacity == "")
												{
													alert "Please Fill the value for Capacity";
													cancel submit;
												}
												else
												{
													if(input.RAM_Status == "")
													{
														alert "Please Fill value for RAM Status";
													}
												}
											}
											if(input.HDD == "")
											{
												alert "Please Fill value for HDD";
												cancel submit;
											}
											if(input.HDD == "Yes")
											{
												if(input.Catagory == "")
												{
													alert "Please Fill value for Category";
													cancel submit;
												}
												if(input.HDD_Capacity == "")
												{
													alert "Please Fill value for HDD Capacity";
													cancel submit;
												}
												else
												{
													if(input.Health == "")
													{
														alert "Please Fill value for HDD Health";
														cancel submit;
													}
												}
											}
											if(input.Display == "")
											{
												alert "Please Fill value for Display";
												cancel submit;
											}
											if(input.SMPS == "")
											{
												alert "Please Fill value for SMPS";
												cancel submit;
											}
											if(input.SMPS == "Yes")
											{
												if(input.SMPS_status == "")
												{
													alert "Please Fill value for SMPS Status";
													cancel submit;
												}
											}
											if(input.HDD_Casing == "")
											{
												alert "Please Fill value for HDD Casing";
												cancel submit;
											}
											if(input.USB == "")
											{
												alert "Please Fill value for USB";
												cancel submit;
											}
											if(input.Cabinet == "")
											{
												alert "Please Fill value for Cabinet";
												cancel submit;
											}
										}
						)
					}
				}

			}
