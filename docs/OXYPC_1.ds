			Updated_Harvested_Part_In as "Updated Harvested Part Inventory in zoho books"
			{
				type =  form
				form = Harvested_Parts1
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											Harvested_Part_Details = Harvested_Parts1[ID = input.ID];
										Part_Name = Harvested_Part_Details.Spare_Part_Name;
										Items = invokeurl
										[
											url :"https://www.zohoapis.in/inventory/v1/items/?name=" + Part_Name + "&organization_id=60020430422"
											type :GET
											connection:"zoho_books"
										];
										List_size = Items.get("items").size();
										if(List_size == 0)
										{
											create_product_map = Map();
											create_product_map.put("name",Part_Name);
											create_product_map.put("sku",Part_Name);
											custom_field_list = List();
											customfieldmap1 = Map();
											customfieldmap1.put("field_id","1243157000000823315");
											customfieldmap1.put("customfield_id","1243157000000823315");
											customfieldmap1.put("value",Harvested_Part_Details.Make.Make);
											custom_field_list.add(customfieldmap1);
											customfieldmap2 = Map();
											customfieldmap2.put("field_id","1243157000000823321");
											customfieldmap2.put("customfield_id","1243157000000823321");
											customfieldmap2.put("value",Harvested_Part_Details.Model.Model);
											custom_field_list.add(customfieldmap2);
											customfieldmap3 = Map();
											customfieldmap3.put("field_id","1243157000000823327");
											customfieldmap3.put("customfield_id","1243157000000823327");
											customfieldmap3.put("value",Harvested_Part_Details.Spare_Part_Category);
											custom_field_list.add(customfieldmap3);
											customfieldmap4 = Map();
											customfieldmap4.put("field_id","1243157000000823333");
											customfieldmap4.put("customfield_id","1243157000000823333");
											customfieldmap4.put("value",Harvested_Part_Details.Spare_Part_Sub_Category);
											custom_field_list.add(customfieldmap4);
											customfieldmap5 = Map();
											customfieldmap5.put("field_id","1243157000000823339");
											customfieldmap5.put("customfield_id","1243157000000823339");
											customfieldmap5.put("value","Harvested");
											custom_field_list.add(customfieldmap5);
											create_product_map.put("custom_fields",custom_field_list);
											create_product_map.put("rate",0);
											create_product_map.put("unit","pcs");
											create_product_map.put("item_type","inventory");
											create_product_map.put("initial_stock",Harvested_Part_Details.In_Quantity);
											create_product_map.put("initial_stock_rate",5);
											info create_product_map;
											create_Item = invokeurl
											[
												url :"https://www.zohoapis.in/inventory/v1/items?organization_id=60020430422"
												type :POST
												parameters:create_product_map.toString()
												connection:"zoho_books"
											];
											info create_Item;
										}
										else
										{
											for each  Item in Items.get("items")
											{
												Item_Id = Item.get("item_id");
												Item_Details = invokeurl
												[
													url :"https://www.zohoapis.in/inventory/v1/items/" + Item_Id + "?organization_id=60020430422"
													type :GET
													connection:"zoho_books"
												];
												info "lgfljgdfjdhas;nfcobuhflkjrf;mljefouhce cnowfguhrgyjfelkhvoinufwhnguvrhfeivu" + Item_Details;
												Available_stock = Item_Details.get("item").get("available_stock");
												Custom_fields = Item_Details.get("item").get("custom_fields");
												for each  field in Custom_fields
												{
													if(field.get("value") == "Harvested")
													{
														Inventory_type = field.get("value");
													}
													else if(field.get("value") == Harvested_Part_Details.Make.Make)
													{
														Make1 = field.get("value");
													}
													else if(field.get("value") == Harvested_Part_Details.Model.Model)
													{
														Model1 = field.get("value");
													}
													if(Inventory_type == "Harvested" && Make1 == Harvested_Part_Details.Make.Make && Model1 == Harvested_Part_Details.Model.Model)
													{
														adjustment_map = Map();
														adjustment_map.put("date",zoho.currentdate.toString("yyyy-MM-dd"));
														adjustment_map.put("reason","new quantity received");
														adjustment_map.put("adjustment_type","quantity");
														line_item_map = Map();
														line_item_map.put("item_id",Item_Id);
														line_item_map.put("quantity_adjusted",Harvested_Part_Details.In_Quantity);
														line_item_map.put("item_total",Available_stock + Harvested_Part_Details.In_Quantity);
														line_item_list = List();
														line_item_list.add(line_item_map);
														adjustment_map.put("line_items",line_item_list);
														adjust_inventory = invokeurl
														[
															url :"https://www.zohoapis.in/inventory/v1/inventoryadjustments?organization_id=60020430422"
															type :POST
															parameters:adjustment_map.toString()
															connection:"zoho_books"
														];
														info adjust_inventory;
													}
												}
											}
										}
						)
					}
				}

			}
