			Change_Stage_and_Status_i as "Change Stage and Status in Inventory"
			{
				type =  form
				form = L1_L2_Assignment_Screen
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Tag_No != "")
										{
											if(input.Assigned_to == "LOT Sale")
											{
												master_rec = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(input.Tag_No)];
												master_rec.Product_Stages="Assign to Lot";
												master_rec.Product_Category="Lot";
												master_rec.Warehouse="TRC 2ND Floor";
											}
											else
											{
												master_rec = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(input.Tag_No)];
												master_rec.Product_Stages="Assigned to L1/L2 Engineer";
												master_rec.Product_Category="Repair";
												master_rec.Warehouse="TRC 2ND Floor";
											}
										}
						)
					}
					actions 
					{
						custom deluge script
						(
											//-----Amazon Inventory---//
										//Search record in Amazon inventory 
										Tag_number_result = invokeurl
										[
											url :"https://creator.zoho.in/api/v2.1/protaiga/amazon-inventory/report/All_Amazon_Assets?Tag_Number=" + input.Tag_No
											type :GET
											connection:"creator"
										];
										info "Amazon Inventory Record" + Tag_number_result;
										//Data mapping 
										Data_map = Map();
										optional_map = Map();
										Data_map.put("Status","Repair");
										Data_map.put("Stage","Assigned to L1/L2 Engineer");
										// update Record if already present in Amazon inventory
										Tag_code = Tag_number_result.getJSON("code");
										Tag_msg = Tag_number_result.getJSON("message");
										if(Tag_code == 3000)
										{
											// info "update Record";
											Tag_data = Tag_number_result.getJSON("data");
											record_ID = Tag_data.getJSON("ID");
											update_rec = zoho.creator.updateRecord("protaiga","amazon-inventory","All_Amazon_Assets",record_ID,Data_map,optional_map,"creator");
											info update_rec;
										}
										else
										{
											info "record not persent";
										}
						)
					}
