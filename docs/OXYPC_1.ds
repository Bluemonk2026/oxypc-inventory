			hide_fields as "hide fields"
			{
				type =  form
				form = Spare_Part_GRN
				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											hide GRN_Number2;
										hide Freight_Cost;
										hide Pickup_cost;
										hide Data_to_sbfrm;
										hide Freight_Cost;
										hide Pickup_cost;
										hide GRN_Number_System;
										hide Items.GRN_Number;
										hide Items.Vehicle_Number;
										hide Items.Vendor_Name;
										hide Items.Freight_Cost;
										hide Items.Invoice_Value;
										hide Items.Pickup_cost;
										hide Items.Invoice_Number;
										// hide Items.Model;
										hide Items.Category11;
										// hide Items.Spare_Part_Name;
										hide Items.Make;
										hide Items.Sub_Category;
										disable Items.PO_Quantity;
										disable Items.Total_Item_Price;
										disable Items.Tax_Percentage;
										// disable Total_Invoice_Value;
										// disable CGST_Invoice;
										// disable IGST_Invoice;
										// disable SGST_Invoice;
										hide Items.GRN_Number_New;
						)
					}
					actions 
					{
						custom deluge script
						(
											disable SGST;
										disable CGST;
										disable IGST;
										disable Taxable_Amount;
										disable Tax_Amount;
										disable Invoice_Value;
										disable Total_Quantity;
										disable Total_Invoice_Quantity;
										disable Total_PO_Quantity;
										disable Variance;
										disable Total_Quantity;
										disable Total_Purchase_Value_Without_Tax;
						)
					}
				}

