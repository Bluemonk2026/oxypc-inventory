			Set_replace_values as "Set replace values"
			{
				type =  form
				form = IQC_Format_for_Laptop
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											base_value = input.Base;
										num = 0;
										lst = {};
										if(isNull(base_value) is false)
										{
											if(base_value == "Colour Fade")
											{
												input.Base_replace = "no";
												input.Base_Rate = 0;
											}
											else if(base_value == "Jali Broken")
											{
												input.Base_replace = "yes";
												num = num + 1;
												lst.add("BASE");
											}
											else if(base_value == "Major Broken")
											{
												input.Base_replace = "yes";
												num = num + 1;
												lst.add("BASE");
											}
											else if(base_value == "Major Scratch")
											{
												input.Base_replace = "no";
												input.Base_Rate = 0;
											}
											else if(base_value == "Minor Broken")
											{
												input.Base_replace = "no";
												input.Base_Rate = 0;
											}
											else if(base_value == "Minor Scratch")
											{
												input.Base_replace = "no";
												input.Base_Rate = 0;
											}
											else if(base_value == "Missing")
											{
												input.Base_replace = "yes";
												num = num + 1;
												lst.add("BASE");
											}
											else if(base_value == "Ok")
											{
												input.Base_replace = "no";
												input.Base_Rate = 0;
											}
										}
										DVD_flap_value = input.DVD_Flap;
