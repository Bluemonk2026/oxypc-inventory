											recs.Product_Stages="Assigned to Seller Flex";
											recs.Product_Category="Finished Good";
											final_qc = Final_QC1[Tag_Number.equalsIgnoreCase(input.Tag_Number)];
											input.Serial_Number = final_qc.Serial_Number;
											// 	######---RAM------#######
											if(final_qc.Updated_RAM == "" || final_qc.Updated_RAM == null)
											{
												input.RAM = final_qc.RAM;
											}
											else
											{
												input.RAM = final_qc.Updated_RAM;
											}
											// 	#############-----HDD------######
											if(final_qc.Updated_HDD == "" || final_qc.Updated_HDD == null)
											{
												input.HDD = final_qc.HDD;
