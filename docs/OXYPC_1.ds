	 			column = 0   
				width = medium
			)
			must have Status
			(
				type = picklist
				maxchar = 100
				values = {"Line","Scrap","Ok"}
	 			row = 2
	 			column = 1   
				width = medium
			)
			Scrap_Reason
			(
				type = picklist
				displayname = "Scrap Reason"
				maxchar = 100
				values = {"Broken","Unrepairable Line"}
	 			row = 2
	 			column = 1   
				width = medium
			)
	
