			Check_if_Final_QC_passed2 as "Check if Final QC passed"
			{
				type =  form
				form = Stock_Transfer_B2_to_Showroom_TRC_2nd_Floor
				record event = on add or edit

				on user input of Tag_Number
				{
					actions 
					{
						custom deluge script
						(
											transfer_rec = Stock_tranfer_TRC_to_Showroom[Tag_Number.equalsIgnoreCase(input.Tag_Number)];
										if(transfer_rec.count() != 0)
										{
											openUrl("https://creator.zoho.in" + zoho.appuri + "Stock_Transfer_B2_to_Showroom_TRC_2nd_Floor/record-edit/Stock_tranfer_TRC_to_Showroom_Report/" + transfer_rec.ID + "/","same window");
										}
										else
										{
											// ###################- Desktop Record -##############################
											desk_iqc_rec = IQC_Format_for_Desktop[Tag_No.equalsIgnoreCase(input.Tag_Number)];
											if(desk_iqc_rec.count() == 0)
											{
												// 	test
											}
											else
											{
												input.Make = desk_iqc_rec.Make.Make;
												input.Serial_Number = desk_iqc_rec.Serial_No;
												input.LOT_Number = desk_iqc_rec.LOT_No1.LOT_No;
												input.Model = desk_iqc_rec.Model.Model;
												input.Generation = desk_iqc_rec.Generation;
												input.CPU = desk_iqc_rec.Processors;
											}
											// ####################- TFT Record -####################################
											tft_iqc_rec = IQC_Format_for_TFT[TAG.equalsIgnoreCase(input.Tag_Number)];
											if(tft_iqc_rec.count() == 0)
											{
												// 	test
											}
											else
											{
												input.Make = tft_iqc_rec.Make;
												input.Serial_Number = tft_iqc_rec.Serial_Number;
												input.LOT_Number = tft_iqc_rec.Lot_No1.LOT_No;
											}
											// #########################- Laptop Record -#####################################
											// final_qc_rec = Final_QC1[Tag_Number.equalsIgnoreCase(input.Tag_Number)];
											Iqc_rec = IQC_Format_for_Laptop[TAG_NO == input.Tag_Number];
											// if(final_qc_rec.count() != 0)
											// {
											// 	if(final_qc_rec.Final_Status == "Fail")
											// 	{
											// 		alert "This Laptop has not been passed at Final QC";
											// 		input.Tag_Number = "";
											// 	}
											// 	else
											// 	{
											finalqqc_rec = Final_QC1[Tag_Number.equalsIgnoreCase(input.Tag_Number)];
											master_recs = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(input.Tag_Number)];
											if(master_recs.count() > 0)
											{
												finalqc_rec = Final_QC1[Tag_Number.equalsIgnoreCase(input.Tag_Number)];
												if(finalqc_rec.count() > 0)
												{
													if(finalqc_rec.Make == null)
													{
														input.Make = finalqc_rec.Make;
													}
													else
													{
														input.Make = finalqc_rec.Make;
													}
													if(finalqc_rec.Model == null)
													{
														input.Model = finalqc_rec.Model;
													}
													else
													{
														input.Model = finalqc_rec.Model;
													}
													if(finalqc_rec.Update_CPU1 == null || finalqc_rec.Update_CPU1 == "")
													{
														input.CPU = finalqc_rec.CPU;
													}
													else
													{
														input.CPU = finalqc_rec.Update_CPU1;
													}
													if(finalqc_rec.Generation == null || finalqc_rec.Generation == "")
													{
														input.Generation = finalqc_rec.Generation;
													}
													else
													{
														input.Generation = finalqc_rec.Generation;
													}
													if(finalqc_rec.Updated_RAM == null || finalqc_rec.Updated_RAM == "")
													{
														input.RAM = finalqc_rec.RAM;
													}
													else
													{
														input.RAM = finalqc_rec.Updated_RAM;
													}
													if(finalqc_rec.Updated_HDD == null || finalqc_rec.Updated_HDD == "")
													{
														input.HDD = finalqc_rec.HDD;
													}
													else
													{
														input.HDD = finalqc_rec.Updated_HDD;
													}
													input.Serial_Number = finalqc_rec.Serial_Number;
													input.LOT_Number = finalqc_rec.LOT_Number;
													input.Category = finalqc_rec.Category;
												}
												// 		}
												else
												{
													info "master_rec" + master_recs;
													master_recs.Warehouse="Bluemonk House Showroom";
													if(master_recs.Product_Sub_Category == "Laptop" || master_recs.Product_Sub_Category == "Desktop" || master_recs.Product_Sub_Category == "TFT")
													{
														info "if_loop" + master_recs.Product_Sub_Category;
														input.Category = master_recs.Product_Sub_Category;
													}
													// 	--------------------- Make ---------------------------------
													if(master_recs.Make == null || master_recs.Make == "")
													{
														if(master_recs.Make == null || master_recs.Make == "")
														{
															input.Make = master_recs.Make;
															input.Model = master_recs.Model;
														}
														else
														{
															input.Make = master_recs.Make;
														}
													}
													else
													{
														info "if_master_recs.Make" + master_recs.Make;
														input.Make = master_recs.Make;
													}
													// 	--------------------- Model --------------------------------
													if(master_recs.Model == null || master_recs.Model == "")
													{
														if(master_recs.Model == null || master_recs.Model == "")
														{
															input.Model = master_recs.Model;
														}
														else
														{
															input.Model = master_recs.Model;
														}
													}
													else
													{
														input.Model = master_recs.Model;
													}
													// --------------- CPU -----------------------------------
													if(master_recs.CPU == null || master_recs.CPU == "")
													{
														if(master_recs.CPU == null || master_recs.CPU == "")
														{
															input.CPU = master_recs.CPU;
														}
														else
														{
															input.CPU = master_recs.CPU;
														}
													}
													else
													{
														input.CPU = master_recs.CPU;
													}
													// ----------------- Generation ----------------------------
													if(master_recs.Generation == null || master_recs.Generation == "")
													{
														if(master_recs.Generation == null || master_recs.Generation == "")
														{
															input.Generation = master_recs.Generation;
														}
														else
														{
															input.Generation = master_recs.Generation;
														}
													}
													else
													{
														info master_recs.Generation;
														input.Generation = master_recs.Generation;
														info "else" + input.Generation;
													}
													// 	--------------------------- RAM,HDD,Serial number---------------------------------
													// 	input.RAM = master_recs.RAM;
													// 	input.HDD = master_recs.HDD;
													input.RAM = master_recs.RAM;
													input.HDD = master_recs.HDD;
													input.LOT_Number = master_recs.LOT_No;
													input.Serial_Number = master_recs.Serial_No;
												}
											}
											else
											{
												input.Make = Iqc_rec.Make.Make;
												input.Model = Iqc_rec.Model1.Model;
												input.CPU = Iqc_rec.CPU;
												input.Generation = Iqc_rec.Generation;
												input.RAM = Iqc_rec.Capacity;
												if(Iqc_rec.HDD_Capacity1 == null || Iqc_rec.HDD_Capacity1 == "")
												{
													input.HDD = Iqc_rec.HDD_Capacity;
												}
												else
												{
													input.HDD = Iqc_rec.HDD_Capacity1;
												}
												input.Category = "Laptop";
												input.Serial_Number = Iqc_rec.Serial_No;
											}
										}
						)
					}
				}

			}
