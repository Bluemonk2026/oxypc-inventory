												// 		url :"https://www.zohoapis.in/inventory/v1/transferorders?organization_id=60020430422"
												// 		type :POST
												// 		parameters:tranfer_mapp.toString()
												// 		connection:"zoho_books"
												// 	];
												// 	info tranfer_order_create;
											}
											else
											{
												line_item_list = List();
												line_item_map = Map();
												line_item_map.put("item_id",search_Item.get("items").get(0).get("item_id"));
												line_item_map.put("name",search_Item.get("items").get(0).get("name"));
												line_item_map.put("quantity_adjusted",1);
												// 	line_item_map.put("serial_numbers",Serial_Number_list2);
												// 		line_item_map.put("warehouse_id",1243157000002593007);
												// 		line_item_map.put("warehouse_name","Pre-Sales QC");
												line_item_list.add(line_item_map);
												Main_map = Map();
												Main_map.put("line_items",line_item_list);
												Main_map.put("date",zoho.currentdate.toString("yyyy-MM-dd"));
												Main_map.put("reason","new quantity received");
												Main_map.put("adjustment_type","quantity");
												Main_map.put("status","adjusted");
												// 	Main_map.put("branch_id",1243157000000034231)
												adjust_inventory = invokeurl
												[
													url :"https://www.zohoapis.in/inventory/v1/inventoryadjustments?organization_id=60020430422"
													type :POST
													parameters:Main_map.toString()
													connection:"zoho_books"
												];
												input.Zoho_Books_ID = search_Item.get("items").get(0).get("item_id");
											}
											so_items_rec = Sales_Order_Items[ID == input.Sales_order_item_id.toLong()];
											info so_items_rec.count();
											so_items_rec.Product_ready="Yes";
										}
						)
					}
				}

			}
			Add_or_Update_data_to_Fau as "Add or Update data to Faulty Spare Part"
			{
				type =  form
				form = L1_L2_Engineer_Screen
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											for each  i in faults
										{
											fault_id = i.ID;
											Faults_data = Faulty_Spare_Parts_After_IQC1[ID == fault_id];
											info "Faults_data_count" + Faults_data.count();
											info Faults_data.ID;
											if(Faults_data.count() == 0)
											{
												mapp = Map();
												mapp.put("Lot_No",input.LOT_No);
												if(input.New_Make == null || input.New_Make == "")
												{
													mapp.put("Make",input.Make);
												}
												else
												{
													mapp.put("Make",input.New_Make);
												}
												if(input.New_Model_Value == null || input.New_Model_Value == "")
												{
													mapp.put("Model",input.Model);
												}
												else
												{
													mapp.put("Model",input.New_Model_Value);
												}
												tag_number_iqc = IQC_Format_for_Laptop[TAG_NO == input.Barcode];
												mapp.put("Tag_No",tag_number_iqc.ID);
												mapp.put("Quantity",1);
												mapp.put("Consumed_By",input.Modified_User);
												mapp.put("L1_L2_Engineer_Date",zoho.currentdate.toString("dd-MMM-yyyy"));
												mapp.put("L1_L2_Engineer_Time",zoho.currenttime.getTime().toString("HH:mm:ss"));
												empty_mapp = Map();
												info "create_record_mapp" + mapp;
												info zoho.creator.createRecord("protaiga","oxypc-1","Faulty_Spare_Parts_After_IQC1",mapp,empty_mapp,"creator");
											}
											else
											{
												mapp = Map();
												mapp.put("Lot_No",input.LOT_No);
												if(input.New_Make == null || input.New_Make == "")
												{
													mapp.put("Make",input.Make);
												}
												else
												{
													mapp.put("Make",input.New_Make);
												}
												if(input.New_Model_Value == null || input.New_Model_Value == "")
												{
													mapp.put("Model",input.Model);
												}
												else
												{
													mapp.put("Model",input.New_Model_Value);
												}
												tag_number_iqc = IQC_Format_for_Laptop[TAG_NO == input.Barcode];
												if(tag_number_iqc.count() != 0)
												{
													mapp.put("Tag_No",tag_number_iqc.ID);
												}
												else
												{
													info "Tag Number Not Found in IQC";
												}
												mapp.put("Quantity",1);
												mapp.put("Consumed_By",input.Modified_User);
												mapp.put("L1_L2_Engineer_Date",zoho.currentdate.toString("dd-MMM-yyyy"));
												mapp.put("L1_L2_Engineer_Time",zoho.currenttime.getTime().toString("HH:mm:ss"));
												info "update_record_mapp" + mapp;
												empty_mapp = Map();
												info zoho.creator.updateRecord("protaiga","oxypc-1","Faulty_Spare_Parts_After_IQC1_Report",Faults_data.ID,mapp,empty_mapp,"creator");
											}
										}
						)
					}
				}

			}
			Get_Details_to_fill_in_Re as "Get Details to fill in Record"
			{
				type =  form
				form = L1_L2_Engineer_Screen
				record event = on add or edit

				on add row of faults
				{
					actions 
					{
						custom deluge script
						(
											row.Tag_No1=input.Barcode;
										// 	#########--Make--############
										if(input.New_Make == "" || input.New_Make == null)
										{
											mke = input.Make;
										}
										else
										{
											mke = input.New_Make;
										}
										// 	#########--Model--############
										if(input.New_Model_Value == "" || input.New_Model_Value == null)
										{
											mdl = input.Model;
										}
										else
										{
											mdl = input.New_Model_Value;
										}
										// 	#########--CPU--############
										if(input.New_CPU_Value == "" || input.New_CPU_Value == null)
										{
											cp = input.CPU;
										}
										else
										{
											cp = input.New_CPU_Value;
										}
										// 	#########--Generation--############
										if(input.New_Generation_Value == "" || input.New_Generation_Value == null)
										{
											gen = input.Generation;
										}
										else
										{
											gen = input.New_Generation_Value;
										}
										// 	###########--HDD--#################
										if(input.Added_Capacity1 == "" || input.Added_Capacity1 == null)
										{
											info "Entered If loop of HDD";
										}
										else
										{
											if(input.HDD != "" || input.HDD != null)
											{
												real_hdd = input.HDD.getprefix(" ");
											}
											else
											{
												real_hdd = 0;
											}
											info "Real_hdd !!!!-->" + real_hdd;
											pre_Added_Capacity1 = input.Added_Capacity1.getprefix(" ");
											info "pre_added_capacity1!!!!-->" + pre_Added_Capacity1;
											hdd_val = real_hdd.toNumber() + pre_Added_Capacity1.toNumber();
											hd = hdd_val.toString() + " GB";
										}
										if(input.Removed_Capacity1 == null || input.Removed_Capacity1 == "")
										{
											info "Entered If loop of HDD";
										}
										else
										{
											if(input.HDD != "" || input.HDD != null)
											{
												real_hdd = input.HDD.getprefix(" ");
											}
											else
											{
												real_hdd = 0;
											}
											pre_removed_Capacity1 = input.Removed_Capacity1.getprefix(" ");
											hdd_val = real_hdd.toNumber() - pre_removed_Capacity1.toNumber();
											hd = abs(hdd_val).toString() + " GB";
										}
										if(input.Added_Capacity1 == "" && input.Removed_Capacity1 == "")
										{
											hd = input.HDD;
										}
										// ########## -- RAM -- ############
										if(input.Removed_Capacity == null || input.Removed_Capacity == "")
										{
											info "Entered If loop of RAM";
										}
										else
										{
											if(input.RAM == null || input.RAM == "")
											{
												real_ram = 0;
											}
											else
											{
												real_ram = input.RAM.getprefix("GB");
											}
											pre_removed_capacity = input.Removed_Capacity.getprefix("GB");
											if(real_ram == 0)
											{
												alert "The RAM Storage Degradation is Invalid";
											}
											else
											{
												ram_val = real_ram.toNumber() - pre_removed_capacity.toNumber();
												ramm = abs(ram_val).toString() + "GB";
											}
										}
										if(input.Added_Capacity == null || input.Added_Capacity == "")
										{
											info "Entered If loop of RAM";
										}
										else
										{
											if(input.RAM == null || input.RAM == "")
											{
												real_ram = 0;
											}
											else
											{
												real_ram = input.RAM.getprefix("GB");
											}
											pre_added_capacity = input.Added_Capacity.getprefix("GB");
											ram_val = real_ram.toNumber() + pre_added_capacity.toNumber();
											ramm = abs(ram_val).toString() + "GB";
										}
										if(input.Removed_Capacity == "" && input.Added_Capacity == "")
										{
											ramm = input.RAM;
										}
										row.Make=mke;
										row.Model=mdl;
										row.Tag_No1=input.Barcode;
										row.Lot_No=input.LOT_No;
										row.Category="Laptop";
										row.L1_L2_Engineer_Date=zoho.currentdate.toString("dd-MMM-yyyy");
										row.Consumed_By=zoho.loginuser;
										row.L1_L2_Engineer_Time=zoho.currenttime.toString("HH:mm:ss");
										row.Model_Description=mke + " " + mdl + " " + cp + " " + gen + " " + ramm + " " + hd;
						)
					}
				}

			}
