			Add_data_to_the_Items_GRN as "Add data to the Items-GRN"
			{
				type =  form
				form = GRN
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											Creator_records = zoho.creator.getRecordById("protaiga","oxypc-1","GRN_Report",input.ID,"creator");
										// get_grn = GRN[GRN_Number == 305];
										file_upload1 = invokeurl
										[
											url :"https://creator.zoho.in/api/v2.1/protaiga/oxypc-1/report/GRN_Report/" + input.ID + "/Invoice_Image/download"
											type :GET
											connection:"creator"
										];
										info "invoice Image " + file_upload1;
										file_upload1.setParamName("file");
										file_upload2 = invokeurl
										[
											url :"https://creator.zoho.in/api/v2.1/protaiga/oxypc-1/report/GRN_Report/" + input.ID + "/E_way_Bill/download"
											type :GET
											connection:"creator"
										];
										info "E-way bill image " + file_upload2;
										file_upload2.setParamName("file");
										for each  itemm in Item
										{
											items_grn_rec = Items_GRN[Row_ID == toString(itemm.ID)];
											// 	items_grn_rec = Items_GRN[LOT_No == itemm.Lot_No && GRN_Number == input.GRN_Number && Category1 == itemm.Category && Sub_Category1 == itemm.Sub_Category1 && Physical_Quantity == itemm.Quantity.toLong() && Make == itemm.Make && Model == itemm.Model];
											if(items_grn_rec.count() == 0)
											{
												mapp = Map();
												mapp.put("GRN_Date",input.Date_field.toString("dd-MMM-yyyy"));
												mapp.put("Make",itemm.Make);
												if(isNull(itemm.Model) is false)
												{
													mapp.put("Model",itemm.Model);
												}
												if(isNull(input.Vendor_Name) is false)
												{
													mapp.put("Vendor_Name",input.Vendor_Name);
												}
												// 	if(isNull(input.Enter_Vendor_Name) is false)
												// 	{
												// 		mapp.put("Enter_Vendor_Name",input.Enter_Vendor_Name);
												// 	}
												// 		if(isNull(input.Freight_Cost) is false)
												// 		{
												// 			mapp.put("Freight_Cost",input.Freight_Cost);
												// 		}
												if(isNull(input.Invoice_Number) is false)
												{
													mapp.put("Invoice_Number",input.Invoice_Number);
												}
												// 		if(isNull(input.Pickup_Cost) is false)
												// 		{
												// 			mapp.put("Pickup_Cost",input.Pickup_Cost);
												// 		}
												if(isNull(input.Invoice_Value) is false)
												{
													mapp.put("Invoice_Value",input.Invoice_Value);
												}
												mapp.put("GRN_Number",input.GRN_Number);
												// 		mapp.put("Category1",itemm.Category);
												// 		mapp.put("Sub_Category1",itemm.Sub_Category1);
												info "mapp" + mapp;
												if(isNull(itemm.Quantity.toLong()) is false)
												{
													mapp.put("Physical_Quantity",itemm.Quantity.toLong());
												}
												mapp.put("Row_ID",itemm.ID);
												customer_rec = Customers_database[ID == itemm.Customer_Name];
												customer_namee = customer_rec.Customer_Name;
												if(isNull(customer_namee) is false)
												{
													mapp.put("Customer_Name",customer_namee);
												}
												if(isNull(itemm.Price) is false)
												{
													mapp.put("Price",itemm.Price);
												}
												if(isNull(itemm.Unit_Price_With_Tax_18) is false)
												{
													mapp.put("Unit_Price_With_Tax",itemm.Unit_Price_With_Tax_18);
												}
												filevariable = input.Invoice_Image;
												info input.Invoice_Image;
												mapp.put("Location",itemm.Location);
												mapp.put("LOT_No",itemm.Lot_No);
												mapp.put("Category1",itemm.Category);
												mapp.put("Sub_Category1",itemm.Sub_Category1);
												mapp.put("Item_Name",itemm.Item_Name1);
												mapp.put("PO_Quantity",itemm.Purchase_Order_Quantity);
												// 		mapp.put("PO_Number",input.Purchase_Order);
												mapp.put("Quantity_in_Invoice",itemm.Quantity_in_Invoice);
												mapp.put("Tag_Numbers",itemm.Tag_Numbers);
												mapp.put("Invoice_Date",input.Invoice_Date.toString("dd-MMM-yyyy"));
												mapp.put("Date_of_Material_Received",input.Date_of_Material_Received.toString("dd-MMM-yyyy"));
												if(itemm.HSN_Code != "" && itemm.HSN_Code != null)
												{
													mapp.put("HSN_code",itemm.HSN_Code);
												}
												mapp1 = Map();
												info mapp;
												create_record_in_item = zoho.creator.createRecord("protaiga","oxypc-1","Items_GRN",mapp,mapp1,"creator");
												info "Record Getting cREATED IN Items GRN: " + create_record_in_item;
												sendmail
												[
													from :zoho.loginuserid
													to :"shubham.oxypc@gmail.com"
													subject :"Items-GRN Report Create Record"
													message :"code_response: " + create_record_in_item
												]
												item_id = create_record_in_item.get("data").get("ID").toLong();
												upload = invokeurl
												[
													url :"https://creator.zoho.in/api/v2.1/protaiga/oxypc-1/report/Items_GRN_Report/" + item_id + "/Invoice_Image/upload"
													type :POST
													files:file_upload1
													connection:"creator"
												];
												info upload;
												upload2 = invokeurl
												[
													url :"https://creator.zoho.in/api/v2.1/protaiga/oxypc-1/report/Items_GRN_Report/" + item_id + "/E_way_Bill_Image/upload"
													type :POST
													files:file_upload2
													connection:"creator"
												];
												info upload2;
											}
											else
											{
												items_grn_rec.Location=itemm.Location;
												items_grn_rec.Make=itemm.Make;
												items_grn_rec.Model=itemm.Model;
												items_grn_rec.GRN_Number=input.GRN_Number;
												// 		items_grn_rec.PO_Number=input.Purchase_Order;
												items_grn_rec.Price=itemm.Price;
												items_grn_rec.GRN_Date=input.Date_field.toString("dd-MMM-yyyy");
												items_grn_rec.Date_of_Material_Received=input.Date_of_Material_Received.toString("dd-MMM-yyyy");
												items_grn_rec.Unit_Price_With_Tax=itemm.Unit_Price_With_Tax_18;
												items_grn_rec.Tag_Numbers=itemm.Tag_Numbers;
												items_grn_rec.Quantity_in_Invoice=itemm.Quantity_in_Invoice;
												items_grn_rec.PO_Quantity=itemm.Purchase_Order_Quantity;
												items_grn_rec.Category1=itemm.Category;
												// 		items_grn_rec.Sub_Category1=itemm.Sub_Category1;
												// 		items_grn_rec.Pickup_Cost=input.Pickup_Cost;
												items_grn_rec.GRN_Date=input.Date_field;
												// 		items_grn_rec.Freight_Cost=input.Freight_Cost;
												items_grn_rec.Invoice_Value=input.Invoice_Value;
												items_grn_rec.Invoice_Number=input.Invoice_Number;
												items_grn_rec.Physical_Quantity=itemm.Quantity;
												items_grn_rec.Sub_Category1=itemm.Sub_Category1;
												items_grn_rec.LOT_No=itemm.Lot_No;
												items_grn_rec.HSN_Code=itemm.HSN_Code;
												customer_rec = Customers_database[ID == itemm.Customer_Name];
												customer_namee = customer_rec.Customer_Name;
												items_grn_rec.Customer_Name=customer_namee;
												items_grn_rec.Vendor_Name=input.Vendor_Name;
												items_grn_rec.Row_ID=itemm.ID;
												items_grn_rec.Item_Name=itemm.Item_Name1;
												// 		items_grn_rec.Category=itemm.Item_Name_Unused;
												upload = invokeurl
												[
													url :"https://creator.zoho.in/api/v2.1/protaiga/oxypc-1/report/Items_GRN_Report/" + items_grn_rec.ID + "/Invoice_Image/upload"
													type :POST
													files:file_upload1
													connection:"creator"
												];
												info upload;
												upload2 = invokeurl
												[
													url :"https://creator.zoho.in/api/v2.1/protaiga/oxypc-1/report/Items_GRN_Report/" + items_grn_rec.ID + "/E_way_Bill_Image/upload"
													type :POST
													files:file_upload2
													connection:"creator"
												];
												info upload2;
											}
										}
						)
					}
				}

			}
