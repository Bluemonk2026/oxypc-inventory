			Send_harvested_Parts_to_H2 as "Send harvested Parts to Harvest inventory"
			{
				type =  form
				form = Desktop_L1_L2_Engineer_Screen1
				record event = on add
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											row1 = Desktop_L1_L2_Engineer_Screen1.faults();
										for each  i in faults
										{
											if(i.Status == "Replaced")
											{
												mapp = Map();
												mapp.put("Spare_Part_Name",i.Spare_Part);
												// 		make_val = Make[Make == input.Make];
												mapp.put("Make",input.Make);
												mapp.put("Model",input.Model);
												mapp.put("In_Quantity",i.Quantity);
