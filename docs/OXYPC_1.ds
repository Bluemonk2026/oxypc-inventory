			refresh_quantity as "refresh quantity"
			{
				type =  form
				form = Sales_Orders
				record event = on add or edit

				on delete row of Item_Table
				{
					actions 
					{
						custom deluge script
						(
											total_quan = 0;
										for each  i in Item_Table
										{
											if(i.Quantity != null)
											{
												total_quan = total_quan + i.Quantity;
											}
										}
										input.Total_Quantity = total_quan;
										// ------------ Laptop, Desktop and TFT Quantity ----------
										laptop_quan = 0;
										for each  i in Item_Table
										{
											if(i.Quantity != null && i.Category == "Laptop")
											{
												laptop_quan = laptop_quan + i.Quantity;
												show Laptop_Quantity;
											}
											else
											{
												laptop_quan = 0;
												hide Laptop_Quantity;
											}
										}
										input.Laptop_Quantity = laptop_quan;
										// ########--Desktop--########
										desktop_quan = 0;
										for each  i in Item_Table
										{
											if(i.Quantity != null && i.Category == "Desktop")
											{
												desktop_quan = desktop_quan + i.Quantity;
												show Desktop_Quantity;
											}
											else
											{
												desktop_quan = 0;
												hide Desktop_Quantity;
											}
										}
										input.Desktop_Quantity = desktop_quan;
										// ########--TFT--########
										tft_quan = 0;
										for each  i in Item_Table
										{
											if(i.Quantity != null && i.Category == "TFT")
											{
												tft_quan = tft_quan + i.Quantity;
												show TFT_Quantity;
											}
											else
											{
												tft_quan = 0;
												hide TFT_Quantity;
											}
										}
										input.TFT_Quantity = tft_quan;
						)
					}
				}

			}
