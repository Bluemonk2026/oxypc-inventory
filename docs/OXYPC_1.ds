			Update_the_Item_and_Stock as "Update the Item and Stock in zoho books"
			{
				type =  form
				form = Final_QC1
				record event = on add
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(Updated_Make != null)
										{
											Make1 = input.Updated_Make.Make;
										}
										else
										{
											Make1 = input.Make;
										}
										if(Updated_Model != null)
										{
											Model1 = input.Updated_Model.Model;
										}
										else
										{
											Model1 = input.Model;
										}
										if(Update_CPU1 != null)
										{
											CPU1 = input.Update_CPU1;
										}
										else
										{
											CPU1 = input.CPU;
										}
										if(Updated_Generation != null)
										{
											Generation1 = input.Updated_Generation;
										}
										else
										{
											Generation1 = input.Generation;
										}
										Model_Description = Make1 + " " + Model1 + " " + CPU1 + " " + Generation1;
										info Model_Description;
										search_Item = invokeurl
										[
											url :"https://www.zohoapis.in/inventory/v1/items?name=" + Model_Description + "&organization_id=60020430422"
											type :GET
											connection:"zoho_books"
										];
										Item_size = search_Item.get("items").size();
										if(Item_size == 0)
										{
											Serial_Number_list = List();
											Serial_Number_list.add(input.Serial_Number);
											create_product_map = Map();
											create_product_map.put("item_type","inventory");
											create_product_map.put("unit","pcs");
											create_product_map.put("initial_stock",1);
											create_product_map.put("rate",1);
											create_product_map.put("purchase_rate",1);
											create_product_map.put("name",Model_Description);
											create_product_map.put("track_serial_number",true);
											create_product_map.put("serial_numbers",Serial_Number_list);
											customfieldmap1 = Map();
											customfieldmap2 = Map();
											customfieldmap1.put("custom_field_id",1243157000000823315);
											customfieldmap1.put("field_id",1243157000000823315);
											customfieldmap1.put("value",Make1);
											customfieldmap2.put("custom_field_id",1243157000000823321);
											customfieldmap2.put("field_id",1243157000000823321);
											customfieldmap2.put("value",Model1);
											customfieldlist = List();
											customfieldlist.add(customfieldmap1);
											customfieldlist.add(customfieldmap2);
											create_product_map.put("custom_fields",customfieldlist);
											info create_product_map;
											create_item_in_books = invokeurl
											[
												url :"https://www.zohoapis.in/inventory/v1/items?&organization_id=60020430422"
												type :POST
												parameters:create_product_map.toString()
												connection:"zoho_books"
											];
											info create_item_in_books;
											sendmail
											[
												from :zoho.adminuserid
												to :"shivam.kountey@bluemonk.in"
												subject :"Testing Final QC"
												message :create_item_in_books
											]
										}
										else
										{
											info search_Item.get("items").get(0).get("item_id");
											Serial_Number_list2 = List();
											Serial_Number_list2.add(input.Serial_Number);
											line_item_list = List();
											line_item_map = Map();
											line_item_map.put("item_id",search_Item.get("items").get(0).get("item_id"));
											line_item_map.put("name",search_Item.get("items").get(0).get("name"));
											line_item_map.put("quantity_adjusted",1);
											line_item_map.put("serial_numbers",Serial_Number_list2);
											line_item_list.add(line_item_map);
											Main_map = Map();
											Main_map.put("line_items",line_item_list);
											Main_map.put("date",zoho.currentdate.toString("yyyy-MM-dd"));
											Main_map.put("reason","new quantity received");
											Main_map.put("adjustment_type","quantity");
											Main_map.put("status","adjusted");
											Main_map.put("branch_id",1243157000000034231);
											adjust_inventory = invokeurl
											[
												url :"https://www.zohoapis.in/inventory/v1/inventoryadjustments?organization_id=60020430422"
												type :POST
												parameters:Main_map.toString()
												connection:"zoho_books"
											];
											info adjust_inventory;
											sendmail
											[
												from :zoho.adminuserid
												to :"shivam.kountey@bluemonk.in"
												subject :"Testing Final QC"
												message :adjust_inventory
											]
										}
										someMap = Map();
										someMap.put("fullname","bhupendra jogi");
										someVariable = invokeurl
										[
											url :"https://www.zohoapis.in/crm/v2/functions/inventory_adjustment/actions/execute?auth_type=apikey&zapikey=1003.9eac3735cc5f804ed598f5dc508d2123.08409bf756dba1d51222d577019f07bf&name=shivam"
											type :GET
										];
										// <variable> = invokeUrl
										// [
										// 	url: <expression>
										// 	type: <request_type>
										// 	parameters: <expression>
										// 	headers: <expression>
										// 	connection: <connection>
										// ];
										info "someVariable";
										info someVariable;
						)
					}
				}

			}
			Delete_extra_faulty_spare as "Delete extra faulty spare records"
			{
				type =  form
				form = Desktop_L1_L2_Engineer_Screen1
				record event = on edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											// info "Enterered ny code";
										sendmail
										[
											from :zoho.loginuserid
											to :"shubham.namdev@crm-masters.com"
											subject :"Testing my function"
											message :"Testing Complete"
										]
										for each  i in input.faults
										{
											recss = Faulty_Spare_Parts_After_IQC1[ID != i.ID && Tag_No1 == input.Barcode];
											for each  j in recss
											{
												sendmail
												[
													from :zoho.loginuserid
													to :"shubham.namdev@crm-masters.com"
													subject :"Testing all the faults in Faulty spare part report"
													message :"records in faulty spare part to be deleted" + j
												]
												delete from Faulty_Spare_Parts_After_IQC1[ID == j.ID];
											}
										}
						)
					}
				}

			}
