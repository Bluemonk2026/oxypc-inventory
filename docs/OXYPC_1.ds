				record event = on add or edit

				on user input of Item_Table.Quantity
				{
					actions 
					{
						custom deluge script
						(
											if(row.Quantity > row.Quantity_Available)
										{
											alert "Quantity not Available";
											row.Quantity=null;
										}
						)
					}
				}

			}
