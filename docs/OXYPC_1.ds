			CreateRecordInCRMfromCrea as "CreateRecordInCRMfromCreator"
			{
				type =  form
				form = Spare_Part_Cost_LOT_Wise
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											fetch = Make[ID == input.Make];
										make = fetch.Make;
										model_laptop = Model[ID == input.Model];
										model = model_laptop.Model;
										cpu_laptop = CPU_Master[ID == input.CPU];
										laptop_cpu = cpu_laptop.CPU;
										gen_laptop = Classifications_of_Make_and_Model[ID == input.Generation];
										gen = gen_laptop.Generation;
										create_map = Map();
										create_map.put("LOT_No",input.LOT_No);
										create_map.put("Make",make);
										create_map.put("Model",model);
										create_map.put("Product_Description",input.Product_Description1);
										create_map.put("Number_of_replacements",input.Number_of_replacements);
										create_map.put("Replacements",input.Replacements);
										create_map.put("Total_Cost",input.Total_Cost);
										create_map.put("Purchase_Price",input.Purchase_Price);
										create_map.put("Sales_Price",input.Sales_Price);
										create_map.put("Name",make);
										create_rec = zoho.crm.createRecord("Profit_and_Loss",create_map);
						)
					}
				}

			}
			PushDatainZohoCRM as "PushDatainZohoCRM"
			{
				type =  form
				form = GRN
				record event = on add
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											main_form = GRN[ID == input.ID];
										data_map = Map();
										data_map.put("Name",input.Lot_No);
										data_map.put("Lot_No",input.Lot_No);
										data_map.put("Date",input.Date_field);
										data_map.put("Vehicle_Number",input.Vehicle_Number);
										data_map.put("Invoice_Number",input.Invoice_Number);
										data_map.put("Invoice_Value",input.Invoice_Value);
										// data_map.put("Customer_Name",input.itCustomer_Name);
										data_map.put("Vendor_Name",input.Vendor_Name);
										// data_map.put("Enter_Vendor_Name",input.Enter_Vendor_Name);
										// new="https://creator.zoho.in/api/v2/oxypccomputers/oxypc-1/report/GRN_Report/<record_ID>/Invoice_Image/download";
										// var2 = invokeurl
										// [
										// url :new
										// type :GET
										// connection: zcrm
										// ];
										// info var2;
										// var2.setParamName("file");
										// info var2.isfile();
										//response = zoho.crm.attachFile("Contacts", <crm_record_id>, var2, "zcrm");
										product_items = List();
										for each  r in main_form.Item
										{
											// 	get_pro_detail = Product_Master[ID == r.Item_Name_Unused];
											lineitem = Map();
											lineitem.put("Item_Name",r.Category);
											lineitem.put("Quantity",r.Quantity);
											lineitem.put("Price",r.Price);
											product_items.add(lineitem);
										}
										data_map.put("Item",product_items);
										updateresp = zoho.crm.createRecord("GRN",data_map);
										info updateresp;
						)
					}
				}

			}
