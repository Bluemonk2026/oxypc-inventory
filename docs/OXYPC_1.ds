			Create_record_in_final_qc as "Create record in final qc if status OK"
			{
				type =  form
				form = IQC_Format_for_TFT
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Status != "" || input.Status != null)
										{
											if(input.Status == "Ok")
											{
												mapp = Map();
												mapp.put("Tag_Number",input.TAG);
												mapp.put("Final_Status","Pass");
												mapp.put("Category","TFT");
												mapp.put("Make",input.Make);
												mapp.put("Remarks",input.Remarks);
												mapp.put("Serial_Number",input.Serial_Number);
												mapp.put("Warehouse","TRC 2ND Floor");
												mapp.put("Date_field",zoho.currentdate.toString("dd-MMM-yyyy"));
												mapp.put("Time",zoho.currenttime.getTime().toString("HH:mm:ss"));
												info mapp;
												empty_mapp = Map();
												create_rec = zoho.creator.createRecord("protaiga","oxypc-1","Final_QC1",mapp,empty_mapp,"creator");
												sendmail
												[
													from :zoho.loginuserid
													to :"shubham.oxypc@gmail.com"
													subject :"OK record in Final QC"
													message :create_rec
												]
											}
										}
						)
					}
				}

			}
			Update_Stage_in_Inventory as "Update Stage in Inventory"
			{
				type =  form
				form = Product_Master_Inventory1
				record event = on edit
					status = inactive

				on update of Checkbox
				{
					actions 
					{
						custom deluge script
						(
											inv_rec = Product_Master_Inventory1[ID == input.ID];
										for each  i in inv_rec
										{
											info "inventory record===" + i;
											product_cat = i.Product_Category2;
											info product_cat;
											if(product_cat != "" && product_cat == "Laptop")
											{
												final_qc_rec = Final_QC1[Tag_Number == i.Tag_No2];
												painting_rec = Painting[Tag_No == i.Tag_No2];
												cleaning_rec = Cleaning[Tag_No == i.Tag_No2];
												qc_rec = Final_QC_for_Engineer[Tag_No == i.Tag_No2];
												l3_l4_rec = L3_L4_Engineer_Screen[Barcode == i.Tag_No2];
												l1_l2_rec = L1_L2_Engineer_Screen[Barcode == i.Tag_No2];
												iqc_rec = IQC_Format_for_Laptop[TAG_NO == i.Tag_No2];
												if(final_qc_rec.count() != 0)
												{
													info "entered final_qc";
													i.Product_Category="Finished Good";
													i.Product_Stages="Inventory Finalized";
													if(final_qc_rec.Serial_Number != null || final_qc_rec.Serial_Number != "")
													{
														i.Serial_No=final_qc_rec.Serial_Number;
													}
												}
												else if(painting_rec.count() != 0)
												{
													info "entered painting";
													i.Product_Stages="Assigned to Final QC";
													i.Product_Category="Paint";
													if(painting_rec.Serial_Number != null || painting_rec.Serial_Number != "")
													{
														i.Serial_No=painting_rec.Serial_Number;
													}
												}
												else if(cleaning_rec.count() != 0)
												{
													info "enetered cleaning";
													i.Product_Stages="Assigned for Paint";
													i.Product_Category="Cleaning";
													if(painting_rec.Serial_Number != null || painting_rec.Serial_Number != "")
													{
														i.Serial_No=painting_rec.Serial_Number;
													}
												}
												else if(qc_rec.count() != 0)
												{
													info "qc entered";
													if(qc_rec.Final_Status == "Pass")
													{
														i.Product_Stages="Assigned for Cleaning";
														i.Product_Category="QC Pass";
													}
													else if(qc_rec.Final_Status == "Fail")
													{
														i.Product_Stages="Assigned to L1/L2 Engineer";
														i.Product_Category="QC Fail";
													}
													if(qc_rec.Serial_Number != null || qc_rec.Serial_Number != "")
													{
														i.Serial_No=qc_rec.Serial_Number;
													}
												}
												else if(l3_l4_rec.count() != 0)
												{
													info "entered l4";
													if(l3_l4_rec.Final_Status == "Ok")
													{
														i.Product_Stages="Assigned to L1/L2 Engineer";
														i.Product_Category="L4 Repair";
													}
													else if(l3_l4_rec.Final_Status == "Scrap")
													{
														i.Product_Stages="Scrap";
														i.Product_Category="Scrap";
													}
												}
												else if(l1_l2_rec.count() != 0)
												{
													info "l1/l2 entered";
													info l1_l2_rec.Final_Status;
													if(l1_l2_rec.Final_Status == "Completed")
													{
														i.Product_Stages="Assigned to QC";
														i.Product_Category="Repair";
													}
													if(l1_l2_rec.Final_Status == "Escalate to L4")
													{
														i.Product_Stages="Assigned to L3/L4";
														i.Product_Category="Repair";
														if(l3_l4_rec.count() != 0)
														{
															if(l3_l4_rec.Final_Status == "Ok")
															{
																i.Product_Stages="Assigned to L1/L2 Engineer";
																i.Product_Category="L4 Repair";
															}
															else if(l3_l4_rec.Final_Status == "Scrap")
															{
																i.Product_Stages="Scrap";
																i.Product_Category="Scrap";
															}
														}
													}
													else if(l1_l2_rec.Final_Status == "PNA")
													{
														i.Product_Stages="PNA(Part not available)";
														i.Product_Category="Repair";
													}
													else if(l1_l2_rec.Final_Status == "Scrap")
													{
														i.Product_Stages="Scrap";
														i.Product_Category="Scrap";
													}
													if(l1_l2_rec.Serial_Number != null || l1_l2_rec.Serial_Number != "")
													{
														i.Serial_No=l1_l2_rec.Serial_Number;
													}
												}
												else if(iqc_rec.count() != 0)
												{
													info "iqc entered";
													if(iqc_rec.Status == "BER")
													{
														i.Product_Stages="BER";
														i.Product_Category="BER";
													}
													else if(iqc_rec.Status == "Scrap")
													{
														i.Product_Stages="Scrap";
														i.Product_Category="Scrap";
													}
													else
													{
														i.Product_Stages="Assigned to L1/L2 Engineer";
														i.Product_Category="IQC Completed";
													}
													if(iqc_rec.Serial_No != null || iqc_rec.Serial_No != "")
													{
														i.Serial_No=iqc_rec.Serial_No;
													}
												}
											}
										}
						)
					}
				}

			}
