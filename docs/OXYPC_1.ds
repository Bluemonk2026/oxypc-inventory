					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		default list Desktop_L1_L2_Engineer_Screen1_Report
		{
			displayName = "Desktop Repair Report"
			show all rows from Desktop_L1_L2_Engineer_Screen1    
			(
				Barcode as "Tag No."
				Time
				LOT_No as "LOT No."
				checkbox as "Checkbox"
				Make
				Update_Make as "Update Make"
				New_Make as "New Make"
				CPU
				Update_CPU as "Update CPU"
				New_CPU_Value as "New CPU"
				RAM
				RAM_Status as "RAM Status"
				Action_Taken_RAM as "Action Taken(RAM) "
				Action_Taken_RAM1 as "Action Taken(RAM)"
				Removed_Capacity as "Removed Capacity RAM"
				Added_Capacity as "Added Capacity RAM"
				Date_field as "Date"
				Model
				Update_Model as "Update Model"
				New_Model_Value as "New Model"
				Serial_Number as "Serial Number"
				Generation
				Update_Generation as "Update Generation"
				New_Generation_Value as "New Generation"
				Engineer as "IQC Engineer"
				HDD
				Update_HDD as "Update HDD"
				Removed_Capacity1 as "Removed Capacity HDD"
				Added_Capacity1 as "Added Capacity HDD"
				Dust_Cleaning as "Dust Cleaning"
				C_MOS_Battery_Change as "C-MOS Battery Change"
				CPU_Thermal_Paste1 as "CPU Thermal Paste"
				Final_Status as "Final Status"
				Problem_Reported as "Problem Reported"
				Remarks
				Added_User as "Added User"
				Modified_Time as "Modified Time"
				Modified_User as "Modified User"
				New_Make1 as "New Make"
				New_Model as "New Model"
				New_CPU as "New CPU"
				New_Generation as "New Generation"
			)
			conditional formatting
			(
				"Final Status - Completed"
				{
				condition = (Final_Status == "Completed")
				fields = [Final_Status]
				format = "color:#ffffff;background-color:#5dc35a;"
				}
				"Final Status - Scrap"
				{
				condition = (Final_Status == "Scrap" || Final_Status == "Escalate to L4" || Final_Status == "PNA")
				fields = [Final_Status]
				format = "font-weight:bold;color:#ffffff;background-color:#ef1616;"
				}
			)
			quickview
			(
				layout
				(
		 			type = -1
					datablock1
					(
						layout type = -1
						fields
						(
							Added_User as "Added User"
							Modified_User as "Modified User"
							Modified_Time as "Modified Time"
							LOT_No as "LOT No."
							Barcode as "Tag No."
							Serial_Number as "Serial Number"
							Make
							Model
							CPU
							Generation
							RAM
							HDD
							Final_Status as "Final Status"
							Remarks
							Action_Taken_RAM as "Action Taken(RAM) "
							RAM_Status as "RAM Status"
							Action_Taken_RAM1 as "Action Taken(RAM)"
							Removed_Capacity as "Removed Capacity RAM"
							Added_Capacity as "Added Capacity RAM"
							New_Make as "New Make"
							New_Model_Value as "New Model"
							New_CPU_Value as "New CPU"
							New_Generation_Value as "New Generation"
							Update_HDD as "Update HDD"
							Removed_Capacity1 as "Removed Capacity HDD"
