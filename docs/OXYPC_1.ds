										mp.put("Remarks",input.Remarks);
										mp.put("Required_Replacements",input.Required_Replacements);
										mp.put("Total_Cost",input.Total_Cost);
										mp.put("Total_Number_of_Replacements",input.Number_of_replacements);
										crmresp = zoho.crm.createRecord("IQCs",mp);
						)
