			Update_Checkbox_of_each_r as "Update Checkbox of each row?"
			{
				type =  schedule
				form = GRN
				start = after 5 minutes from Modified_Time
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						for each  i in input.Item
										{
											newline = hextotext("0A");
											list_rec = i.Tag_Numbers.toList(newline);
											size_of_list = list_rec.size() - 1;
											info "Sizeeeeee" + size_of_list;
											count_of_recs = 0;
											for each  j in list_rec
											{
												inv_rec = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(j)];
												if(inv_rec.count() > 0 && inv_rec.Purchase_Price != null)
												{
													info "entered loop shubbhhh";
													count_of_recs = count_of_recs + 1;
												}
											}
											info "count of recssssssssSSSSSSSSSS ---> " + count_of_recs;
											info "size of listTTTTTTTTTTTTTT --> " + size_of_list;
											if(count_of_recs.toNumber() == size_of_list.toNumber())
											{
												info "Entered If loop";
												i.GRN_Check1="Yes";
												i.GRN_Check=true;
											}
										}
										// info "count of recs ---> " + count_of_recs;
										// info "size of list --> " + size_of_list;
					)
					}
				}
			}
			QCAssignment as "QCAssignment"
			{
				type =  schedule
				start = "2025-04-23 17:35:20"
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						qc_ass = QC_Assignment[ID > 0];
										qc_rec = Final_QC_for_Engineer[ID > 0];
										for each  i in qc_ass
										{
											qc_rec = Final_QC_for_Engineer[Tag_No.equalsIgnoreCase(i.Tag_No)];
											for each  j in qc_rec
											{
												if(j.Final_Status == "Pass")
												{
													i.Status="QC Done";
												}
											}
										}
					)
					}
				}
			}
			Update_Cleaning_Assignmen as "Update Cleaning Assignmen make nd model"
			{
				type =  schedule
				start = "2025-05-02 15:22:58"
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						for each  i in Cleaning_Assignment[ID != 0]
										{
											inv_rec = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(i.Tag_No)];
											i.Make=inv_rec.Make;
											i.Model=inv_rec.Model;
											i.CPU=inv_rec.CPU;
											i.Generation=inv_rec.Generation;
										}
					)
					}
				}
			}
		}

