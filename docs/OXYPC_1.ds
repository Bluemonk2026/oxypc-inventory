											{
												alert "Please Correct the Tag_No No.!!";
												input.Tag_No = "";
											}
											if(input.Tag_No.length() < 10 && input.Tag_No != "")
											{
												alert "Please Enter 10 digit Tag_No Number";
												input.Tag_No = "";
											}
											if(input.Tag_No.startswith("SN") is false && input.Tag_No != "")
											{
												alert "Tag_No Number should start with 'SN'";
												input.Tag_No = "";
											}
										}
						)
					}
				}

			}
