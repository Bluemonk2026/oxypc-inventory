				 void Test.AmazonTest(string Tagnumber)
                 {
                 	Tag_number_result = invokeurl
                 	[
                 		url :"https://creator.zoho.in/api/v2.1/protaiga/amazon-inventory/report/All_Amazon_Assets?Tag_Number=" + Tagnumber
                 		type :GET
                 		connection:"creator"
                 	];
                 	// 	info "Amazon Inventory Record" + Tag_number_result;
                 	Tag_code = Tag_number_result.getJSON("code");
                 	Tag_msg = Tag_number_result.getJSON("message");
                 	// 	info Tag_msg;
                 	// 	info Tag_code;
                 	if(Tag_code == "9220" && Tag_msg == "No records exist in this report.")
                 	{
                 		info "create record";
                 	}
                 	else if(Tag_code == 3000)
                 	{
                 		info "update Record";
                 		Tag_data = Tag_number_result.getJSON("data");
                 		// 		info Tag_data;
                 		record_ID = Tag_data.getJSON("ID");
                 		info record_ID;
                 		// 		ID : "164568000013889286"
                 	}
                 }
				 void Test.TestGRN()
                 {
                 	// 	IDx = 164568000013062054;
                 	rex = GRN[ID == 164568000013062054];
                 	//info rex;
                 	for each  linex in rex.Item
                 	{
                 		//info linex;
                 		newline = hextotext("0A");
                 		Tag_data = linex.Tag_Numbers.toList(newline);
                 		size_of_tagnumber = Tag_data.size();
                 		info "Size of Tag numbers" + size_of_tagnumber;
                 		count_tag_number = 0;
                 		for each  i in linex.Tag_Numbers.toList(newline)
                 		{
                 			count_tag_number = count_tag_number + 1;
                 			info "count of Loop" + count_tag_number;
                 		}
                 		if(count_tag_number == size_of_tagnumber)
                 		{
                 			linex.GRN_Check=true;
                 		}
                 	}
                 }
				 void Test.TestGRNZ(string id)
                 {
                 	IDx = 164568000013062054;
                 	rex = GRN[ID == IDx];
                 	//rec = GRN [ ID == id.toNumber() ];
                 	for each  i in rex.Item
                 	{
                 		if(i.Tag_Numbers != null)
                 		{
                 			newline = hextotext("0A");
                 			list_rec = i.toList();
                 			size_of_list = list_rec.size();
                 			info "size of list" + size_of_list;
                 			count_tag_number = 0;
                 			for each  j in i.Tag_Numbers.toList(newline)
                 			{
                 				count_tag_number = count_tag_number + 1;
                 			}
                 		}
                 	}
                 	info "Inside Loop count" + count_tag_number;
                 }
			 }
		 }




		workflow
		{
		form
		{
			Get_details_from_Tag_numb as "Get details from Tag number"
			{
				type =  form
				form = Stock_Location_Showroom
				record event = on add or edit

				on user input of Tag_Number
				{
					actions 
					{
						custom deluge script
						(
											if(input.Tag_Number != "")
										{
											Stock_tranfer_rec = Stock_tranfer_TRC_to_Showroom[Tag_Number.equalsIgnoreCase(input.Tag_Number)];
											if(Stock_tranfer_rec.count() == 0)
											{
												alert "Product Didn't Transferred to Showroom";
												input.Tag_Number = "";
											}
											else
											{
												input.Make = Stock_tranfer_rec.Make;
												input.Model = Stock_tranfer_rec.Model;
												input.CPU = Stock_tranfer_rec.CPU;
												input.Generation = Stock_tranfer_rec.Generation;
												input.RAM = Stock_tranfer_rec.RAM;
												input.HDD = Stock_tranfer_rec.HDD;
											}
										}
						)
					}
				}

			}
			Make_Product_Description as "Make Product Description"
			{
				type =  form
				form = Stock_Location_Showroom
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Make != null && input.Model != null && input.CPU != null && input.Generation != null && input.RAM != null && input.HDD != null)
										{
											model_description = input.Make + " " + input.Model + " " + input.CPU + " " + input.Generation + " " + input.RAM + " " + input.HDD;
											input.Product_Description = model_description;
										}
										else if(input.Make != null && input.Model != null && input.CPU != null && input.Generation != null && input.RAM != null && input.HDD == null)
										{
											model_description = input.Make + " " + input.Model + " " + input.CPU + " " + input.Generation + " " + input.RAM;
											input.Product_Description = model_description;
										}
										else if(input.Make != null && input.Model != null && input.CPU != null && input.Generation != null && input.RAM == null && input.HDD != null)
										{
											model_description = input.Make + " " + input.Model + " " + input.CPU + " " + input.Generation + " " + input.HDD;
											input.Product_Description = model_description;
										}
										else if(input.Make != null && input.Model != null && input.CPU != null && input.Generation == null && input.RAM != null && input.HDD != null)
										{
											model_description = input.Make + " " + input.Model + " " + input.CPU + " " + input.RAM + " " + input.HDD;
											input.Product_Description = model_description;
										}
										else if(input.Make != null && input.Model != null && input.CPU == null && input.Generation != null && input.RAM != null && input.HDD != null)
										{
											model_description = input.Make + " " + input.Model + " " + input.Generation + " " + input.RAM + " " + input.HDD;
											input.Product_Description = model_description;
										}
						)
					}
				}

			}
			Send_to_Final_QC_if_OK as "Send to Final QC if OK"
			{
				type =  form
				form = IQC_Format_for_Desktop
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Status != "")
										{
											if(input.Status = "Ok")
											{
												finalqc_rec = Final_QC1[Tag_Number == input.Tag_No];
												if(finalqc_rec.count() == 0)
												{
													mapp = Map();
													mapp.put("Final_Status","Pass");
													mapp.put("Make",input.Make.Make);
													mapp.put("Model",input.Model.Model);
													mapp.put("Tag_Number",input.Tag_No);
													mapp.put("Serial_Number",input.Serial_No);
													mapp.put("CPU",input.Processors);
													mapp.put("RAM",input.Capacity);
													mapp.put("HDD",input.HDD_Capacity);
													mapp.put("Remarks",input.Remarks);
													mapp.put("Category","Desktop");
													mapp.put("Date_field",zoho.currentdate.toString("dd-MMM-yyyy"));
													mapp.put("Time",zoho.currenttime.toString("HH:mm:ss"));
													mapp.put("LOT_Number",input.LOT_No1.LOT_No);
													mapp1 = Map();
													create_record = zoho.creator.createRecord("protaiga","oxypc-1","Final_QC1",mapp,mapp1,"creator");
													sendmail
													[
														from :zoho.loginuserid
														to :"shubham.namdev@crm-masters.com"
														subject :"Final QC"
														message :"Final QC If Ok Desktop" + create_record
													]
												}
											}
										}
						)
					}
				}

			}
