			Send_to_L3_L4_Engineer as "Send to L3/L4 Engineer"
			{
				type =  form
				form = L4_Support_Screen
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Final_Status = "Motherboard (Ok)")
										{
											rec_iqc = IQC_Format_for_Laptop[TAG_NO == input.Tag_No];
											rec_iqc.Assign_Status="Not Assigned";
											inventory_rec = Product_Master_Inventory1[Tag_No2 == input.Tag_No];
											if(inventory_rec.count(Make) != 0)
											{
												inventory_rec.Product_Stages="IQC Completed";
											}
											// 	delete from L4_Support_Pending_Bucket[Tag_No == input.Tag_No];
										}
										else if(input.Final_Status == "Escalate to L4")
										{
											mapp = Map();
											mapp.put("Tag_No1",input.Tag_No);
											mapp.put("Received_from","L4 Support");
											mapp.put("Received_from_Engineer",zoho.loginuser);
											mapp.put("Problem_Reported1",input.Fault);
											mapp1 = Map();
											zoho.creator.createRecord("protaiga","oxypc-1","Repair_Completed_L3_L4",mapp,mapp1,"creator");
											// 	delete from L4_Support_Pending_Bucket[Tag_No == input.Tag_No];
										}
										else
										{
											inventory_rec = Product_Master_Inventory1[Tag_No2 == input.Tag_No];
											// 	info inventory_rec.COUNT(RAM);
											if(inventory_rec.count(Make) != 0)
											{
												inventory_rec.Product_Stages="Scrap";
											}
											// 	delete from L4_Support_Pending_Bucket[Tag_No == input.Tag_No];
										}
						)
					}
				}

			}
