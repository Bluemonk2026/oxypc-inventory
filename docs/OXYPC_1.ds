			update_production_tracker6 as "update_production_tracker"
			{
				type =  form
				form = Desktop_L1_L2_Engineer_Screen1
				record event = on add
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											fgh = L1_L2_Engineer_Screen[ID == input.ID];
										User = fgh.Added_User;
										info User;
										Today_Production_Tracker = Production_Tracker[Engineer_Name == User.toString() && Date_field == zoho.currentdate];
										Tracker_Size = Today_Production_Tracker.count();
										info Tracker_Size;
										if(Tracker_Size == 0)
										{
											Create_map = Map();
											Create_map.put("IQC_Completed",0);
											Create_map.put("Date_field",zoho.currentdate.toString("dd-MMM-yyyy"));
											Create_map.put("L1_L2",1);
											Create_map.put("L3_L4",0);
											Create_map.put("L4_Support",0);
											Create_map.put("Final_QC",0);
											Create_map.put("Cleaning",0);
											Create_map.put("Painting",0);
											Create_map.put("Engineer_Name",User);
											empty_map = Map();
											Create_record = zoho.creator.createRecord("protaiga","oxypc-1","Production_Tracker",Create_map,empty_map,"creator");
											info Create_record;
										}
										else
										{
											Today_Production_Tracker = zoho.creator.getRecords("protaiga","oxypc-1","All_Production_Trackers","Date_field == \"" + zoho.currentdate + "\" && Engineer_Name== \"" + User + "\"",1,200,"creator");
											info Today_Production_Tracker;
											L1_L2_Count = Today_Production_Tracker.get("data").get("0").get("L1_L2");
											update_map = Map();
											update_map.put("L1_L2",L1_L2_Count.toNumber() + 1);
											emptymap = Map();
											update_map1 = zoho.creator.updateRecord("protaiga","oxypc-1","All_Production_Trackers",Today_Production_Tracker.get("data").get("0").get("ID").toLong(),update_map,emptymap,"creator");
										}
						)
					}
				}

			}
			Sending_to_Final_QC2 as "Sending to Final QC"
			{
				type =  form
				form = Desktop_L1_L2_Engineer_Screen1
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Final_Status = "Completed")
										{
											mapp = Map();
											mapp.put("Final_Status","Pass");
											if(input.New_Make == "" || input.New_Make == null)
											{
												mapp.put("Make",input.Make);
											}
											else
											{
												mapp.put("Make",input.New_Make);
											}
											if(input.New_Model_Value == "" || input.New_Model_Value == null)
											{
												mapp.put("Model",input.Model);
											}
											else
											{
												mapp.put("Model",input.New_Model_Value);
											}
											if(input.New_CPU_Value == "" || input.New_CPU_Value == null)
											{
												mapp.put("CPU",input.CPU);
											}
											else
											{
												mapp.put("CPU",input.New_CPU_Value);
											}
											if(input.New_Generation_Value == "" || input.New_Generation_Value == null)
											{
												mapp.put("Generation",input.Generation);
											}
											else
											{
												mapp.put("Generation",input.New_Generation_Value);
											}
											if(input.Removed_Capacity1 == "" || input.Removed_Capacity1 == null)
											{
												if(input.Added_Capacity1 == "" || input.Added_Capacity1 == null)
												{
													mapp.put("HDD",input.HDD);
												}
												else
												{
													mapp.put("HDD",input.Added_Capacity1);
												}
											}
											else
											{
												mapp.put("HDD",input.Removed_Capacity1);
											}
											if(input.Removed_Capacity == "" || input.Removed_Capacity == null)
											{
												if(input.Added_Capacity == "" || input.Added_Capacity == null)
												{
													mapp.put("RAM",input.RAM);
												}
												else
												{
													mapp.put("RAM",input.Added_Capacity);
												}
											}
											else
											{
												mapp.put("RAM",input.Removed_Capacity);
											}
											mapp.put("Tag_Number",input.Barcode);
											mapp.put("Serial_Number",input.Serial_Number);
											mapp.put("Remarks",input.Remarks);
											mapp.put("Category","Desktop");
											mapp1 = Map();
											create_record = zoho.creator.createRecord("protaiga","oxypc-1","Final_QC",mapp,mapp1,"creator");
											sendmail
											[
												from :zoho.loginuserid
												to :"shubham.oxypc@gmail.com"
												subject :"Create Record in Final QC after L1/L2 Desktop"
												message :"Ok Product" + create_record
											]
										}
						)
					}
				}

			}
			Show_RAM_Downgraded2 as "Show RAM Downgraded"
			{
				type =  form
				form = Desktop_L1_L2_Engineer_Screen1
				record event = on add or edit

				field rules
				{
					actions  (RAM_Status == "Downgraded")
					{
						show Action_Taken_RAM;
					}
					actions  (RAM_Status == "Upgraded")
					{
						show Action_Taken_RAM1;
					}
					actions  (Action_Taken_RAM == "Removed")
					{
						show Removed_Capacity;
					}
					actions  (Action_Taken_RAM1 == "Added")
					{
						show Added_Capacity;
					}
				}

			}
