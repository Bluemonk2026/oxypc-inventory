			Fetch_Count_from_Oxy_Pc_C as "Fetch Count from Oxy Pc Counts form"
			{
				type =  form
				form = RMA_Create_Job
				record event = on add
					status = inactive

				on load
				{
					actions 
					{
						custom deluge script
						(
											result = Oxy_Pc_Count[ID != null];
										current_date = zoho.currentdate;
										current_month = current_date.getMonth();
										current_year = current_date.getYear();
										// List of month names
										months = {"1":"Jan","2":"Feb","3":"Mar","4":"Apr","5":"May","6":"Jun","7":"Jul","8":"Aug","9":"Sep","10":"Oct","11":"Nov","12":"Dec"};
										months_name = months.get(current_month.toString());
										input.RMA_Number = months_name + "-" + current_year + "-" + "00" + result.RMA_Create_Job_Count;
						)
					}
				}

			}
