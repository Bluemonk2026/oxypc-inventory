				values = {"[AP] - Andhra Pradesh","[AR] - Arunachal Pradesh","[AS] - Assam","[BR] - Bihar","[CG] - Chhattisgarh","[GA] - Goa","[GJ] - Gujarat","[HR] - Haryana","[HP] - Himachal Pradesh","[JK] - Jammu and Kashmir","[JH] - Jharkhand","[KA] - Karnataka","[KL] - Kerala","[MP] - Madhya Pradesh","[MH] - Maharashtra","[MN] - Manipur","[ML] - Meghalaya","[MZ] - Mizoram","[NL] - Nagaland","[OR] - Orissa","[PB] - Punjab","[RJ] - Rajasthan","[SK] - Sikkim","[TN] - Tamil Nadu","[TR] - Tripura","[UK] - Uttarakhand","[UP] - Uttar Pradesh","[WB] - West Bengal","[AN] - Andaman and Nicobar Islands","[CH] - Chandigarh","[DH] - Dadra and Nagar Haveli and Daman and Diu","[DD] - Daman and Diu","[DL] - Delhi","[LD] - Lakshadweep","[PY] - Puducherry","[TS] - Telangana","[FC] - Foreign Country"}
				sortorder = ascending
