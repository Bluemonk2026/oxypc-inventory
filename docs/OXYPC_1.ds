	section Format_IQC_Faulty_Battery
	{
		displayname= "Format - IQC Faulty Battery"
		icon = "objects-battery"
		form IQC_Format_for_Battery
		{
			displayname = "IQC Format for Battery"
			success message = "Data Added Successfully!"
			field alignment = left
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have unique Tag_Number
			(
    			type = text
				displayname = "Tag Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Part_No
			(
    			type = text
				displayname = "Part No"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Make
			(
				type = picklist	
				values  = Make.ID
    			displayformat = [Make]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Battery_Option
			(
				type = picklist
				displayname = "Battery Option"
				maxchar = 100
				values = {"Internal","External"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Start_Time
			(
    			type = time
				displayname = "Start Time"
				initial value = "${zoho.currenttime}"	
				timedisplayoptions = "hh:mm:ss" 
	 			row = 1
	 			column = 1   
				width = medium
			)
			IQC_date
			(
    			type = date
				displayname = "IQC date"
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			IQC_Remarks
			(
    			type = textarea
				displayname = "IQC Remarks"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have LOT_Number
			(
    			type = text
				displayname = "LOT Number"
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Serial_No
			(
    			type = text
				displayname = "Serial No"
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Model
			(
				type = picklist	
				values  = Model[Make.ID == input.Make].ID
    			displayformat = [Model]
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Battery_Model
			(
				type = picklist	
				displayname = "Battery Model"
				values  = Battery_Models.ID
    			displayformat = [Model]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Type_of_Battery
			(
				type = picklist
				displayname = "Type of Battery"
				maxchar = 100
				values = {"Lithium","Polymer"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Type_cell
			(
				type = picklist
				displayname = "Type cell"
				maxchar = 100
				values = {"3 Cell","4 Cell","6 Cell","9 Cell"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Status
			(
				type = picklist
				maxchar = 100
				values = {"Ok","Scrap","Repair"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Problem_Reported
			(
				type = picklist
				displayname = "Problem Reported"
				maxchar = 100
				values = {"Dead Cell","Battery Not charging","Battery Not detected","Battery Damage","Battery Swelled"}
	 			row = 1
	 			column = 2   
				width = medium
			)
	
			customize
			(
				icon = "objects-battery"
			)
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
