													if(i == "BASE")
													{
														mapp3.put("Base",spp_rec.Base + 1);
													}
													if(i == "KEYBOARD")
													{
														mapp3.put("Keyboard",spp_rec.Keyboard + 1);
													}
													if(i == "LOGIC CARD")
													{
														mapp3.put("Logic_Card",spp_rec.Logic_Card + 1);
													}
													if(i == "USB")
													{
														mapp3.put("USB",spp_rec.USB + 1);
													}
													if(i == "HDD CONNECTOR")
													{
														mapp3.put("HDD_Connector",spp_rec.HDD_Connector + 1);
													}
													if(i == "SPEAKER")
													{
														mapp3.put("Sound",spp_rec.Sound + 1);
													}
													if(i == "HDD CASING")
													{
														mapp3.put("HDD_Casing",spp_rec.HDD_Casing + 1);
													}
													if(i == "HDD COVER")
													{
														mapp3.put("HDD_Cover",spp_rec.HDD_Cover + 1);
													}
													if(i == "RAM COVER")
													{
														mapp3.put("RAM_Cover",spp_rec.RAM_Cover + 1);
													}
													if(i == "WIFI")
													{
														mapp3.put("WIFI",spp_rec.WIFI + 1);
													}
													if(i == "DVD")
													{
														mapp3.put("DVD",spp_rec.DVD + 1);
													}
													if(i == "DVD FLAP")
													{
														mapp3.put("DVD_Flap",spp_rec.DVD_Flap + 1);
													}
												}
												mapp3.put("Model_Count",spp_rec.Model_Count + 1);
												empty_map = Map();
												update_rec = zoho.creator.updateRecord("protaiga","oxypc-1","All_Spare_Part_Plannings",spp_rec.ID,mapp3,empty_map,"creator");
												sendmail
												[
													from :zoho.loginuserid
													to :"shubham.namdev@crm-masters.com"
													subject :"SPP Updation"
													message :"Update Record in spp" + update_rec
												]
											}
										}
						)
					}
				}

			}
			Update_Faulty_spare_parts as "Update Faulty spare parts"
			{
				type =  form
				form = IQC_Format_for_Desktop
				record event = on edit

				on update of Checkbox
				{
					actions 
					{
						custom deluge script
						(
											if(input.Motherboard == "Yes")
										{
											mapp = Map();
											if(input.SMPS == "No" || (input.SMPS == "Yes" && input.SMPS_status == "Faulty"))
											{
												// 		input.Required_Replacements = model_value;
												mapp.put("Lot_No",input.LOT_No1.LOT_No);
												mapp.put("Make","DESKTOP");
												mapp.put("Model",input.Model.Model);
												rec = Spare_Parts2[Spare_Part_Name == "SMPS" && Category == "Desktop"];
												mapp.put("Spare_Part_Desktop",rec.ID);
												mapp.put("Spare_Part","SMPS");
												mapp.put("Tag_No1",input.Tag_No);
												mapp.put("Quantity",1);
												mapp.put("Category","Desktop");
												mapp1 = Map();
												create_record = zoho.creator.createRecord("protaiga","oxypc-1","Faulty_Spare_Parts_After_IQC1",mapp,mapp1,"creator");
											}
											if(input.HDD_Casing == "No")
											{
												// 		input.Required_Replacements = model_value;
												mapp.put("Lot_No",input.LOT_No1.LOT_No);
												mapp.put("Make","DESKTOP");
												mapp.put("Model",input.Model.Model);
												rec = Spare_Parts2[Spare_Part_Name == "HDD CASING" && Category == "Desktop"];
												mapp.put("Spare_Part_Desktop",rec.ID);
												mapp.put("Spare_Part","HDD CASING");
												mapp.put("Tag_No1",input.Tag_No);
												mapp.put("Quantity",1);
												mapp.put("Category","Desktop");
												mapp1 = Map();
												create_record = zoho.creator.createRecord("protaiga","oxypc-1","Faulty_Spare_Parts_After_IQC1",mapp,mapp1,"creator");
											}
										}
						)
					}
				}

			}
