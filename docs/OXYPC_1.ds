			(
				type = picklist
				displayname = "Final Status"
				maxchar = 100
				values = {"Escalate to L4","Escalate to Plastic Repair","Replacement Required","PNA","Replacement Issued","Repair Completed","Pending for Approval","CN Required","CN Issued","Return without Repair"}
