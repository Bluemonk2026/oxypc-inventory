			Update_the_SNo_and_IQC_Co as "Update the SNo and IQC Count in GRNvsIQC Report"
			{
				type =  form
				form = IQC_Format_for_Laptop
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											Lot_number1 = input.LOT_No2.LOT_No;
										get_GRN_vs_IQC = GRN_vs_IQC[Category_Wise_IQC_GRN.Lot_Number == Lot_number1];
										Subform_data = get_GRN_vs_IQC.Category_Wise_IQC_GRN;
										update_record_list = List();
										for each  data_item in Subform_data
										{
											if(data_item.Category == "Laptop")
											{
												update_record_map = Map();
												iqc_count_value = data_item.IQC_Count;
												info "testing" + iqc_count_value;
												if(iqc_count_value == null || iqc_count_value == 0)
												{
													iqc_count_value = 0;
												}
												info "tets" + iqc_count_value;
												data_item.IQC_Count=iqc_count_value + 1;
												Update_Tag = data_item.Tag_Numbers;
												if(Update_Tag == null)
												{
													Update_Tag1 = List();
													Update_Tag1.add(input.TAG_NO);
													data_item.Tag_Numbers=Update_Tag1;
												}
												else
												{
													info "jaa raha hai";
													upd = Update_Tag.toList();
													upd.add(input.TAG_NO);
													data_item.Tag_Numbers=upd;
												}
											}
										}
										// info update_record_map;
										// update_record_list = List();
										// final_map = Map();
										// final_map.put("Category_Wise_IQC_GRN",update_record_list);
										// empty_mp2 = Map();
										// final_update = zoho.creator.updateRecord("protaiga","oxypc-1","GRN_vs_IQC_Report",get_GRN_vs_IQC.ID,final_map,empty_mp2,"creator");
										// info final_update;
						)
					}
				}

			}
			Update_L3_L4_Bucket_if_es as "Update L3/L4 Bucket if escalate to l4"
			{
				type =  form
				form = L1_L2_Engineer_Screen
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Final_Status == "Escalate to L4")
										{
											mapp = Map();
											mapp.put("Tag_No1",input.Barcode);
											mapp.put("Problem_Reported1",input.Problem_Reported);
											mapp.put("Received_from_Engineer",zoho.loginuser);
											mapp.put("Received_from","L1/L2 Engineer");
											if(input.New_Make != "")
											{
												mapp.put("Make",input.New_Make);
											}
											else
											{
												mapp.put("Make",input.Make);
											}
											if(input.New_Model_Value != "")
											{
												mapp.put("Model",input.New_Model_Value);
											}
											else
											{
