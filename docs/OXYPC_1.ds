			Fetch_Information1 as "Fetch Information"
			{
				type =  form
				form = Screen_Cleaning
				record event = on add or edit

				on user input of Tag_Number
				{
					actions 
					{
						custom deluge script
						(
											if(input.Serial_Number1 == "" || input.Serial_Number1 == null)
										{
											input.Pin = "";
											input.Lot_Number = "";
											input.Serial_Number = "";
											input.Screen_Size = "";
											input.Problem_Reported = "";
											input.Screen_Type = "";
											input.Tag_Number = "";
										}
										else
										{
											del_rec = Delamination[Serial_Number1.equalsIgnoreCase(input.Serial_Number1)];
											if(del_rec.count() > 0)
											{
												iqc_screen_rec = IQC_format_for_Screen[Serial_Number.equalsIgnoreCase(input.Serial_Number1)];
												if(iqc_screen_rec.count() > 0)
												{
													input.Pin = iqc_screen_rec.Screen_Pin;
													input.Lot_Number = iqc_screen_rec.Lot_Number;
													input.Serial_Number = iqc_screen_rec.Part_No;
													input.Screen_Size = iqc_screen_rec.Screen_Size;
													input.Problem_Reported = iqc_screen_rec.Problem_Reported;
													input.Screen_Type = iqc_screen_rec.Screen_Type;
													input.Tag_Number = iqc_screen_rec.Tag_No;
												}
											}
											else
											{
												alert "Delamination Not Done for this Tag !!";
												input.Pin = "";
												input.Lot_Number = "";
												input.Serial_Number = "";
												input.Screen_Size = "";
												input.Problem_Reported = "";
												input.Screen_Type = "";
												input.Tag_Number = "";
											}
										}
						)
					}
				}

			}
