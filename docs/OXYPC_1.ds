			Calculation_of_GRN_number as "Calculation of GRN number"
			{
				type =  form
				form = GRN
				record event = on add or edit
					status = inactive

				on user input of Invoice_Number
				{
					actions 
					{
						custom deluge script
						(
											rec = GRN[ID != 0 && Invoice_Number != input.Invoice_Number] sort by Added_Time desc;
										if(rec.GRN != null)
										{
											input.GRN = rec.GRN + 1;
										}
						)
					}
				}

			}
