	section Raw_Data_Sales
	{
		displayname= "Raw Data - Sales"
		form Raw_Data_Sales
		{
			displayname = "Raw Data - Sales"
			success message = "Data Added Successfully!"
			field alignment = left
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have unique Tag_Number
			(
    			type = text
				displayname = "Tag Number"
				qrcode = true
				barcode = true
				camera = primary
	 			row = 1
	 			column = 1   
				width = medium
			)
			Invoice_Number
			(
    			type = text
				displayname = "Invoice Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Adapter
			(
				type = radiobuttons
				maxchar = 100
				values = {"Yes","No"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Battery
			(
				type = radiobuttons
				maxchar = 100
				values = {"Yes","No"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Quantity
			(
				type = number
				initial value = 1
	 			row = 1
	 			column = 1   
				width = medium
			)
			Date_field
			(
    			type = date
				displayname = "Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 2   
				width = medium
			)
			Customer_Name1
			(
				type = picklist	
				displayname = "Customer Name"
				values  = Customer_Database.ID
    			displayformat = [Customer_Name]
				allow new entries
				[
					displayname = "Add New"
				]
