											input.Capacity:ui.add("256 MB");
											input.Capacity:ui.add("512 MB");
											input.Capacity:ui.add("1 GB");
										}
										if(input.RAM_Type == "DDR 2")
										{
											input.Capacity:ui.add("256 MB");
											input.Capacity:ui.add("512 MB");
											input.Capacity:ui.add("1 GB");
											input.Capacity:ui.add("2 GB");
											input.Capacity:ui.add("4 GB");
										}
										if(input.RAM_Type == "DDR 3")
										{
											input.Capacity:ui.add("1 GB");
											input.Capacity:ui.add("2 GB");
											input.Capacity:ui.add("4 GB");
											input.Capacity:ui.add("8 GB");
											input.Capacity:ui.add("16 GB");
										}
										if(input.RAM_Type == "DDR 4")
										{
											input.Capacity:ui.add("4 GB");
											input.Capacity:ui.add("8 GB");
											input.Capacity:ui.add("16 GB");
											input.Capacity:ui.add("32 GB");
											input.Capacity:ui.add("64 GB");
											input.Capacity:ui.add("128 GB");
										}
										if(input.RAM_Type == "DDR 5")
										{
											input.Capacity:ui.add("8 GB");
											input.Capacity:ui.add("16 GB");
											input.Capacity:ui.add("32 GB");
											input.Capacity:ui.add("64 GB");
											input.Capacity:ui.add("128 GB");
											input.Capacity:ui.add("256 GB");
										}
										if(input.RAM_Type == "PC3L")
										{
											input.Capacity:ui.add("2 GB");
											input.Capacity:ui.add("4 GB");
											input.Capacity:ui.add("8 GB");
											input.Capacity:ui.add("16 GB");
											input.Capacity:ui.add("32 GB");
										}
						)
					}
				}

			}
