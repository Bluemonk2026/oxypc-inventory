			Update_Total_Invoice_Valu as "Update Total Invoice Value"
			{
				type =  form
				form = Spare_Part_GRN
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											sum = 0;
										for each  line_item in input.Items
										{
											if(line_item.Total_Item_Price == null)
											{
												line_item.Total_Item_Price=0;
											}
											sum = sum + line_item.Total_Item_Price;
										}
										input.Total_Invoice_Value = sum;
						)
					}
					actions 
					{
						custom deluge script
						(
											Rec_sum = 0;
										if(IGST > 0)
										{
											for each  line_item in input.Items
											{
												Total_price_of_line_item = line_item.Price * line_item.Quantity_in_Invoice;
												Tax_percentage = line_item.Tax_Percentage / 100;
												Rec_sum = Rec_sum + Total_price_of_line_item * Tax_percentage;
											}
											input.IGST_Invoice = Rec_sum;
										}
										else
										{
											for each  line_item in input.Items
											{
												Total_price_of_line_item = line_item.Price * line_item.Quantity_in_Invoice;
												Tax_percentage = line_item.Tax_Percentage / 100;
												Rec_sum = Rec_sum + Total_price_of_line_item * Tax_percentage;
											}
											final_result = Rec_sum / 2;
											input.SGST_Invoice = final_result;
											input.CGST_Invoice = final_result;
										}
						)
					}
				}

			}
