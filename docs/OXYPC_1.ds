		form Spare_Part_Cost_LOT_Wise
		{
			displayname = "Profit & Loss"
			success message = "Data Added Successfully!"
			field alignment = left
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			LOT_No
			(
    			type = text
				displayname = "LOT No."
	 			row = 1
	 			column = 1   
				width = medium
			)
			Make1
			(
    			type = text
				displayname = "Make"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Model
			(
				type = picklist	
				values  = Model[Make.ID == input.Make].ID
    			displayformat = [Model]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Model1
			(
    			type = text
				displayname = "Model"
	 			row = 1
	 			column = 1   
				width = medium
			)
			CPU1
			(
    			type = text
				displayname = "CPU"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Generation
			(
				type = picklist	
				values  = Classifications_of_Make_and_Model[Make.ID == input.Make && Model.ID == input.Model && CPU.ID == input.CPU].ID
    			displayformat = [Generation]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Generation1
			(
    			type = text
				displayname = "Generation"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Product_Description1
			(
    			type = text
				displayname = "Product Description"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Purchase_Price
			(
				displayname = " Purchase Price"
				type = INR
				format = commadotindian
	 			row = 1
	 			column = 1   
				width = medium
			)
			Total_Purchase_Price
			(
    			type = formula
				displayname = "Total Purchase Price"
				value =  input.Purchase_Price * input.Model_Count
				visibility = false
	 			row = 1
	 			column = 1   
				width = medium
			)
			Total_Purchase_Price1
			(
				displayname = "Total Purchase Price"
				type = INR
				format = commadotindian
	 			row = 1
	 			column = 1   
				width = medium
			)
			Total_Profit_Loss_Percentage
			(
    			type = formula
				displayname = "Total Profit/Loss Percentage"
				value =  ((input.Sales_Price - (input.Purchase_Price + input.Marketing_Expense + input.Other_Expense + input.SEZ_Expense + input.Total_Cost)) * input.Model_Count) / ((input.Purchase_Price + input.Marketing_Expense + input.Other_Expense + input.SEZ_Expense + input.Total_Cost) * input.Model_Count) * 100
				visibility = false
	 			row = 1
	 			column = 1   
				width = medium
			)
			Total_Profit_Loss_Percentage1
			(
    			type = percentage
				displayname = "Total Profit/Loss Percentage"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Profit_Loss
			(
    			type = formula
				displayname = "Profit/Loss"
				value =  input.Sales_Price - (input.Total_Cost + input.Purchase_Price)
				visibility = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			Replacements
			(
    			type = textarea
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			Category
			(
				type = picklist
				maxchar = 100
				values = {"Laptop","Desktop","TFT"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Make
			(
				type = picklist	
				values  = Make.ID
    			displayformat = [Make]
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			CPU
			(
				type = picklist	
				values  = CPU_Master[Make.ID == input.Make && Model.ID == input.Model].ID
    			displayformat = [CPU]
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			GRN
			(
				type = picklist	
				values  = GRN.ID
    			displayformat = [Vendor_Name]
				advanced field search = true
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			Number_of_replacements
			(
				type = number
				displayname = "Number of Faults"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Total_Cost
			(
				displayname = "Spare Part Cost"
				type = INR
				format = commadotindian
	 			row = 1
	 			column = 2   
				width = medium
			)
			Sales_Price
			(
				displayname = "Sales Price"
				type = INR
				format = commadotindian
	 			row = 1
	 			column = 2   
				width = medium
			)
			Customer_Name
			(
    			type = text
				displayname = "Customer Name"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Model_Count
			(
				type = number
				displayname = "Model Count"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Total_Sales_Price
			(
    			type = formula
				displayname = "Total Sales Price"
				value =  input.Sales_Price * input.Model_Count
				visibility = false
	 			row = 1
	 			column = 2   
				width = medium
			)
			Total_Sales_Price1
			(
				displayname = "Total Sales Price"
				type = INR
				format = commadotindian
	 			row = 1
	 			column = 2   
				width = medium
			)
			Total_Profit
			(
    			type = formula
				displayname = "Total Profit/Loss"
				value =  (input.Sales_Price - (input.Purchase_Price + input.Total_Cost)) * input.Model_Count
				visibility = false
	 			row = 1
	 			column = 2   
				width = medium
			)
			Total_Profit_Loss
			(
				displayname = "Total Profit/Loss"
				type = INR
				format = commadotindian
	 			row = 1
	 			column = 2   
				width = medium
			)
			Other_Expenses
			(
				type = section
				displayname = "Other Expenses"
				visibility = true
	 			row = 2
	 			column = 0   
				width = medium
			)
			Marketing_Expense
			(
				displayname = "Marketing Expense"
				type = INR
				format = commadotindian
				initial value = 0
	 			row = 2
	 			column = 1   
				width = medium
			)
			Other_Expense
			(
				displayname = "Other Expense"
				type = INR
				format = commadotindian
				initial value = 0
	 			row = 2
	 			column = 1   
				width = medium
			)
			SEZ_Expense
			(
				displayname = "SEZ Expense"
				type = INR
				format = commadotindian
				initial value = 0
	 			row = 2
	 			column = 2   
				width = medium
			)
	
			customize
			(
				icon = "sport-cardio"
			)
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
	}
