			Making_Fields_mandatory as "Making Fields mandatory"
			{
				type =  form
				form = IQC_Format_for_Laptop
				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											////////////////////////////////////////////////////////////////////////////////////////////////////////
										if(input.HDD_1 == "Yes")
										{
											if(input.Category == "")
											{
												alert "Please Fill HDD Category";
												cancel submit;
											}
											if(input.Category == "HDD" && input.HDD_Capacity1 == "")
											{
												alert "Please Fill HDD Capacity";
												cancel submit;
											}
											if(input.Category != "" && input.Category != "HDD" && input.HDD_Capacity == "")
											{
												alert "Please Fill HDD Capacity";
												cancel submit;
											}
											if(input.Health == "")
											{
												alert "Please Fill HDD Health";
												cancel submit;
											}
										}
										if(input.HDD_1 == "No")
										{
											input.Category = "";
											input.HDD_Capacity1 = "";
											input.HDD_Capacity = "";
											input.Health = "";
										}
										// && input.Category == "" || input.HDD_Capacity1 == "" || input.HDD_Capacity == "" || input.Health == "")
										// {
										// 		alert "Please Fill the HDD Fields";
										// 		cancel submit;
										// }
										if(input.RAM_1 == "Yes" && input.RAM_Type == "" || input.Capacity == "" || RAM_Status == "")
										{
											alert "Please Fill the RAM Fields";
											cancel submit;
										}
										if(input.RAM_1 == "No")
										{
											input.RAM_Type = "";
											input.Capacity = "";
											input.RAM_Status = "";
										}
										if(input.Model1 == null)
										{
											alert "Please fill all the details before submit the form";
											cancel submit;
										}
										lst = list();
										if(input.Front_Panel.size() == 0)
										{
											lst.add("Front Panel(Bazel)");
											alert "Please check Front Panel once";
											cancel submit;
										}
										if(input.Touch_Pad.size() == 0)
										{
											lst.add("Touch Pad");
											alert "Please check Touch Pad once";
											cancel submit;
										}
										if(input.Panel.size() == 0)
										{
											lst.add("Panel");
											alert "Please check Panel once";
											cancel submit;
										}
										if(input.Screen.size() == 0)
										{
											lst.add("Screen");
											alert "Please check Screen once";
											cancel submit;
										}
										if(input.Screen_Size == "")
										{
											lst.add("Screen Size");
											alert "Please check Screen Size once";
											cancel submit;
										}
										if(input.Logic_Card == null || input.Logic_Card == "")
										{
											lst.add("Logic Card");
											alert "Please check Logic Card once";
											cancel submit;
										}
										if(input.Base == null || input.Base == "")
										{
											lst.add("Base");
											alert "Please check Base once";
											cancel submit;
										}
										if(input.Keyboard == null || input.Keyboard == "")
										{
											lst.add("Keyboard");
											alert "Please check Keyboard once";
											cancel submit;
										}
										if(input.HDD_Connector == null || input.HDD_Connector == "")
										{
											lst.add("HDD Connector");
											alert "Please check HDD Connector once";
											cancel submit;
										}
										if(input.HDD_Cover == null || input.HDD_Cover == "")
										{
											lst.add("HDD Cover");
											alert "Please check HDD Cover once";
											cancel submit;
										}
										if(input.HDD_Casing == null || input.HDD_Casing == "")
										{
											lst.add("HDD Casing");
											alert "Please check HDD Casing once";
											cancel submit;
										}
										if(input.WIFI == null || input.WIFI == "")
										{
											lst.add("WIFI");
											alert "Please check WIFI once";
											cancel submit;
										}
										if(input.Microphone == null || input.Microphone == "")
										{
											lst.add("Microphone");
											alert "Please check Microphone once";
											cancel submit;
										}
										if(input.Power_Panel == null || input.Power_Panel == "")
										{
											lst.add("Power Panel");
											alert "Please check Power Panel once";
											cancel submit;
										}
										if(input.Sound == null || input.Sound == "")
										{
											lst.add("Sound");
											alert "Please check Sound once";
											cancel submit;
										}
										if(input.Web_Cam == null || input.Web_Cam == "")
										{
											lst.add("Web Cam");
											alert "Please check Web Cam once";
											cancel submit;
										}
										if(input.USB == null || input.USB == "")
										{
											lst.add("USB");
											alert "Please check USB once";
											cancel submit;
										}
										if(input.DVD == null || input.DVD == "")
										{
											lst.add("DVD");
											alert "Please check DVD once";
											cancel submit;
										}
										if(input.DVD_Flap == null || input.DVD_Flap == "")
										{
											lst.add("DVD Flap");
											alert "Please check DVD Flap once";
											cancel submit;
										}
										if(input.Battery == null || input.Battery == "")
										{
											lst.add("Battery");
											alert "Please check Battery once";
											cancel submit;
										}
										if(input.Battery == "Yes" && input.Health1 == "")
										{
											alert "Please check Battery Health once";
											cancel submit;
										}
										if(input.Battery == "No")
										{
											input.Health1 = "";
										}
										if(input.Hinch != "Ok" && Defected_Side == "")
										{
											alert "Please Fill Hinge Defected Side";
											cancel submit;
										}
										if(input.Hinch == "Ok")
										{
											input.Defected_Side = "";
										}
										if(input.Battery_Cable == null || input.Battery_Cable == "")
										{
											lst.add("Battery Cable");
											alert "Please check Battery Cable once";
											cancel submit;
										}
										if(input.Hinch == null || input.Hinch == "")
										{
											lst.add("Hinge");
											alert "Please check Hinge once";
											cancel submit;
										}
										if(input.Hinch_Cover == null || input.Hinch_Cover == "")
										{
											lst.add("Hinge Cover");
											alert "Please check Hinge Cover once";
											cancel submit;
										}
										if(input.Int_Battery == null || input.Int_Battery == "")
										{
											lst.add("Int Battery");
											alert "Please check Int Battery once";
											cancel submit;
										}
										if(input.Int_Battery == "Yes" && input.Health2 == "")
										{
											lst.add("Int Battery");
											alert "Please check Int Battery Health once";
											cancel submit;
										}
										if(input.Int_Battery == "No")
										{
											input.Health2 = "";
										}
										if(input.Status == "" || input.Status == null)
										{
											alert "Please Fill value for status";
											cancel submit;
										}
										if(lst.size() != 0)
										{
											alert "Fields " + lst.toString() + " are not filled. Please fill all the fields to move forward.";
											cancel submit;
										}
						)
					}
				}

			}
			Hide_all_fields_if_screen as "Hide all fields if screen status Broken"
			{
				type =  form
				form = IQC_Format_for_TFT
				record event = on add or edit

				on user input of Screen_Status
				{
					actions 
					{
						custom deluge script
						(
											if(input.Screen_Status == "Broken")
										{
											hide Menu_Button;
											hide VGA_Port;
											hide HDMI_Port;
											hide DP_Port;
											hide USB_Port;
											hide DVI_Port;
											input.Menu_Button = "Not Checked";
											input.VGA_Port = "Not Checked";
											input.HDMI_Port = "Not Checked";
											input.DP_Port = "Not Checked";
											input.USB_Port = "Not Checked";
											input.DVI_Port = "Not Checked";
											input.Status = "Scrap";
										}
										else
										{
											show Menu_Button;
											show VGA_Port;
											show HDMI_Port;
											show DP_Port;
											show USB_Port;
											show DVI_Port;
											input.Menu_Button = "";
											input.VGA_Port = "";
											input.HDMI_Port = "";
											input.DP_Port = "";
											input.USB_Port = "";
											input.DVI_Port = "";
											input.Status = "";
										}
						)
					}
				}

			}
			Setting_Mandatory_Fields as "Setting Mandatory Fields"
			{
				type =  form
				form = IQC_Format_for_TFT
				record event = on add

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.Screen_Status != "Broken")
										{
											if(input.Menu_Button == "" || input.Menu_Button == null)
											{
												alert "Please Fill value for Menu Button";
												cancel submit;
											}
											if(input.VGA_Port == "" || input.VGA_Port == null)
											{
												alert "Please Fill value for VGA Port";
												cancel submit;
											}
											if(input.HDMI_Port == "" || input.HDMI_Port == null)
											{
												alert "Please Fill value for HDMI Port";
												cancel submit;
											}
											if(input.DP_Port == "" || input.DP_Port == null)
											{
												alert "Please Fill value for DP Port";
												cancel submit;
											}
											if(input.USB_Port == "" || input.USB_Port == null)
											{
												alert "Please Fill value for USB Port";
												cancel submit;
											}
											if(input.DVI_Port == "" || input.DVI_Port == null)
											{
