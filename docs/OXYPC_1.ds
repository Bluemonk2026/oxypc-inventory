						custom deluge script
						(
											recs = Engineer_day_In_Out[Engineer_Name == zoho.loginuser && Day_In_Date == zoho.currentdate.toString("dd-MMM-yyyy")];
										if(recs.Update1 == "" || recs.Update1 == null)
