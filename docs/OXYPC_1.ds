			Update_Details as "Update Details"
			{
				type =  form
				form = L1_L2_Engineer_Screen
				record event = on add or edit

				on user input of Barcode
				{
					actions 
					{
						custom deluge script
						(
											// l1_l2_screen = L1_L2_Engineer_Screen[Barcode == input.Barcode];
										// if(l1_l2_screen.count(Final_Status) < 0)
										// {
										Barcode1 = input.Barcode;
										// inven_rec = Product_Master_Inventory1[Tag_No2 == Barcode1];
										l1_l2_engg_rec = L1_L2_Engineer_Screen[Barcode.equalsIgnoreCase(Barcode1)];
										product_master_rec = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(Barcode1)];
										// product_master_rec = Product_Master_Inventory1[Tag_No2 == Barcode1];
										info product_master_rec.count();
										info product_master_rec;
										iqc_data = IQC_Format_for_Laptop[TAG_NO.equalsIgnoreCase(input.Barcode)];
										if(l1_l2_engg_rec.count() == 0)
										{
											if(product_master_rec.count() != 0)
											{
												info "From Inventory";
												input.Make = product_master_rec.Make;
												input.Engineer = iqc_data.Modified_User;
												input.Model = product_master_rec.Model;
												input.CPU = product_master_rec.CPU;
												input.Generation = product_master_rec.Generation;
												input.RAM = product_master_rec.RAM;
												if(product_master_rec.HDD_Capacity == "" || product_master_rec.HDD_Capacity == null)
												{
													input.HDD = product_master_rec.HDD;
												}
												else
												{
													input.HDD = product_master_rec.HDD_Capacity;
												}
												input.LOT_No = product_master_rec.LOT_No;
												input.Serial_Number = product_master_rec.Serial_No;
											}
											else
											{
												info "Inventory 0 h to IQC se aayege";
												rec = IQC_Format_for_Laptop[TAG_NO.equalsIgnoreCase(Barcode1)];
												input.Make = rec.Make.Make;
												input.Model = rec.Model1.Model;
												input.CPU = rec.CPU;
												input.Engineer = rec.Modified_User;
												input.Generation = rec.Generation;
												input.RAM = rec.Capacity;
												info "RAM Capacity" + rec.Capacity;
												info "HDD" + rec.HDD_Capacity1;
												info "SSD" + rec.HDD_Capacity;
												if(rec.HDD_Capacity1 != "" || rec.HDD_Capacity1 != null)
												{
													input.HDD = rec.HDD_Capacity1;
												}
												else if(rec.HDD_Capacity != "" || rec.HDD_Capacity != null)
												{
													input.HDD = rec.HDD_Capacity;
												}
												input.LOT_No = rec.LOT_Number;
												input.Serial_Number = rec.Serial_No;
												// 		info rec.Added_Time.getDate().toString("dd-MMM-yyyy");
												// 		input.IQC_Completion_Date = rec.Added_Time.getDate().toString("dd-MMM-yyyy");
											}
											rec = IQC_Format_for_Laptop[TAG_NO.equalsIgnoreCase(Barcode1)];
											info "iqc_rec--->" + rec.count();
											if(rec.count() > 0)
											{
												info "IQC se aaya h";
												faults_s = rec.Faulty_Spare_Parts;
												rowww = Collection();
												recss = Faulty_Spare_Parts_After_IQC1[Tag_No.equalsIgnoreCase(rec.ID.toString())];
												info "faulty spare parts ----------->" + recss.count();
												ids = List();
												info recss;
												for each  i in recss
												{
													ids.add(i.ID);
													row1 = L1_L2_Engineer_Screen.faults();
													recs = Spare_Parts2[Spare_Part_Name.equalsIgnoreCase(i.Spare_Part)];
													row1.Spare_Part1=recs.ID;
													row1.Spare_Part=i.Spare_Part;
													row1.Make=i.Make;
													row1.Model=i.Model;
													row1.Category=i.Category;
													row1.Tag_No=i.Tag_No;
													row1.Model_Description=i.Model_Description;
													row1.Quantity=i.Quantity;
													row1.Lot_No=i.Lot_No;
													row1.Lot_No1=i.Lot_No1;
													row1.Status=i.Status;
													row1.Price=i.Price;
													///////////////////////////////////////
													rowww.insert(row1);
												}
												input.faults.insert(rowww);
											}
										}
										else
										{
											alert "This Laptop already got repaired!!";
											openurl("https://creator.zoho.in" + zoho.appuri + "L1_L2_Engineer_Screen/record-edit/For_editing_L1_L2_Engineer_Screen_hidden/" + l1_l2_engg_rec.ID + "/","same window");
										}
						)
					}
				}

			}
