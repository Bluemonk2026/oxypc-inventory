			Show_fields_for_amount as "Show fields for amount"
			{
				type =  form
				form = Sales_Orders
				record event = on add or edit

				on user input of Payment_Mode1
				{
					actions 
					{
						custom deluge script
						(
											info input.Payment_Mode1;
										for each  i in input.Payment_Mode1
										{
											if(i == "Cash")
											{
												show CaAmount;
											}
											else if(i == "Cheque")
											{
												show Cheque_Amount;
											}
											else if(i == "UPI")
											{
												show UPI_Amount;
											}
											else if(i == "Card Swipe")
											{
												show Card_Swipe_Amount;
											}
											else if(i == "Bank Transfer")
											{
												show Bank_Transfer_Amount;
											}
										}
										if(input.Payment_Mode1.toList().contains("Cash") is false)
										{
											hide CaAmount;
											if(input.CaAmount != null)
											{
												input.Total_Amount = input.Total_Amount - input.CaAmount;
											}
											input.CaAmount = null;
										}
										if(input.Payment_Mode1.toList().contains("Cheque") is false)
										{
											hide Cheque_Amount;
											if(input.Cheque_Amount != null)
											{
												input.Total_Amount = input.Total_Amount - input.Cheque_Amount;
											}
											input.Cheque_Amount = null;
										}
										if(input.Payment_Mode1.toList().contains("UPI") is false)
										{
											hide UPI_Amount;
											if(input.UPI_Amount != null)
											{
												input.Total_Amount = input.Total_Amount - input.UPI_Amount;
											}
											input.UPI_Amount = null;
										}
										if(input.Payment_Mode1.toList().contains("Card Swipe") is false)
										{
											hide Card_Swipe_Amount;
											if(input.Card_Swipe_Amount != null)
											{
												input.Total_Amount = input.Total_Amount - input.Card_Swipe_Amount;
											}
											input.Card_Swipe_Amount = null;
										}
										if(input.Payment_Mode1.toList().contains("Bank Transfer") is false)
										{
											hide Bank_Transfer_Amount;
											if(input.Bank_Transfer_Amount != null)
											{
												input.Total_Amount = input.Total_Amount - input.Bank_Transfer_Amount;
											}
											input.Bank_Transfer_Amount = null;
										}
						)
					}
				}

			}
