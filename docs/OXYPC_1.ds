			Update_stage_in_Product_M1 as "Update stage in Product Master Inventory"
			{
				type =  form
				form = Final_QC1
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											info "Entered Workflow 1";
										Product_Master_Details = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(input.Tag_Number)];
										info "Inventory rECORD COUNT --> " + Product_Master_Details.count();
										if(Product_Master_Details.count() != 0)
										{
											info "Entered in If Loop";
											Product_Master_Details.Serial_No=input.Serial_Number;
											Product_Master_Details.Date_field=zoho.currentdate.toString("dd-MMM-yyyy");
											Product_Master_Details.Time=zoho.currenttime.toString("HH:mm:ss");
											Product_Master_Details.Grade=input.Grade;
											if(input.Updated_Make == null)
											{
												Product_Master_Details.Make=input.Make;
											}
											else
											{
												Product_Master_Details.Make=input.Updated_Make.Make;
											}
											if(input.Updated_Model == null)
											{
												Product_Master_Details.Model=input.Model;
											}
											else
											{
												Product_Master_Details.Model=input.Updated_Model.Model;
											}
											if(input.Update_CPU1 == null)
											{
												Product_Master_Details.CPU=input.CPU;
											}
											else
											{
												Product_Master_Details.CPU=input.Update_CPU1;
											}
											if(input.Updated_Generation == null)
											{
												Product_Master_Details.Generation=input.Generation;
											}
											else
											{
												Product_Master_Details.Generation=input.Updated_Generation;
											}
											if(input.Updated_RAM == null)
											{
												Product_Master_Details.RAM=input.RAM;
											}
											else
											{
												Product_Master_Details.RAM=input.Updated_RAM;
											}
											if(input.Updated_HDD == null)
											{
												Product_Master_Details.HDD=input.HDD;
											}
											else
											{
												Product_Master_Details.HDD=input.Updated_HDD;
											}
											// 	Product_Master_Details.Make_FinalQC=input.Make;
											// 	Product_Master_Details.Model_FinalQC=input.Model;
											// 	Product_Master_Details.Updated_Make=input.Updated_Make;
											// 	Product_Master_Details.Updated_Model=input.Updated_Model;
											// 	Product_Master_Details.Generation_FinalQC=input.Generation;
											// 	Product_Master_Details.Updated_Generation=input.Updated_Generation;
											// 	Product_Master_Details.CPU2=input.CPU;
											// 	Product_Master_Details.Updated_CPU=input.Update_CPU1;
											// 	Product_Master_Details.HDD_FinalQC=input.HDD;
											// 	Product_Master_Details.RAM_FinalQC=input.RAM;
											// 	Product_Master_Details.Final_Status_FinalQC=input.Final_Status;
											// 	Product_Master_Details.Faults_FinalQC=input.Faults;
											// 	Product_Master_Details.Product_Stages="Inventory Finalized";
											if(input.Final_Status == "Pass")
											{
												Product_Master_Details.Product_Stages="Inventory Finalized";
												Product_Master_Details.Product_Category="Finished Good";
											}
											if(input.Final_Status == "Fail" && input.Failure_Reason == "Paint")
											{
												Product_Master_Details.Product_Stages="Painting";
												Product_Master_Details.Product_Category="Paint";
											}
											if(input.Final_Status == "Fail" && input.Failure_Reason == "Functional")
											{
												Product_Master_Details.Product_Stages="Assigned to L1/L2 Engineer";
												Product_Master_Details.Product_Category="Repair";
											}
											if(input.Final_Status == "Fail" && input.Failure_Reason == "Plastic Part")
											{
												Product_Master_Details.Product_Stages="Assigned to L1/L2 Engineer";
												Product_Master_Details.Product_Category="Plastic Repair";
											}
											if(input.Warehouse == "TRC 2ND Floor")
											{
												Product_Master_Details.Warehouse="TRC 2ND Floor";
											}
											else if(input.Warehouse == "Amazon")
											{
												Product_Master_Details.Warehouse="Amazon";
											}
											else if(input.Warehouse == "Bluemonk House Showroom")
											{
												Product_Master_Details.Warehouse="Bluemonk House Showroom";
											}
										}
										else
										{
											info "Into the else loop - Update loop";
											mapp = Map();
											mapp.put("Date_Field",zoho.currentdate.toString("dd-MMM-yyyy"));
											mapp.put("Time",zoho.currenttime.toString("HH:mm:ss"));
											if(input.Updated_Make == null)
											{
												mapp.put("Make",input.Make);
											}
											else
											{
												mapp.put("Make",input.Updated_Make.Make);
											}
											if(input.Updated_Model == null)
											{
												mapp.put("Model",input.Model);
											}
											else
											{
												mapp.put("Model",input.Updated_Model.Model);
											}
											if(input.Update_CPU1 == null)
											{
												mapp.put("CPU",input.CPU);
											}
											else
											{
												mapp.put("CPU",input.Update_CPU1);
											}
											if(input.Updated_Generation == null)
											{
												mapp.put("Generation",input.Generation);
											}
											else
											{
												mapp.put("Generation",input.Updated_Generation);
											}
											if(input.Updated_RAM == null)
											{
												mapp.put("RAM",input.RAM);
											}
											else
											{
												mapp.put("RAM",input.Updated_RAM);
											}
											if(input.Updated_HDD == null)
											{
												mapp.put("HDD",input.HDD);
											}
											else
											{
												mapp.put("HDD",input.Updated_HDD);
											}
											// 	mapp.put("Make_FinalQC",input.Make);
											// 	mapp.put("Model_FinalQC",input.Model);
											// 	mapp.put("Updated_Make",input.Updated_Make);
											// 	mapp.put("Updated_Model",input.Updated_Model);
											// 	mapp.put("Generation_FinalQC",input.Generation);
											// 	mapp.put("Updated_Generation",input.Updated_Generation);
											// 	mapp.put("CPU2",input.CPU);
											// 	mapp.put("Updated_CPU",input.Update_CPU1);
											// 	mapp.put("HDD_FinalQC",input.HDD);
											// 	mapp.put("RAM_FinalQC",input.RAM);
											// 	mapp.put("Final_Status_FinalQC",input.Final_Status);
											// 	mapp.put("Faults_FinalQC",input.Faults);
											mapp.put("Product_Stages","Inventory Finalized");
											if(input.Final_Status == "Pass")
											{
												Product_Master_Details.Product_Stages="Inventory Finalized";
												Product_Master_Details.Product_Category="Finished Good";
											}
											if(input.Final_Status == "Fail" && input.Failure_Reason == "Paint")
											{
												Product_Master_Details.Product_Stages="Painting";
												Product_Master_Details.Product_Category="Paint";
											}
											if(input.Final_Status == "Fail" && input.Failure_Reason == "Functional")
											{
												Product_Master_Details.Product_Stages="Assigned to L1/L2 Engineer";
												Product_Master_Details.Product_Category="Repair";
											}
											if(input.Final_Status == "Fail" && input.Failure_Reason == "Plastic Part")
											{
												Product_Master_Details.Product_Stages="Assigned to L1/L2 Engineer";
												Product_Master_Details.Product_Category="Plastic Repair";
												info "In Sahi loop";
											}
											if(input.Warehouse == "TRC 2ND Floor")
											{
												Product_Master_Details.Warehouse="TRC 2ND Floor";
											}
											else if(input.Warehouse == "Amazon")
											{
												Product_Master_Details.Warehouse="Amazon";
											}
											else if(input.Warehouse == "Bluemonk House Showroom")
											{
												Product_Master_Details.Warehouse="Bluemonk House Showroom";
											}
											mapp.put("Tag_No2",input.Tag_Number);
											mapp.put("Serial_No",input.Serial_Number);
											mapp.put("LOT_No",input.LOT_Number);
											mapp.put("Serial_No",input.Serial_Number);
											empty_mapp = Map();
											create_Rec = zoho.creator.createRecord("protaiga","oxypc-1","Product_Master_Inventory1",mapp,empty_mapp,"creator");
											info "Create_rec" + create_Rec;
										}
										if(input.Final_Status == "Fail")
										{
											if(input.Failure_Reason == "Paint")
											{
												prouct_master_rec = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(input.Tag_Number)];
												prouct_master_rec.Product_Stages="Painting";
												prouct_master_rec.Product_Category="Paint";
											}
											if(input.Failure_Reason == "Functional")
											{
												prouct_master_rec = Product_Master_Inventory1[Tag_No2.equalsIgnoreCase(input.Tag_Number)];
												prouct_master_rec.Product_Stages="Assigned to L1/L2 Engineer";
