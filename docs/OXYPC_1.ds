	section Plastic_Process
	{
		displayname= "Plastic Process"
		icon = "shopping-bag-20"
		form IQC_Format_for_Plastic
		{
			displayname = "IQC Format for Plastic"
			success message = "Data Added Successfully!"
			field alignment = left
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have unique Tag_No
			(
    			type = text
				displayname = "Tag No"
				qrcode = true
				barcode = true
				camera = primary
				switch camera = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Make
			(
				type = picklist	
				values  = Make.ID
    			displayformat = [Make]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Date_field
			(
    			type = date
				displayname = "Date"
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			Start_Time
			(
    			type = time
				displayname = "Start Time"
				initial value = "${zoho.currenttime}"	
				timedisplayoptions = "hh:mm:ss" 
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Part_Type
			(
				type = picklist
				displayname = "Part Type"
				maxchar = 100
				values = {"New","Old"}
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			IQC_Remark
			(
    			type = textarea
				displayname = "IQC Remarks"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Lot_Number
			(
    			type = text
				displayname = "Lot Number"
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Model
			(
				type = picklist	
				values  = Model[Make.ID == input.Make].ID
    			displayformat = [Model]
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			Part_Name
			(
    			type = text
				displayname = "Part Name"
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Part_Repair
			(
				type = picklist
				displayname = "Part Repair"
				maxchar = 100
				values = {"Body A","Body B","Body C","Body D","Body E"}
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			Body_A
			(
				type = radiobuttons
				displayname = "Body A"
				maxchar = 100
				values = {"Minor Broken","Major Broken","Ok","Dent","Scrap","Body Crack"}
				layout = 3
	 			row = 1
	 			column = 2   
				width = medium
			)
			Body_B
			(
				type = radiobuttons
				displayname = "Body B"
				maxchar = 100
				values = {"Minor Broken","Major Broken","Ok","Scrap","Dent","Rubber Cut","Body Crack"}
				layout = 3
	 			row = 1
	 			column = 2   
				width = medium
			)
			Body_C1
			(
				type = radiobuttons
				displayname = "Body C"
				maxchar = 100
				values = {"Minor Broken","Major Broken","Ok","Dent","Rubber Cut","Scrap","Body Crack","Jali Broken"}
				layout = 3
	 			row = 1
	 			column = 2   
				width = medium
			)
			Body_D1
			(
				type = radiobuttons
				displayname = "Body D"
				maxchar = 100
				values = {"Minor Broken","Major Broken","Ok","Dent","Scrap","Jail Broken","Body Crack"}
				layout = 3
	 			row = 1
	 			column = 2   
				width = medium
			)
			Body_E1
			(
				type = radiobuttons
				displayname = "Body E"
				maxchar = 100
				values = {"Minor Broken","Major Broken","Ok","Dent","Scrap","Jail Broken","Body Crack"}
				layout = 3
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Status
			(
				type = picklist
				maxchar = 100
				values = {"Ok","Scrap","Repair"}
	 			row = 1
	 			column = 2   
				width = medium
			)
	
			customize
			(
				icon = "shopping-bag-20"
			)
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form Plastic_Repair
		{
			displayname = "Plastic Repair"
			success message = "Data Added Successfully!"
			field alignment = left
			Section
			(
				type = section
				displayname = ""
	 			row = 1
	 			column = 0   
				width = medium
			)
