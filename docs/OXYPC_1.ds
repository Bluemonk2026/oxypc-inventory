		form Product_Master_Inventory1
		{
			displayname = "Product Master Inventory"
			success message = "Product Master Inventory Added Successfully"
			field alignment = left
					hide = true
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			Inventory_ID_Autonum
			(
    			type = autonumber
				displayname = "Inventory ID Autonum"
				start index = 1
	 			row = 1
	 			column = 1   
				width = medium
			)
			Make
			(
    			type = text
				maxchar = 50
	 			row = 1
	 			column = 1   
				width = medium
			)
			CPU
			(
    			type = text
				maxchar = 30
	 			row = 1
	 			column = 1   
				width = medium
			)
			RAM
			(
    			type = text
				displayname = "IQC RAM"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Screen_Size1
			(
				type = picklist
				displayname = "Screen Size"
				maxchar = 100
				values = {"14.5\"","15\"","15.5\"","17\"","17.5\"","18\"","18.5\"","19\"","19.5\"","20\"","20.5\"","21\"","21.5\"","22\"","22.5\"","24\"","24.5\"","26\"","12.5\"","13.3\"","14.0\"","15.0\"","15.6\"","17.0\"","Others"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Customer_Location
			(
    			type = text
				displayname = "Customer Location"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Invoice_Number
			(
    			type = text
				displayname = "Invoice Number"
				private = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			Invoice_Date
			(
    			type = date
				displayname = "Invoice Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			GRN_Date
			(
    			type = date
				displayname = "GRN Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			Inventory_Formula
			(
    			type = formula
				displayname = "Inventory Formula"
				value =  "INV-" + input.Inventory_ID_Autonum
				visibility = false
				format = plaintext
	 			row = 1
	 			column = 1   
				width = medium
			)
			unique Inventory_ID
			(
    			type = text
				displayname = "Inventory ID"
	 			row = 1
	 			column = 1   
				width = medium
			)
			LOT_No
			(
    			type = text
				displayname = "LOT No."
	 			row = 1
	 			column = 1   
				width = medium
			)
			Serial_No
			(
    			type = text
				displayname = "Serial No."
				maxchar = 60
	 			row = 1
	 			column = 1   
				width = medium
			)
			Checkbox
			(
				type = checkboxes	
				values = {"Update"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Product_Category2
			(
    			type = text
				displayname = "Product Category"
				maxchar = 150
	 			row = 1
	 			column = 1   
				width = medium
			)
			Quantity
			(
				type = number
	 			row = 1
	 			column = 1   
				width = medium
			)
			Customer_Name_Sale
			(
    			type = text
				displayname = "Customer Name(Sale)"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Invoice_Number_Sale
			(
    			type = text
				displayname = "Invoice Number(Sale)"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Sales_Price
			(
				displayname = "Sales Price"
				type = INR
				format = commadotindian
	 			row = 1
	 			column = 1   
				width = medium
			)
			Vendor_Name
			(
				type = picklist	
				displayname = "Vendor Name"
				values  = Vendors_Database.ID
    			displayformat = [Vendor_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Sale_Date
			(
    			type = date
				displayname = "Sale Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			Product_Type
			(
				type = picklist
				displayname = "Product Type"
				maxchar = 100
				values = {"Server","Switch","Storage","Workstation","Router","CONTROLLER","WORKSTATION DEVICE","All In One","STABILISAR","Amplifier","soundstation","AIR PURIFIER","PRINTER","ups","TFT","projector","CCTV  Camera","dvr","Tap Drive","VC Equipment","TV","Speaker","Telephone","Desktop","Thinclient","Laptop"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Product_Stages
			(
				type = picklist
				displayname = "Product Stage"
				maxchar = 100
				values = {"Sold Out","Ready for Engineer Assignment","Ready for Final QC Assignment","Ready for Cleaning Assignment","Assigned to Seller Flex","Ready to Assign to QC","Assigned to L1/L2 Engineer","Assigned to L3/L4","Assigned to QC","PNA(Part not available)","Scrap","BER","Send for testing","Assigned for Dry Sanding","Assigned for Masking","Assigned for Water Sanding","Assigned for Plastic Repair","Assigned for Office Use","Part Harvesting","Assigned for Cleaning","Assigned for Paint","Painting","Assign to Lot","Assigned to Final QC","Final QC","Booked for Sale","Product QC Passed","Board Repairing/No Display (L4)","Inventory Finalized","L4 Support","IQC Completed"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			Warehouse
			(
				type = picklist
				maxchar = 100
				values = {"Nehru Place (Delhi)","Bluemonk House Basement","Bluemonk House Showroom","TRC 2ND Floor","Bluemonk House 5th Floor","Amazon","Mumbai","Manesar","Not Found in Physical"}
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Remarks
			(
    			type = textarea
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			PO_Number
			(
    			type = text
				displayname = "PO Number"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Model
			(
    			type = text
				maxchar = 100
	 			row = 1
	 			column = 2   
				width = medium
			)
			Generation
			(
    			type = text
				maxchar = 20
	 			row = 1
	 			column = 2   
				width = medium
			)
			HDD
			(
    			type = text
				displayname = "IQC HDD"
				maxchar = 30
	 			row = 1
	 			column = 2   
				width = medium
			)
			GRN_Number
			(
    			type = text
				displayname = "GRN Number"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Zoho_Books_Product_ID
			(
    			type = text
				displayname = "Zoho Books Product ID"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Unique_Lot_No
			(
				type = number
				displayname = "Unique Lot No."
				maxchar = 19
	 			row = 1
	 			column = 2   
				width = medium
			)
			Update1
			(
				type = picklist
				displayname = "Update stage"
				maxchar = 100
				values = {"Yes","No"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			unique Tag_No2
			(
    			type = text
				displayname = "Tag No."
				maxchar = 50
	 			row = 1
	 			column = 2   
				width = medium
			)
			Grade
			(
				type = radiobuttons
				maxchar = 100
				values = {"A","B","C","D","E","Box Packed"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Product_Sub_Category
			(
    			type = text
				displayname = "Product Sub-Category"
				maxchar = 150
	 			row = 1
	 			column = 2   
				width = medium
			)
			Sales_Person_Name
			(
    			type = text
				displayname = "Sales Person Name"
				maxchar = 100
	 			row = 1
	 			column = 2   
				width = medium
			)
			Purchase_Price
			(
				displayname = "Purchase Price"
				type = INR
				format = commadotindian
	 			row = 1
	 			column = 2   
				width = medium
			)
			Model_Description
			(
    			type = text
				displayname = "Model Description"
				maxchar = 200
	 			row = 1
	 			column = 2   
				width = medium
			)
			Customer_Name
			(
				type = picklist	
				displayname = "Customer Name"
				values  = Customers_database.ID
    			displayformat = [Customer_Name]
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			Aging_Formula
			(
    			type = formula
				displayname = "Aging Formula"
				value =  daysBetween(input.Added_Time,zoho.currenttime).toLong().abs()
				visibility = true
	 			row = 1
	 			column = 2   
				width = medium
			)
			Aging
			(
				type = decimal
				initial value = 0.00
	 			row = 1
	 			column = 2   
				width = medium
			)
			Product_Category
			(
				type = picklist
				displayname = "Product Status"
				maxchar = 100
				values = {"GRN Done","Repair Completed","BER","Inspection","Office Use","OK/Power ON/No Power/BER/Scrap","Repair","L4 Repair","QC Completed","QC Fail","PNA","PNA CHINA","Scrap","Water Sanding","Dry Sanding","Masking","Paint","IQC Completed","Power On","Cleaning","Lot","Final QC","Booked","Finished Good","Paint Reject","FQC Reject","Sold Out","Motherboard","Plastic Repair","Inventory Finalized","In-Transit","QC","Final QC Pending"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Crate_Location
			(
    			type = text
				displayname = "Crate Location"
				maxchar = 200
	 			row = 1
	 			column = 2   
				width = medium
			)
			Type_field
			(
				type = picklist
				displayname = "Type"
				maxchar = 100
				values = {"New record","Old record"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Used_or_not
			(
				type = picklist
				displayname = "Used or not"
				maxchar = 100
				values = {"In-Zoho","Not In-Zoho"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Showroom_Inventory_Date
			(
    			type = date
				displayname = "Showroom Inward Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 2   
				width = medium
			)
			Showroom_Outward_Date
			(
    			type = date
				displayname = "Showroom Outward Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 2   
				width = medium
			)
			Desktop
			(
				type = grid
				values  = IQC_Format_for_Desktop.ID
	 			row = 2
	 			column = 1   
				width = medium
			)
			Screen_Type
			(
				type = picklist
				displayname = "Screen Type"
				maxchar = 100
				values = {"LED","LCD","Touchscreen","IPS"}
	 			row = 3
	 			column = 1   
				width = medium
			)
			IQC
			(
				type = section
				displayname = "IQC Laptop"
				visibility = true
	 			row = 4
	 			column = 0   
				width = medium
			)
			IQC_Submitted
			(
				type = checkboxes	
				displayname = "IQC Submission"
				values = {"Submitted"}
	 			row = 4
	 			column = 1   
				width = medium
			)
			HDD_1
			(
				type = radiobuttons
				displayname = "HDD"
				maxchar = 100
				values = {"Yes","No"}
				layout = 3
	 			row = 4
	 			column = 2   
				width = medium
			)
			HDD_Capacity
			(
				type = radiobuttons
				displayname = "SSD Capacity"
				maxchar = 100
				values = {"250 GB","64 GB","N/A","128 GB","256 GB","500 GB","512 GB","1 TB","2 TB","Others","3 TB","4 TB","5 TB","8 TB","16 TB"}
				layout = 3
				others option = true
	 			row = 4
	 			column = 2   
				width = medium
			)
			L1_L2_Engineer_Screen
			(
				type = section
				displayname = "L1/L2 Engineer Screen"
				visibility = true
	 			row = 5
	 			column = 0   
				width = medium
			)
			L1_L2_Date
			(
    			type = date
				displayname = "L1/L2 Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 5
	 			column = 1   
				width = medium
			)
			L3_L4_Engineer_Screen
			(
				type = section
				displayname = "L3/L4 Engineer Screen"
				visibility = true
	 			row = 6
	 			column = 0   
				width = medium
			)
			Date_L3_L4_Engineer
