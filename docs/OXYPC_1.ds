			Spare_Part_Inventory_Mana as "Spare Part Inventory Management"
			{
				type =  form
				form = Spare_Part_Consumption
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											make_rec = Make_Spare_Part[Make.equalsIgnoreCase(input.Make)];
										model_rec = Model_Spare_Part[Model.equalsIgnoreCase(input.Model)];
										spare_part_master_rec = Spare_Parts[Make == make_rec.ID && Model == model_rec.ID && Spare_Part_Name.equalsIgnoreCase(input.Spare_Part_Name)];
										if(spare_part_master_rec.count() > 0)
										{
											if(input.Part_Type == "New Part")
											{
												spare_part_master_rec.Available_SOH=spare_part_master_rec.Available_SOH - 1;
											}
											else
											{
												spare_part_master_rec.Cannablized=spare_part_master_rec.Cannablized - 1;
											}
										}
						)
					}
				}

			}
			Get_Values_from_Battery_I as "Get Values from Battery IQC"
			{
				type =  form
				form = Battery_Repair
				record event = on add or edit

				on user input of Tag_Number
				{
					actions 
					{
						custom deluge script
						(
											battery_iqc_rec = IQC_Format_for_Battery[Tag_Number.equalsIgnoreCase(input.Tag_Number)];
										if(battery_iqc_rec.count() > 0)
										{
											if(battery_iqc_rec.Status == "Repair")
											{
												input.Lot_Number = battery_iqc_rec.LOT_Number;
												input.Make = battery_iqc_rec.Make.Make;
												input.Model = battery_iqc_rec.Model.Model;
												input.Problem_Reported = battery_iqc_rec.Problem_Reported;
												input.Battery_Model = battery_iqc_rec.Battery_Model.Model;
												disable Lot_Number;
												disable Make;
												disable Model;
												disable Problem_Reported;
												disable Battery_Model;
											}
											else
											{
												alert "IQC Status is not Repair for this Battery";
											}
										}
										else
										{
											alert "IQC Not Done for battery";
											input.Tag_Number = "";
										}
						)
					}
				}

			}
			Hide_Show_fields as "Hide Show fields"
			{
				type =  form
				form = Battery_Repair
				record event = on add or edit

				on user input of Repairable
				{
					actions 
					{
						custom deluge script
						(
											if(input.Repairable == "Yes")
										{
											show Battery_Backup;
											show Action_Taken;
											hide Not_Repairable_reason;
											input.Status1:ui.add("Ok");
											input.Status1:ui.add("PNA");
											input.Not_Repairable_reason = "";
											show Health;
										}
										else
										{
											hide Battery_Backup;
											hide Action_Taken;
											hide Cell_Capacity1;
											hide Health;
											input.Battery_Backup = "";
											input.Health = "";
											input.Action_Taken = "";
											input.Cell_Capacity1 = "";
											show Not_Repairable_reason;
											input.Status1:ui.add("Scrap");
											input.Status1 = "Scrap";
										}
						)
					}
				}

			}
