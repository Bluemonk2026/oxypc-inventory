			Show_alert_if_Tag_number_ as "Show alert if Tag number already exited"
			{
				type =  form
				form = Final_QC1
				record event = on add or edit

				on user input of Tag_Number
				{
					actions 
					{
						custom deluge script
						(
											qc_rec = Final_QC1[Tag_Number == input.Tag_Number];
										info qc_rec;
										if(qc_rec.count() == 1)
										{
											alert "Warning: Tag Number already exited for this Laptop and last modified time is:" + qc_rec.Modified_Time;
										}
										iqc_rec = IQC_Format_for_Laptop[TAG_NO.equalsIgnoreCase(input.Tag_Number)];
										if(iqc_rec.count() > 0)
										{
											input.Grade = iqc_rec.Grade;
										}
						)
					}
				}

			}
			Calculate_Tax_and_Taxable as "Calculate Tax and Taxable Amount"
			{
				type =  form
				form = Sales_Form
				record event = on add or edit
					status = inactive

				on user input of Line_Items.Unit_Price
				{
					actions 
					{
						custom deluge script
						(
											if(input.Customer != null)
										{
											if(row.Quantity != null)
											{
												result = ifNull(row.Taxable_Amount,0) * row.Quantity;
												tax_ammount = result * 18 / 100;
												row.Unit_Price=tax_ammount - result;
												row.Tax_Amount=tax_ammount;
											}
										}
						)
					}
				}

			}
