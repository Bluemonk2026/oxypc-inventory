			Add_to_Inventory1 as "Add to Inventory"
			{
				type =  form
				form = IQC_format_for_Screen
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											spare_part_Rec = Spare_Parts[Tag_Number.equalsIgnoreCase(input.Tag_No)];
										if(spare_part_Rec.count() > 0)
										{
											data_mapp = Map();
											data_mapp.put("Tag_Number",input.Tag_No);
											data_mapp.put("Screen_Type",input.Screen_Type);
											data_mapp.put("Screen_Pin",input.Screen_Pin);
											data_mapp.put("Screen_Size",input.Screen_Size);
											data_mapp.put("Part_Number",input.Part_No);
											data_mapp.put("Lot_Number",input.Lot_Number);
											data_mapp.put("Screen_Serial_Number",input.Serial_Number);
											data_mapp.put("Part_Type","Old");
											if(input.Status == "OK")
											{
												data_mapp.put("Screen_Stage","Assigned to Final QC");
											}
											else if(input.Status == "Repair")
											{
												data_mapp.put("Screen_Stage","Assigned to Delamination");
											}
											else if(input.Status == "Non-Repairable")
											{
												data_mapp.put("Screen_Stage","Non-Repairable");
											}
											else
											{
												data_mapp.put("Screen_Stage","Scrap");
											}
											empty_mapp = Map();
											update_inv = zoho.creator.updateRecord("protaiga","oxypc-1","All_Spare_Parts",spare_part_Rec.ID,data_mapp,empty_mapp,"creator");
											info update_inv;
										}
										else
										{
											data_mapp = Map();
											data_mapp.put("Tag_Number",input.Tag_No);
											data_mapp.put("Screen_Type",input.Screen_Type);
											data_mapp.put("Screen_Pin",input.Screen_Pin);
											data_mapp.put("Screen_Size",input.Screen_Size);
											data_mapp.put("Lot_Number",input.Lot_Number);
											data_mapp.put("Part_Number",input.Part_No);
											data_mapp.put("Screen_Serial_Number",input.Serial_Number);
											data_mapp.put("Part_Type","Old");
											if(input.Status == "OK")
											{
												data_mapp.put("Screen_Stage","Assigned to Final QC");
											}
											else if(input.Status == "Repair")
											{
												data_mapp.put("Screen_Stage","Assigned to Delamination");
											}
											else if(input.Status == "Non-Repairable")
											{
												data_mapp.put("Screen_Stage","Non-Repairable");
											}
											else
											{
												data_mapp.put("Screen_Stage","Scrap");
											}
											empty_mapp = Map();
											update_inv = zoho.creator.createRecord("protaiga","oxypc-1","Spare_Parts",data_mapp,empty_mapp,"creator");
											info update_inv;
										}
						)
					}
				}

			}
