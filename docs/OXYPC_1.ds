				displayname = "Invoice Created"
				maxchar = 100
				values = {"Yes","No"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Payment_Terms
			(
				type = picklist
				displayname = "Payment Terms"
				maxchar = 100
				values = {"100% Advance","PDC Cheque","21 Days","14 Days","7 Days"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Tag_Number
			(
    			type = textarea
				displayname = "Tag Number"
				height = 100px
				barcode = true
				camera = primary
	 			row = 1
	 			column = 1   
				width = medium
			)
			Sales_Order_Date
			(
    			type = date
				displayname = "Sales Order Date"
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 2   
				width = 120px
			)
			SO_Books_ID
			(
    			type = text
				displayname = "SO Books ID"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Expected_Shipment_Date
			(
    			type = date
				displayname = "Expected Shipment Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 2   
				width = 120px
			)
			must have Salesperson
			(
				type = picklist
				maxchar = 100
				values = {"Manoj"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			All_Products_Ready
			(
				type = radiobuttons
				displayname = "All Products Ready"
				maxchar = 100
				values = {"Yes","No"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Branch
			(
				type = picklist
				maxchar = 100
				values = {"Nehru Place","Gurgaon","Mumbai"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Warehouse
			(
				type = picklist
				maxchar = 100
				values = {"TRC 2ND Floor","Bluemonk House Showroom","Bluemonk House Basement","Manesar","Nehru Place (Delhi)","Mumbai"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Sales_Order_File
			(
    			type = upload file
				displayname = "Sales Order File"
				browse = local_drive
	 			row = 1
	 			column = 2   
				width = medium
			)
			Section5
			(
				type = section
				displayname = ""
				visibility = true
	 			row = 2
	 			column = 0   
				width = medium
			)
			Payment_Mode1
			(
				type = checkboxes	
				displayname = "Payment Mode"
				values = {"Cash","Cheque","UPI","Card Swipe","Bank Transfer"}
	 			row = 2
	 			column = 1   
				width = medium
			)
			CaAmount
			(
				displayname = "Cash Amount"
				type = INR
				format = commadotindian
	 			row = 2
	 			column = 2   
				width = 140px
			)
			Cheque_Amount
			(
				displayname = "Cheque Amount"
				type = INR
				format = commadotindian
	 			row = 2
	 			column = 2   
				width = 140px
			)
			UPI_Amount
			(
				displayname = "UPI Amount"
				type = INR
				format = commadotindian
	 			row = 2
	 			column = 2   
				width = 140px
			)
			Card_Swipe_Amount
			(
				displayname = "Card Swipe Amount"
				type = INR
				format = commadotindian
	 			row = 2
	 			column = 2   
				width = 140px
			)
			Bank_Transfer_Amount
			(
				displayname = "Bank Transfer Amount"
				type = INR
				format = commadotindian
	 			row = 2
	 			column = 2   
				width = 140px
			)
			Total_Amount
			(
				displayname = "Total Amount"
				type = INR
				format = commadotindian
				initial value = 0.00
	 			row = 2
	 			column = 2   
				width = 140px
			)
			Section3
			(
				type = section
				displayname = "Section"
	 			row = 3
	 			column = 0   
				width = medium
			)
			Section2
			(
				type = section
				displayname = "Section"
	 			row = 4
	 			column = 0   
				width = medium
			)
			must have Item_Table
			(
				type = grid
				displayname = "Item Table"
				values  = Sales_Order_Items.ID
				auto width = false
	 			row = 5
	 			column = 1   
				width = medium
			)
			Section1
			(
				type = section
				displayname = "Section"
	 			row = 6
	 			column = 0   
				width = medium
			)
			Laptop_Quantity
			(
				type = number
				displayname = "Laptop Quantity"
	 			row = 6
	 			column = 1   
				width = 120px
			)
			TFT_Quantity
			(
				type = number
				displayname = "TFT Quantity"
	 			row = 6
	 			column = 1   
				width = 120px
			)
			Basic_Value
			(
				displayname = "Basic Value"
				type = INR
				format = commadotindian
	 			row = 6
	 			column = 1   
				width = 120px
			)
			Tax_Percent
			(
    			type = percentage
				displayname = "Tax Percent"
				initial value = 18%
	 			row = 6
	 			column = 1   
				width = 120px
			)
			Desktop_Quantity
			(
				type = number
				displayname = "Desktop Quantity"
	 			row = 6
	 			column = 2   
				width = 120px
			)
			Total_Quantity
			(
				type = number
				displayname = "Total Quantity"
	 			row = 6
	 			column = 2   
				width = 120px
			)
			Tax_Value
			(
				displayname = "Tax Value"
				type = INR
				format = commadotindian
	 			row = 6
	 			column = 2   
				width = 120px
			)
			Grand_Total
			(
				displayname = "Grand Total"
				type = INR
				format = commadotindian
	 			row = 6
	 			column = 2   
				width = 120px
			)
	
			customize
			(
				icon = "shopping-list"
			)
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
