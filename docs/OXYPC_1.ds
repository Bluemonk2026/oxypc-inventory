			(
    			type = text
				displayname = "Zoho Books Item Name"
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Warehouse
			(
				type = picklist
				maxchar = 100
				values = {"Bluemonk House Showroom","TRC 2ND Floor"}
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			Make
			(
    			type = text
	 			row = 1
	 			column = 2   
				width = medium
			)
			CPU
			(
    			type = text
	 			row = 1
	 			column = 2   
				width = medium
			)
			RAM
			(
    			type = text
	 			row = 1
	 			column = 2   
				width = medium
			)
			Product_Description
			(
    			type = formula
				displayname = "Product Description"
				value =  input.Make + " " + input.Model + " " + input.CPU + " " + input.Generation + " " + input.RAM + " " + input.HDD
				visibility = false
				format = plaintext
	 			row = 1
	 			column = 2   
				width = medium
			)
			Time
			(
    			type = time
				initial value = "${zoho.currenttime}"	
				timedisplayoptions = "hh:mm:ss" 
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Product_Category
			(
				type = picklist
				displayname = "Product Stage"
				maxchar = 100
				values = {"Scrap","Lot","Finished Good","Repair"}
				sortorder = ascending
	 			row = 1
	 			column = 3   
				width = medium
			)
			Product_Sub_Category
			(
    			type = text
				displayname = "Product Sub-Category"
	 			row = 1
	 			column = 3   
				width = medium
			)
	
