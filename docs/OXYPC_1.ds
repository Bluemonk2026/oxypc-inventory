	section Copy_of_IQC_Format_for_Laptop
	{
		displayname= "Copy of IQC Format for Laptop"
		icon = "tech-desktop"
		form Copy_of_IQC_Format_for_Laptop
		{
			displayname = "Copy of IQC Format for Laptop"
			success message = "Data Added Successfully!"
			field alignment = left
			feature property = 256
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			User_Name
			(
    			type = text
				displayname = "User Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Updating_Inv
			(
				type = picklist
				displayname = "Updating Inv"
				maxchar = 100
				values = {"Yes","No"}
				private = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have unique TAG_NO
			(
    			type = text
				displayname = "TagNo"
				maxchar = 20
				qrcode = true
				barcode = true
				camera = primary
				show gallery = true
				switch camera = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			Model2
			(
    			type = text
				displayname = "Model"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Sub_Category
			(
				type = picklist	
				displayname = "Sub-Category"
				values  = Sub_Category_database_for_GRN[Product_Master.Item_Name23 == "Laptop"].ID
    			displayformat = [Sub_Category]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Inv_Update
			(
				type = checkboxes	
				displayname = "Inv Update"
				values = {"Update"}
				private = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			Date_field
			(
    			type = date
				displayname = "Date"
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
				private = true
	 			row = 1
	 			column = 1   
				width = small
			)
			Previous_Model
			(
    			type = text
				displayname = "Previous Model"
				private = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			SPPID
			(
    			type = text
				private = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			Updating_Checkbox
			(
				type = checkboxes	
				displayname = "Updating Checkbox"
				values = {"Update"}
				private = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			Time_Difference
			(
    			type = time
				displayname = "Time Difference"
				timedisplayoptions = "hh:mm:ss" 
	 			row = 1
	 			column = 1   
				width = medium
			)
			Copy_Previous_Submitted_Data
			(
				type = checkboxes	
				displayname = "Copy Previous Submitted Data"
				values = {"Update"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			LOT_No2
			(
				type = picklist	
				displayname = "LOT No."
				values  = LOT_No_s_GRN.ID
    			displayformat = [LOT_No]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = small
			)
			LOT_Number
			(
    			type = text
				displayname = "LOT Number"
	 			row = 1
	 			column = 1   
				width = small
			)
			Model1
			(
				type = picklist	
				displayname = "Model"
				values  = Model[Make.ID == input.Make].ID
    			displayformat = [Model]
	 			row = 1
	 			column = 1   
				width = small
			)
			must have CPU
			(
				type = picklist
				maxchar = 100
				values = {"I3","I4","I5","I7","I9","M5","M7","celeron","C2D","AMD","AMD PRO","PENTIUM R","XEON","Centrino","Other"}
	 			row = 1
	 			column = 1   
				width = small
			)
			Enter_Value_for_CPU
			(
    			type = text
				displayname = "Enter Value for CPU"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Generation
			(
				type = picklist
				maxchar = 100
				values = {"1ST","2ND","3RD","4TH","5TH","6TH","7TH","8TH","9TH","10TH","11TH","12TH","A10","C2D","Other"}
	 			row = 1
	 			column = 1   
				width = small
			)
			Enter_Value_for_Generation
			(
