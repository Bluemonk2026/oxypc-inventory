  stress_report text
}

// ── stock_transfers ──────────────────────────────────────────
Table stock_transfers {
  id uuid [pk, not null]
  device_id uuid [not null, note: 'indexed']
  transfer_type varchar(30) [not null]
  from_warehouse varchar(100) [not null]
  to_warehouse varchar(100) [not null]
  transferred_by varchar(100)
  received_by varchar(100)
  department varchar(100)
  barcode varchar(50)
  serial_no varchar(100)
  make varchar(50)
  model varchar(100)
  cpu varchar(50)
  generation varchar(20)
  ram varchar(20)
  hdd varchar(20)
  category varchar(50)
  lot_number varchar(20)
  product_stage varchar(50)
  transfer_date datetime [not null, default: `now()`]
  notes text
  created_by varchar(50)
  created_at datetime [default: `now()`]
}

// ── crm_contacts ─────────────────────────────────────────────
Table crm_contacts {
  id uuid [pk, not null]
  contact_code varchar(20) [not null, unique, note: 'indexed']
  contact_type varchar(20) [default: 'supplier']
  company_name varchar(200) [not null, note: 'indexed']
  contact_person varchar(100)
  phone varchar(20) [note: 'indexed']
  whatsapp varchar(20)
  email varchar(100)
  gstin varchar(20)
  pan varchar(20)
  address text
  city varchar(100)
  state varchar(100)
  pincode varchar(10)
  source_type varchar(30)
  buyer_type varchar(30)
  credit_limit decimal(14,2) [default: 0]
  outstanding decimal(14,2) [default: 0]
  tags varchar(300)
  notes text
  status varchar(20) [default: 'active']
  assigned_to varchar(50)
  created_by varchar(50)
  created_at datetime [default: `now()`]
  updated_at datetime [default: `now()`]
}

// ── crm_sourcing_deals ───────────────────────────────────────
Table crm_sourcing_deals {
  id uuid [pk, not null]
  deal_number varchar(30) [not null, unique, note: 'indexed']
  contact_id uuid [note: 'indexed']
  title varchar(300) [not null]
  source_type varchar(30)
  device_type varchar(50)
  est_quantity int
  material_type varchar(30)
  asking_price_unit decimal(10,2)
  asking_price_total decimal(14,2)
  our_offer_unit decimal(10,2)
  our_offer_total decimal(14,2)
  final_price_unit decimal(10,2)
  final_price_total decimal(14,2)
  stage varchar(30) [default: 'lead', note: 'indexed']
  inspection_date date
  inspection_result varchar(20)
  inspection_notes text
  expected_pickup_date date
  payment_advance_pct int [default: 0]
  payment_terms text
  linked_lot_id uuid
  win_loss_reason text
  assigned_to varchar(50)
  priority varchar(10) [default: 'medium']
  notes text
  created_by varchar(50)
  created_at datetime [default: `now()`]
  updated_at datetime [default: `now()`]
}

// ── crm_sales_opportunities ──────────────────────────────────
Table crm_sales_opportunities {
  id uuid [pk, not null]
  opp_number varchar(30) [not null, unique, note: 'indexed']
  contact_id uuid [note: 'indexed']
  title varchar(300) [not null]
  buyer_type varchar(30)
  device_type varchar(50)
  required_qty int
  material_type varchar(30)
  grade_required varchar(10)
  budget_per_unit decimal(10,2)
  stage varchar(30) [default: 'lead', note: 'indexed']
  quote_id uuid
  linked_sale_ids text
  expected_close_date date
  estimated_value decimal(14,2)
  win_loss_reason text
  assigned_to varchar(50)
  priority varchar(10) [default: 'medium']
  notes text
  created_by varchar(50)
  created_at datetime [default: `now()`]
  updated_at datetime [default: `now()`]
}

// ── crm_quotes ───────────────────────────────────────────────
Table crm_quotes {
  id uuid [pk, not null]
  quote_number varchar(30) [not null, unique, note: 'indexed']
  contact_id uuid [note: 'indexed']
  quote_date date [default: `now()`]
  valid_until date
  payment_terms varchar(200)
  special_conditions text
  total_amount decimal(14,2) [default: 0]
  status varchar(20) [default: 'draft']
  sent_at datetime
  created_by varchar(50)
  created_at datetime [default: `now()`]
  updated_at datetime [default: `now()`]
}

// ── crm_quote_items ──────────────────────────────────────────
Table crm_quote_items {
  id uuid [pk, not null]
  quote_id uuid [not null, note: 'indexed']
  line_number int [not null, default: 1]
  device_type varchar(100) [not null]
  material_type varchar(30)
  grade varchar(10)
  quantity int [not null, default: 1]
  unit_price decimal(10,2) [not null]
  total_price decimal(14,2) [not null]
  specs_note text
  sort_order int [default: 0]
}

// ── crm_activities ───────────────────────────────────────────
Table crm_activities {
  id uuid [pk, not null]
  contact_id uuid [note: 'indexed']
  deal_id uuid [note: 'indexed']
  deal_type varchar(20)
  activity_type varchar(20) [default: 'call']
  direction varchar(10)
  summary text [not null]
  outcome varchar(30)
  performed_by varchar(50) [not null]
  activity_date datetime [default: `now()`]
  next_followup datetime [note: 'indexed']
  followup_assigned_to varchar(50)
  followup_done bool [default: false, note: 'indexed']
  created_at datetime [default: `now()`]
}

// ── crm_grade_price_matrix ───────────────────────────────────
Table crm_grade_price_matrix {
  id uuid [pk, not null]
  device_type varchar(100) [not null, note: 'indexed']
  grade varchar(10) [not null]
  material_type varchar(30)
  brand varchar(50)
  min_buy_price decimal(10,2)
  max_buy_price decimal(10,2)
  target_sell decimal(10,2)
  min_margin_pct decimal(5,2) [default: 15.0]
  notes text
  updated_by varchar(50)
  updated_at datetime [default: `now()`]
  created_at datetime [default: `now()`]
}

// ── crm_purchase_orders ──────────────────────────────────────
Table crm_purchase_orders {
  id uuid [pk, not null]
  po_number varchar(30) [not null, unique, note: 'indexed']
  deal_id uuid
  contact_id uuid [note: 'indexed']
  po_date date [not null, default: `now()`]
  expected_delivery_date date
  delivery_address text
  payment_terms text
  advance_amount decimal(14,2)
  total_amount decimal(14,2) [default: 0]
  status varchar(20) [default: 'draft']
  issued_by varchar(50)
  issued_at datetime
  notes text
  created_by varchar(50)
  created_at datetime [default: `now()`]
  updated_at datetime [default: `now()`]
}

// ── crm_po_line_items ────────────────────────────────────────
Table crm_po_line_items {
  id uuid [pk, not null]
  po_id uuid [not null]
  description varchar(300) [not null]
  device_type varchar(100)
  grade varchar(10)
  quantity int [not null, default: 1]
  unit_price decimal(10,2) [not null]
  total_price decimal(14,2) [not null]
  sort_order int [default: 0]
}

// ── supplier_payments ────────────────────────────────────────
Table supplier_payments {
  id uuid [pk, not null]
  contact_id uuid
  lot_id uuid
  po_id uuid
  payment_date date [not null, default: `now()`]
  amount decimal(14,2) [not null]
  payment_mode varchar(20)
  reference_no varchar(100)
  is_advance bool [default: false]
  notes text
  created_by varchar(50)
  created_at datetime [default: `now()`]
}

// ── customer_receipts ────────────────────────────────────────
Table customer_receipts {
  id uuid [pk, not null]
  contact_id uuid
  dealer_id uuid
  sale_id uuid
  dealer_order_id uuid
  receipt_date date [not null, default: `now()`]
  amount decimal(14,2) [not null]
  payment_mode varchar(20)
  reference_no varchar(100)
  notes text
  created_by varchar(50)
  created_at datetime [default: `now()`]
}

// ── qa_requirements ──────────────────────────────────────────
Table qa_requirements {
  id uuid [pk, not null]
  req_code varchar(30)
  title varchar(200) [not null]
  description text
  source varchar(30) [not null, default: 'PRD']
  priority varchar(20) [not null, default: 'Medium']
  status varchar(20) [not null, default: 'Open']
  module varchar(100)
  created_by varchar(100)
  created_at datetime [default: `now()`]
  updated_at datetime [default: `now()`]
}

// ── qa_test_cases ────────────────────────────────────────────
Table qa_test_cases {
  id uuid [pk, not null]
  tc_code varchar(30)
  requirement_id uuid
  title varchar(200) [not null]
  scenario text
  preconditions text
  steps text
  expected_result text
  type varchar(20) [not null, default: 'Functional']
  status varchar(10) [not null, default: 'Active']
  is_automated bool [default: false]
  module varchar(100)
  created_by varchar(100)
  created_at datetime [default: `now()`]
  updated_at datetime [default: `now()`]
}

// ── qa_test_executions ───────────────────────────────────────
Table qa_test_executions {
  id uuid [pk, not null]
  test_case_id uuid [not null]
  status varchar(10) [not null, default: 'Pass']
  actual_result text
  notes text
  build_version varchar(50)
  environment varchar(50) [default: 'QA']
  executed_by varchar(100)
  executed_at datetime [default: `now()`]
}

// ── qa_defects ───────────────────────────────────────────────
Table qa_defects {
  id uuid [pk, not null]
  defect_code varchar(30)
  test_case_id uuid
  title varchar(200) [not null]
  description text
  steps_to_reproduce text
  expected_result text
  actual_result text
  severity varchar(10) [not null, default: 'Medium']
  priority varchar(20) [not null, default: 'P3 - Medium']
  status varchar(15) [not null, default: 'New']
  module varchar(100)
  environment varchar(50) [default: 'QA']
  build_version varchar(50)
  assigned_to varchar(100)
  root_cause text
  resolution text
  reported_by varchar(100)
  reported_at datetime [default: `now()`]
  resolved_at datetime
  closed_at datetime
}

// ── qa_uat_scenarios ─────────────────────────────────────────
Table qa_uat_scenarios {
  id uuid [pk, not null]
  uat_code varchar(30)
  requirement_id uuid
  title varchar(200) [not null]
  scenario text
  acceptance_criteria text
  business_owner varchar(100)
  status varchar(20) [not null, default: 'Pending Execution']
  executed_by varchar(100)
  executed_at datetime
  result_notes text
  feedback text
  sign_off_by varchar(100)
  sign_off_at datetime
  created_by varchar(100)
  created_at datetime [default: `now()`]
}

// ── qa_releases ──────────────────────────────────────────────
Table qa_releases {
  id uuid [pk, not null]
  version varchar(50) [not null]
  title varchar(200)
  description text
  status varchar(15) [not null, default: 'Planned']
  planned_date datetime
  release_date datetime
  qa_sign_off_by varchar(100)
  qa_sign_off_at datetime
  uat_sign_off_by varchar(100)
  uat_sign_off_at datetime
  deployed_by varchar(100)
  notes text
  rollback_plan text
  created_by varchar(100)
  created_at datetime [default: `now()`]
  updated_at datetime [default: `now()`]
}


// ============================================================
// FOREIGN KEY REFERENCES
// ============================================================

// users pool
Ref: login_logs.user_id > users.id
Ref: user_permissions.user_id > users.id
Ref: audit_logs.user_id > users.id
Ref: attendance.user_id > users.id
Ref: device_location_logs.actor_id > users.id
Ref: inventory_audits.initiated_by > users.id
Ref: audit_scan_items.scanned_by > users.id
Ref: repair_jobs.engineer_id > users.id
Ref: qc_checks.inspector_id > users.id

// lots pool
Ref: devices.lot_id > lots.id
Ref: lot_line_items.lot_id > lots.id
Ref: spare_parts_consumption.lot_id > lots.id
Ref: crm_sourcing_deals.linked_lot_id > lots.id
Ref: supplier_payments.lot_id > lots.id

// lot_line_items
Ref: devices.lot_line_item_id > lot_line_items.id

// devices pool
Ref: stage_movements.device_id > devices.id
Ref: repair_jobs.device_id > devices.id
Ref: qc_checks.device_id > devices.id
Ref: sales.device_id > devices.id
Ref: returns.device_id > devices.id
Ref: spare_parts_consumption.device_id > devices.id
Ref: ram_tracking.device_id > devices.id
Ref: ram_tracking.destination_device_id > devices.id
Ref: repair_attempts.device_id > devices.id
Ref: device_costing.device_id > devices.id
Ref: spare_parts_ledger.device_id > devices.id
Ref: device_aging.device_id > devices.id
Ref: iqc_inspections.device_id > devices.id
Ref: stock_transfers.device_id > devices.id
Ref: device_location_logs.device_id > devices.id
Ref: audit_scan_items.device_id > devices.id

// repair pool
Ref: repair_attempts.repair_job_id > repair_jobs.id

// spare_parts pool
Ref: spare_parts_purchases.part_id > spare_parts.id
Ref: spare_parts_consumption.part_id > spare_parts.id
Ref: spare_parts_ledger.part_id > spare_parts.id

// dealers pool
Ref: dealer_assignments.dealer_id > dealers.id
Ref: dealer_calls.dealer_id > dealers.id
Ref: dealer_orders.dealer_id > dealers.id
Ref: dealer_credit_notes.dealer_id > dealers.id
Ref: dealer_credit_notes.order_id > dealer_orders.id
Ref: dealer_credit_notes.applied_to_order_id > dealer_orders.id
Ref: telecalling_records.dealer_id > dealers.id
Ref: whatsapp_messages.dealer_id > dealers.id
Ref: whatsapp_groups.linked_dealer_id > dealers.id
Ref: market_availability.dealer_id > dealers.id
Ref: customer_receipts.dealer_id > dealers.id

// location pool
Ref: device_location_logs.location_id > storage_locations.id
Ref: audit_scan_items.location_id > storage_locations.id
Ref: audit_scan_items.audit_id > inventory_audits.id

// stage pool
Ref: allowed_transitions.from_stage > stage_master.name
Ref: allowed_transitions.to_stage > stage_master.name

// sales pool
Ref: returns.sale_id > sales.id
Ref: customer_receipts.sale_id > sales.id

// CRM pool
Ref: crm_sourcing_deals.contact_id > crm_contacts.id
Ref: crm_sales_opportunities.contact_id > crm_contacts.id
Ref: crm_quotes.contact_id > crm_contacts.id
Ref: crm_activities.contact_id > crm_contacts.id
Ref: crm_purchase_orders.contact_id > crm_contacts.id
Ref: supplier_payments.contact_id > crm_contacts.id
Ref: customer_receipts.contact_id > crm_contacts.id
Ref: crm_quote_items.quote_id > crm_quotes.id
Ref: crm_sales_opportunities.quote_id > crm_quotes.id
Ref: crm_purchase_orders.deal_id > crm_sourcing_deals.id
Ref: crm_po_line_items.po_id > crm_purchase_orders.id
Ref: supplier_payments.po_id > crm_purchase_orders.id
Ref: customer_receipts.dealer_order_id > dealer_orders.id

// WhatsApp pool
Ref: market_availability.source_message_id > whatsapp_messages.id

// QA pool
Ref: qa_test_cases.requirement_id > qa_requirements.id
Ref: qa_uat_scenarios.requirement_id > qa_requirements.id
Ref: qa_test_executions.test_case_id > qa_test_cases.id
Ref: qa_defects.test_case_id > qa_test_cases.id

// ══════════════════════════════════════════════════════════════════════
// Sprint 29 — Workflow & Fulfilment pool (added Jun 2026)
// ══════════════════════════════════════════════════════════════════════

Table work_orders {
  id uuid [pk, not null]
  work_id varchar(12) [unique, not null, note: '12-digit WorkID']
  device_id uuid [not null, note: 'indexed']
  barcode varchar(100)
  stage varchar(5) [note: 'l1 | l2 | l3']
  assigned_role varchar(30)
  assigned_user_id uuid [note: 'indexed']
  assigned_username varchar(50)
  assigned_name varchar(100)
  status varchar(20) [not null, default: 'pending']
  source_transfer_id uuid
  assigned_at datetime [not null, default: `now()`]
  started_at datetime
  completed_at datetime
  created_by varchar(50)
  created_at datetime [default: `now()`]
}

Table part_requests {
  id uuid [pk, not null]
  work_order_id uuid
  work_id varchar(12)
  device_id uuid [not null, note: 'indexed']
  barcode varchar(100)
  stage varchar(5)
  part_id uuid
  part_name varchar(150) [not null]
  requested_by varchar(50)
  engineer_name varchar(100)
  qty_requested int [not null, default: 1]
  qty_handed_over int [not null, default: 0]
  status varchar(20) [not null, default: 'requested', note: 'requested|handed_over|not_in_stock|procure']
  created_at datetime [default: `now()`]
  actioned_at datetime
  actioned_by varchar(50)
}

Table part_sourcing_requests {
  id uuid [pk, not null]
  part_request_id uuid
  part_id uuid
  part_code varchar(20)
  part_name varchar(150) [not null]
  qty_requested int [not null, default: 1]
  qty_sourced int [not null, default: 0]
  raised_by varchar(50)
  status varchar(10) [not null, default: 'open', note: 'open|closed']
  source_deal_id varchar(50)
  created_at datetime [default: `now()`]
  closed_at datetime
  closed_by varchar(50)
}

Table telecaller_dispatch_requests {
  id uuid [pk, not null]
  device_id uuid [not null, note: 'indexed']
  barcode varchar(100)
  telecaller_username varchar(50)
  telecaller_name varchar(100)
  qty_requested int [not null, default: 1]
  qty_available int [not null, default: 1]
  grade varchar(10)
  status varchar(20) [not null, default: 'requested', note: 'requested|approved']
  created_at datetime [default: `now()`]
  approved_at datetime
  approved_by varchar(50)
}

// Sprint 29 refs
Ref: work_orders.device_id > devices.id
Ref: work_orders.assigned_user_id > users.id
Ref: work_orders.source_transfer_id > stock_transfers.id
Ref: part_requests.work_order_id > work_orders.id
Ref: part_requests.device_id > devices.id
Ref: part_requests.part_id > spare_parts.id
Ref: part_sourcing_requests.part_request_id > part_requests.id
Ref: part_sourcing_requests.part_id > spare_parts.id
Ref: telecaller_dispatch_requests.device_id > devices.id
