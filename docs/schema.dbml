// ── users ────────────────────────────────────────────────────
Table users {
  id uuid [pk, not null]
  username varchar(50) [not null, unique, note: 'indexed']
  full_name varchar(100) [not null]
  password_hash varchar(200) [not null]
  role varchar(50) [not null, default: 'sales']
  status bool [default: true]
  created_at datetime [default: `now()`]
  created_by varchar(50)
  last_login datetime
  tenant varchar(50) [default: 'oxypc_internal', note: 'indexed']
}

// ── login_logs ───────────────────────────────────────────────
Table login_logs {
  id uuid [pk, not null]
  user_id uuid [not null]
  action varchar(50) [not null]
  ip_address varchar(50)
  timestamp datetime [default: `now()`]
  notes varchar(200)
}

// ── user_permissions ─────────────────────────────────────────
Table user_permissions {
  id uuid [pk, not null]
  user_id uuid [not null]
  permission varchar(100) [not null]
  granted bool [default: true]
  granted_by varchar(50)
  granted_at datetime [default: `now()`]
}

// ── lots ─────────────────────────────────────────────────────
Table lots {
  id uuid [pk, not null]
  lot_number varchar(20) [not null, unique, note: 'indexed']
  supplier_name varchar(200) [not null]
  grn_system_number varchar(50)
  grn_number_new int
  grn_date datetime
  invoice_date datetime
  invoice_no varchar(100)
  invoice_value decimal(14,2)
  taxable_amount decimal(14,2)
  sgst decimal(12,2)
  cgst decimal(12,2)
  igst decimal(12,2)
  vehicle_number varchar(30)
  e_way_bill varchar(50)
  po_number varchar(100)
  vendor_name varchar(200)
  buying_price decimal(12,2) [not null]
  qty int [not null]
  purchase_date datetime [not null]
  notes text
  created_by varchar(50)
  created_at datetime [default: `now()`]
}

// ── lot_line_items ───────────────────────────────────────────
Table lot_line_items {
  id uuid [pk, not null]
  lot_id uuid [not null, note: 'indexed']
  sub_category varchar(50) [not null]
  brand varchar(50)
  model varchar(100)
  cpu varchar(100)
  generation varchar(50)
  ram_gb int
  has_ram bool [default: true]
  storage_gb int
  storage_type varchar(20)
  has_storage bool [default: true]
  screen_size varchar(20)
  grade varchar(10)
  unit_price decimal(12,2) [not null]
  qty int [not null, default: 1]
  notes text
  created_at datetime [default: `now()`]
}

// ── devices ──────────────────────────────────────────────────
Table devices {
  id uuid [pk, not null]
  barcode varchar(100) [not null, unique, note: 'indexed']
  lot_id uuid [not null]
  brand varchar(50) [note: 'indexed']
  model varchar(100)
  device_type varchar(30)
  serial_no varchar(100)
  sub_category varchar(20) [note: 'indexed']
  cpu varchar(100)
  generation varchar(50)
  ram_gb int
  storage_gb int
  storage_type varchar(20)
  hdd_capacity_gb int
  battery_health_pct int
  screen_size varchar(20)
  color varchar(30)
  bios_password bool [default: false]
  grade varchar(10)
  current_stage varchar(30) [not null, default: 'iqc', note: 'indexed']
  floor varchar(50)
  warehouse varchar(100)
  grn_number varchar(50)
  device_price decimal(12,2)
  lot_line_item_id uuid
  notes text
  created_at datetime [default: `now()`]
  updated_at datetime [default: `now()`, note: 'indexed']
}

// ── stage_movements ──────────────────────────────────────────
Table stage_movements {
  id uuid [pk, not null]
  device_id uuid [not null]
  from_stage varchar(30)
  to_stage varchar(30) [not null]
  moved_by varchar(50)
  moved_at datetime [default: `now()`]
  exited_at datetime
  notes text
}

// ── repair_jobs ──────────────────────────────────────────────
Table repair_jobs {
  id uuid [pk, not null]
  device_id uuid [not null, note: 'indexed']
  stage varchar(5) [not null, note: 'indexed']
  engineer_id uuid
  engineer_name varchar(100)
  started_at datetime [default: `now()`]
  completed_at datetime
  issue_description text
  resolution text
  status varchar(30) [default: 'open', note: 'indexed']
  team_name varchar(100)
  assigned_engineer varchar(100)
  faults text
  dust_cleaning varchar(20)
  cmos_battery_change varchar(20)
  thermal_paste varchar(20)
  final_status varchar(30)
  ram_status varchar(20)
  ram_removed_gb varchar(20)
  ram_added_gb varchar(20)
  hdd_updated varchar(5)
  hdd_removed varchar(30)
  hdd_added varchar(30)
  problem_reported text
  action_taken varchar(50)
  problem_observed text
  scrap_reason varchar(100)
  received_from varchar(50)
  customer_internal varchar(30)
}

// ── qc_checks ────────────────────────────────────────────────
Table qc_checks {
  id uuid [pk, not null]
  device_id uuid [not null, note: 'indexed']
  inspector_id uuid
  inspector_name varchar(100)
  battery_score int
  screen_score int
  keyboard_score int
  body_score int
  total_score int
  result varchar(10) [not null]
  grade varchar(5)
  attempt_number int [not null, default: 1]
  checked_at datetime [default: `now()`]
  notes text
  issues_found text
  send_to_stage varchar(20)
}

// ── sales ────────────────────────────────────────────────────
Table sales {
  id uuid [pk, not null]
  sale_number varchar(20) [not null, unique, note: 'indexed']
  device_id uuid [not null]
  sale_price decimal(12,2) [not null]
  customer_name varchar(100)
  customer_phone varchar(20)
  customer_state varchar(100)
  invoice_no varchar(50)
  payment_mode varchar(20)
  sold_by varchar(50) [note: 'indexed']
  sold_at datetime [default: `now()`]
  notes text
}

// ── returns ──────────────────────────────────────────────────
Table returns {
  id uuid [pk, not null]
  sale_id uuid [not null, note: 'indexed']
  device_id uuid [not null, note: 'indexed']
  return_date datetime [default: `now()`]
  reason text
  condition_on_return varchar(50)
  action_taken varchar(30)
  reentered_stage varchar(50)
  processed_by varchar(50)
  refund_amount decimal(12,2)
  notes text
}

// ── spare_parts ──────────────────────────────────────────────
Table spare_parts {
  id uuid [pk, not null]
  part_code varchar(20) [not null, unique, note: 'indexed']
  name varchar(150) [not null]
  category varchar(30) [not null]
  unit_price decimal(10,2) [not null, default: 0]
  qty_in_stock int [not null, default: 0]
  min_stock_alert int [not null, default: 5]
  supplier varchar(100)
  notes text
  created_at datetime [default: `now()`]
}

// ── spare_parts_purchases ────────────────────────────────────
Table spare_parts_purchases {
  id uuid [pk, not null]
  part_id uuid [not null]
  qty int [not null]
  unit_price decimal(10,2) [not null]
  total_price decimal(12,2) [not null]
  supplier varchar(100)
  purchase_date datetime [not null, default: `now()`]
  invoice_no varchar(50)
  purchased_by varchar(50)
}

// ── spare_parts_consumption ──────────────────────────────────
Table spare_parts_consumption {
  id uuid [pk, not null]
  device_id uuid
  lot_id uuid
  part_id uuid [not null]
  qty_used int [not null]
  unit_cost decimal(10,2) [not null]
  total_cost decimal(12,2) [not null]
  used_by varchar(50)
  used_at datetime [default: `now()`]
  stage varchar(20)
  notes text
}

// ── ram_tracking ─────────────────────────────────────────────
Table ram_tracking {
  id uuid [pk, not null]
  action varchar(20) [not null]
  device_id uuid
  destination_device_id uuid
  ram_gb int
  ram_type varchar(20)
  by_user varchar(50)
  at datetime [default: `now()`]
  notes text
}

// ── repair_attempts ──────────────────────────────────────────
Table repair_attempts {
  id uuid [pk, not null]
  device_id uuid [not null, note: 'indexed']
  repair_job_id uuid
  level int [not null]
  attempt_no int [not null, default: 1]
  cost decimal(10,2) [not null, default: 0]
  time_spent int
  outcome varchar(30)
  notes text
  created_by varchar(50)
  created_at datetime [default: `now()`]
}

// ── device_costing ───────────────────────────────────────────
Table device_costing {
  id uuid [pk, not null]
  device_id uuid [not null, unique, note: 'indexed']
  base_cost decimal(12,2) [not null, default: 0]
  parts_cost decimal(12,2) [not null, default: 0]
  labour_cost decimal(12,2) [not null, default: 0]
  total_cost decimal(12,2) [not null, default: 0]
  expected_sale_value decimal(12,2)
  updated_at datetime [default: `now()`]
}

// ── spare_parts_ledger ───────────────────────────────────────
Table spare_parts_ledger {
  id uuid [pk, not null]
  part_id uuid [not null, note: 'indexed']
  entry_type varchar(10) [not null]
  qty int [not null]
  cost_per_unit decimal(10,2) [not null, default: 0]
  total_cost decimal(12,2) [not null, default: 0]
  reference_type varchar(30)
  reference_id varchar(50)
  device_id uuid
  notes text
  created_by varchar(50)
  created_at datetime [default: `now()`]
}

// ── device_aging ─────────────────────────────────────────────
Table device_aging {
  id uuid [pk, not null]
  device_id uuid [not null, unique, note: 'indexed']
  days_in_stage int [not null, default: 0]
  total_days int [not null, default: 0]
  stage_entered_at datetime
  is_stuck bool [not null, default: false]
  is_dead_stock bool [not null, default: false]
  refreshed_at datetime [default: `now()`]
}

// ── audit_logs ───────────────────────────────────────────────
Table audit_logs {
  id uuid [pk, not null]
  user_id uuid
  username varchar(50)
  action varchar(50) [not null]
  table_name varchar(50)
  record_id varchar(50)
  old_value text
  new_value text
  ip_address varchar(45)
  notes text
  timestamp datetime [not null, note: 'indexed', default: `now()`]
}

// ── dealers ──────────────────────────────────────────────────
Table dealers {
  id uuid [pk, not null]
  dealer_code varchar(20) [not null, unique, note: 'indexed']
  business_name varchar(200) [not null]
  first_name varchar(100)
  last_name varchar(100)
  contact_person varchar(100)
  phone varchar(20)
  whatsapp_number varchar(20)
  email varchar(100)
  address text
  city varchar(100)
  state varchar(100)
  pincode varchar(10)
  gstin varchar(20)
  dealer_type varchar(30) [default: 'retail']
  credit_limit decimal(14,2) [default: 0]
  outstanding_amount decimal(14,2) [default: 0]
  total_purchases decimal(14,2) [default: 0]
  last_sale_date datetime
  last_sale_amount decimal(14,2)
  preferred_categories varchar(200)
  notes text
  status varchar(20) [default: 'active']
  assigned_to varchar(50)
  created_by varchar(50)
  source varchar(200)
  added_by varchar(50)
  created_at datetime [default: `now()`]
  updated_at datetime [default: `now()`]
}

// ── dealer_assignments ───────────────────────────────────────
Table dealer_assignments {
  id uuid [pk, not null]
  dealer_id uuid [not null]
  assigned_to varchar(50) [not null]
  assigned_by varchar(50) [not null]
  assigned_at datetime [default: `now()`]
  is_active bool [default: true]
  notes text
}

// ── dealer_calls ─────────────────────────────────────────────
Table dealer_calls {
  id uuid [pk, not null]
  dealer_id uuid [not null]
  called_by varchar(50) [not null]
  call_date datetime [default: `now()`]
  call_type varchar(20) [default: 'outbound']
  call_mode varchar(20) [default: 'phone']
  duration_mins int
  call_outcome varchar(30)
  items_discussed text
  quote_given decimal(12,2)
  next_followup_date datetime [note: 'indexed']
  whatsapp_sent bool [default: false]
  notes text
  created_at datetime [default: `now()`]
}

// ── dealer_orders ────────────────────────────────────────────
Table dealer_orders {
  id uuid [pk, not null]
  dealer_id uuid [not null]
  order_number varchar(30) [not null, unique]
  order_date datetime [default: `now()`]
  items_description text
  total_amount decimal(14,2) [default: 0]
  paid_amount decimal(14,2) [default: 0]
  due_amount decimal(14,2) [default: 0]
  payment_due_date datetime
  payment_mode varchar(20)
  invoice_number varchar(50)
  invoice_sent_whatsapp bool [default: false]
  payment_reminder_sent bool [default: false]
  status varchar(20) [default: 'pending']
  notes text
  created_by varchar(50)
  created_at datetime [default: `now()`]
}

// ── dealer_credit_notes ──────────────────────────────────────
Table dealer_credit_notes {
  id uuid [pk, not null]
  credit_number varchar(30) [not null, unique, note: 'indexed']
  dealer_id uuid [not null, note: 'indexed']
  order_id uuid [note: 'indexed']
  credit_date datetime [default: `now()`]
  amount decimal(14,2) [not null]
  reason varchar(200)
  items_description text
  notes text
  created_by varchar(50)
  created_at datetime [default: `now()`]
  is_applied bool [not null, default: false]
