}

// ── storage_locations ────────────────────────────────────────
Table storage_locations {
  id uuid [pk, not null]
  zone varchar(30) [not null]
  unit_type varchar(20) [not null]
  unit_id varchar(50) [not null, unique]
  slot varchar(20)
  description varchar(200)
  capacity int
  is_active bool [default: true]
  created_at datetime [default: `now()`]
}

// ── device_location_logs ─────────────────────────────────────
Table device_location_logs {
  id uuid [pk, not null]
  device_id uuid [not null]
  location_id uuid
  action varchar(20) [not null]
  actor_id uuid [not null]
  actor_name varchar(100)
  notes text
  logged_at datetime [default: `now()`, note: 'indexed']
}

// ── inventory_audits ─────────────────────────────────────────
Table inventory_audits {
  id uuid [pk, not null]
  audit_number varchar(30) [not null, unique]
  zone_filter varchar(50)
  status varchar(20) [default: 'pending']
  initiated_by uuid [not null]
  initiated_by_name varchar(100)
  initiated_at datetime [default: `now()`]
  completed_at datetime
  notes text
  expected_count int [default: 0]
  found_count int [default: 0]
  missing_count int [default: 0]
  extra_count int [default: 0]
}

// ── audit_scan_items ─────────────────────────────────────────
Table audit_scan_items {
  id uuid [pk, not null]
  audit_id uuid [not null]
  device_id uuid
  barcode_scanned varchar(100) [not null]
  location_id uuid
  scan_status varchar(20) [not null]
  scanned_by uuid
  scanned_by_name varchar(100)
  scanned_at datetime [default: `now()`]
  notes text
}

// ── stage_master ─────────────────────────────────────────────
Table stage_master {
  id uuid [pk, not null]
  name varchar(50) [not null, unique]
  label varchar(100) [not null]
  sequence int [not null, default: 0]
  created_at datetime [default: `now()`]
}

// ── allowed_transitions ──────────────────────────────────────
Table allowed_transitions {
  id uuid [pk, not null]
  from_stage varchar(50) [not null]
  to_stage varchar(50) [not null]
  created_at datetime [default: `now()`]

  indexes {
    (from_stage, to_stage) [unique, name: 'uq_transition']
  }
}

// ── master_data ──────────────────────────────────────────────
Table master_data {
  id uuid [pk, not null]
  category varchar(50) [not null, note: 'indexed']
  value varchar(200) [not null]
  description varchar(500)
  display_order int [default: 0]
  is_active bool [default: true]
  created_at datetime [default: `now()`]

  indexes {
    (category, value) [unique, name: 'uq_master_category_value']
  }
}

// ── market_availability ──────────────────────────────────────
Table market_availability {
  id uuid [pk, not null]
  brand varchar(100)
  model varchar(200)
